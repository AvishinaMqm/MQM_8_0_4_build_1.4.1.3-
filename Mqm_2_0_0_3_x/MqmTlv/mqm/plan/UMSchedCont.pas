function TMSchedCont.GetNbrOfUniqueIds() : Integer;
var
  lic: TRecLicVers1;
  strErr: string;
  ph, pd   : integer;
  tHdr : TSCProdReqHdr;
  tDet : TSCProdReqDet;
  UserRequestForSplit : boolean;
begin
  Result := 0;
  if DBAppGlobals.MCM_App then
  begin
    if not DecodeLicVers1(lic, s_licBytesMcm, strErr) then exit
  end
  else
  begin
    if not DecodeLicVers1(lic, s_licBytes, strErr) then exit;
  end;
  if lic.instType = INST_CUST_DEMO then exit;
  if lic.instType = INST_DEMO then exit;

  for ph := 0 to m_prodReqList.Count-1 do
  begin
    tHdr := TSCProdReqHdr(m_prodReqList[ph]);
    for pd := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[pd]);
      tDet.m_list.Sort(SortSubStep);
      if (tDet.p_Count > 1) and (tHdr.m_LeadStepForSplit <> -1) and (tHdr.m_LeadStepForSplit = tDet.m_code) then
      begin
        if (tHdr.m_ConfLevels <> '') then
          UserRequestForSplit := false
        else
          UserRequestForSplit := true;
        Result := Result + CheckHostLeadStepSplit(tDet, UserRequestForSplit, 0);
      end;
    end;
  end;
end;

