function FindGroupRuleCriteria(var GroupRuleCriteria_List : TList; StringRuleCriteria : string; IsGroup : boolean) : PRGroupRuleCriteria;
var
  i, Index : integer;
  Multiplier, NumberOfEntries, NumberOfEntriesMinusOne : integer;
  RGroupRuleCriteria : PRGroupRuleCriteria;
begin
  NumberOfEntries := GroupRuleCriteria_List.Count;
  Result := nil;
  Index := NumberOfEntries;

  if NumberOfEntries > 0 then
  begin
    NumberOfEntriesMinusOne := NumberOfEntries - 1;
    Multiplier := 1;
    while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
    i := Multiplier - 1;

    while (Multiplier > 0) do
    begin
      Multiplier := trunc(Multiplier / 2);

      if (i > NumberOfEntriesMinusOne) then
      begin
        i := i - Multiplier;
        Continue;
      end;

      if  (PRGroupRuleCriteria(GroupRuleCriteria_List[i]).GroupCriteria > StringRuleCriteria) then
      begin
        if I < Index then Index := I;
        i := i - Multiplier;
        Continue;
      end;

      if  (PRGroupRuleCriteria(GroupRuleCriteria_List[i]).GroupCriteria < StringRuleCriteria) then
      begin
        i := i + Multiplier;
        Continue;
      end;

      Result := PRGroupRuleCriteria(GroupRuleCriteria_List[i]);
      Index := i;
      Break;

    end;

  end;

  if not IsGroup and (Result = nil) then
  begin
    new(RGroupRuleCriteria);
    RGroupRuleCriteria.GroupCriteria := StringRuleCriteria;
    RGroupRuleCriteria.JobIdsList    := TList.Create;
    RGroupRuleCriteria.GroupList     := TList.Create;
    GroupRuleCriteria_List.insert(Index, RGroupRuleCriteria);
    Result := RGroupRuleCriteria;
  end;

end;

