function TMSchedCont.GetFldDescr(id: TSchedID; fld: CBinColId; RealValueInCell : boolean): string;

  function OutDate(dt: TDateTime): string;
  begin
//    Result := FormatDateTime('dd/mm/yy hh:nn', dt)
    Result := DateToStr(dt) + ' ' + TimeToStr(dt)
  end;

var
  value:    variant;
  dataType: CBinColValType;
  res:      boolean;
  st:       CScSchedType;
begin
  try
    if not p_sc.IsGroup(Id) and p_sc.IsProdSchedMaterial(Id) then
        res := GetFldSupportMat(id, fld, value, dataType)
    else
      res := GetFldSupport(id, fld, value, dataType, RealValueInCell);
    if not res then
      Result := '----'
    else
      case dataType of
      CBT_date:     begin
                      if value = '00:00:00' then
                        Result := '-------------'
                      else
                        Result := OutDate(value);
                    end;
      CBT_integer:  if fld <> CSC_StepType then
                      Result := IntToStr(value)
                    else
                    begin
                      st := value;
                      case st of
                      CST_batch:      Result := _('batch');
                      CST_Continuous: Result := _('continuous')
                      else
                        // CST_printing
                        Result := _('printing')
                      end
                    end;

      CBT_float:    Result := FloatToStr(value);
    //    CBT_dur:      Result := FormatDuration(value);
      CBT_dur:      Result := FormatDuration(value, true);
      CBT_string:   Result := value;
      CBT_bool:     if value then
                      Result := _('yes')
                    else
                      Result := _('no')
      end
  except
    Result := ''
  end;
end;

