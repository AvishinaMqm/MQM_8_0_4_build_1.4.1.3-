          begin
            next;
            continue;
          end;

          if FirstRow or (Req <> PrevReq) then
             tHdr := FindHdrFromCode(self, Req);
          FirstRow := false;
          PrevReq := Req;

          if Assigned(tHdr) then
          begin
            tDet := nil;
            tDet := AddReqDet(tHdr, DetCode);
          end;

          if Assigned(tHdr) and Assigned(tDet) then
          begin
            tmpStr := fPD_StepType.AsString;
            if tmpStr = 'B' then
              tDet.m_stepType := CST_batch
            else if tmpStr = 'C' then
              tDet.m_stepType := CST_continuous
            else if tmpStr = 'H' then
            begin
              tDet.m_stepType := CST_continuous;
              tDet.m_batch_ContinuesTime := true;
            end
            else if tmpStr = 'P' then
            begin
              tDet.m_stepType := CST_batch;
              tDet.m_Continues_Parallel := true;
            end
            else
              tDet.m_stepType := CST_continuous;
          //  tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_ToBeSched)).AsString = '1');
            if DBAppGlobals.MCM_App then
            begin
              tDet.m_StepToSched       := (fPD_SchedulByMcm.AsString = '1');
              tDet.m_prevStep          := fPD_prevStepSched_Mcm.AsInteger;
              tDet.m_nextStep          := fPD_NextStepSched_Mcm.AsInteger;
            end
            else
            begin
              tDet.m_StepToSched       := (fPD_SchedulByMqm.AsString = '1');
              tDet.m_prevStep          := fPD_prevStepSched_Mqm.AsInteger;
              tDet.m_nextStep          := fPD_NextStepSched_Mqm.AsInteger;
            end;
            tDet.m_GenericPlan       := fPD_StepPartGenralPlan.AsString;
            tDet.m_prevRealStep      := fPD_prevStepTrue.AsInteger;
            tDet.m_nextRealStep      := fPD_NextStepTrue.AsInteger;
            tDet.m_materialArrivDate := fPD_MaterialArrivDate.AsDateTime;
            tDet.m_planStart         := fPD_planStart.AsDateTime;
            tDet.m_planStart_orig    := tDet.m_planStart;
            tDet.m_planEnd           := fPD_planEnd.AsDateTime;
            tDet.m_planEnd_Orig      := tDet.m_planEnd;
            if not DBAppGlobals.MCM_App then
            begin
              if not fPD_InitialPlanScheduledDateTime.isnull and
                 (fPD_InitialPlanScheduledDateTime.AsDateTime > 0) then
              begin
                tDet.m_lowStartTimeLimit := fPD_InitialPlanScheduledDateTime.AsDateTime;
                tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit
              end
              else
              begin
                tDet.m_lowStartTimeLimit := fPD_LowStartTimeLimit.AsDateTime;
                tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit;
              end;

              if not fPD_finalPlanScheduledDateTime.isnull and
                 (fPD_finalPlanScheduledDateTime.AsDateTime > 0) then
              begin
                tDet.m_highEndTimeLimit := fPD_finalPlanScheduledDateTime.AsDateTime;
                tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit;
              end
              else
              begin
                tDet.m_highEndTimeLimit := fPD_HighEndTimeLimit.AsDateTime;
                tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit
              end;
            end
            else
            begin
              tDet.m_lowStartTimeLimit := fPD_LowStartTimeLimit.AsDateTime;
              tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit;
              tDet.m_highEndTimeLimit  := fPD_HighEndTimeLimit.AsDateTime;
              tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit;
            end;
            tDet.m_Approvaldate      := fPD_ApprovalDate.AsDateTime;
            tDet.m_calCod            := fPD_CalCod.AsString;
            tDet.m_quantInit         := fPD_quantInit.AsFloat;
            tDet.m_quantFinl         := fPD_quantFinl.AsFloat;
            tDet.P_quantAlternative  := fPD_alternative_Qty.AsFloat;
            tDet.P_UmAlternative     := fPD_alternative_UM.AsString;
            tDet.m_weight            := fPD_Weight.AsFloat;
            tDet.m_weightUM          := fPD_DescUM.AsString;
            tDet.m_planWkctr         := fPD_wkCtrCode.AsString;
            tDet.m_PlanWrkCtrPtr     := findWC(tDet.m_planWkctr);
            tDet.m_planWkctrProc     := fPD_wkcProc.AsString;
            tDet.m_CanGroup          := fPD_StepCanGroup.AsString;
            tDet.p_OverlapWithOtherSteps := false;
            if fPD_OverlapWithOtherSteps.AsString = '1' then
               tDet.p_OverlapWithOtherSteps := true;

            MqmWrkCtr := TMqmWrkCtr(p_pl.FindWrkCtrByCode(tDet.m_planWkctr));
            if assigned(MqmWrkCtr) then
              tDet.P_IgnoreProgress := MqmWrkCtr.P_IgnoreProgress;

            if fPD_FrcMatDate.AsString = '1' then
               tDet.m_FrcMatDate := CSF_Forceable
            else if fPD_FrcMatDate.AsString = '2' then
               tDet.m_FrcMatDate := CSF_Yes
            else
               tDet.m_FrcMatDate := CSF_No;

            if fPD_FrcLowestDate.AsString = '1' then
               tDet.m_FrcLowestDate := CSF_Forceable
            else if fPD_FrcLowestDate.AsString = '2' then
               tDet.m_FrcLowestDate := CSF_Yes
            else
               tDet.m_FrcLowestDate := CSF_No;

            if fPD_FrcHighestDate.AsString = '1' then
               tDet.m_FrcHighestDate := CSF_Forceable
            else if fPD_FrcHighestDate.AsString = '2' then
               tDet.m_FrcHighestDate := CSF_Yes
            else if fPD_FrcHighestDate.AsString = '3' then
               tDet.m_FrcHighestDate := CSF_Forceable
            else
               tDet.m_FrcHighestDate := CSF_No;

            if fPD_FrcOverlapp.AsString = '1' then
               tDet.m_FrcOverlapp := CSF_Forceable
            else if fPD_FrcOverlapp.AsString = '2' then
               tDet.m_FrcOverlapp := CSF_Yes
            else
               tDet.m_FrcOverlapp := CSF_No;

            if fPD_StepClosed.AsString = '1' then
               tDet.m_stepClosed := true
            else
               tDet.m_stepClosed := false;

            if not fPD_GrpContinueSeq.IsNull then
              tDet.P_Grp_Sequence := Trim(fPD_GrpContinueSeq.AsString);

            if not fPD_BatchSizePerStep.IsNull then
            begin
              if fPD_BatchSizePerStep.AsString = '1' then
                tDet.m_BatchSizePerStep := true
              else
                tDet.m_BatchSizePerStep := false;
            end;

            if not fPD_MinBatchSize.IsNull then
              tDet.m_MinBatchSize := fPD_MinBatchSize.AsFloat;

            if not fPD_OptimumBatchSize.IsNull then
              tDet.m_OptimumBatchSize := fPD_OptimumBatchSize.AsFloat;

            if not fPD_MaxBatchSize.IsNull then
              tDet.m_MaxBatchSize := fPD_MaxBatchSize.AsFloat;

            tDet.m_SetupTimeStep := fPD_SetupTimStep.AsFloat;
            tDet.m_ExeTimeStep   := fPD_excTimeStep.AsFloat;
            tDet.m_planNumRes    := fPD_NumResPlan.AsFloat;
            tDet.p_rscComp       := fPD_NumSubRscComponents.AsInteger;
            tDet.p_MaxStartingDateAutoSeq := fPD_MaxStartDateAutoSeq.AsDateTime;

            tDet.m_connTypeToPrevious:= fPD_ConnTypToPrevStepSplit.AsString;
            tDet.m_OfThisWrkst   := true;
            if tDet.m_quantInit = 0 then
            begin
              tDet.P_LeadTimePrev := 0;
              tDet.P_LeadTimeNext := 0;
              tDet.P_LeadTimePrevBatch := 0;
              tDet.P_LeadTimeNextBatch := 0;
            end
            else
            begin
              tDet.P_LeadTimePrev := fPD_PrevLeadTime_mqm.AsFloat / tDet.m_quantInit;
              tDet.P_LeadTimeNext := fPD_NextLeadTime_mqm.AsFloat / tDet.m_quantInit;
              tDet.P_LeadTimePrevBatch := fPD_PrevLeadTimeBatch_mqm.AsFloat;
              tDet.P_LeadTimeNextBatch := fPD_NextLeadTimeBatch_mqm.AsFloat;
            end;

            tJob := AddJobDet(tDet, 0, CSnoGroupDef);

            if (fWW_TypeOfUse.AsString = '2') then
              tJob.m_VisbleInBin := CSB_ReadOnly
            else
              tJob.m_VisbleInBin := CSB_Normal;

            tDet.p_CurveType := CSC_No;
            if fPD_LearningCurveType.AsString = '1' then
              tDet.p_CurveType := CSC_Managed
            else if fPD_LearningCurveType.AsString = '2' then
              tDet.p_CurveType := CSC_Forced_By_Host;
            if tDet.p_CurveType <> CSC_No then
              tJob.p_CurveCode := fPD_LearningCurveCode.AsString;

            if not fPD_GrpContinueSeq.IsNull then
              tJob.P_Grp_Sequence := trim(fPD_GrpContinueSeq.AsString);

            tDet.m_SplitAllow := CSB_No;
            if fPD_AllowSplit.AsString = '1' then
               tDet.m_SplitAllow := CSB_Yes
            else if fPD_AllowSplit.AsString = '2' then
            begin
              tDet.m_SplitAllow := CSB_Father;
              if not fPD_SplitFamaly.IsNull then
                tJob.m_SplitFamilyCode := fPD_SplitFamaly.AsString;
            end
            else if fPD_AllowSplit.AsString = '3' then
            begin
              tDet.m_SplitAllow := CSB_Son;
              if not fPD_SplitFamaly.IsNull then
                tJob.m_SplitFamilyCode := fPD_SplitFamaly.AsString;
            end;

            tJob.m_fromPD         := true;
            tJob.m_status         := CSS_none;
            tJob.m_subLinRscId    := 0;
            tJob.m_srvPtr         := nil;
            tJob.m_reprocNo       := 0;
            tJob.p_SetStepType    := '0';
            tJob.m_comment        := '';
            tJob.p_WorkCenter     := '';
            tJob.p_Process        := '';
            tJob.p_NewSetup  := -1;
            tJob.p_quantSched     := tDet.m_quantInit;
            tJob.p_exeMin         := 0;
            tJob.p_supMinBase     := 0;
            tJob.p_supMinReal     := 0;
            tJob.p_supMinOvlp     := 0;
            tJob.m_fwdConnSubStp  := -2;
            tJob.m_fwdConnReProcs := -2;
            tJob.m_bkwConnSubStp  := -2;
            tJob.m_bkwConnReProcs := -2;
            tJob.m_TimeDescr      := '';
            tJob.m_MachSetupCode  := '';
            tJob.m_PrgSt          := 0;
            tJob.m_PrgCurDt       := 0;
            tJob.m_PrgEd          := 0;
            tJob.m_PrgQty         := 0;
            tJob.m_PrgStartingQty := 0;
            tJob.m_PrgRemTime     := -1;
            tJob.m_ProgType       := '';
            tJob.m_ProgRsc        := '';
            tJob.m_PrgStHost      := 0;
            tJob.m_PrgCurDtHost   := 0;
            tJob.m_PrgEdHost      := 0;
            tJob.m_PrgQtyHost     := 0;
            tJob.m_PrgRemTimeHost := -1;
            tJob.m_ProgTypeHost   := '';
            tJob.m_ProgRscHost    := '';
            tJob.m_MsgFromHost :=  CSH_New_step;
            tJob.p_quantManualChg := 0;
            tJob.p_NewSetup  := -1;

            tJob.m_GroupType :=  fPD_StepCanGroup.AsString;
            tJob.m_forcedGrpNo := fPD_ForcedGroupNo.AsInteger;

            if (tJob.m_GroupType = '2') and (tJob.m_forcedGrpNo < 0) then
              AddForcedGroup(tJob.m_Id,tJob.m_forcedGrpNo);

            if (tJob.m_VisbleInBin = CSB_ReadOnly) then
              tJob.m_status := CSS_none;
         //   tJob.p_WrkCtrPtr      := findWC(tJob.m_reqDet.m_planWkctr);
         //   tDet.m_PlanWrkCtrPtr  := tJob.p_WrkCtrPtr;
            DispoList.Add(_('New step:') + ' ' + IntToStr(tDet.m_code) + ', ' + _('entered in request:') + ' ' + tDet.m_hdr.m_code);;
          end;

        except
          if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Insert New Step:') +
              ' ' + _('Request:') + Req + ' ,' + _('Step:') + IntTostr(DetCode) + ' Technical code: UMSchedCont:InsertNewStep' , mtConfirmation, [mbOk], 0) = idOk then
          begin
            Next;
            Continue;
          end;
        end;

        next;
      end;
    end;

    except
      if MessageDlg(_('A sever error occured while inserting steps') + #13#10 +
         ' Technical code: UMSchedCont:InsertNewStep' , mtConfirmation, [mbOk], 0) = idOk then
      begin
        Exit;
      end;
    end;

    qry.Close;
  end;

