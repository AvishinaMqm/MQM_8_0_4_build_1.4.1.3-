function FindRequestHeader(sc: TMSchedCont; hdrCode: string; Step : Integer) : TList;
var
  i, J: integer;
  Multiplier, NumberOfEntries : integer;
  ReqHdr : TSCProdReqHdr;
begin
  Result := nil;
  NumberOfEntries := sc.m_prodReqList.Count;
  if NumberOfEntries = 0 then exit;

  if not sc.m_prodReqListSorted then
  begin
    sc.m_prodReqList.Sort(HdrOrderGrowing);
    sc.m_prodReqListSorted := true;
  end;

  Multiplier := 1;
  while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
  i := Multiplier - 1;

  while (Multiplier > 0) do
  begin
    if  (i < NumberOfEntries)
    and (TSCProdReqHdr(sc.m_prodReqList[i]).m_code = hdrCode) then break;

    Multiplier := trunc(Multiplier / 2);

    if  (i < NumberOfEntries)
    and (TSCProdReqHdr(sc.m_prodReqList[i]).m_code < hdrCode) then
      i := i + Multiplier
    else
      i := i - Multiplier;
  end;

  if Multiplier > 0 then
  begin
    ReqHdr := TSCProdReqHdr(sc.m_prodReqList[i]);
    for J := 0 to ReqHdr.m_list.count - 1 do
    begin
      if Step = TSCProdReqDet(ReqHdr.m_list[J]).m_code then
      begin
        Result := TSCProdReqDet(ReqHdr.m_list[J]).m_StepTimeList;
        break;
      end;
    end;
  end;
end;

