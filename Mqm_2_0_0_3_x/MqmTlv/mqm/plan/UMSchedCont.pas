procedure TMSchedCont.GetColors(id: TSchedId; ForPlan: boolean; cmp: TCompatVal; PlanTyp: TPlanType;
                                CanvasDates,CanvasMat,CanvasStatus: TCanvas);
var
  sc:  TSCSchedOnPlan;
//  job: TSCProdSched;
  errSet: SetOfErrors;
//  TmpColor: TColor;
  SchedType: String;
  Status: CScErrors;
  ProgType: CProgress;
  SonId, compId : TSchedId;
  G: Integer;
  FieldVal : variant;
  dataType: CBinColValType;
  DummyList : TList;
  OverrideStatus : CProgressIgnor;
  ProgressIgnoredType : CProgressTypeIgnored;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  //Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then exit;
  CanvasDates.Pen.Style  := psSolid;
  CanvasMat.Pen.Style    := psSolid;
  CanvasStatus.Pen.Style := psSolid;
  DummyList := nil;

  if (p_pl.GetCompatModeInPlanId = CSchedIdNull) or (cmp = CompValNotValid) then
  begin

    errSet := [];
    CheckErrors(id, CSEG_Dates, errSet, DummyList);
    GetDateWarningColor(errSet, ForPlan, CanvasDates.brush, CanvasDates.pen, CanvasDates.font);
//    GetErrorColor(GetWorstError(errSet), ForPlan, CanvasDates.brush, CanvasDates.pen, CanvasDates.font);

    errSet := [];
    CheckErrors(id, CSEG_Materials, errSet, DummyList);
    GetMatWarningColor(errSet, ForPlan, CanvasMat.brush, CanvasMat.pen, CanvasMat.font);

    errSet := [];
    ProgType := isProgressed(id);
    SchedType := GetSchedType(id);
    status := CSE_NoError;

    if (sc is TSCProdGroup) then
    begin
      GetFldSupport(Id, CSC_Closed, FieldVal, dataType, false);
      if FieldVal then
         status := CSE_Closed;
    end
    else if TSCProdSched(sc).m_reqDet.m_stepClosed then
      status := CSE_Closed;


//    if not (sc is TSCProdGroup)
//    and TSCProdSched(sc).m_reqDet.m_stepClosed then
    if not (status = CSE_Closed) then
//    else
    begin
      case ProgType of
        prg_Starting,
        prg_General : status := CSE_NotFinProg;
        prg_Final,
        prg_FinalSplit : status := CSE_FinProg;
      else
        if SchedType = '1' then
          status := CSE_Temp
        else
          if SchedType = '2' then
            status := CSE_Final
          else
            if (SchedType = '3') then
              status := CSE_Level1
            else if (SchedType = '4') then
              status := CSE_Level2
            else if (SchedType = '5') then
              status := CSE_Level3
            else if (SchedType = '6') then
              status := CSE_Level4
            else if (SchedType = '7') then
              status := CSE_Level5
            else if (SchedType = '8') then
              status := CSE_Level5;

      end;

    end;

    OverrideStatus := GetProgressOverrideStatus(id, ProgressIgnoredType);
    if (OverrideStatus = Prg_Ignored) or (OverrideStatus = Prg_IgnoredAndSave) then
    begin
      if ProgressIgnoredType = Ign_Ignored_Initial then
         status := CSE_Ignored_Initial
      else if ProgressIgnoredType = Ign_Ignored_Generic then
         status := CSE_Ignored_Generic
      else if ProgressIgnoredType = Ign_Ignored_Final then
         status := CSE_Ignored_Final
    end;

    GetStatusColor(status, ForPlan, CanvasStatus.brush, CanvasStatus.pen, CanvasStatus.font);

//    GetErrorColor(status, ForPlan, CanvasStatus.brush, CanvasStatus.pen, CanvasStatus.font);

    if not (sc is TSCProdGroup) then
    begin
//      if job.p_GetStepType = '1' then
//        CanvasStatus.pen.Style := psDot
//      else
        CanvasStatus.pen.Style := psSolid;
    end else
      if TSCProdSched(TSCProdGroup(sc).m_list[0]).m_reqDet.m_stepType = CST_Continuous then
        CanvasStatus.pen.Color := clGreen;
  end
  else
  begin
{
    if sc is TSCProdGroup then
    begin
      brush.Color  := clBlue;
      font.Color   := clWhite;
      pen.Color    := clBlack;
      if TSCProdSched(TSCProdGroup(sc).m_list[0]).m_reqDet.m_stepType = CST_Continuous then
        pen.Color := clWhite;
    end
    else
}
    GetOccCompatColor(cmp, ForPlan, CanvasStatus.brush, CanvasStatus.pen, CanvasStatus.font);

    if not (sc is TSCProdGroup) then
    begin
//      job := TSCProdSched(sc);
//      if job.p_GetStepType = '1' then
//        CanvasStatus.pen.Style := psDot
//      else
        CanvasStatus.pen.Style := psSolid;
    end;
  end;

  if (PlanTyp = PDynamic) and not HasFlags(id, [CSF_FilterJobsInDynamicGantt]) then
  begin
    CanvasStatus.pen.Color := CanvasStatus.brush.Color;
    CanvasStatus.brush.Style := bsClear;
    CanvasStatus.pen.Width := 1
  end
  else if (PlanTyp = PDynamic) and HasFlags(id, [CSF_FilterJobsInDynamicGantt]) then
  begin
    CanvasStatus.pen.Color := clblack;
    CanvasStatus.brush.Style := bsSolid;
    CanvasStatus.pen.Width := 1;  // avi , make problems with the width = 2 ///
  end
  else
    CanvasStatus.pen.Width := 1;

  // set the border if the object is selected
  if HasFlags(id, [CSF_moveSelect]) then
  begin
    CanvasStatus.pen.Color := Cl_STNDRD_LIGHT_BLUE;//16758380;//clYellow;
    CanvasStatus.pen.Width := 2
  end;

{
  if (CanvasStatus.Brush.Style = bsBDiagonal)
  or (CanvasStatus.Brush.Style = bsFDiagonal)
  or (CanvasStatus.Brush.Style = bsDiagCross) then
  begin
    //set the background color
    TmpColor := CanvasStatus.brush.Color;
    CanvasStatus.brush.Color := CanvasStatus.pen.Color;
    SetBkColor(CanvasStatus.Handle, ColorToRGB(TmpColor));
    SetBkMode(CanvasStatus.Handle, OPAQUE);
  end;
}
end;

