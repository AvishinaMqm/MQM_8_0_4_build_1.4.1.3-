        fPD_AllowSplit                   := FieldByName(CreateFld(tbiPD.pfx, fli_AllowSplit));
        fPD_SplitFamaly                  := FieldByName(CreateFld(tbiPD.pfx, fli_SplitFamaly));
        fPD_LearningCurveType            := FieldByName(CreateFld(tbiPD.pfx, fli_LearningCurveType));
        fPD_LearningCurveCode            := FieldByName(CreateFld(tbiPD.pfx, fli_LearningCurveCode));
        fPD_FrcMatDate                   := FieldByName(CreateFld(tbiPD.pfx, fli_FrcMatDate));
        fPD_FrcLowestDate                := FieldByName(CreateFld(tbiPD.pfx, fli_FrcLowestDate));
        fPD_FrcHighestDate               := FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate));
        fPD_FrcOverlapp                  := FieldByName(CreateFld(tbiPD.pfx, fli_FrcOverlapp));
        fPD_StepClosed                   := FieldByName(CreateFld(tbiPD.pfx, fli_StepClosed));
        fPD_GrpContinueSeq               := FieldByName(CreateFld(tbiPD.pfx, fli_GrpContinueSeq));
        fPD_BatchSizePerStep             := FieldByName(CreateFld(tbiPD.pfx, fli_BatchSizePerStep));
        fPD_MinBatchSize                 := FieldByName(CreateFld(tbiPD.pfx, fli_MinBatchSize));
        fPD_OptimumBatchSize             := FieldByName(CreateFld(tbiPD.pfx, fli_OptimumBatchSize));
        fPD_MaxBatchSize                 := FieldByName(CreateFld(tbiPD.pfx, fli_MaxBatchSize));
        fPD_SetupTimStep                 := FieldByName(CreateFld(tbiPD.pfx, fli_SetupTimStep));
        fPD_excTimeStep                  := FieldByName(CreateFld(tbiPD.pfx, fli_excTimeStep));
        fPD_NumResPlan                   := FieldByName(CreateFld(tbiPD.pfx, fli_NumResPlan));
        fPD_NumSubRscComponents          := FieldByName(CreateFld(tbiPD.pfx, fli_NumSubRscComponents));
        fPD_MaxStartDateAutoSeq          := FieldByName(CreateFld(tbiPD.pfx, fli_MaxStartDateAutoSeq));
        fPD_ConnTypToPrevStepSplit       := FieldByName(CreateFld(tbiPD.pfx, fli_ConnTypToPrevStepSplit));
        fPD_PrevLeadTime_mqm             := FieldByName(CreateFld(tbiPD.pfx, fli_PrevLeadTime_mqm));
        fPD_NextLeadTime_mqm             := FieldByName(CreateFld(tbiPD.pfx, fli_NextLeadTime_mqm));
        fPD_PrevLeadTimeBatch_mqm        := FieldByName(CreateFld(tbiPD.pfx, fli_PrevLeadTimeBatch_mqm));
        fPD_NextLeadTimeBatch_mqm        := FieldByName(CreateFld(tbiPD.pfx, fli_NextLeadTimeBatch_mqm));
        fPD_ForcedGroupNo                := FieldByName(CreateFld(tbiPD.pfx, fli_ForcedGroupNo));
        fWW_TypeOfUse                    := FieldByName(CreateFld(tbiww.pfx, fli_TypeOfUse));

        oldHdrCode := '';
        oldDetCode := -1;
        tHdr       := nil;
        tDet       := nil;

        while not EOF do
        begin
          Req := fPD_preqNo.AsString;

          try

            if fPH_ModulHandled.AsString = '1' then
            begin
              Next;
              continue
            end;

            if oldHdrCode <> Req then
            begin

              oldHdrCode := fPD_preqNo.AsString;

              tHdr := AddReqHdr(oldHdrCode);
              tHdr.m_prodLine        := fPH_ProdLine.AsString;
              tHdr.m_prodType        := fPH_ProdType.AsString;
              tHdr.m_prodFamily      := fPH_ProdFamily.AsString;
              tHdr.m_matFamily       := fPH_MaterialFamily.AsString;
              tHdr.m_prodUMCode      := fPH_ProdUMCode.AsString;
              tHdr.m_NumOfDecimals   := GetUmNumOfDecimals(tHdr.m_prodUMCode);
              tHdr.m_prodLowDateTime := fPH_ProdLowDataTime.AsDateTime;
              tHdr.m_prodDelivDate   := fPH_ProdDelivDate.AsDateTime;
              if fPH_FrcDelDate.AsString = '1' then
                tHdr.m_FrcDelDate := CSF_Forceable
              else if fPH_FrcDelDate.AsString = '2' then
                tHdr.m_FrcDelDate := CSF_Yes
              else if fPH_FrcDelDate.AsString = '3' then
                tHdr.m_FrcDelDate := CSF_Forceable2
              else if fPH_FrcDelDate.AsString = '4' then
                tHdr.m_FrcDelDate := CSF_Yes2
              else
                tHdr.m_FrcDelDate := CSF_No;

              tHdr.m_LeadStepForSplit := -1;

              if not DBAppGlobals.MCM_App then
              begin
                if (not fPH_LeadpstepIdForSplit.IsNull) and
                  (fPH_LeadpstepIdForSplit.AsInteger <> 0) then
                begin
                  tHdr.m_LeadStepForSplit := fPH_LeadpstepIdForSplit.AsInteger;
                  m_ProdReqLeadStepSplitList.Add(tHdr);
                end;
              end;

              tHdr.m_CurveFamilyIdCode := '';
              if (not fPH_CurveFamilyIdCode.IsNull) and
               (trim(fPH_CurveFamilyIdCode.AsString) <> '') then
                  tHdr.m_CurveFamilyIdCode := fPH_CurveFamilyIdCode.AsString;

              tHdr.m_ConfLevels := '';
              if (not fPH_SplitConfLevels.IsNull) and
               (trim(fPH_SplitConfLevels.AsString) <> '') then
                  tHdr.m_ConfLevels := fPH_SplitConfLevels.AsString;

              tHdr.m_NewReqUniqId := '';
              if (not fPH_NewPreqUniqId.IsNull) and
                (trim(fPH_NewPreqUniqId.AsString) <> '') then
                  tHdr.m_NewReqUniqId := fPH_NewPreqUniqId.AsString;

              if (not fPH_Serving_Code.IsNull) and (trim(fPH_Serving_Code.AsString) <> '') then
              begin
                if not Assigned(m_ServingCodeList) then
                   m_ServingCodeList := TList.Create;
                tHdr.m_ServingCode := trim(fPH_Serving_Code.AsString);
                tHdr.m_ServingCodeHdrList := EnterServingCodeToList(tHdr.m_ServingCode, tHdr);
              end;

              oldDetCode := -1;
              DispoList.Add(_('New request:') + ' ' + oldHdrCode);
            end;

            if oldDetCode <> fPD_pstepId.AsInteger then
            begin
              oldDetCode := fPD_pstepId.AsInteger;

              tDet := AddReqDet(tHdr, oldDetCode);

              tmpStr := fPD_StepType.AsString;
              if tmpStr = 'B' then
                tDet.m_stepType := CST_batch
              else if tmpStr = 'C' then
                tDet.m_stepType := CST_continuous
              else if tmpStr = 'H' then
              begin
                tDet.m_stepType := CST_continuous;
                tDet.m_batch_ContinuesTime := true;
              end
              else if tmpStr = 'P' then
              begin
                tDet.m_stepType := CST_batch;
                tDet.m_Continues_Parallel := true;
              end
              else
                tDet.m_stepType := CST_continuous;
          //    tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_ToBeSched)).AsString = '1');
              if DBAppGlobals.MCM_App then
              begin
                tDet.m_StepToSched     := (fPD_SchedulByMcm.AsString = '1');
                tDet.m_prevStep        := fPD_prevStepSched_Mcm.AsInteger;
                tDet.m_nextStep        := fPD_NextStepSched_Mcm.AsInteger;
              end
              else
              begin
                tDet.m_StepToSched     := (fPD_SchedulByMqm.AsString = '1');
                tDet.m_prevStep        := fPD_prevStepSched_Mqm.AsInteger;
                tDet.m_nextStep        := fPD_NextStepSched_Mqm.AsInteger;
              end;
              tDet.m_GenericPlan       := fPD_StepPartGenralPlan.AsString;
              tDet.m_prevRealStep      := fPD_prevStepTrue.AsInteger;
              tDet.m_nextRealStep      := fPD_NextStepTrue.AsInteger;
              tDet.m_materialArrivDate := fPD_MaterialArrivDate.AsDateTime;
              tDet.m_planStart         := fPD_planStart.AsDateTime;
              tDet.m_planStart_Orig    := tDet.m_planStart;
              tDet.m_planEnd           := fPD_planEnd.AsDateTime;
              tDet.m_planEnd_Orig      := tDet.m_planEnd;

              if not DBAppGlobals.MCM_App then
              begin
                if not fPD_InitialPlanScheduledDateTime.IsNull and
                  (fPD_InitialPlanScheduledDateTime.AsDateTime > 0) then
                begin
                  tDet.m_lowStartTimeLimit := fPD_InitialPlanScheduledDateTime.AsDateTime;
                  tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit
                end
                else
                begin
                  tDet.m_lowStartTimeLimit := fPD_LowStartTimeLimit.AsDateTime;
                  tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit;
                end;

                if not fPD_finalPlanScheduledDateTime.IsNull and
                   (fPD_finalPlanScheduledDateTime.AsDateTime > 0) then
                begin
                  tDet.m_highEndTimeLimit := fPD_finalPlanScheduledDateTime.AsDateTime;
                  tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit;
                end
                else
                begin
                  tDet.m_highEndTimeLimit  := fPD_HighEndTimeLimit.AsDateTime;
                  tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit;
                end;
              end
              else
              begin
                tDet.m_lowStartTimeLimit := fPD_LowStartTimeLimit.AsDateTime;
                tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit;
                tDet.m_highEndTimeLimit  := fPD_HighEndTimeLimit.AsDateTime;
                tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit;
              end;

              tDet.m_Approvaldate      := fPD_ApprovalDate.AsDateTime;
              tDet.m_calCod            := fPD_CalCod.AsString;
              tDet.m_quantInit         := fPD_quantInit.AsFloat;
              tDet.m_quantFinl         := fPD_quantFinl.AsFloat;
              tDet.P_quantAlternative  := fPD_alternative_Qty.AsFloat;
              tDet.P_UmAlternative     := fPD_alternative_UM.AsString;
              tDet.m_weight            := fPD_Weight.AsFloat;
              tDet.m_weightUM          := fPD_DescUM.AsString;
              tDet.m_planWkctr         := fPD_wkCtrCode.AsString;
              tDet.m_PlanWrkCtrPtr     := findWC(tDet.m_planWkctr);
              tDet.m_planWkctrProc     := fPD_wkcProc.AsString;
              tDet.m_CanGroup          := fPD_StepCanGroup.AsString;
              tDet.p_OverlapWithOtherSteps := false;
              if fPD_OverlapWithOtherSteps.AsString = '1' then
                 tDet.p_OverlapWithOtherSteps := true;

              MqmWrkCtr := TMqmWrkCtr(p_pl.FindWrkCtrByCode(tDet.m_planWkctr));
              if assigned(MqmWrkCtr) then
                tDet.P_IgnoreProgress := MqmWrkCtr.P_IgnoreProgress;

              if fPD_FrcMatDate.AsString = '1' then
                 tDet.m_FrcMatDate := CSF_Forceable
              else if fPD_FrcMatDate.AsString = '2' then
                 tDet.m_FrcMatDate := CSF_Yes
              else
                 tDet.m_FrcMatDate := CSF_No;

              if fPD_FrcLowestDate.AsString = '1' then
                 tDet.m_FrcLowestDate := CSF_Forceable
              else if fPD_FrcLowestDate.AsString = '2' then
                 tDet.m_FrcLowestDate := CSF_Yes
              else
                 tDet.m_FrcLowestDate := CSF_No;

              if fPD_FrcHighestDate.AsString = '1' then
                 tDet.m_FrcHighestDate := CSF_Forceable
              else if fPD_FrcHighestDate.AsString = '2' then
                 tDet.m_FrcHighestDate := CSF_Yes
              else if fPD_FrcHighestDate.AsString = '3' then
              begin
                 tDet.m_FrcHighestDate := CSF_RequestedHighesEndDate;
                 tDet.m_highEndTimeLimitTemp := tDet.m_highEndTimeLimit
              end
              else
                 tDet.m_FrcHighestDate := CSF_No;

              if fPD_FrcOverlapp.AsString = '1' then
                 tDet.m_FrcOverlapp := CSF_Forceable
              else if fPD_FrcOverlapp.AsString = '2' then
                 tDet.m_FrcOverlapp := CSF_Yes
              else
                 tDet.m_FrcOverlapp := CSF_No;

              if fPD_StepClosed.AsString = '1' then
                 tDet.m_stepClosed := true
              else
                 tDet.m_stepClosed := false;

              tDet.p_CurveType := CSC_No;
              if fPD_LearningCurveType.AsString = '1' then
                tDet.p_CurveType := CSC_Managed
              else if fPD_LearningCurveType.AsString = '2' then
                tDet.p_CurveType := CSC_Forced_By_Host;

              if not fPD_GrpContinueSeq.IsNull then
                tDet.P_Grp_Sequence := Trim(fPD_GrpContinueSeq.AsString);

              if not fPD_BatchSizePerStep.IsNull then
              begin
                if fPD_BatchSizePerStep.AsString = '1' then
                  tDet.m_BatchSizePerStep := true
                else
                  tDet.m_BatchSizePerStep := false;
              end;

              if not fPD_MinBatchSize.IsNull then
                tDet.m_MinBatchSize := fPD_MinBatchSize.AsFloat;

              if not fPD_OptimumBatchSize.IsNull then
                tDet.m_OptimumBatchSize := fPD_OptimumBatchSize.AsFloat;

              if not fPD_MaxBatchSize.IsNull then
                tDet.m_MaxBatchSize := fPD_MaxBatchSize.AsFloat;

              tDet.m_SetupTimeStep := fPD_SetupTimStep.AsFloat;
              tDet.m_ExeTimeStep   := fPD_excTimeStep.AsFloat;
              tDet.m_planNumRes    := fPD_NumResPlan.AsFloat;
              tDet.p_rscComp       := fPD_NumSubRscComponents.AsInteger;
              tDet.p_MaxStartingDateAutoSeq := fPD_MaxStartDateAutoSeq.AsDateTime;
              tDet.m_connTypeToPrevious:= fPD_ConnTypToPrevStepSplit.AsString;
              if tDet.m_quantInit = 0 then
              begin
                tDet.P_LeadTimePrev := 0;
                tDet.P_LeadTimeNext := 0;
                tDet.P_LeadTimePrevBatch := 0;
                tDet.P_LeadTimeNextBatch := 0;
              end
              else
              begin
                tDet.P_LeadTimePrev := fPD_PrevLeadTime_mqm.AsFloat /  tDet.m_quantInit;
                tDet.P_LeadTimeNext := fPD_NextLeadTime_mqm.AsFloat /  tDet.m_quantInit;
                tDet.P_LeadTimePrevBatch := fPD_PrevLeadTimeBatch_mqm.AsFloat;
                tDet.P_LeadTimeNextBatch := fPD_NextLeadTimeBatch_mqm.AsFloat;
              end;
              tDet.m_OfThisWrkst   := true;
            end;

            tJob := AddJobDet(tDet , 0, CSnoGroupDef);

            tDet.m_SplitAllow := CSB_No;
            if fPD_AllowSplit.AsString = '1' then
              tDet.m_SplitAllow := CSB_yes
            else if fPD_AllowSplit.AsString = '2' then
            begin
              tDet.m_SplitAllow := CSB_Father;
              if not fPD_SplitFamaly.IsNull then
                tJob.m_SplitFamilyCode := fPD_SplitFamaly.AsString;
            end
            else if fPD_AllowSplit.AsString = '3' then
            begin
              tDet.m_SplitAllow := CSB_Son;
              if not fPD_SplitFamaly.IsNull then
                tJob.m_SplitFamilyCode := fPD_SplitFamaly.AsString;
            end;

            if not fPD_GrpContinueSeq.IsNull then
              tJob.P_Grp_Sequence := trim(fPD_GrpContinueSeq.AsString);

            if (tDet.p_CurveType <> CSC_No) and not fPD_LearningCurveCode.IsNull then
              tJob.p_CurveCode := fPD_LearningCurveCode.AsString;

            if (fWW_TypeOfUse.AsString = '2') then
               tJob.m_VisbleInBin := CSB_ReadOnly
            else
              tJob.m_VisbleInBin := CSB_Normal;
            tJob.m_fromPD         := true;

            tJob.m_status         := CSS_none;
            tJob.m_MsgFromHost    := CSH_New_request;
            tJob.m_subLinRscId    := 0;
            tJob.m_srvPtr         := nil;
            tJob.m_reprocNo       := 0;
            tJob.p_SetStepType    := '0';
            tJob.m_comment        := '';
            tJob.p_WorkCenter     := '';
            tJob.p_Process        := '';
            tJob.p_NewSetup  := -1;
            tJob.p_quantSched     := tDet.m_quantInit;
            tJob.p_exeMin         := 0;
            tJob.p_supMinBase     := 0;
            tJob.p_supMinReal     := 0;
            tJob.p_supMinOvlp     := 0;
            tJob.m_fwdConnSubStp  := -2;
            tJob.m_fwdConnReProcs := -2;
            tJob.m_bkwConnSubStp  := -2;
            tJob.m_bkwConnReProcs := -2;
            tJob.m_TimeDescr      := '';
            tJob.m_MachSetupCode  := '';
            tJob.m_PrgSt          := 0;
            tJob.m_PrgCurDt       := 0;
            tJob.m_PrgEd          := 0;
            tJob.m_PrgQty         := 0;
            tJob.m_PrgStartingQty := 0;
            tJob.m_PrgRemTime     := -1;
            tJob.m_ProgType       := '';
            tJob.m_ProgRsc        := '';
            tJob.m_PrgStHost      := 0;
            tJob.m_PrgCurDtHost   := 0;
            tJob.m_PrgEdHost      := 0;
            tJob.m_PrgQtyHost     := 0;
            tJob.m_PrgRemTimeHost := -1;
            tJob.m_ProgTypeHost   := '';
            tJob.m_ProgRscHost    := '';

            tJob.p_WorkCenter     := '';
            tJob.p_Process        := '';

          //  tJob.p_WrkCtrPtr      := findWC(tJob.m_reqDet.m_planWkctr);
          //  tDet.m_PlanWrkCtrPtr  := tJob.p_WrkCtrPtr;

            tJob.m_GroupType :=  fPD_StepCanGroup.AsString;
            tJob.m_forcedGrpNo := fPD_ForcedGroupNo.AsInteger;

            if (tJob.m_GroupType = '2') and (tJob.m_forcedGrpNo < 0) then
              AddForcedGroup(tJob.m_Id,tJob.m_forcedGrpNo);

            if (tJob.m_VisbleInBin = CSB_ReadOnly) then
              tJob.m_status := CSS_none;

  //          RefreshStepProgressTime(Qry2,Qry3,tHdr,tDet.m_code);
{            tJobFound := nil;
            if (tHdr.m_NewReqUniqId <> '') then
               tJobFound := FindProdReqLeadStep(tHdr.m_NewReqUniqId);

            if Assigned(tJobFound) then
            begin
              for J := 0 to tHdr.m_list.Count - 1 do
              begin
                tDet := tHdr.m_list[J];
                if (tDet.m_code = tJobFound.m_reqDet.m_code) then
                begin
                  tJobFound.CopyDataFromJobToJob(tDet.m_list[0]);
                  TSCProdSched(tDet.m_list[0]).m_fromPD := true;
                  TSCProdSched(tDet.m_list[0]).m_status := CSS_new;
                  if Assigned(tJobFound.m_srvPtr) then
                  begin
                    actArea := TMqmActArea(tJobFound.m_srvptr);
                    if Assigned(actArea) then
                      actArea.RemoveSchedObj(tJobFound.m_id);
                  end;

                  tJobFound.SetRscCode('');
                  if assigned(tJobFound.m_grp) then
                  begin
                    p_sc.AddJobToGroup(TSCProdSched(tDet.m_list[0]).m_id, tJobFound.m_grp.m_id);
                    p_sc.RemoveJobFromGroup(tJobFound.m_Id);
                  end
                  else
                    fLoad(TSCProdSched(tDet.m_list[0]).p_rscCode, TSCProdSched(tDet.m_list[0]).m_Id, nil);
                  tJobFound.m_isDeleted := true;
                end;
              end;
            end;    }

          except

            if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Insert new request:') +
              ' ' + Req + '  ' + ' Technical code: UMSchedCont:InsertNewRequest' , mtConfirmation, [mbOk], 0) = idOk then
            begin
              next;
              continue;
            end;
          end;

          next;
        end;

      end;

    except

      if MessageDlg(_('A sever error occured while newrequests') + #13#10 +
         ' Technical code: UMSchedCont:InsertNewRequest' , mtConfirmation, [mbOk], 0) = idOk then
      begin
        qry.Close;
        Exit;
      end;

    end;

    qry.Close;

  end;

  ///////////////////////////////////////////////////////////////////////////////

  //  update historical request ...

  procedure UpdateHistoricalRequest(qry: TMqmQuery; UpdateNr : integer; DispoList : TStringList);
  var
    hdrCode : string;
    j1, j2 : integer;
    fPH_preqNo : TField;
  begin
    tbiPH := @tblInfo[tbl_prod_reqHdr];
    try
      with qry do
      begin
        Application.ProcessMessages;
        Sql.Clear;
        Sql.Add('select');
        Sql.Add(' ' + tbiPH.GetTableName + '.*');
        Sql.Add(' from ' + tbiPH.GetTableName);
        Sql.Add(' inner join ' + tbiCR.GetTableName);
        Sql.Add(' on  ' + CreateFld(tbiCR.pfx, fli_ChangeType) + '=' + QuotedStr('3'));
        Sql.Add(' and  ' + CreateFld(tbiCR.pfx, fli_pstepId) + '=' + '0');
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_updCode) + '=' + IntToStr(UpdateNr));
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_preqNo) + '=' + CreateFld(tbiPH.pfx, fli_preqNo));
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_Identifier) + '=' + CreateFld(tbiPH.pfx, fli_Identifier));
        Sql.Add(' where ' + CreateFld(tbiPH.pfx, fli_HistoriclReq) + '=' + QuotedStr('1'));
        SQL.Add(AND_IDF_Condition(CreateFld(tbiPH.pfx, fli_Identifier)));
        Sql.Add(' order by ');
        Sql.Add(CreateFld(tbiPH.pfx, fli_preqNo));
        Prepare;
        FetchOptions.RowsetSize := 5000;
        Open;
        Application.ProcessMessages;
        fPH_preqNo := FieldByName(CreateFld(tbiPH.pfx, fli_preqNo));

        while not EOF do
        begin
          hdrCode := fPH_preqNo.AsString;

          try
            tHdr := FindHdrFromCode(self, hdrCode);

            if not Assigned(tHdr) then
            begin
              Next;
              continue;
            end;

            for j1 := 0 to tHdr.m_list.Count - 1 do
            begin
              tDet := TSCProdReqDet(tHdr.m_list[j1]);
              tDet.m_stepClosed := true;
              for j2 := 0 to tDet.m_list.Count -1 do
              begin
                tJob := tDet.m_list[j2];
                tJob.m_MsgFromHost := CSH_Historical;
              end;
            end;

            DispoList.Add(_('Historical request:') + ' ' + tHdr.m_code);

          except
            if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Update The Historical Request:') +
               ' ' + hdrCode + '  ' + ' Technical code: UMSchedCont:UpdateTheHistoricalRequest' , mtConfirmation, [mbOk], 0) = idOk then
            begin
               next;
               continue;
            end;
          end;

          next;
        end;

      end;

    except
      if MessageDlg(_('A sever error occured while historical request') + #13#10 +
            ' Technical code: UMSchedCont:UpdateTheHistoricalRequest' , mtConfirmation, [mbOk], 0) = idOk then
      begin
        qry.Close;
        exit;
      end;
    end;

    qry.Close;
  end;


  ///////////////////////////////////////////////////////////////////////////////


  procedure RefreshRequestHeader(qry: TMqmQuery; ChangeType : String; UpdateNr : integer; JobRefresh : boolean; DispoList : TStringList);
  var
    Req, PrevReq : String;
    FirstRow : boolean;
    oldDetCode, j1, j2: integer;
    MqmWrkCtr : TMqmWrkCtr;
    fPH_preqNo, fPH_ModulHandled : TField;
    fPH_ProdLine, fPH_ProdType, fPH_ProdFamily, fPH_MaterialFamily : TField;
    fPH_ProdUMCode, fPH_ProdLowDataTime, fPH_ProdDelivDate : TField;
    fPH_FrcDelDate, fPH_LeadpstepIdForSplit : TField;
    fPH_CurveFamilyIdCode, fPH_SplitConfLevels, fPH_NewPreqUniqId : TField;
    fPD_pstepId, fPD_StepType : TField;
    fPD_prevStepSched_Mcm, fPD_NextStepSched_Mcm : TField;
    fPD_prevStepSched_Mqm, fPD_NextStepSched_Mqm : TField;
    fPD_prevStepTrue, fPD_NextStepTrue : TField;
    fPD_MaterialArrivDate, fPD_planStart, fPD_planEnd : TField;
    fPD_InitialPlanScheduledDateTime, fPD_LowStartTimeLimit : TField;
    fPD_finalPlanScheduledDateTime, fPD_HighEndTimeLimit : TField;
    fPD_ApprovalDate, fPD_CalCod : TField;
    fPD_quantInit, fPD_quantFinl : TField;
    fPD_alternative_Qty, fPD_alternative_UM : TField;
    fPD_Weight, fPD_DescUM : TField;
    fPD_wkCtrCode, fPD_wkcProc : TField;
    fPD_StepCanGroup, fPD_OverlapWithOtherSteps : TField;
    fPD_AllowSplit, fPD_SplitFamaly : TField;
    fPD_LearningCurveType : TField;
    fPD_FrcMatDate, fPD_FrcLowestDate : TField;
    fPD_FrcHighestDate, fPD_FrcOverlapp, fPD_StepClosed : TField;
    fPD_SetupTimStep, fPD_excTimeStep : TField;
    fPD_NumResPlan, fPD_NumSubRscComponents : TField;
    fPD_MaxStartDateAutoSeq, fPD_ConnTypToPrevStepSplit : TField;
    fPD_PrevLeadTime_mqm, fPD_NextLeadTime_mqm : TField;
    fPD_PrevLeadTimeBatch_mqm, fPD_NextLeadTimeBatch_mqm : TField;
    fWW_TypeOfUse : TField;
  begin
    FirstRow := true;
    oldDetCode := -1;

    try

      with qry do
      begin

        Sql.Clear;
        Sql.Add('select');
        Sql.Add(' ' + tbiPH.GetTableName + '.*');
        Sql.Add(',' + tbiPD.GetTableName + '.*');
        Sql.Add(',' + tbiWW.GetTableName + '.*');
        Sql.Add(' from ' + tbiPH.GetTableName);
        Sql.Add(' inner join ' + tbiCR.GetTableName);
        Sql.Add(' on  ' + CreateFld(tbiCR.pfx, fli_ChangeType) + '=' + QuotedStr(ChangeType));
        Sql.Add(' and  ' + CreateFld(tbiCR.pfx, fli_pstepId) + '=' + '0');
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_updCode) + '=' + IntToStr(UpdateNr));
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_Identifier) + '=' + CreateFld(tbiPH.pfx, fli_Identifier));
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_preqNo) + '=' + CreateFld(tbiPH.pfx, fli_preqNo));
        Sql.Add(' inner join ' + tbiPD.GetTableName);
//        Sql.Add(' on  ' + CreateFld(tbiPD.pfx, fli_ToBeSched) + '<>' + QuotedStr('0'));
        if DBAppGlobals.MCM_App then
          Sql.Add(' on  ' + CreateFld(tbiPD.pfx, fli_SchedulByMcm) + '=' + QuotedStr('1'))
        else
          Sql.Add(' on  ' + CreateFld(tbiPD.pfx, fli_SchedulByMqm) + '=' + QuotedStr('1'));

        Sql.Add(' and ' + CreateFld(tbiPD.pfx, fli_Identifier) + '=' + CreateFld(tbiPH.pfx, fli_Identifier));
        Sql.Add(' and ' + CreateFld(tbiPD.pfx, fli_preqNo) + '=' + CreateFld(tbiPH.pfx, fli_preqNo));
        Sql.Add(' inner join ' + tbiWW.GetTableName);
        Sql.Add(' on  ' + CreateFld(tbiWW.pfx, fli_wkstCode) + '=' + QuotedStr(IniAppGlobals.WkstCode));
        Sql.Add(' and ' + CreateFld(tbiWW.pfx, fli_Identifier) + '=' + CreateFld(tbiPD.pfx, fli_Identifier));
        Sql.Add(' and ' + CreateFld(tbiWW.pfx, fli_wkCtrCode) + '=' + CreateFld(tbiPD.pfx, fli_wkCtrCode));
        SQL.Add(WHERE_IDF_Condition(CreateFld(tbiPH.pfx, fli_Identifier)));
        Sql.Add(' order by ');
        Sql.Add(CreateFld(tbiPD.pfx, fli_preqNo)  + ',');
        Sql.Add(CreateFld(tbiPD.pfx, fli_pstepId));
        Prepare;
        FetchOptions.RowsetSize := 5000;
        Open;
        Application.ProcessMessages;
        // Cache TField pointers once after Open
        fPH_preqNo                       := FieldByName(CreateFld(tbiPH.pfx, fli_preqno));
        fPH_ModulHandled                 := FieldByName(CreateFld(tbiPH.pfx, fli_ModulHandled));
        fPH_ProdLine                     := FieldByName(CreateFld(tbiPH.pfx, fli_ProdLine));
        fPH_ProdType                     := FieldByName(CreateFld(tbiPH.pfx, fli_ProdType));
        fPH_ProdFamily                   := FieldByName(CreateFld(tbiPH.pfx, fli_ProdFamily));
        fPH_MaterialFamily               := FieldByName(CreateFld(tbiPH.pfx, fli_MaterialFamily));
        fPH_ProdUMCode                   := FieldByName(CreateFld(tbiPH.pfx, fli_ProdUMCode));
        fPH_ProdLowDataTime              := FieldByName(CreateFld(tbiPH.pfx, fli_ProdLowDataTime));
        fPH_ProdDelivDate                := FieldByName(CreateFld(tbiPH.pfx, fli_ProdDelivDate));
        fPH_FrcDelDate                   := FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate));
        fPH_LeadpstepIdForSplit          := FieldByName(CreateFld(tbiPH.pfx, fli_LeadpstepIdForSplit));
        fPH_CurveFamilyIdCode            := FieldByName(CreateFld(tbiPH.pfx, fli_CurveFamilyIdCode));
        fPH_SplitConfLevels              := FieldByName(CreateFld(tbiPH.pfx, fli_SplitConfLevels));
        fPH_NewPreqUniqId                := FieldByName(CreateFld(tbiPH.pfx, fli_NewPreqUniqId));
        fPD_pstepId                      := FieldByName(CreateFld(tbiPD.pfx, fli_pstepId));
        fPD_StepType                     := FieldByName(CreateFld(tbiPD.pfx, fli_StepType));
        fPD_prevStepSched_Mcm            := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mcm));
        fPD_NextStepSched_Mcm            := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mcm));
        fPD_prevStepSched_Mqm            := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mqm));
        fPD_NextStepSched_Mqm            := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mqm));
        fPD_prevStepTrue                 := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepTrue));
        fPD_NextStepTrue                 := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepTrue));
        fPD_MaterialArrivDate            := FieldByName(CreateFld(tbiPD.pfx, fli_MaterialArrivDate));
        fPD_planStart                    := FieldByName(CreateFld(tbiPD.pfx, fli_planStart));
        fPD_planEnd                      := FieldByName(CreateFld(tbiPD.pfx, fli_planEnd));
        fPD_InitialPlanScheduledDateTime := FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime));
        fPD_LowStartTimeLimit            := FieldByName(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit));
        fPD_finalPlanScheduledDateTime   := FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime));
        fPD_HighEndTimeLimit             := FieldByName(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit));
        fPD_ApprovalDate                 := FieldByName(CreateFld(tbiPD.pfx, fli_ApprovalDate));
        fPD_CalCod                       := FieldByName(CreateFld(tbiPD.pfx, fli_CalCod));
        fPD_quantInit                    := FieldByName(CreateFld(tbiPD.pfx, fli_quantInit));
        fPD_quantFinl                    := FieldByName(CreateFld(tbiPD.pfx, fli_quantFinl));
        fPD_alternative_Qty              := FieldByName(CreateFld(tbiPD.pfx, fli_alternative_Qty));
        fPD_alternative_UM               := FieldByName(CreateFld(tbiPD.pfx, fli_alternative_UM));
        fPD_Weight                       := FieldByName(CreateFld(tbiPD.pfx, fli_Weight));
        fPD_DescUM                       := FieldByName(CreateFld(tbiPD.pfx, fli_DescUM));
        fPD_wkCtrCode                    := FieldByName(CreateFld(tbiPD.pfx, fli_wkCtrCode));
        fPD_wkcProc                      := FieldByName(CreateFld(tbiPD.pfx, fli_wkcProc));
        fPD_StepCanGroup                 := FieldByName(CreateFld(tbiPD.pfx, fli_StepCanGroup));
        fPD_OverlapWithOtherSteps        := FieldByName(CreateFld(tbiPD.pfx, fli_OverlapWithOtherSteps));
        fPD_AllowSplit                   := FieldByName(CreateFld(tbiPD.pfx, fli_AllowSplit));
        fPD_SplitFamaly                  := FieldByName(CreateFld(tbiPD.pfx, fli_SplitFamaly));
        fPD_LearningCurveType            := FieldByName(CreateFld(tbiPD.pfx, fli_LearningCurveType));
        fPD_FrcMatDate                   := FieldByName(CreateFld(tbiPD.pfx, fli_FrcMatDate));
        fPD_FrcLowestDate                := FieldByName(CreateFld(tbiPD.pfx, fli_FrcLowestDate));
        fPD_FrcHighestDate               := FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate));
        fPD_FrcOverlapp                  := FieldByName(CreateFld(tbiPD.pfx, fli_FrcOverlapp));
        fPD_StepClosed                   := FieldByName(CreateFld(tbiPD.pfx, fli_StepClosed));
        fPD_SetupTimStep                 := FieldByName(CreateFld(tbiPD.pfx, fli_SetupTimStep));
        fPD_excTimeStep                  := FieldByName(CreateFld(tbiPD.pfx, fli_excTimeStep));
        fPD_NumResPlan                   := FieldByName(CreateFld(tbiPD.pfx, fli_NumResPlan));
        fPD_NumSubRscComponents          := FieldByName(CreateFld(tbiPD.pfx, fli_NumSubRscComponents));
        fPD_MaxStartDateAutoSeq          := FieldByName(CreateFld(tbiPD.pfx, fli_MaxStartDateAutoSeq));
        fPD_ConnTypToPrevStepSplit       := FieldByName(CreateFld(tbiPD.pfx, fli_ConnTypToPrevStepSplit));
        fPD_PrevLeadTime_mqm             := FieldByName(CreateFld(tbiPD.pfx, fli_PrevLeadTime_mqm));
        fPD_NextLeadTime_mqm             := FieldByName(CreateFld(tbiPD.pfx, fli_NextLeadTime_mqm));
        fPD_PrevLeadTimeBatch_mqm        := FieldByName(CreateFld(tbiPD.pfx, fli_PrevLeadTimeBatch_mqm));
        fPD_NextLeadTimeBatch_mqm        := FieldByName(CreateFld(tbiPD.pfx, fli_NextLeadTimeBatch_mqm));
        fWW_TypeOfUse                    := FieldByName(CreateFld(tbiww.pfx, fli_TypeOfUse));

        while not EOF do
        begin
          Req := fPH_preqNo.AsString;

          try

            if fPH_ModulHandled.AsString = '1' then
            begin
              Next;
              Continue;
            end;

            if FirstRow or (Req <> PrevReq) then
            begin
              tHdr := FindHdrFromCode(self, Req);
              oldDetCode := -1;

              if Assigned(tHdr) then
              begin
                if ChangeType = '5' then
                  UnscheduleAllStepsReqForDataChange(tHdr , true, false, DispoList);
                if ChangeType = '6' then
                  UnscheduleAllStepsReqForDataChange(tHdr , false, true, DispoList);
                if ChangeType = '7' then
                begin
                  DispoList.Add(_('Refresh data for request:') + ' ' + Req);
                  for j1 := 0 to tHdr.m_list.Count - 1 do
                  begin
                    tDet := tHdr.m_list[j1];
                    if Assigned(tDet) then
                    begin
                      for j2 := 0 to tDet.m_list.Count -1 do
                      begin
                        tJob := tDet.m_list[j2];
                        if Assigned(tJob) then
                          tJob.m_MsgFromHost := CSH_Minor_change;
                      end;
                    end;
                  end;
                end;

                tHdr.m_prodLine        := fPH_ProdLine.AsString;
                tHdr.m_prodType        := fPH_ProdType.AsString;
                tHdr.m_prodFamily      := fPH_ProdFamily.AsString;
                tHdr.m_matFamily       := fPH_MaterialFamily.AsString;
                tHdr.m_prodUMCode      := fPH_ProdUMCode.AsString;
                tHdr.m_NumOfDecimals   := GetUmNumOfDecimals(tHdr.m_prodUMCode);
                tHdr.m_prodLowDateTime := fPH_ProdLowDataTime.AsDateTime;
                tHdr.m_prodDelivDate   := fPH_ProdDelivDate.AsDateTime;
                if fPH_FrcDelDate.AsString = '1' then
                  tHdr.m_FrcDelDate := CSF_Forceable
                else if fPH_FrcDelDate.AsString = '2' then
                  tHdr.m_FrcDelDate := CSF_Yes
                else if fPH_FrcDelDate.AsString = '3' then
                  tHdr.m_FrcDelDate := CSF_Forceable2
                else if fPH_FrcDelDate.AsString = '4' then
                  tHdr.m_FrcDelDate := CSF_Yes2
                else
                  tHdr.m_FrcDelDate := CSF_No;
                tHdr.m_LeadStepForSplit := -1;
                if not DBAppGlobals.MCM_App then
                begin
                  if (not fPH_LeadpstepIdForSplit.IsNull) and
                    (fPH_LeadpstepIdForSplit.AsInteger <> 0) then
                  begin
                    tHdr.m_LeadStepForSplit := fPH_LeadpstepIdForSplit.AsInteger;
                    if not SearchProdReqLeadStepInSplitList(tHdr) then
                       m_ProdReqLeadStepSplitList.Add(tHdr);
                  end;
                end;

                tHdr.m_CurveFamilyIdCode := '';
                if (not fPH_CurveFamilyIdCode.IsNull) and
                 (trim(fPH_CurveFamilyIdCode.AsString) <> '') then
                    tHdr.m_CurveFamilyIdCode := fPH_CurveFamilyIdCode.AsString;

                tHdr.m_ConfLevels := '';
                if (not fPH_SplitConfLevels.IsNull) and
                 (trim(fPH_SplitConfLevels.AsString) <> '') then
                    tHdr.m_ConfLevels := fPH_SplitConfLevels.AsString;

                tHdr.m_NewReqUniqId := '';
                if (not fPH_NewPreqUniqId.IsNull) and
                   (trim(fPH_NewPreqUniqId.AsString) <> '') then
                    tHdr.m_NewReqUniqId := fPH_NewPreqUniqId.AsString;
              end;
            end;

            FirstRow := false;
            PrevReq := Req;

            if not Assigned(tHdr) then
            begin
              Next;
              Continue;
            end;

            if oldDetCode <> fPD_pstepId.AsInteger then
            begin
              oldDetCode := fPD_pstepId.AsInteger;
              tDet := tHdr.FindDetFromCode(fPD_pstepId.AsInteger);
              if Assigned(tDet) then
              begin
                tmpStr := fPD_StepType.AsString;
                if tmpStr = 'B' then
                  tDet.m_stepType := CST_batch
                else if tmpStr = 'C' then
                  tDet.m_stepType := CST_continuous
                else if tmpStr = 'H' then
                begin
                  tDet.m_stepType := CST_continuous;
                  tDet.m_batch_ContinuesTime := true;
                end
                else if tmpStr = 'P' then
                begin
                  tDet.m_stepType := CST_batch;
                  tDet.m_Continues_Parallel := true;
                end
                else
                  tDet.m_stepType := CST_continuous;
                if DBAppGlobals.MCM_App then
                begin
                  tDet.m_prevStep          := fPD_prevStepSched_Mcm.AsInteger;
                  tDet.m_nextStep          := fPD_NextStepSched_Mcm.AsInteger;
                end
                else
                begin
                  tDet.m_prevStep          := fPD_prevStepSched_Mqm.AsInteger;
                  tDet.m_nextStep          := fPD_NextStepSched_Mqm.AsInteger;
                end;

                tDet.m_prevRealStep      := fPD_prevStepTrue.AsInteger;
                tDet.m_nextRealStep      := fPD_NextStepTrue.AsInteger;
                tDet.m_materialArrivDate := fPD_MaterialArrivDate.AsDateTime;
                tDet.m_planStart         := fPD_planStart.AsDateTime;
                tDet.m_planStart_Orig    := tDet.m_planStart;
                tDet.m_planEnd           := fPD_planEnd.AsDateTime;
                tDet.m_planEnd_Orig      := tDet.m_planEnd;

                if not DBAppGlobals.MCM_App then
                begin
                  if not fPD_InitialPlanScheduledDateTime.IsNull and
                     (fPD_InitialPlanScheduledDateTime.AsDateTime > 0) then
                  begin
                    tDet.m_lowStartTimeLimit := fPD_InitialPlanScheduledDateTime.AsDateTime;
                    tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit
                  end
                  else
                  begin
                    tDet.m_lowStartTimeLimit := fPD_LowStartTimeLimit.AsDateTime;
                    tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit
                  end;

                  if not fPD_finalPlanScheduledDateTime.IsNull and
                     (fPD_finalPlanScheduledDateTime.AsDateTime > 0) then
                  begin
                    tDet.m_highEndTimeLimit := fPD_finalPlanScheduledDateTime.AsDateTime;
                    tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit
                  end
                  else
                  begin
                    tDet.m_highEndTimeLimit  := fPD_HighEndTimeLimit.AsDateTime;
                    tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit
                  end;
                end
                else
                begin
                  tDet.m_lowStartTimeLimit := fPD_LowStartTimeLimit.AsDateTime;
                  tDet.m_lowStartTimeLimit_Orig := tDet.m_lowStartTimeLimit;
                  tDet.m_highEndTimeLimit  := fPD_HighEndTimeLimit.AsDateTime;
                  tDet.m_highEndTimeLimit_Orig := tDet.m_highEndTimeLimit;
                end;

                if not tDet.m_Approvaldate_UserChanged then
                  tDet.m_Approvaldate      := fPD_ApprovalDate.AsDateTime;
                tDet.m_calCod            := fPD_CalCod.AsString;
                tDet.m_quantInit         := fPD_quantInit.AsFloat;
                tDet.m_quantFinl         := fPD_quantFinl.AsFloat;
                tDet.P_quantAlternative  := fPD_alternative_Qty.AsFloat;
                tDet.P_UmAlternative     := fPD_alternative_UM.AsString;
                tDet.m_weight            := fPD_Weight.AsFloat;
                tDet.m_weightUM          := fPD_DescUM.AsString;
                tDet.m_planWkctr         := fPD_wkCtrCode.AsString;
                tDet.m_PlanWrkCtrPtr     := findWC(tDet.m_planWkctr);
                tDet.m_planWkctrProc     := fPD_wkcProc.AsString;
                tDet.m_CanGroup          := fPD_StepCanGroup.AsString;
                tDet.p_OverlapWithOtherSteps := false;
                if fPD_OverlapWithOtherSteps.AsString = '1' then
                   tDet.p_OverlapWithOtherSteps := true;

                MqmWrkCtr := TMqmWrkCtr(p_pl.FindWrkCtrByCode(tDet.m_planWkctr));
                if assigned(MqmWrkCtr) then
                  tDet.P_IgnoreProgress := MqmWrkCtr.P_IgnoreProgress;

                tDet.m_SplitAllow := CSB_No;
                if fPD_AllowSplit.AsString = '1' then
                  tDet.m_SplitAllow := CSB_yes
                else if fPD_AllowSplit.AsString = '2' then
                  tDet.m_SplitAllow := CSB_Father
                else if fPD_AllowSplit.AsString = '3' then
                  tDet.m_SplitAllow := CSB_Son;

                tDet.p_CurveType := CSC_No;
                if fPD_LearningCurveType.AsString = '1' then
                  tDet.p_CurveType := CSC_Managed
                else if fPD_LearningCurveType.AsString = '2' then
                  tDet.p_CurveType := CSC_Forced_By_Host;

                if fPD_FrcMatDate.AsString = '1' then
                   tDet.m_FrcMatDate := CSF_Forceable
                else if fPD_FrcMatDate.AsString = '2' then
                   tDet.m_FrcMatDate := CSF_Yes
                else
                   tDet.m_FrcMatDate := CSF_No;

                if fPD_FrcLowestDate.AsString = '1' then
                   tDet.m_FrcLowestDate := CSF_Forceable
                else if fPD_FrcLowestDate.AsString = '2' then
                   tDet.m_FrcLowestDate := CSF_Yes
                else
                   tDet.m_FrcLowestDate := CSF_No;

                if fPD_FrcHighestDate.AsString = '1' then
                   tDet.m_FrcHighestDate := CSF_Forceable
                else if fPD_FrcHighestDate.AsString = '2' then
                   tDet.m_FrcHighestDate := CSF_Yes
                else if fPD_FrcHighestDate.AsString = '3' then
                begin
                   tDet.m_FrcHighestDate := CSF_RequestedHighesEndDate;
                   tDet.m_highEndTimeLimitTemp := tDet.m_highEndTimeLimit
                end
                else
                   tDet.m_FrcHighestDate := CSF_No;

                if fPD_FrcOverlapp.AsString = '1' then
                   tDet.m_FrcOverlapp := CSF_Forceable
                else if fPD_FrcOverlapp.AsString = '2' then
                   tDet.m_FrcOverlapp := CSF_Yes
                else
                   tDet.m_FrcOverlapp := CSF_No;

                if fPD_StepClosed.AsString = '1' then
                   tDet.m_stepClosed := true
                else
                   tDet.m_stepClosed := false;

                tDet.m_SetupTimeStep := fPD_SetupTimStep.AsFloat;
                tDet.m_ExeTimeStep   := fPD_excTimeStep.AsFloat;
                tDet.m_planNumRes    := fPD_NumResPlan.AsFloat;
                tDet.p_rscComp       := fPD_NumSubRscComponents.AsInteger;
                tDet.p_MaxStartingDateAutoSeq := fPD_MaxStartDateAutoSeq.AsDateTime;
                tDet.m_connTypeToPrevious:= fPD_ConnTypToPrevStepSplit.AsString;

                if tDet.m_quantInit = 0 then
                begin
                  tDet.P_LeadTimePrev := 0;
                  tDet.P_LeadTimeNext := 0;
                  tDet.P_LeadTimePrevBatch := 0;
                  tDet.P_LeadTimeNextBatch := 0;
                end
                else
                begin
                  tDet.P_LeadTimePrev := fPD_PrevLeadTime_mqm.AsFloat /  tDet.m_quantInit;
                  tDet.P_LeadTimeNext := fPD_NextLeadTime_mqm.AsFloat /  tDet.m_quantInit;
                  tDet.P_LeadTimePrevBatch := fPD_PrevLeadTimeBatch_mqm.AsFloat;
                  tDet.P_LeadTimeNextBatch := fPD_NextLeadTimeBatch_mqm.AsFloat;
                end;
                tDet.m_OfThisWrkst   := true;

                if JobRefresh then
                begin
                  tJob := tDet.m_list[0];
                  if (fWW_TypeOfUse.AsString = '2') then
                    tJob.m_VisbleInBin := CSB_ReadOnly
                  else
                    tJob.m_VisbleInBin := CSB_Normal;
                  if not fPD_SplitFamaly.IsNull then
                     tJob.m_SplitFamilyCode := fPD_SplitFamaly.AsString;
                  tJob.m_fromPD         := true;
                  tJob.m_status         := CSS_none;
                  tJob.m_subLinRscId    := 0;
                  tJob.m_srvPtr         := nil;
                  tJob.m_reprocNo       := 0;
                  tJob.p_SetStepType    := '0';
                  tJob.m_comment        := '';
                  tJob.p_WorkCenter     := '';
                  tJob.p_Process        := '';
                  tJob.p_quantSched     := tDet.m_quantInit;
                  tJob.p_exeMin         := 0;
                  tJob.p_supMinBase     := 0;
                  tJob.p_supMinReal     := 0;
                  tJob.p_supMinOvlp     := 0;
                  tJob.m_fwdConnSubStp  := -2;
                  tJob.m_fwdConnReProcs := -2;
