procedure TMSchedCont.OrganizeHighLimitToAllRequest;
var
  hdr, det, FirstDet, I, P : integer;
  tHdr : TSCProdReqHdr;
  tDet, tDetNxt : TSCProdReqDet;
  tJob : TSCProdSched;
  PlanInfo : TSQplanInfo;
  IdToCheck, TempId : TSchedId;
  Proprty : TProperties;
  PropId  : TPropId;
  TempEndDateTime, CalculatedDate, HighestLinkedDate : TDateTime;
  PropCode  : string;
  ActArea   : TMQMActArea;
  cal       : TPGCALObj;
  PrevReqJobs : TMSchedList;
  DatesInfoTemp : TSQDatesInfo;
  ForcesInfo: TSQForcesInfo;
begin
  PropId := GetCalculatedHighDateProp;
  if PropId = nil then exit;
  for hdr := 0 to m_prodReqList.Count-1 do
  begin
    tHdr := TSCProdReqHdr(m_prodReqList[hdr]);
    FirstDet := -1;
    for det := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[det]);
      if not Assigned(tDet) then continue;
      if not tDet.m_StepToSched then continue;
      if (FirstDet = -1) then FirstDet := det;
      tJob := TSCProdSched(tDet.m_list[0]);
      p_sc.GetForcesInfo(tJob.m_id, ForcesInfo);
      if (ForcesInfo.FrcHighestDate <> CSF_RequestedHighesEndDate) then Continue;
      if not p_sc.GetHighEndTimeLimitOverriden(tJob.m_id) then continue;

      if (det = FirstDet) then
      begin
        HighestLinkedDate := 0;
        PrevReqJobs := TMSchedList.Create(self);
        p_sc.GetPrevConnReqLastStepJobs(tJob.m_id, PrevReqJobs);
        for P := 0 to PrevReqJobs.GetLinkCount -1 do
        begin
          TempId := PrevReqJobs.GetLink(p);
          if Assigned(p_sc.GetExtLinkPtr(TempId)) then
          begin
            p_sc.GetDatesInfo(TempId, DatesInfoTemp);
            if DatesInfoTemp.HighEndDate > HighestLinkedDate then
              HighestLinkedDate := DatesInfoTemp.HighEndDate;
          end;
        end;
        PrevReqJobs.ClearList;
        PrevReqJobs.Free;

        if HighestLinkedDate > 0 then
        begin
          CalculatedDate := 0;
          for I := 0 to tDet.m_list.Count - 1 do
          begin
            tJob := TSCProdSched(tDet.m_list[I]);
            if not Assigned(GetExtLinkPtr(tJob.m_id)) then continue;
            actArea := TMqmActArea(tJob.m_srvptr);
            if not assigned(ActArea) then continue;
            cal := ActArea.GetCalendar;
            if not assigned(cal) then continue;
            if assigned(tJob.m_grp) and (tDet.m_stepType = CST_batch) then
              IdToCheck := tJob.m_grp.m_Id
            else
             IdToCheck := tJob.m_id;
            p_sc.GetPlanInfo(IdToCheck, PlanInfo);
            cal.OfsByWH((PlanInfo.supMinReal + PlanInfo.exeMin)/60, true, HighestLinkedDate , TempEndDateTime, ActArea.m_CrossDownTmList);
            if TempEndDateTime > CalculatedDate then CalculatedDate := TempEndDateTime;
          end;
	        if CalculatedDate > tDet.m_highEndTimeLimit then
	        begin
	          tDet.m_highEndTimeLimit := CalculatedDate;
            PropCode := GetPropCodeFromID(PropId);
            tJob := TSCProdSched(tDet.m_list[0]);
            Proprty := p_sc.GetProperties(tJob.m_Id,nil);
            FMPlannerPropDefine.UpdatePropInJobList(Proprty, PropId, DateTimeToStr(CalculatedDate));
            UpdateMainListPropChange(tJob.m_Id, PropCode, DateTimeToStr(CalculatedDate), false);
	        end;
        end;
      end;

      tJob := TSCProdSched(tDet.m_list[0]);
      tDetNxt := tJob.GetNextStepToSched(tJob.m_reqDet.m_code);
      if (tDetNxt = nil) then continue;
      if not tDetNxt.m_highEndTimeLimitOverriden then continue;
      tJob := TSCProdSched(tDetNxt.m_list[0]);
      p_sc.GetPlanInfo(tJob.m_Id, PlanInfo);
      if (planInfo.VisibleInBin = CSB_ReadOnly) then continue;
      if tDet.m_highEndTimeLimit > tDetNxt.m_highEndTimeLimit then
	      CalculatedDate := tDet.m_highEndTimeLimit
      else
        CalculatedDate := tDetNxt.m_highEndTimeLimit;
      for I := 0 to tDetNxt.m_list.Count - 1 do
      begin
        tJob := TSCProdSched(tDetNxt.m_list[I]);
        if not Assigned(GetExtLinkPtr(tJob.m_id)) then continue;
        actArea := TMqmActArea(tJob.m_srvptr);
        if not assigned(ActArea) then continue;
        cal := ActArea.GetCalendar;
        if not assigned(cal) then continue;
        if assigned(tJob.m_grp) and (tDetNxt.m_stepType = CST_batch) then
          IdToCheck := tJob.m_grp.m_Id
        else
          IdToCheck := tJob.m_id;
        p_sc.GetPlanInfo(IdToCheck, PlanInfo);
        cal.OfsByWH((PlanInfo.supMinReal + PlanInfo.exeMin)/60, true, tDet.m_highEndTimeLimit , TempEndDateTime, ActArea.m_CrossDownTmList);
        if TempEndDateTime > CalculatedDate then CalculatedDate := TempEndDateTime;
      end;
	    if CalculatedDate > tDetNxt.m_highEndTimeLimit then
	    begin
	      tDetNxt.m_highEndTimeLimit := CalculatedDate;
        PropCode := GetPropCodeFromID(PropId);
        tJob := TSCProdSched(tDetNxt.m_list[0]);
        Proprty := p_sc.GetProperties(tJob.m_Id,nil);
        FMPlannerPropDefine.UpdatePropInJobList(Proprty, PropId, DateTimeToStr(CalculatedDate));
        UpdateMainListPropChange(tJob.m_Id, PropCode, DateTimeToStr(CalculatedDate), false);
	    end;
    end;
  end;
end;

