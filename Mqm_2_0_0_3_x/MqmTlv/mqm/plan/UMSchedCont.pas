function CreateNewRequestNumber(CurrReq : string; SubStep : Integer; SpitStartPos : integer; SplitEndPos : integer) : string;
var
  NewSubStr : string;
  I : Integer;
begin
  Result := '';
  NewSubStr := '';
  if (SpitStartPos = -1) or (SpitStartPos > Length(CurrReq)) then
     exit
  else
  begin
    NewSubStr := IntTostr(SubStep);
    for I := Length(IntTostr(SubStep)) to 2 do
      NewSubStr := '0' + NewSubStr;
    Insert(NewSubStr, CurrReq, SpitStartPos + 1);
    Result := CurrReq;
  end;
end;

