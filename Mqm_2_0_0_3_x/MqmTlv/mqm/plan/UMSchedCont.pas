function TMSchedCont.CheckJobValueToGroupByRules(Job : TSCProdSched; PROCESS_GROUP_BY : PTPROCESS_GROUP_BY; var StringToCheck : string) : boolean;
var
  JobProperties : TProperties;
  jobPropVal    : VARIANT;
  PropValueStrForRuleTemp : string;
  I : integer;
begin
  Result := false;
  StringToCheck := '';
  JobProperties := p_sc.GetProperties(Job.m_Id, nil);

  for I := Low(PROCESS_GROUP_BY.PropIdForRule) to High(PROCESS_GROUP_BY.PropIdForRule) do
  begin
    if PROCESS_GROUP_BY.PropIdForRule[I] <> nil then
    begin
      if (JobProperties.GetValforProp(PROCESS_GROUP_BY.PropIdForRule[I],jobPropVal)) and (Trim(jobPropVal) <> '') then
      begin
        result := true;
        PropValueStrForRuleTemp := PropValueStrForRuleTemp + Trim(jobPropVal) + '||';
      end;
    end;
  end;

  if not result then exit;
  StringToCheck := Job.m_reqDet.m_planWkctr + '||' + Job.m_reqDet.m_planWkctrProc + '||' + PropValueStrForRuleTemp;
end;

