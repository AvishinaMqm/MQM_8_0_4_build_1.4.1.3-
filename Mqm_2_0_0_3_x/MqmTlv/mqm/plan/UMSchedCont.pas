procedure TMSchedCont.LinkJobs(fLoad: TLinkJobFunc; ptr: pointer; ProgBar: TMqmProgBar; Status: TStaticText);
var
  i,j:      integer;
  sc:     TSCSchedOnPlan;
  scProd: TSCProdSched;
begin
  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(m_codeList.Count);
  end;

  if Assigned(Status) then
    Status.Caption := _('Linking jobs...');

  for i := 0 to m_codeList.Count-1 do
  begin
     Application.ProcessMessages;
    if Assigned(ProgBar) then
      ProgBar.SetPosition(i+1);
    if Assigned(m_codeList[i]) then
    begin
      sc := TSCSchedOnPlan(m_codeList[i]);
      if sc is TSCProdSched then
      begin
        scProd := TSCProdSched(sc);
        if Assigned(scProd.m_grp) then continue;
        if Assigned(scProd.m_mtr) then continue
      end else
      begin
        if TSCProdGroup(sc).m_isDeleted then continue;
        //Assert(TSCProdGroup(sc).m_list.Count > 0);
        if not (TSCProdGroup(sc).m_list.Count > 0) then exit;
        scProd := TSCProdSched(TSCProdGroup(sc).m_list[0]);
        if (scProd.p_rscCode = CSnoResCode) and (scProd.m_ProgRsc = CSnoResCode) then
        begin
          for J := 1 to TSCProdGroup(sc).m_list.Count - 1 do
          begin
            scProd := TSCProdSched(TSCProdGroup(sc).m_list[J]);
            if not ((scProd.p_rscCode = CSnoResCode) and (scProd.m_ProgRsc = CSnoResCode)) then
               break;
          end;
        end;
      end;

    {  if (scProd.p_rscCode <> CSnoResCode) and (scProd.m_ProgRsc = CSnoResCode) and
         scProd.m_reqDet.m_stepClosed and (DBAppGlobals.UnscheduleJobsOnStart = '1') then continue
      else if (scProd.p_rscCode <> CSnoResCode) and (scProd.m_ProgRsc = CSnoResCode) and
         scProd.m_reqDet.m_stepClosed and (DBAppGlobals.UnscheduleJobsOnStart = '2') and (scProd.p_schedEnd > date) then continue; }

      if (scProd.p_rscCode = CSnoResCode) and (scProd.m_ProgRsc = CSnoResCode) then
        sc.m_srvPtr := nil
      else
      begin
        if scProd.m_ProgRsc <>  CSnoResCode then
          scProd.p_rscCode := scProd.m_ProgRsc;

        if scProd.m_reqDet.P_IgnoreProgress and (scProd.m_ProgRsc <> '') then
           fLoad(scProd.p_OldrscCode, sc.m_Id, ptr)
        else
          fLoad(scProd.p_rscCode, sc.m_Id, ptr);
      //  if not (sc is TSCProdSched) and (TSCProdSched(TSCProdGroup(sc).m_list[0]).m_reqDet.m_stepType = CST_Continuous) then
      //    UpdContGrpTimings(sc.m_Id, sc.m_Id);
      end;
    end
  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';
  Application.ProcessMessages;
end;

