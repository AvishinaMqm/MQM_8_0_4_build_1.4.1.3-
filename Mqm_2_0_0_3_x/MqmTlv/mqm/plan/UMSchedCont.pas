procedure TMSchedCont.SetSearchLinks(var JobsList: TMSchedList ; LinksList : TList);
var
  i : integer;
  LinkObjs: PTLink;
  ObjId : TSchedId;
begin
  for I := 0 to JobsList.GetLinkCount - 1 do
  begin
    ObjId := JobsList.GetLink(i);
    if p_sc.HasFlags(ObjId, [CSF_FilterJobsInDynamicGantt]) then
    begin
      new(LinkObjs);
      LinkObjs.LK_StObj  := Pointer(ObjId);
      LinkObjs.LK_EndObj := nil;
      LinkObjs.LK_Type   := LT_ConnJob;
      LinksList.Add(LinkObjs);
    end;
  end;

  LinksList.Sort(SortOnDates);

  for I := 0 to LinksList.Count - 1 do
  begin
    LinkObjs := PTLink(LinksList[I]);
    if I + 1 <= LinksList.Count - 1 then
    begin
      LinkObjs.LK_EndObj := PTLink(LinksList[I + 1]).LK_StObj;
    end
    else
      LinksList.Delete(LinksList.Count - 1);
  end;

end;

