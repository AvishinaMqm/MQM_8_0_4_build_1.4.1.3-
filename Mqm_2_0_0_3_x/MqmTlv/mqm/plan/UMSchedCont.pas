procedure TMSchedCont.CleanInstanceCounterProperty(Id : TschedId);
var
  prop : TProperties;
  I, J : Integer;
  IdInGrp : TSchedId;
begin
  if p_sc.IsGroup(Id) then
  begin
    for I := 0 to p_sc.GetGrpNumSons(id) - 1 do
    begin
      IdInGrp := p_sc.GetGrpSon(id, I);
      prop := p_sc.GetProperties(IdInGrp,nil);
      for J := 0 to prop.P_PropCountInstanceCounter - 1 do
        prop.CleanPropertyInstanceCounter(J);
    end;
    exit;
  end;
  prop := p_sc.GetProperties(Id,nil);
  for I := 0 to prop.P_PropCountInstanceCounter - 1 do
    prop.CleanPropertyInstanceCounter(I);
end;

