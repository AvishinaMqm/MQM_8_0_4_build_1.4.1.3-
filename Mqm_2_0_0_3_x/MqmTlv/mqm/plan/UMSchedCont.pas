  tJob := TSCProdSched(ps);
  if not Assigned(tJob.m_reqDet) then exit;

  StrHdr := TSCProdReqHdr(tJob.m_reqDet.m_hdr);
  if not Assigned(StrHdr) then exit;

  OnPlan := false;

  for i := 0 to StrHdr.m_PrecLinkedReqList.Count-1 do
  begin
    tHdr := StrHdr.m_PrecLinkedReqList[i];
    //get last step
    tDet := tHdr.m_list[tHdr.m_list.Count-1];
    for y := 0 to tDet.m_list.Count-1 do
    begin
      tJob := tDet.m_list[y];
      if tJob.p_rscCode = '' then
      begin
        OnPlan := true;
        if Assigned(ErrList) then
          ErrList.Add(_('Request') + ' ' + tHdr.m_code + ' ' + _('Step') + ' ' + IntToStr(tDet.m_code) +
                      ' ' + _('SubStep') + ' '  + IntToStr(tJob.m_code) + ' ' + _('Reprocess') +
                      ' ' + IntToStr(tJob.m_reprocNo) + ' ' + _('must be scheduled before this job because is linked'));
      end;
    end;
  end;

  if OnPlan then
    Result := false;
end;
}
