function TMSchedCont.BelongsToGroup(id: TSchedID; ShowBatchLines : boolean; ShowContinuesLines : CScShowContinueGroupLinesInBin) : boolean;
var
  sc: TSCSchedOnPlan;
begin
  Result := false;
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  if (ShowContinuesLines <> CsSCG_No) or ShowBatchLines then
  begin

    if (sc is TSCProdSched) and (ShowContinuesLines = CsSCG_No) and (GetJobType(id) = CST_Continuous) then
    begin
      if Assigned(TSCProdSched(sc).m_grp) then
        result := true;
    end

    else if (sc is TSCProdSched) and not ShowBatchLines and (GetJobType(id) = CST_batch) then
    begin
      if Assigned(TSCProdSched(sc).m_grp) then
        result := true;
    end

    else if (sc is TSCProdGroup) and ShowBatchLines and (GetJobType(id) = CST_batch) then
    begin
      Result := true;
      exit;
    end

    else if (sc is TSCProdGroup) and (ShowContinuesLines = CsSCG_Yes) and (GetJobType(id) = CST_Continuous) then
    begin
      Result := true;
      exit;
    end

    else if (ShowContinuesLines = CsSCG_YesSameSequence) and (GetJobType(id) = CST_Continuous) then
    begin
      if (sc is TSCProdGroup) then
      begin
        Result := true;
        exit;
      end

      else if (sc is TSCProdSched) and Assigned(TSCProdSched(sc).m_grp) and assigned(TSCProdGroup(TSCProdSched(sc).m_grp).m_ListOfSequence) then
      begin
        inc(TSCProdSched(sc).m_grp.m_Job_Sequence);
        if TSCProdSched(sc).p_Grp_Sequence <> '' then
        begin
          if TSCProdGroup(TSCProdSched(sc).m_grp).m_ListOfSequence.IndexOf(TSCProdSched(sc).p_Grp_Sequence) = -1 then
             TSCProdGroup(TSCProdSched(sc).m_grp).m_ListOfSequence.Add(TSCProdSched(sc).p_Grp_Sequence)
          else
             Result := true;
        end;
        if (TSCProdSched(sc).m_grp.m_list.Count = TSCProdSched(sc).m_grp.m_Job_Sequence) then
        begin
          TSCProdGroup(TSCProdSched(sc).m_grp).m_ListOfSequence.Clear;
          TSCProdSched(sc).m_grp.m_Job_Sequence := 0;
        end;
      end;

    end;

  end
  else
  begin
    if sc is TSCProdGroup then exit;
    if Assigned(TSCProdSched(sc).m_grp) then
      Result := true
  end;

end;

