function TMSchedCont.CanAddJobToGroup(job, grp: TSchedID; canAdd: TGrpAddFunc; canAddGrpSameType : TGrpAddFunc; out ErrDesc: string): boolean;
var
  sc:      TSCSchedOnPlan;
  tJob,
  tJobGrp: TSCProdSched;
  tDet,
  tDetGrp: TSCProdReqDet;
  tGrp:    TSCProdGroup;
  GroupingTypeGrp, GroupingTypeJob : CGroupingType;
  SChedListGroup, SChedListJob : TMSchedList;
  I : Integer;
begin
  ErrDesc := _('Undefined error');
  sc := TSCSchedOnPlan(m_codeList[job]);
//  Assert(sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  tJob := TSCProdSched(sc);
  tDet := tJob.m_reqDet;

  sc := TSCSchedOnPlan(m_codeList[grp]);
  //Assert(sc is TSCProdGroup);
  if not (sc is TSCProdGroup) then Exit;

  tGrp := TSCProdGroup(sc);

  Result := true;
  if tGrp.m_list.Count = 0 then exit;

  tJobGrp := TSCProdSched(tGrp.m_list[0]);
  tDetGrp := tJobGrp.m_reqDet;

  GroupingTypeGrp := p_sc.GetStepGroupType(tJobGrp.m_Id);
  if (GroupingTypeGrp = FromOtherStep_grp) then
  begin
    Result := false;
    exit
  end;

  if (tDet.m_CanGroup <> '1') and (tDet.m_CanGroup <> '3') then
  begin
    ErrDesc := _('This job can''t be grouped');
    Result := false;
    exit
  end;
  {if (tDetGrp.m_hdr.m_prodUMCode <> tDet.m_hdr.m_prodUMCode) then
  begin
    ErrDesc := _('Different unit of measure');
    Result := false;
    exit
  end;}

  if (tDetGrp.m_stepType <> tDet.m_stepType) then
  begin
    ErrDesc := _('Different step type');
    Result := false;
    exit
  end;

  if tJobGrp.p_WorkCenter <> tJob.p_WorkCenter then
  begin
    ErrDesc := _('Different workcenter');
    Result := false;
    exit
  end;

  if tJobGrp.p_Process <> tJob.p_Process then
  begin
    ErrDesc := _('Different workcenter process');
    Result := false;
    exit
  end;

  // compatibility O to O same group
  if not Assigned(p_sc.GetExtLinkPtr(grp)) then
  begin
{
    for i := 0 to p_sc.GetGrpNumSons(grp)-1 do
    begin
      GrpJobId   := p_sc.GetGrpSon(grp, i);
      Res.GetSetupParms(job, GrpJobId, supRec, compatVal);
      if not supRec.onSameGroup then exit;
    end;
}
  end;

  if Assigned(canAdd) and (not canAdd(job, grp, ErrDesc)) then
  begin
    Result := false;
    exit
  end;

  if (GroupingTypeGrp = MultiStepForward_grp) or (GroupingTypeGrp = MultiStepBackward_grp) or (GroupingTypeGrp = MultiStepForwardBackward_grp) then
  begin
    GroupingTypeJob := p_sc.GetStepGroupType(job);
    if (GroupingTypeJob = GroupingTypeGrp) then
    begin
      SChedListGroup := TMSchedList.Create(self);
      SChedListJob   := TMSchedList.Create(self);
      p_sc.GetALLStepBrothersForGrouping(tJobGrp.m_Id, SChedListGroup, true);
      p_sc.GetALLStepBrothersForGrouping(Job, SChedListJob, true);
      if (SChedListGroup.GetLinkCount <> SChedListJob.GetLinkCount) then
      begin
        Result := false;
        exit
      end
      else
      begin
        for I := 0 to SChedListGroup.GetLinkCount - 1 do
        begin
          sc := TSCSchedOnPlan(m_codeList[SChedListGroup.getlink(I)]);
          //Assert(sc is TSCProdSched);
          if not (sc is TSCProdSched) then Exit;
          tJobGrp := TSCProdSched(sc);
          tDetGrp := tJobGrp.m_reqDet;
          sc := TSCSchedOnPlan(m_codeList[SChedListJob.getlink(I)]);
//          Assert(sc is TSCProdSched);
          if not (sc is TSCProdSched) then Exit;
          tJob := TSCProdSched(sc);
          tDet := tJob.m_reqDet;

          if (tDet.m_CanGroup <> '1') and (tDet.m_CanGroup <> '3') then
          begin
            ErrDesc := _('This job can''t be grouped');
            Result := false;
            exit
          end;
        {  if (tDetGrp.m_hdr.m_prodUMCode <> tDet.m_hdr.m_prodUMCode) then
          begin
            ErrDesc := _('Different unit of measure');
            Result := false;
            exit
          end; }

          if (tDetGrp.m_stepType <> tDet.m_stepType) then
          begin
            ErrDesc := _('Different step type');
            Result := false;
            exit
          end;

          if tJobGrp.p_WorkCenter <> tJob.p_WorkCenter then
          begin
            ErrDesc := _('Different workcenter');
            Result := false;
            exit
          end;

          if tJobGrp.p_Process <> tJob.p_Process then
          begin
            ErrDesc := _('Different workcenter process');
            Result := false;
            exit
          end;

          if assigned(canAddGrpSameType) and (not canAddGrpSameType(tJob.m_Id, tJobGrp.m_Id, ErrDesc)) then
          begin
            Result := false;
            exit
          end;

        end;
      end;

    end;

  end;

end;

