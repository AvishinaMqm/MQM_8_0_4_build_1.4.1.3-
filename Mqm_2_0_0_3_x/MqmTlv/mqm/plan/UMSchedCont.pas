procedure TMSchedCont.LoadChain(qry: TMqmQuery; ProdReqNo: string);
var
  tbiPS:      ^TTblInfo;
  tbiPD:      ^TTblInfo;
  tbiPH:      ^TTblInfo;
  tbiSP:      ^TTblInfo;
  oldHdrCode: string;
  oldDetCode: integer;
  tHdr:       TSCProdReqHdr;
  tDet:       TSCProdReqDet;
  tJob:       TSCProdSched;
  EndSchedPs: TDateTime;
  tmpStr:     string;
begin
  tbiPH := @tblInfo[tbl_prod_reqHdr];
  tbiPD := @tblInfo[tbl_prod_step];
  tbiPS := @tblInfo[tbl_prod_sched];
  tbiSP := @tblInfo[tbl_sched_progress];

//  qry.Transaction.Active := true;

  with qry.SQL do
  begin
    Clear;

    Add('select ');

    // production request header data (PH)
    Add(CreateFld(tbiPH.pfx,fli_ProdLine)           + ','); // Prod Line
    Add(CreateFld(tbiPH.pfx,fli_ProdType)           + ','); // Prod Type
    Add(CreateFld(tbiPH.pfx,fli_ProdFamily)         + ','); // ProdFamily
    Add(CreateFld(tbiPH.pfx,fli_MaterialFamily)     + ','); // MaterialFamily
    Add(CreateFld(tbiPH.pfx,fli_ProdUMCode)         + ','); // Um Code
    Add(CreateFld(tbiPH.pfx,fli_ProdLowDataTime)    + ','); // Low Start Day Limit
    Add(CreateFld(tbiPH.pfx,fli_ProdDelivDate)      + ','); // Delivery Line
    Add(CreateFld(tbiPH.pfx, fli_HistoriclReq)      + ','); // Historical request
    Add(CreateFld(tbiPH.pfx, fli_FrcDelDate)        + ','); // Force delivery date
    Add(CreateFld(tbiPH.pfx, fli_ModulHandled)      + ','); // Modul handled

    // production request detail data (PD)
    Add(CreateFld(tbiPD.pfx, fli_preqNo)            + ','); // prod Req number
    Add(CreateFld(tbiPD.pfx, fli_pstepId)           + ','); // prod Step
