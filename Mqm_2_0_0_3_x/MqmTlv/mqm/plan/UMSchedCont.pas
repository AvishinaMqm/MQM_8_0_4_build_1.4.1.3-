function TMSchedCont.GetStepInfoByNumber(ProdReq: string; Step: integer): TSQStepInfo;
var
  tDet: TSCProdReqDet;
  tHdr: TSCProdReqHdr;
  N, I : integer;
begin
  tHdr := FindHdrFromCode(self, ProdReq);
  if not Assigned(tHdr) then exit;

  for I := 0 to tHdr.m_list.Count - 1 do
  begin
    tDet := TSCProdReqDet(tHdr.m_list[I]);
    if tDet.m_code = Step then
       break;
  end;

  if not Assigned(tDet) then exit;

  with tDet do
  begin
   // for time being only those fields , since it is new function for Warp // avi 180722
    Result.ProdTypeBaseLvl   := m_ProdTypeBaseLvl;
    Result.ProdTypeSecondLvl := m_ProdTypeSecondLvl;
    Result.ProductBaseLvl    := m_ProductBaseLvl;
    Result.ProductSecondLvl  := m_ProductSecondLvl;

  {  Result.StepNo     := m_code;
    Result.stepType   := m_stepType;
    Result.wkCtrPtr   := m_PlanWrkCtrPtr;
    Result.wkCtrCode  := m_planWkctr;
    Result.wkCtrProc  := m_planWkctrProc;
    Result.StepClosed := m_stepClosed;
    Result.InitQty    := m_quantInit;
    Result.planStart  := m_planStart;
    Result.LowStart   := m_lowStartTimeLimit;
    Result.planEnd    := m_planEnd;
    Result.HighEnd    := m_highEndTimeLimit;
    Result.NumResPlan := m_planNumRes;
    N := StrToIntDef(m_connTypeToPrevious , 0);
    if N = 0 then
      Result.connTypeToPrevious := 0
    else
      Result.connTypeToPrevious := StrToInt(m_connTypeToPrevious);
    Result.ProdUM     := tHdr.m_prodUMCode;

    if TSCProdSched(tDet.m_list[0]).m_isDeleted then
      Result.isDeleted := true
    else
      Result.isDeleted := false;   }
  end;
end;

