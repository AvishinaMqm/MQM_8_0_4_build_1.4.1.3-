procedure TMSchedCont.SetSchedObjStatus(id: TSchedId; status: CScStatus);
var
  sc:  TSCSchedOnPlan;
  grp: TSCProdGroup;
  i:   integer;
begin
  try
  sc := TSCSchedOnPlan(m_codeList[id]);
  //Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then exit;
  if (TSCProdSched(sc).m_VisbleInBin <> CSB_ReadOnly) then
    sc.m_status := status;

  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
      if TSCProdSched(TSCSchedOnPlan(grp.m_list[i])).m_VisbleInBin <> CSB_ReadOnly then
         TSCSchedOnPlan(grp.m_list[i]).m_status := status
  end;
  except

  end;

{
  case ps.m_status of
  CSC_none:
    begin
      Assert(status <> CSC_new);
      ps.m_status := status
    end;

  CSC_new:
    begin
      Assert(status = CSC_modi);
    end;

  CSC_modi:
    begin
      Assert(status = CSC_modi);
    end;

  CSC_del:  Assert(false);
  end;
}
end;

