function TMSchedCont.GetStepSchedQty(ProdReq: string; StepNr: integer): double;
var
  i: integer;
  tHdr: TSCProdReqHdr;
  tDet: TSCProdReqDet;
  tJob:  TSCProdSched;
begin
  Result := 0;
  tHdr := FindHdrFromCode(self, ProdReq);
  if not Assigned(tHdr) then exit;

  tDet := tHdr.FindDetFromCode(StepNr);
  if not Assigned(tDet) then exit;

  for i := 0 to tDet.m_list.Count-1 do
  begin
    tJob := tDet.m_list[i];
    if tJob.p_rscCode <> '' then
      Result := Result + tJob.p_quantSched;
  end;
end;

