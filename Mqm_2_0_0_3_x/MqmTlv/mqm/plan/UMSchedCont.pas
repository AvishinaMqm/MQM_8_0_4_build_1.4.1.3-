  oldHdrCode := '';
  oldDetCode := -1;
  tHdr       := nil;
  tDet       := nil;

  try

  qry.Open;

  with qry do
  begin

    while not EOF do
    begin
      EndSchedPs := FieldByName(CreateFld(tbiPS.pfx, fli_schedEnd)).AsDateTime;

      if (EndSchedPs < date) and (FieldByName(CreateFld(tbiPH.pfx, fli_HistoriclReq)).AsString = '1') then
      begin
        next;
        continue
      end;

      if FieldByName(CreateFld(tbiPH.pfx, fli_ModulHandled)).AsString = '1' then
      begin
        Next;
        continue
      end;

      if oldHdrCode <> FieldByName(CreateFld(tbiPD.pfx, fli_preqNo)).AsString then
      begin
        if Assigned(tHdr) then tHdr.m_list.Sort(StepOrderGrowing);

        oldHdrCode := FieldByName(CreateFld(tbiPD.pfx, fli_preqNo)).AsString;
        tHdr := FindHdrFromCode(self, oldHdrCode);

        if not Assigned(tHdr) then
        begin
          tHdr := AddReqHdr(oldHdrCode);
          tHdr.m_prodLine        := FieldByName(CreateFld(tbiPH.pfx, fli_ProdLine)).AsString;
          tHdr.m_prodType        := FieldByName(CreateFld(tbiPH.pfx, fli_ProdType)).AsString;
          tHdr.m_prodFamily      := FieldByName(CreateFld(tbiPH.pfx, fli_ProdFamily)).AsString;
          tHdr.m_matFamily       := FieldByName(CreateFld(tbiPH.pfx, fli_MaterialFamily)).AsString;
          tHdr.m_prodUMCode      := FieldByName(CreateFld(tbiPH.pfx, fli_ProdUMCode)).AsString;
          tHdr.m_NumOfDecimals   := GetUmNumOfDecimals(tHdr.m_prodUMCode);
          tHdr.m_prodLowDateTime := FieldByName(CreateFld(tbiPH.pfx, fli_ProdLowDataTime)).AsDateTime;
          tHdr.m_prodDelivDate   := FieldByName(CreateFld(tbiPH.pfx, fli_ProdDelivDate)).AsDateTime;
          if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '1' then
            tHdr.m_FrcDelDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '2' then
            tHdr.m_FrcDelDate := CSF_Yes
          else if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '3' then
            tHdr.m_FrcDelDate := CSF_Forceable2
          else if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '4' then
            tHdr.m_FrcDelDate := CSF_Yes2
          else
            tHdr.m_FrcDelDate := CSF_No;
        end;

        oldDetCode := -1
      end;

      if oldDetCode <> FieldByName(CreateFld(tbiPD.pfx, fli_pstepId)).AsInteger then
      begin
        oldDetCode := FieldByName(CreateFld(tbiPD.pfx, fli_pstepId)).AsInteger;

        tDet := tHdr.FindDetFromCode(oldDetCode);

        if not Assigned(tDet) then
        begin
          tDet := AddReqDet(tHdr, oldDetCode);

          tmpStr := FieldByName(CreateFld(tbiPD.pfx, fli_StepType)).AsString;
          if tmpStr = 'B' then
            tDet.m_stepType := CST_batch
          else if tmpStr = 'C' then
            tDet.m_stepType := CST_continuous
          else if tmpStr = 'H' then
          begin
            tDet.m_stepType := CST_continuous;
            tDet.m_batch_ContinuesTime := true;
          end
          else if tmpStr = 'P' then
          begin
            tDet.m_stepType := CST_batch;
            tDet.m_Continues_Parallel := true;
          end
          else
            tDet.m_stepType := CST_continuous;
      //    tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_ToBeSched)).AsString = '1');
          if DBAppGlobals.MCM_App then
          begin
            tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_SchedulByMcm)).AsString = '1');
            tDet.m_prevStep          := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mcm)).AsInteger;
            tDet.m_nextStep          := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mcm)).AsInteger;
          end
          else
          begin
            tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_SchedulByMqm)).AsString = '1');
            tDet.m_prevStep          := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mqm)).AsInteger;
            tDet.m_nextStep          := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mqm)).AsInteger;
          end;
          tDet.m_GenericPlan       := FieldByName(CreateFld(tbiPD.pfx, fli_StepPartGenralPlan)).AsString;
          tDet.m_prevRealStep      := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepTrue)).AsInteger;
          tDet.m_nextRealStep      := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepTrue)).AsInteger;
          tDet.m_materialArrivDate := FieldByName(CreateFld(tbiPD.pfx, fli_MaterialArrivDate)).AsDateTime;
          tDet.m_planStart         := FieldByName(CreateFld(tbiPD.pfx, fli_planStart)).AsDateTime;
          tDet.m_planEnd           := FieldByName(CreateFld(tbiPD.pfx, fli_planEnd)).AsDateTime;

          if not DBAppGlobals.MCM_App then
          begin
            if not FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime)).isnull and
               (FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime)).AsDateTime > 0) then
              tDet.m_lowStartTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime)).AsDateTime
            else
              tDet.m_lowStartTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit)).AsDateTime;

            if not FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime)).isnull and
               (FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime)).AsDateTime > 0) then
              tDet.m_highEndTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime)).AsDateTime
            else
              tDet.m_highEndTimeLimit  := FieldByName(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit)).AsDateTime;
          end
          else
          begin
            tDet.m_lowStartTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit)).AsDateTime;
            tDet.m_highEndTimeLimit  := FieldByName(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit)).AsDateTime;
          end;

          if not tDet.m_Approvaldate_UserChanged then
            tDet.m_Approvaldate      := FieldByName(CreateFld(tbiPD.pfx, fli_ApprovalDate)).AsDateTime;
          tDet.m_calCod            := FieldByName(CreateFld(tbiPD.pfx, fli_CalCod)).AsString;
          tDet.m_quantInit         := FieldByName(CreateFld(tbiPD.pfx, fli_quantInit)).AsFloat;
          tDet.m_quantFinl         := FieldByName(CreateFld(tbiPD.pfx, fli_quantFinl)).AsFloat;
          tDet.m_weight            := FieldByName(CreateFld(tbiPD.pfx, fli_Weight)).AsFloat;
          tDet.m_weightUM          := FieldByName(CreateFld(tbiPD.pfx, fli_DescUM)).AsString;
          tDet.m_planWkctr         := FieldByName(CreateFld(tbiPD.pfx, fli_wkCtrCode)).AsString;
          tDet.m_PlanWrkCtrPtr     := p_pl.FindWrkCtrByCode(tDet.m_planWkctr);
          tDet.m_planWkctrProc     := FieldByName(CreateFld(tbiPD.pfx, fli_wkcProc)).AsString;
          tDet.m_CanGroup          := FieldByName(CreateFld(tbiPD.pfx, fli_StepCanGroup)).AsString;
          tDet.p_OverlapWithOtherSteps := false;
          if FieldByName(CreateFld(tbiPD.pfx, fli_OverlapWithOtherSteps)).AsString = '1' then
             tDet.p_OverlapWithOtherSteps := true;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcMatDate)).AsString = '1' then
             tDet.m_FrcMatDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcMatDate)).AsString = '2' then
             tDet.m_FrcMatDate := CSF_Yes
          else
             tDet.m_FrcMatDate := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcLowestDate)).AsString = '1' then
             tDet.m_FrcLowestDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcLowestDate)).AsString = '2' then
             tDet.m_FrcLowestDate := CSF_Yes
          else
             tDet.m_FrcLowestDate := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate)).AsString = '1' then
             tDet.m_FrcHighestDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate)).AsString = '2' then
             tDet.m_FrcHighestDate := CSF_Yes
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate)).AsString = '3' then
          begin
             tDet.m_FrcHighestDate := CSF_RequestedHighesEndDate;
             tDet.m_highEndTimeLimitTemp := tDet.m_highEndTimeLimit
          end
          else
             tDet.m_FrcHighestDate := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcOverlapp)).AsString = '1' then
             tDet.m_FrcOverlapp := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcOverlapp)).AsString = '2' then
             tDet.m_FrcOverlapp := CSF_Yes
          else
             tDet.m_FrcOverlapp := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_StepClosed)).AsString = '1' then
             tDet.m_stepClosed        := true
          else
             tDet.m_stepClosed        := false;

          tDet.m_SetupTimeStep     := FieldByName(CreateFld(tbiPD.pfx, fli_SetupTimStep)).AsFloat;
          tDet.m_ExeTimeStep       := FieldByName(CreateFld(tbiPD.pfx, fli_excTimeStep)).AsFloat;
          tDet.m_planNumRes        := FieldByName(CreateFld(tbiPD.pfx, fli_NumResPlan)).AsFloat;
          tDet.p_rscComp       := FieldByName(CreateFld(tbiPD.pfx, fli_NumSubRscComponents)).AsInteger;
          tDet.m_connTypeToPrevious:= FieldByName(CreateFld(tbiPD.pfx, fli_ConnTypToPrevStepSplit)).AsString;
     //     tDet.m_VisbleInBin       := CSB_NotVisible;
          tDet.m_OfThisWrkst       := false;

          tDet.m_PlanWrkCtrPtr := p_pl.FindWrkCtrByCode(tDet.m_planWkctr);

        end
      end;

      if tDet.m_OfThisWrkst then
      begin
        next;
        continue
      end;

      tJob := tDet.FindJobFromCode(FieldByName(CreateFld(tbiPS.pfx, fli_psubstId)).AsInteger,
                                   FieldByName(CreateFld(tbiPS.pfx, fli_reprocNo)).AsInteger);
      if not Assigned(tJob) then
      begin
        tJob := AddJobDet(tDet,
                          FieldByName(CreateFld(tbiPS.pfx, fli_psubstId)).AsInteger,
                          FieldByName(CreateFld(tbiPS.pfx, fli_stGroup)).AsInteger);


        tJob.m_VisbleInBin := CSB_NotVisible;
        tJob.m_fromPD      := false;
        tJob.m_status      := CSS_none;
        tJob.m_subLinRscId := FieldByName(CreateFld(tbiPS.pfx, fli_subLinRscId)).AsInteger;
        tJob.p_schedStart  := FieldByName(CreateFld(tbiPS.pfx, fli_schedStart)).AsDateTime;
        tJob.p_schedEnd    := FieldByName(CreateFld(tbiPS.pfx, fli_schedEnd)).AsDateTime;

        tJob.p_rscCode     := FieldByName(CreateFld(tbiPS.pfx, fli_rsc)).AsString;
  {sav1
        if tJob.m_rscCode <> '' then
          tJob.m_OnPlan := true
        else
          tJob.m_OnPlan := false;
  }
        tJob.m_reprocNo       := FieldByName(CreateFld(tbiPS.pfx, fli_reprocNo)).AsInteger;

  //sav1      tJob.m_Group          := FieldByName(CreateFld(tbiPS.pfx, fli_stGroup)).AsInteger;
        tJob.p_SetStepType      := FieldByName(CreateFld(tbiPS.pfx, fli_schedType)).AsString;
        tJob.m_comment        := FieldByName(CreateFld(tbiPS.pfx, fli_Comment)).AsString;

        tJob.p_WorkCenter     := FieldByName(CreateFld(tbiPS.pfx, fli_wkCtrCode)).AsString;
        tJob.p_Process        := FieldByName(CreateFld(tbiPS.pfx, fli_wkcProc)).AsString;
        if (FieldByName(CreateFld(tbiPS.pfx, fli_wkCtrCode)).AsString <> '') and
           (FieldByName(CreateFld(tbiPS.pfx, fli_wkCtrCode)).AsString <> ' ') then
             tJob.p_WrkCtrPtr := p_pl.FindWrkCtrByCode(tJob.m_PlanWkCtrCode);

        tJob.p_quantSched     := FieldByName(CreateFld(tbiPS.pfx, fli_quant)).AsFloat;
        tJob.p_exeMin         := FieldByName(CreateFld(tbiPS.pfx, fli_exeMin)).AsFloat;
        tJob.p_supMinBase     := FieldByName(CreateFld(tbiPS.pfx, fli_supMinBase)).AsFloat;
        tJob.p_supMinReal     := FieldByName(CreateFld(tbiPS.pfx, fli_supMinReal)).AsFloat;
        tJob.p_supMinOvlp     := FieldByName(CreateFld(tbiPS.pfx, fli_supMinOvlp)).AsFloat;
        tJob.m_numOfRscComp   := FieldByName(CreateFld(tbiPS.pfx, fli_NumSubRscComponents)).AsInteger;
        tJob.m_fwdConnSubStp  := FieldByName(CreateFld(tbiPS.pfx, fli_ConnForwardSubStep)).AsInteger;
        tJob.m_fwdConnReProcs := FieldByName(CreateFld(tbiPS.pfx, fli_ConnForwardReProcess)).AsInteger;
        tJob.m_bkwConnSubStp  := FieldByName(CreateFld(tbiPS.pfx, fli_ConnBackwardSubStep)).AsInteger;
        tJob.m_bkwConnReProcs := FieldByName(CreateFld(tbiPS.pfx, fli_ConnBackwardReProcess)).AsInteger;
        tJob.m_PrgSt          := 0;
        tJob.m_PrgCurDt       := 0;
        tJob.m_PrgEd          := 0;
        tJob.m_PrgQty         := 0;
        tJob.m_PrgStartingQty := 0;
        tJob.m_PrgRemTime     := -1;
        tJob.m_ProgType       := '';
        tJob.m_PrgStHost      := 0;
        tJob.m_PrgCurDtHost   := 0;
        tJob.m_PrgEdHost      := 0;
        tJob.m_PrgQtyHost     := 0;
        tJob.m_PrgRemTimeHost := -1;
        tJob.m_ProgTypeHost   := '';
        tJob.p_NewSetup  := -1;
      end;

      Next
    end
  end;

  if Assigned(tHdr) then tHdr.m_list.Sort(StepOrderGrowing);

  qry.Close;

  with qry.SQL do
  begin
    Clear;

    Add('select ');

    // production request header data (PH)
    Add(CreateFld(tbiPH.pfx,fli_ProdLine)           + ','); // Prod Line
    Add(CreateFld(tbiPH.pfx,fli_ProdType)           + ','); // Prod Type
    Add(CreateFld(tbiPH.pfx,fli_ProdFamily)         + ','); // ProdFamily
    Add(CreateFld(tbiPH.pfx,fli_MaterialFamily)     + ','); // MaterialFamily
    Add(CreateFld(tbiPH.pfx,fli_ProdUMCode)         + ','); // Um Code
    Add(CreateFld(tbiPH.pfx,fli_ProdLowDataTime)    + ','); // Low Start Day Limit
    Add(CreateFld(tbiPH.pfx,fli_ProdDelivDate)      + ','); // Delivery Line
    Add(CreateFld(tbiPH.pfx, fli_FrcDelDate)        + ','); // Force delivery date

    // production request detail data (PD)
    Add(CreateFld(tbiPD.pfx, fli_preqNo)            + ','); // prod Req number
    Add(CreateFld(tbiPD.pfx, fli_pstepId)           + ','); // prod Step
//    Add(CreateFld(tbiPD.pfx, fli_ToBeSched)         + ','); // To Be Sched
    if DBAppGlobals.MCM_App then
    begin
      Add(CreateFld(tbiPD.pfx, fli_SchedulByMcm)         + ','); // To Be Sched
      Add(CreateFld(tbiPD.pfx, fli_prevStepSched_Mcm) + ','); // previous Step
      Add(CreateFld(tbiPD.pfx, fli_NextStepSched_Mcm) + ','); // next Step
    end
    else
    begin
      Add(CreateFld(tbiPD.pfx, fli_SchedulByMqm)         + ','); // To Be Sched
      Add(CreateFld(tbiPD.pfx, fli_prevStepSched_Mqm) + ','); // previous Step
      Add(CreateFld(tbiPD.pfx, fli_NextStepSched_Mqm) + ','); // next Step
    end;
    Add(CreateFld(tbiPD.pfx, fli_StepPartGenralPlan) + ','); // StepPartGenralPlan
    Add(CreateFld(tbiPD.pfx, fli_StepType)          + ','); // Step Type
    Add(CreateFld(tbiPD.pfx, fli_prevStepTrue)      + ','); // real previous Step
    Add(CreateFld(tbiPD.pfx, fli_NextStepTrue)      + ','); // real next Step
    Add(CreateFld(tbiPD.pfx, fli_wkCtrCode)         + ','); // should be from dispm ??
    Add(CreateFld(tbiPD.pfx, fli_wkcProc)           + ','); // workcenter process
    Add(CreateFld(tbiPD.pfx, fli_MaterialArrivDate) + ','); // Material arrive Date
    Add(CreateFld(tbiPD.pfx, fli_planStart)         + ','); // Plan start
    Add(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime) + ',');
    Add(CreateFld(tbiPD.pfx, fli_FinalPlanScheduledDateTime)   + ',');
    Add(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit) + ','); // Low Start Limit
    Add(CreateFld(tbiPD.pfx, fli_planEnd)           + ','); // Plan End
    Add(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit)  + ','); // high End Limit
    Add(CreateFld(tbiPD.pfx, fli_ApprovalDate)      + ','); // Approval date
    Add(CreateFld(tbiPD.pfx, fli_CalCod)            + ','); // Calendar Code
    Add(CreateFld(tbiPD.pfx, fli_quantInit)         + ','); // Init Qty
    Add(CreateFld(tbiPD.pfx, fli_quantFinl)         + ','); // Final Qty
    Add(CreateFld(tbiPD.pfx, fli_Weight)            + ','); // Weight
    Add(CreateFld(tbiPD.pfx, fli_DescUM)            + ','); // Um
    Add(CreateFld(tbiPD.pfx, fli_StepClosed)        + ','); // fli_StepClosed
    Add(CreateFld(tbiPD.pfx, fli_SetupTimStep)      + ','); // Weight
    Add(CreateFld(tbiPD.pfx, fli_StepCanGroup)      + ','); // Can group
    Add(CreateFld(tbiPD.pfx, fli_OverlapWithOtherSteps) + ','); // Overlap With Other Steps
    Add(CreateFld(tbiPD.pfx, fli_FrcMatDate)        + ',');
    Add(CreateFld(tbiPD.pfx, fli_FrcLowestDate)      + ',');
    Add(CreateFld(tbiPD.pfx, fli_FrcHighestDate)      + ',');
    Add(CreateFld(tbiPD.pfx, fli_FrcOverlapp)      + ',');
    Add(CreateFld(tbiPD.pfx, fli_ConnTypToPrevStepSplit)+ ','); // Connection Type
    Add(CreateFld(tbiPD.pfx, fli_excTimeStep));             // Weight

    Add(' from ');
    Add(tbiPH.GetTableName + ',' + tbiPD.GetTableName);
    Add(' where ');
    Add(CreateFld(tbiPD.pfx, fli_Identifier) + ' || ' + CreateFld(tbiPD.pfx, fli_preqNo) + ' || ' + CreateFld(tbiPD.pfx, fli_pstepId) + ' not in ');
    Add('(Select ' + CreateFld(tbiPS.pfx, fli_Identifier) + ' || ' + CreateFld(tbiPS.pfx, fli_preqNo) + ' || ' + CreateFld(tbiPS.pfx, fli_pstepId));
    Add(' from ' + tbiPS.GetTableName +  ') And ');

//sav    Add(CreateFld(tbiPH.pfx, fli_HistoriclReq)   + '=''' + '0' + ''' and ');
    Add(CreateFld(tbiPH.pfx, fli_Identifier) + '=' + CreateFld(tbiPD.pfx, fli_Identifier) + ' AND ');
    Add(CreateFld(tbiPH.pfx, fli_preqNo)   + '=''' + ProdReqNo + ''' and ');
    Add(CreateFld(tbiPH.pfx, fli_preqNo)   + '=' + CreateFld(tbiPD.pfx, fli_preqNo)); //+ ' and ');

    Add(' order by');
    Add(CreateFld(tbiPD.pfx, fli_preqNo)  + ',');
    Add(CreateFld(tbiPD.pfx, fli_pstepId));

  end;

  oldHdrCode := '';
  oldDetCode := -1;
  tHdr       := nil;

  qry.Open;

  with qry do
  begin

    while not EOF do
    begin

      if oldHdrCode <> FieldByName(CreateFld(tbiPD.pfx, fli_preqNo)).AsString then
      begin
        if Assigned(tHdr) then tHdr.m_list.Sort(StepOrderGrowing);
        oldHdrCode := FieldByName(CreateFld(tbiPD.pfx, fli_preqNo)).AsString;
        tHdr := FindHdrFromCode(self, oldHdrCode);

        if not assigned(tHdr) then
        begin
          tHdr := AddReqHdr(oldHdrCode);
          tHdr.m_prodLine        := FieldByName(CreateFld(tbiPH.pfx, fli_ProdLine)).AsString;
          tHdr.m_prodType        := FieldByName(CreateFld(tbiPH.pfx, fli_ProdType)).AsString;
          tHdr.m_prodFamily      := FieldByName(CreateFld(tbiPH.pfx, fli_ProdFamily)).AsString;
          tHdr.m_matFamily       := FieldByName(CreateFld(tbiPH.pfx, fli_MaterialFamily)).AsString;
          tHdr.m_prodUMCode      := FieldByName(CreateFld(tbiPH.pfx, fli_ProdUMCode)).AsString;
          tHdr.m_NumOfDecimals   := GetUmNumOfDecimals(tHdr.m_prodUMCode);
          tHdr.m_prodLowDateTime := FieldByName(CreateFld(tbiPH.pfx, fli_ProdLowDataTime)).AsDateTime;
          tHdr.m_prodDelivDate   := FieldByName(CreateFld(tbiPH.pfx, fli_ProdDelivDate)).AsDateTime;
          if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '1' then
            tHdr.m_FrcDelDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '2' then
            tHdr.m_FrcDelDate := CSF_Yes
          else if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '3' then
            tHdr.m_FrcDelDate := CSF_Forceable2
          else if FieldByName(CreateFld(tbiPH.pfx, fli_FrcDelDate)).AsString = '4' then
            tHdr.m_FrcDelDate := CSF_Yes2
          else
            tHdr.m_FrcDelDate := CSF_No;
        end;

        oldDetCode := -1
      end;

      if oldDetCode <> FieldByName(CreateFld(tbiPD.pfx, fli_pstepId)).AsInteger then
      begin
        oldDetCode := FieldByName(CreateFld(tbiPD.pfx, fli_pstepId)).AsInteger;

        tDet := tHdr.FindDetFromCode(oldDetCode);

        if not Assigned(tDet) then
        begin
          tDet := AddReqDet(tHdr, oldDetCode);

          tmpStr := FieldByName(CreateFld(tbiPD.pfx, fli_StepType)).AsString;
          if tmpStr = 'B' then
            tDet.m_stepType := CST_batch
          else if tmpStr = 'C' then
            tDet.m_stepType := CST_continuous
          else if tmpStr = 'H' then
          begin
            tDet.m_stepType := CST_continuous;
            tDet.m_batch_ContinuesTime := true;
          end
          else if tmpStr = 'P' then
          begin
            tDet.m_stepType := CST_batch;
            tDet.m_Continues_Parallel := true;
          end
          else
            tDet.m_stepType := CST_continuous;

         // tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_ToBeSched)).AsString = '1');
          if DBAppGlobals.MCM_App then
          begin
            tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_SchedulByMcm)).AsString = '1');
            tDet.m_prevStep          := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mcm)).AsInteger;
            tDet.m_nextStep          := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mcm)).AsInteger;
          end
          else
          begin
            tDet.m_StepToSched       := (FieldByName(CreateFld(tbiPD.pfx, fli_SchedulByMqm)).AsString = '1');
            tDet.m_prevStep          := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mqm)).AsInteger;
            tDet.m_nextStep          := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mqm)).AsInteger;
          end;

          tDet.m_GenericPlan       := FieldByName(CreateFld(tbiPD.pfx, fli_StepPartGenralPlan)).AsString;
          tDet.m_prevRealStep      := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepTrue)).AsInteger;
          tDet.m_nextRealStep      := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepTrue)).AsInteger;
          tDet.m_materialArrivDate := FieldByName(CreateFld(tbiPD.pfx, fli_MaterialArrivDate)).AsDateTime;
          tDet.m_planStart         := FieldByName(CreateFld(tbiPD.pfx, fli_planStart)).AsDateTime;
          tDet.m_planEnd           := FieldByName(CreateFld(tbiPD.pfx, fli_planEnd)).AsDateTime;

          if not DBAppGlobals.MCM_App then
          begin
            if not FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime)).isnull and
               (FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime)).AsDateTime > 0) then
              tDet.m_lowStartTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime)).AsDateTime
            else
              tDet.m_lowStartTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit)).AsDateTime;

            if not FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime)).isnull and
               (FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime)).AsDateTime > 0) then
              tDet.m_highEndTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime)).AsDateTime
            else
              tDet.m_highEndTimeLimit  := FieldByName(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit)).AsDateTime;
          end
          else
          begin
            tDet.m_lowStartTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit)).AsDateTime;
            tDet.m_highEndTimeLimit  := FieldByName(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit)).AsDateTime;
          end;

       //   tDet.m_lowStartTimeLimit := FieldByName(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit)).AsDateTime;
       //   tDet.m_highEndTimeLimit  := FieldByName(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit)).AsDateTime;
          if not tDet.m_Approvaldate_UserChanged then
            tDet.m_Approvaldate      := FieldByName(CreateFld(tbiPD.pfx, fli_ApprovalDate)).AsDateTime;
          tDet.m_calCod            := FieldByName(CreateFld(tbiPD.pfx, fli_CalCod)).AsString;
          tDet.m_quantInit         := FieldByName(CreateFld(tbiPD.pfx, fli_quantInit)).AsFloat;
          tDet.m_quantFinl         := FieldByName(CreateFld(tbiPD.pfx, fli_quantFinl)).AsFloat;
          tDet.m_weight            := FieldByName(CreateFld(tbiPD.pfx, fli_Weight)).AsFloat;
          tDet.m_weightUM          := FieldByName(CreateFld(tbiPD.pfx, fli_DescUM)).AsString;

          tDet.m_planWkctr         := FieldByName(CreateFld(tbiPD.pfx, fli_wkCtrCode)).AsString;
          tDet.m_planWkctrProc     := FieldByName(CreateFld(tbiPD.pfx, fli_wkcProc)).AsString;
          tDet.m_CanGroup          := FieldByName(CreateFld(tbiPD.pfx, fli_StepCanGroup)).AsString;
          tDet.p_OverlapWithOtherSteps := false;
          if FieldByName(CreateFld(tbiPD.pfx, fli_OverlapWithOtherSteps)).AsString = '1' then
             tDet.p_OverlapWithOtherSteps := true;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcMatDate)).AsString = '1' then
             tDet.m_FrcMatDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcMatDate)).AsString = '2' then
             tDet.m_FrcMatDate := CSF_Yes
          else
             tDet.m_FrcMatDate := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcLowestDate)).AsString = '1' then
             tDet.m_FrcLowestDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcLowestDate)).AsString = '2' then
             tDet.m_FrcLowestDate := CSF_Yes
          else
             tDet.m_FrcLowestDate := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate)).AsString = '1' then
            tDet.m_FrcHighestDate := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate)).AsString = '2' then
            tDet.m_FrcHighestDate := CSF_Yes
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate)).AsString = '3' then
            tDet.m_FrcHighestDate := CSF_Forceable
          else
            tDet.m_FrcHighestDate := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_FrcOverlapp)).AsString = '1' then
             tDet.m_FrcOverlapp := CSF_Forceable
          else if FieldByName(CreateFld(tbiPD.pfx, fli_FrcOverlapp)).AsString = '2' then
             tDet.m_FrcOverlapp := CSF_Yes
          else
             tDet.m_FrcOverlapp := CSF_No;

          if FieldByName(CreateFld(tbiPD.pfx, fli_StepClosed)).AsString = '1' then
             tDet.m_stepClosed        := true
          else
             tDet.m_stepClosed        := false;

          tDet.m_connTypeToPrevious:= FieldByName(CreateFld(tbiPD.pfx, fli_ConnTypToPrevStepSplit)).AsString;
          tDet.m_SetupTimeStep     := FieldByName(CreateFld(tbiPD.pfx, fli_SetupTimStep)).AsFloat;
          tDet.m_ExeTimeStep       := FieldByName(CreateFld(tbiPD.pfx, fli_excTimeStep)).AsFloat;

      //    tDet.m_totPlanSetup      := tDet.m_SetupTimeStep;  // avi not in used ???
      //    tDet.m_totPlanExeTime    := tDet.m_ExeTimeStep;
      //    tDet.m_VisbleInBin       := CSB_NotVisible;
          tDet.m_OfThisWrkst       := false;
          tDet.m_PlanWrkCtrPtr := p_pl.FindWrkCtrByCode(tDet.m_planWkctr);
        end;

        if tDet.m_OfThisWrkst then
        begin
          next;
          continue
        end;

        tJob := tDet.FindJobFromCode(0,0);
        if not Assigned(tJob) then
          tJob := AddJobDet(tDet, 0, CSnoGroupDef);

        tJob.m_VisbleInBin    := CSB_NotVisible;
        tJob.m_fromPD         := true;
        tJob.m_status         := CSS_none;
        tJob.m_subLinRscId    := 0;
        tJob.p_schedStart     := tDet.m_planStart;
        tJob.p_schedEnd       := tDet.m_planEnd;
        tJob.m_srvPtr         := nil;
        tJob.p_rscCode        := '';
//sav1        tJob.m_OnPlan         := false;
        tJob.m_reprocNo       := 0;
//sav1        tJob.m_Group          := 0;
        tJob.p_SetStepType      := '0';
        tJob.m_comment        := '';

        tJob.p_WorkCenter     := '';
        tJob.p_Process        := '';

        tJob.p_quantSched     := tDet.m_quantInit;
        tJob.p_exeMin         := 0;
        tJob.p_supMinBase     := 0;
        tJob.p_supMinReal     := 0;
        tJob.p_supMinOvlp     := 0;
        tJob.m_fwdConnSubStp  := -2;
        tJob.m_fwdConnReProcs := -2;
        tJob.m_bkwConnSubStp  := -2;
        tJob.m_bkwConnReProcs := -2;
        tJob.m_PrgSt          := 0;
        tJob.m_PrgCurDt       := 0;
        tJob.m_PrgEd          := 0;
        tJob.m_PrgQty         := 0;
        tJob.m_PrgStartingQty := 0;
        tJob.m_PrgRemTime     := -1;
        tJob.m_ProgType       := '';
        tJob.m_PrgStHost      := 0;
        tJob.m_PrgCurDtHost   := 0;
        tJob.m_PrgEdHost      := 0;
        tJob.m_PrgQtyHost     := 0;
        tJob.m_PrgRemTimeHost := -1;
        tJob.m_ProgTypeHost   := '';
        tJob.p_NewSetup  := -1;
      end;
      Next
    end
  end;

  if Assigned(tHdr) then tHdr.m_list.Sort(StepOrderGrowing);

  qry.Close;

  with qry do
  begin
    SQL.Clear;
    SQL.Add('select * ');
    SQL.Add(' from ' + tbiSP.GetTableName + ' where ' + CreateFld(tbiSP.pfx, fli_preqNo) + '=''' + ProdReqNo + '''');
    SQL.Add(AND_IDF_Condition(CreateFld(tbiSP.pfx, fli_Identifier)));
    open;

    tHdr := FindHdrFromCode(self, ProdReqNo);
    if Assigned(tHdr) then
      while not EOF do
      begin
        tDet := tHdr.FindDetFromCode(fieldByName(CreateFld(tbiSP.pfx,fli_pstepId)).AsInteger);
        if tDet.m_OfThisWrkst then
        begin
          next;     // avi
          continue;
        end;

        tjob := tDet.FindJobFromCode(fieldByName(CreateFld(tbiSP.pfx,fli_psubstId)).AsInteger, fieldByName(CreateFld(tbiSP.pfx,fli_reprocNo)).AsInteger);
        if tjob = nil then
        begin
          next;     // avi2
          continue;
        end;

        tJob.m_PrgSt          := fieldByName(CreateFld(tbiSP.pfx,fli_progrStart)).AsDateTime;
        tJob.m_PrgCurDt       := fieldByName(CreateFld(tbiSP.pfx,fli_prgCurrDate)).AsDateTime;
        tJob.m_PrgEd          := fieldByName(CreateFld(tbiSP.pfx,fli_progrEnd)).AsDateTime;
        tJob.m_PrgQty         := fieldByName(CreateFld(tbiSP.pfx,fli_quant)).AsFloat;
        tJob.m_PrgStartingQty := fieldByName(CreateFld(tbiSP.pfx,fli_StartingQty)).AsFloat;
        tJob.m_PrgRemTime     := fieldByName(CreateFld(tbiSP.pfx,fli_prgRemTime)).AsFloat;
        tJob.m_ProgType       := fieldByName(CreateFld(tbiSP.pfx,fli_ProgressType)).AsString;
        tJob.m_ProgTypeHost   := fieldByName(CreateFld(tbiSP.pfx,fli_ProgressTypeHost)).AsString;
        tJob.m_PrgStHost      := fieldByName(CreateFld(tbiSP.pfx,fli_progrStartHost)).AsDateTime;
        tJob.m_PrgCurDtHost   := fieldByName(CreateFld(tbiSP.pfx,fli_prgCurrDateHost)).AsDateTime;
        tJob.m_PrgEdHost      := fieldByName(CreateFld(tbiSP.pfx,fli_progrEndHost)).AsDateTime;
        tJob.m_PrgQtyHost     := fieldByName(CreateFld(tbiSP.pfx,fli_quantHost)).AsFloat;
        tJob.m_PrgRemTimeHost := fieldByName(CreateFld(tbiSP.pfx,fli_prgRemTimeHost)).AsFloat;
        next;
      end;
  end;

  except
    showmessage(' Problem in Loading chain: ' + _('Request:') + ' ' + tHdr.m_code);
  end;

  qry.Close;

end;

