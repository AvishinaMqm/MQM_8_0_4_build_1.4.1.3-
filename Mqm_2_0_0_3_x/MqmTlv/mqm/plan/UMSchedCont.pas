function TMSchedCont.ReprocJob(id: TSchedID; ReprocQty: currency): TSchedID;
var
  sc:  TSCSchedOnPlan;
  tJob, NewJob: TSCProdSched;
  tDet: TSCProdReqDet;
  i, LastReproc: integer;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);

//  Assert(sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  tjob := TSCProdSched(sc);
  tDet := tJob.m_reqDet;

  LastReproc := -1;
  for i := 0 to tDet.m_list.Count-1 do
  begin
    NewJob := tDet.m_list[i];
    if (tJob.m_code = NewJob.m_code) and (LastReproc < NewJob.m_reprocNo) then
      LastReproc := NewJob.m_reprocNo;
  end;

  NewJob := TSCProdSched(AddJobDet(tDet, tJob.m_code, CSnoGroupDef));

  NewJob.p_quantSched     := ReprocQty;
  NewJob.m_fromPD         := false;
  NewJob.m_status         := CSS_new;
  NewJob.m_subLinRscId    := 0;
  NewJob.m_srvPtr         := nil;
  NewJob.m_reprocNo       := LastReproc+1;
  NewJob.p_SetStepType    := '0';
  NewJob.m_comment        := '';
  NewJob.p_WorkCenter     := '';
  NewJob.p_Process        := '';
  NewJob.p_exeMin         := 0;
  NewJob.p_supMinBase     := 0;
  NewJob.p_supMinReal     := 0;
  NewJob.p_supMinOvlp     := 0;
  NewJob.m_fwdConnSubStp  := -2;
  NewJob.m_fwdConnReProcs := -2;
  NewJob.m_bkwConnSubStp  := -2;
  NewJob.m_bkwConnReProcs := -2;
  NewJob.p_NewSetup := -1;
  NewJob.m_PrgSt          := 0;
  NewJob.m_PrgCurDt       := 0;
  NewJob.m_PrgEd          := 0;
  NewJob.m_PrgQty         := 0;
  NewJob.m_PrgStartingQty := 0;
  NewJob.m_PrgRemTime     := -1;
  NewJob.m_ProgType       := '';
  NewJob.m_ProgRsc        := '';
  NewJob.m_PrgStHost      := 0;
  NewJob.m_PrgCurDtHost   := 0;
  NewJob.m_PrgEdHost      := 0;
  NewJob.m_PrgQtyHost     := 0;
  NewJob.m_PrgRemTimeHost := -1;
  NewJob.m_ProgTypeHost   := '';
  NewJob.p_quantManualChg := 0;
  Result := NewJob.m_Id;

end;

