procedure TMSchedCont.JoinJobs(id: TSchedID; JobsList: TList);
var
  sc, scToDel:  TSCSchedOnPlan;
  tJob, tJobToDel: TSCProdSched;
  i: integer;
  SavemanualJobChange, SavemanualJobsListChange:  double;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  tjob := TSCProdSched(sc);

  for i := 0 to JobsList.Count-1 do
  begin
    SavemanualJobsListChange := 0;
    SavemanualJobChange := 0;

    scToDel := TSCSchedOnPlan(m_codeList[TSchedID(JobsList[i])]);
    //Assert(scToDel is TSCProdSched);
    if not (scToDel is TSCProdSched) then Exit;
    tJobToDel := TSCProdSched(scToDel);

    GetManualChange(id,SavemanualJobChange);
    GetManualChange(TSchedID(JobsList[i]),SavemanualJobsListChange);

    SetManualChange(id,0);
    SetManualChange(TSchedID(JobsList[i]),0);

    tjob.p_quantSched := tjob.p_quantSched + tJobToDel.p_quantSched;

    SetManualChange(id,SavemanualJobChange + SavemanualJobsListChange);
    SetManualChange(TSchedID(JobsList[i]),SavemanualJobsListChange);
    ClearSchedObj(TSchedID(JobsList[i]), 'JoinJobs - merged into another job')
  end;

end;

