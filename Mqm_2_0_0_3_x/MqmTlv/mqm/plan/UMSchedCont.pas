function FindPropertyValue(ItemType : string; ProductCode : string; var Index : integer; ProductPropertyList : TList) : PProductProperties;
var
  i: integer;
  Multiplier, NumberOfEntries, NumberOfEntriesMinusOne : integer;
begin
  Result := nil;
  NumberOfEntries := ProductPropertyList.Count;
  Index := NumberOfEntries;

  if NumberOfEntries = 0 then exit;
  NumberOfEntriesMinusOne := NumberOfEntries - 1;

  Multiplier := 1;
  while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
    i := Multiplier - 1;

  while (Multiplier > 0) do
  begin
    Multiplier := trunc(Multiplier / 2);

    if (i > NumberOfEntriesMinusOne) then
    begin
      i := i - Multiplier;
      Continue;
    end;

    if (PProductProperties(ProductPropertyList[i]).Item > ItemType) then
    begin
      if I < Index then Index := I;
      i := i - Multiplier;
      Continue;
    end;

    if  (PProductProperties(ProductPropertyList[i]).Item < ItemType) then
    begin
      i := i + Multiplier;
      Continue;
    end;

    if  (PProductProperties(ProductPropertyList[i]).Product > ProductCode) then
    begin
      if I < Index then Index := I;
      i := i - Multiplier;
      Continue;
    end;

    if  (PProductProperties(ProductPropertyList[i]).Product < ProductCode) then
    begin
      i := i + Multiplier;
      Continue;
    end;

    Result := PProductProperties(ProductPropertyList[i]);
    Index := i;
    Break;

  end;

end;

