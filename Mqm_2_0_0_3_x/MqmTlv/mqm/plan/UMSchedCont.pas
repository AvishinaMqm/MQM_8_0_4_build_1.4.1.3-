    SQL.Add('order by ');
    SQL.Add('PP.' + CreateFld(tbInfoProp.pfx, fli_preqNo)  + ',');
    SQL.Add('PP.' + CreateFld(tbInfoProp.pfx, fli_PropertyCode)  + ',');
    SQL.Add('PP.' + CreateFld(tbInfoProp.pfx, fli_rsc));
