procedure TMSchedCont.AutoSeqCheckMoveServingGroupJobsToCorrectPlace(id: TSchedId);
var
  tHdr: TSCProdReqHdr;
  tJob:  TSCProdSched;
  ps : TSCSchedOnPlan;
  scG : TSCProdGroup;
  I,J,H : Integer;
begin
  ps := TSCSchedOnPlan(m_codeList[id]);
  if ps is TSCProdGroup then
  begin
    scG := TSCProdGroup(m_codeList[id]);
    for I := 0 to scG.m_list.Count - 1 do
      AutoSeqCheckMoveServingGroupJobsToCorrectPlace(TSCProdSched(scG.m_list[I]).m_Id);
  end
  else if ps is TSCProdSched then
  begin
    tJob := TSCProdSched(m_codeList[id]);
    if (tJob.m_reqDet.m_hdr.m_ServingCode <> '') and Assigned(tJob.m_reqDet.m_hdr.m_ServingCodeHdrList) then
    begin
      for J := 0 to tJob.m_reqDet.m_hdr.m_ServingCodeHdrList.Count - 1 do
      begin
        tHdr := TSCProdReqHdr(tJob.m_reqDet.m_hdr.m_ServingCodeHdrList[J]);
        for H := 0 to tHdr.m_list.Count - 1 do
          AutoSeqMoveJobsToCorrectPlace(TSCProdReqDet(tHdr.m_list[H]));
      end;
    end;
  end;

end;

