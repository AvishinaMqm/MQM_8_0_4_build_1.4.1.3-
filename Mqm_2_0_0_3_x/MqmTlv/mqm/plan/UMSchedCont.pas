procedure TMSchedCont.ProcessQryForUpdate(qry: TMqmQuery; fUpdate: TUpdLinkJobFunc; ptr: pointer; ProgBar: TMqmProgBar);
var
  tbiPS:   ^TTblInfo;
  hdrCode: string;
  detCode: integer;
  jobCode: integer;
  ReprocNo: integer;
  id:      TSchedID;
  grpCode: integer;
  scProd:  TSCProdSched;
  scGroup: TSCProdGroup;
  cdRsc:   string;
  IsHeaderDetFound : boolean;
  hdr: TSCProdReqHdr;
  tdet: TSCProdReqDet;
  tjob: TSCProdSched;
  actArea : TMqmActArea;
  Group_id    : TSchedId;
begin
  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);

  tbiPS := @tblInfo[tbl_prod_sched];
  qry.Open;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(qry.RecordCount);

  with qry do
  begin
    while not EOF do
    begin
      Application.ProcessMessages;
      if Assigned(ProgBar) then
        ProgBar.SetPosition(qry.RecNo);

      hdrCode := FieldByName(CreateFld(tbiPS.pfx, fli_preqNo)).AsString;
      detCode := FieldByName(CreateFld(tbiPS.pfx, fli_pstepId)).AsInteger;
      jobCode := FieldByName(CreateFld(tbiPS.pfx, fli_psubstId)).AsInteger;
      ReprocNo := FieldByName(CreateFld(tbiPS.pfx, fli_reprocNo)).AsInteger;

      id := FindProdSched(hdrCode, detCode, jobCode, ReprocNo, IsHeaderDetFound);

      if FieldByName('PS_TYPEUSED').IsNull and (FieldByName('PD_TYPEUSED').AsString = '1')
      and (id <> CSchedIdNull) and (GetVisbleInBin(id) <> CSB_ReadOnly) then
      begin
        Next;
        continue;
      end;

      if (not FieldByName('PS_TYPEUSED').IsNull)and (FieldByName('PS_TYPEUSED').AsString = '1')
      and (id <> CSchedIdNull) and (GetVisbleInBin(id) <> CSB_ReadOnly) then
      begin
        Next;
        continue;
      end;

      if (id = CSchedIdNull) and IsHeaderDetFound then
      begin
        hdr := FindHdrFromCode(self, hdrCode);
        if not Assigned(hdr) then
        begin
          Next;
          continue
        end;

        tdet := hdr.FindDetFromCode(detCode);
        if not Assigned(tdet) then
        begin
          Next;
          continue
        end;
//        tJob := CreateNewJob(tDet, TSCProdSched(tDet.m_list[tDet.m_list.count-1]).m_code+1, CSnoGroupDef);
        tJob := CreateNewJob(tDet, GetNewSubStep(tDet), CSnoGroupDef);
        tJob.m_VisbleInBin    := TSCProdSched(tDet.m_list[0]).m_VisbleInBin;
        id := FindProdSched(hdrCode, detCode, jobCode, ReprocNo, IsHeaderDetFound);
      end;

      if id <> CSchedIdNull then
      begin

        scProd := TSCProdSched(m_codeList[id]);

        scProd.m_fromPD := false;
        scProd.m_status := CSS_none;

        // update the not critical fields
        scProd.p_schedStart     := FieldByName(CreateFld(tbiPS.pfx, fli_schedStart)).AsDateTime;
        scProd.p_schedEnd       := FieldByName(CreateFld(tbiPS.pfx, fli_schedEnd)).AsDateTime;
        scProd.p_LastScheudleChange := FieldByName(CreateFld(tbiPS.pfx, fli_LastScheudleChange)).AsDateTime;
        scProd.p_exeMin         := FieldByName(CreateFld(tbiPS.pfx, fli_exeMin)).AsFloat;
        scProd.m_subLinRscId    := FieldByName(CreateFld(tbiPS.pfx, fli_subLinRscId)).AsInteger;
        scProd.m_reprocNo       := FieldByName(CreateFld(tbiPS.pfx, fli_reprocNo)).AsInteger;
        scProd.m_comment        := FieldByName(CreateFld(tbiPS.pfx, fli_Comment)).AsString;
//        scProd.m_SchedwkCtrCode := FieldByName(CreateFld(tbiPS.pfx, fli_SchedwkCtrCode)).AsString;
//        scProd.m_SchedwkcProc   := FieldByName(CreateFld(tbiPS.pfx, fli_SchedWCProcess)).AsString;
        scProd.p_quantSched     := FieldByName(CreateFld(tbiPS.pfx, fli_quant)).AsFloat;
        scProd.p_supMinBase     := FieldByName(CreateFld(tbiPS.pfx, fli_supMinBase)).AsFloat;
        scProd.p_supMinReal     := FieldByName(CreateFld(tbiPS.pfx, fli_supMinReal)).AsFloat;
        scProd.p_supMinOvlp     := FieldByName(CreateFld(tbiPS.pfx, fli_supMinOvlp)).AsFloat;
        scProd.m_numOfRscComp   := FieldByName(CreateFld(tbiPS.pfx, fli_NumSubRscComponents)).AsInteger;
        scProd.m_fwdConnSubStp  := FieldByName(CreateFld(tbiPS.pfx, fli_ConnForwardSubStep)).AsInteger;
        scProd.m_fwdConnReProcs := FieldByName(CreateFld(tbiPS.pfx, fli_ConnForwardReProcess)).AsInteger;
        scProd.m_bkwConnSubStp  := FieldByName(CreateFld(tbiPS.pfx, fli_ConnBackwardSubStep)).AsInteger;
        scProd.m_bkwConnReProcs := FieldByName(CreateFld(tbiPS.pfx, fli_ConnBackwardReProcess)).AsInteger;
//        scProd.m_TimeDescr      := FieldByName(CreateFld(tbiPS.pfx, fli_TimeDescr)).AsString;
        scProd.m_MachSetupCode  := '';//FieldByName(CreateFld(tbiPS.pfx, fli_MachSetupCode)).AsString;
        scProd.p_SetStepType    := FieldByName(CreateFld(tbiPS.pfx, fli_schedType)).AsString;
        scProd.m_GroupAutomaticInternalSortingSequence := FieldByName(CreateFld(tbiPS.pfx, fli_GroupInternalSortSeq)).AsInteger;

        if not (FieldByName(CreateFld(tbiPS.pfx, fli_GrpContinueSeq)).IsNull) then
          scProd.P_Grp_Sequence := Trim(FieldByName(CreateFld(tbiPS.pfx, fli_GrpContinueSeq)).AsString);

        if (scProd.m_VisbleInBin = CSB_ReadOnly) and not FieldByName(CreateFld(tbiPS.pfx, fli_wkCtrCode)).IsNull and
           (scProd.p_WorkCenter <> FieldByName(CreateFld(tbiPS.pfx, fli_wkCtrCode)).AsString) then
        begin
          scProd.p_WorkCenter := FieldByName(CreateFld(tbiPS.pfx, fli_wkCtrCode)).AsString;
          scProd.p_WrkCtrPtr  := TMqmWrkCtr(p_pl.FindWrkCtrByCode(scProd.p_WorkCenter));
          if assigned(scProd.p_WrkCtrPtr) and not TMqmWrkCtr(scProd.p_WrkCtrPtr).p_ReadOnly then
             scProd.m_VisbleInBin := CSB_Normal
        end;
        {if (scProd.m_ProgressOverride = Prg_NotIgnored) and (FieldByName(CreateFld(tbiPS.pfx, fli_Prog_Override_Type)).AsString = '1') then
        begin
          SetProgressStatus(scProd.m_Id,true,fUpdate, Prg_NotIgnored);
          scProd.m_ProgressOverride := Prg_IgnoredAndSave
        end; }
        grpCode := FieldByName(CreateFld(tbiPS.pfx, fli_stGroup)).AsInteger;
        cdRsc := trim(FieldByName(CreateFld(tbiPS.pfx, fli_rsc)).AsString);
        if grpCode = CSnoGroupDef then  //if now the job is not in a group
        begin
          if Assigned(scProd.m_grp) then //if the job was in a group
          begin
            if p_sc.GetGrpNumSons(scProd.m_grp.m_Id) = 1 then
            begin
              Group_id := scProd.m_grp.m_Id;
              if Assigned(p_sc.GetExtLinkPtr(Group_id)) then
              begin
                actArea := TMqmActArea(p_sc.GetExtLinkPtr(Group_id));
                actArea.RemoveSchedObj(Group_id);
              end;
              RemoveJobFromGroup(scProd.m_id, 'Group removed by server update');
              DeleteGroup(Group_id);
            end
            else
              RemoveJobFromGroup(id, 'Group removed by server update');
          end;

        //  cdRsc := FieldByName(CreateFld(tbiPS.pfx, fli_rsc)).AsString;
          if cdRsc <> scProd.p_rscCode then
          begin
            scProd.p_rscCode := cdRsc;
            fUpdate(scProd.p_rscCode, scProd.m_Id, ptr)
          end;
        end
        else
        begin

          if Assigned(scProd.m_grp) then
          begin
            if grpCode <> scProd.m_grp.m_code then
            begin
              if p_sc.GetGrpNumSons(scProd.m_grp.m_Id) = 1 then
              begin
                Group_id := scProd.m_grp.m_Id;
                if Assigned(p_sc.GetExtLinkPtr(Group_id)) then
                begin
                  actArea := TMqmActArea(p_sc.GetExtLinkPtr(Group_id));
                  actArea.RemoveSchedObj(Group_id);
                end;
                RemoveJobFromGroup(scProd.m_id, 'Group changed by server update');
                DeleteGroup(Group_id);
              end
              else
                RemoveJobFromGroup(id, 'Group changed by server update');
             // RemoveJobFromGroup(scProd.m_grp.m_code);
              scGroup := FindGroupFromCode(self, grpCode);
              if Assigned(scGroup) then
                AddJobToGroup(id, scGroup.m_Id)
              else
                CreateGroupWithCode(id, grpCode)
            end
            else
            begin
              if cdRsc <> scProd.p_rscCode then
              begin
                scGroup := FindGroupFromCode(self, grpCode);
                if Assigned(scGroup) then
                begin
                  scProd.p_rscCode := cdRsc;
                  fUpdate(scProd.p_rscCode, scGroup.m_Id, ptr)
                end;
              end;
            end;
          end
          else
          begin
            scGroup := FindGroupFromCode(self, grpCode);
            if Assigned(scGroup) then
            begin
              AddJobToGroup(id, scGroup.m_Id);
              if cdRsc <> scProd.p_rscCode then
                scProd.p_rscCode := cdRsc;
            end
            else
            begin
              Group_id := CreateGroupWithCode(id, grpCode);
              if (cdRsc <> '') and (Group_id <> CSchedIdNull) then
              begin
                scProd.p_rscCode := cdRsc;
                fUpdate(scProd.p_rscCode, Group_id, ptr)
              end;
            end;
          end;

////////// OLD
{
          if Assigned(scProd.m_grp) and (grpCode <> scProd.m_grp.m_code) then
            RemoveJobFromGroup(scProd.m_grp.m_code);

          scGroup := FindGroupFromCode(self, grpCode);
          if Assigned(scGroup) then
            AddJobToGroup(id, scGroup.m_Id)
          else
            CreateGroupWithCode(id, grpCode)
}
        end;
        SetOvlpUpdate(id, true);
      end;
      Next
    end
  end;

end;

