function TMSchedCont.ToBeSched(id: TSchedID; ErrList: TStrings): CScToBeSched;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  i: integer;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  Result := CSX_Yes;

  if sc is TSCProdGroup then
  begin
    for i := 0 to TSCProdGroup(sc).m_list.Count-1 do
    begin
      job := TSCProdSched(TSCProdGroup(sc).m_list[i]);
      if Result > job.m_reqDet.ToBeSched(ErrList) then
        Result := job.m_reqDet.ToBeSched(ErrList);
    end
  end else
  begin
    job := TSCProdSched(sc);
    Result := job.m_reqDet.ToBeSched(ErrList);
  end;
end;

