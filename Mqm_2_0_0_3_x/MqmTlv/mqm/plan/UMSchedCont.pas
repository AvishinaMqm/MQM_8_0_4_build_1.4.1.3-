function TMSchedCont.IsMoved(id: TSchedID): CMoved;
var
  sc: TSCSchedOnPlan;
  BkPlanInfo: PTSQplanInfo;
  planInfo: TSQplanInfo;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  Result := mov_none;

  if Assigned(sc.m_MoveOp) then
  begin
    BkPlanInfo := p_opStack.GetBkInfo(sc.m_MoveOp);
    if Assigned(BkPlanInfo) then
    begin
      p_sc.GetPlanInfo(id, planInfo);
      if planInfo.startDate < BkPlanInfo.startDate then
        Result := mov_left
      else if planInfo.startDate > BkPlanInfo.startDate then
        Result := mov_right
    end;
  end;
end;

