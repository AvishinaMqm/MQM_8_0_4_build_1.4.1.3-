           Sql.Add(' on  ' + CreateFld(tbiPD.pfx, fli_SchedulByMcm) + '=' + QuotedStr('1'))
        else
           Sql.Add(' on  ' + CreateFld(tbiPD.pfx, fli_SchedulByMqm) + '=' + QuotedStr('1'));
        Sql.Add(' and ' + CreateFld(tbiPD.pfx, fli_Identifier) + '=' + CreateFld(tbiPH.pfx, fli_Identifier));
        Sql.Add(' and ' + CreateFld(tbiPD.pfx, fli_preqNo) + '=' + CreateFld(tbiPH.pfx, fli_preqNo));
        Sql.Add(' and ' + CreateFld(tbiPD.pfx, fli_pstepId) + '=' + CreateFld(tbiCR.pfx, fli_pstepId));
        Sql.Add(' inner join ' + tbiWW.GetTableName);
        Sql.Add(' on  ' + CreateFld(tbiWW.pfx, fli_wkstCode) + '=' + QuotedStr(IniAppGlobals.WkstCode));
        Sql.Add(' and ' + CreateFld(tbiWW.pfx, fli_wkCtrCode) + '=' + CreateFld(tbiPD.pfx, fli_wkCtrCode));
        Sql.Add(' and ' + CreateFld(tbiWW.pfx, fli_Identifier) + '=' + CreateFld(tbiPD.pfx, fli_Identifier));
        SQL.Add(WHERE_IDF_Condition(CreateFld(tbiPH.pfx, fli_Identifier)));
        Sql.Add(' order by ');
        Sql.Add(CreateFld(tbiPD.pfx, fli_preqNo)  + ',');
        Sql.Add(CreateFld(tbiPD.pfx, fli_pstepId));
        Prepare;
        FetchOptions.RowsetSize := 5000;
        Open;
        Application.ProcessMessages;
        // Cache TField pointers once after Open
        fPH_preqNo                       := FieldByName(CreateFld(tbiPH.pfx, fli_preqno));
        fPH_ModulHandled                 := FieldByName(CreateFld(tbiPH.pfx, fli_ModulHandled));
        fPD_pstepId                      := FieldByName(CreateFld(tbiPD.pfx, fli_pstepid));
        fPD_prevStepSched_Mcm            := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mcm));
        fPD_NextStepSched_Mcm            := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mcm));
        fPD_prevStepSched_Mqm            := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepSched_Mqm));
        fPD_NextStepSched_Mqm            := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepSched_Mqm));
        fPD_prevStepTrue                 := FieldByName(CreateFld(tbiPD.pfx, fli_prevStepTrue));
        fPD_NextStepTrue                 := FieldByName(CreateFld(tbiPD.pfx, fli_NextStepTrue));
        fPD_MaterialArrivDate            := FieldByName(CreateFld(tbiPD.pfx, fli_MaterialArrivDate));
        fPD_planStart                    := FieldByName(CreateFld(tbiPD.pfx, fli_planStart));
        fPD_planEnd                      := FieldByName(CreateFld(tbiPD.pfx, fli_planEnd));
        fPD_InitialPlanScheduledDateTime := FieldByName(CreateFld(tbiPD.pfx, fli_InitialPlanScheduledDateTime));
        fPD_LowStartTimeLimit            := FieldByName(CreateFld(tbiPD.pfx, fli_LowStartTimeLimit));
        fPD_finalPlanScheduledDateTime   := FieldByName(CreateFld(tbiPD.pfx, fli_finalPlanScheduledDateTime));
        fPD_HighEndTimeLimit             := FieldByName(CreateFld(tbiPD.pfx, fli_HighEndTimeLimit));
        fPD_ApprovalDate                 := FieldByName(CreateFld(tbiPD.pfx, fli_ApprovalDate));
        fPD_CalCod                       := FieldByName(CreateFld(tbiPD.pfx, fli_CalCod));
        fPD_quantInit                    := FieldByName(CreateFld(tbiPD.pfx, fli_quantInit));
        fPD_quantFinl                    := FieldByName(CreateFld(tbiPD.pfx, fli_quantFinl));
        fPD_alternative_Qty              := FieldByName(CreateFld(tbiPD.pfx, fli_alternative_Qty));
        fPD_alternative_UM               := FieldByName(CreateFld(tbiPD.pfx, fli_alternative_UM));
        fPD_Weight                       := FieldByName(CreateFld(tbiPD.pfx, fli_Weight));
        fPD_DescUM                       := FieldByName(CreateFld(tbiPD.pfx, fli_DescUM));
        fPD_wkCtrCode                    := FieldByName(CreateFld(tbiPD.pfx, fli_wkCtrCode));
        fPD_wkcProc                      := FieldByName(CreateFld(tbiPD.pfx, fli_wkcProc));
        fPD_StepCanGroup                 := FieldByName(CreateFld(tbiPD.pfx, fli_StepCanGroup));
        fPD_OverlapWithOtherSteps        := FieldByName(CreateFld(tbiPD.pfx, fli_OverlapWithOtherSteps));
        fPD_AllowSplit                   := FieldByName(CreateFld(tbiPD.pfx, fli_AllowSplit));
        fPD_LearningCurveType            := FieldByName(CreateFld(tbiPD.pfx, fli_LearningCurveType));
        fPD_FrcMatDate                   := FieldByName(CreateFld(tbiPD.pfx, fli_FrcMatDate));
        fPD_FrcLowestDate                := FieldByName(CreateFld(tbiPD.pfx, fli_FrcLowestDate));
        fPD_StepType                     := FieldByName(CreateFld(tbiPD.pfx, fli_StepType));
        fPD_FrcHighestDate               := FieldByName(CreateFld(tbiPD.pfx, fli_FrcHighestDate));
        fPD_FrcOverlapp                  := FieldByName(CreateFld(tbiPD.pfx, fli_FrcOverlapp));
        fPD_StepClosed                   := FieldByName(CreateFld(tbiPD.pfx, fli_StepClosed));
