        LoadBchUm(false, qry, nil , nil, PrevUpdatNr, m_WorkCentersHandledList, m_WorkCentersViewedList, ChangedReqInClause);

        PrevRequest := '';
        NewRequestExist := false;
        HistoricalRequestExist := false;
        HeaderFieldChangeExist := false;
        HeaderPropertyChangeExist := false;
        HeaderCosmeticChangeExist := false;
        NewStepExist := false;
        StepFieldChangeExist := false;
        StepPropertyChangeExist := false;
        StepCosmeticChangeExist := false;
      end;

      PrevUpdatNr := Rec.DwnNr;

      if  (Rec.Step = 0)
      and (Rec.ChangeType = '2') then NewRequestExist := true;
      if  (Rec.Step = 0)
      and (Rec.ChangeType = '3') then HistoricalRequestExist := true;
      if  (Rec.Step = 0)
      and (Rec.ChangeType = '5') then HeaderFieldChangeExist := true;
      if  (Rec.Step = 0)
      and (Rec.ChangeType = '6') then HeaderPropertyChangeExist := true;
      if  (Rec.Step = 0)
      and (Rec.ChangeType = '7') then HeaderCosmeticChangeExist := true;
      if  (Rec.Step > 0)
      and (Rec.ChangeType = '2') then NewStepExist := true;
      if  (Rec.Step > 0)
      and (Rec.ChangeType = '4') then StepFieldChangeExist := true;
      if  (Rec.Step > 0)
      and (Rec.ChangeType = '5') then StepPropertyChangeExist := true;
      if  (Rec.Step > 0)
      and (Rec.ChangeType = '6') then StepCosmeticChangeExist := true;

      // When not new request, Delete on request level its properties, materials and batch size
//      if (Rec.Step = 0) and (Rec.ChangeType <> '2') then
      if PrevRequest <> Rec.ReqNo then
      begin
        PrevRequest := Rec.ReqNo;
        tHdr := FindHdrFromCode(self, Rec.ReqNo);
        if Assigned(tHdr) then
        begin
          tHdr.m_ProdArtList.CleanList;
          for H_r := 0 to tHdr.m_list.Count - 1 do
          begin
            tDet := TSCProdReqDet(tHdr.m_list[H_r]);
            for Index := 0 to tDet.m_StepTimeList.Count - 1 do
              Dispose(PTRecTiming(tDet.m_StepTimeList[Index]));
            tDet.m_StepTimeList.Clear;
            tDet.m_propList.DeletAllNonPlannerProperties(true);
            for P_d := tDet.m_MacSetupList.p_count - 1 downto 0 do
              TMQMMachineSetup(tDet.m_MacSetupList.p_Item[P_d]).Clear;
            tDet.m_BchUMList.Clear;
          end;
        end;
      end;

      // Delete Request
      if (Rec.Step = 0) and (Rec.ChangeType = '4') then
      begin
        tHdr := nil;
        tHdr := FindHdrFromCode(self, Rec.ReqNo);
        if Assigned(tHdr) then
          UnscheduleAllStepsReqForDataChange(tHdr , true, true, DispoList);
      end;

      // Delete step
      if (Rec.Step > 0) and (Rec.ChangeType = '3') then
      begin
        tHdr := nil;
        hdrCode := Rec.ReqNo;
        tHdr := FindHdrFromCode(self, hdrCode);
        if Assigned(tHdr) then
          UnscheduleStepForDataChange(tHdr, Rec.Step, 3, true, true, false, DispoList,fLoad);
      end;

      // OnlyProgressTime
      if (Rec.Step > 0) and (Rec.ChangeType = '7') then
      begin
        tHdr := nil;
        tHdr := FindHdrFromCode(self, Rec.ReqNo);
        if Assigned(tHdr) then
          DispoList.Add(_('Progress and times refreshed for request:') + ' ' + Rec.ReqNo + ' ' + _('Step:') + ' ' + IntToStr(Rec.Step));
      end;

    end;
  end;

  if Changed_Req_List.Count > 0 then
  begin
    if NewRequestExist then InsertNewRequest(Qry,findWc,PrevUpdatNr, DispoList);
    if HistoricalRequestExist then UpdateHistoricalRequest(Qry, PrevUpdatNr, DispoList);
    if HeaderFieldChangeExist then RefreshRequestHeader(Qry, '5', PrevUpdatNr, true, DispoList);
    if HeaderPropertyChangeExist then RefreshRequestHeader(Qry, '6', PrevUpdatNr, false, DispoList);
    if HeaderCosmeticChangeExist then RefreshRequestHeader(Qry, '7', PrevUpdatNr, false, DispoList);
    if NewStepExist then InsertNewStep(Qry, PrevUpdatNr, findWc,DispoList);
    if StepFieldChangeExist then StepRefresh('4', PrevUpdatNr, DispoList);
    if StepPropertyChangeExist then StepRefresh('5', PrevUpdatNr, DispoList);
    if StepCosmeticChangeExist then StepRefresh('6', PrevUpdatNr, DispoList);
//    InsertProperties(Qry,PrevUpdatNr,DispoList);
    LoadStepTimes(false, qry, nil, nil, nil, PrevUpdatNr, m_WorkCentersHandledList, m_WorkCentersViewedList, ChangedReqInClause);
    LoadJobProperties(false, qry, nil, nil, nil, PrevUpdatNr, m_WorkCentersHandledList, m_WorkCentersViewedList, ChangedReqInClause);
    RefreshStepProgressTime(Qry, PrevUpdatNr,  '', 0);
    LoadIssuedMaterials(false, qry, nil , nil, DispoList, PrevUpdatNr, m_WorkCentersHandledList, m_WorkCentersViewedList, ChangedReqInClause);
    LoadProdArt(false, qry, nil , nil, DispoList, PrevUpdatNr, m_WorkCentersHandledList, m_WorkCentersViewedList, ChangedReqInClause);
    LoadBchUm(false, qry, nil , nil, PrevUpdatNr, m_WorkCentersHandledList, m_WorkCentersViewedList, ChangedReqInClause);
  end;

  DeletedNotNeededJobs;
  ReLinkRequests(ProgBar);
  LinkRequests(ProgBar, nil);

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);

  RefreshStockDetails(qry,ProgBar);
  if DBAppGlobals.WarpCngClientUpdate or DBAppGlobals.WarpOnlyCngClientUpdate then
  begin
    DispoList.add(_('Warp data was refreshed ...'));
    LoadMaterialSched(false, qry, ProgBar, nil, nil);
    DBAppGlobals.WarpCngClientUpdate := false;
    DBAppGlobals.WarpOnlyCngClientUpdate := false;
  end;

  qry.Close;

  try
    LoadNewSplitRequets(nil);
    FindJobsToGroupByProcessPropertyRules(true, nil, nil); // add to group by process
    UpdateBalanceForAllJobs(ProgBar,nil);  //Update the warehouses balance
  except
    //ShowMessage(_('An error occured while refreshing Balance.  Please Reopen mqm program to be updated'))
  end;

  if (Changed_Req_List.Count > 0) then
  begin
    for I := 0 to Changed_Req_List.Count - 1 do
    begin
      if (PReqChanged(Changed_Req_List[I]).Step > 0) and (PReqChanged(Changed_Req_List[I]).ChangeType = '4') and
         PReqChanged(Changed_Req_List[I]).StepRefreshHandled then
      begin
        tHdr := FindHdrFromCode(self, PReqChanged(Changed_Req_List[I]).ReqNo);
        if assigned(tHdr) then
        begin
          tDet := tHdr.FindDetFromCode(PReqChanged(Changed_Req_List[I]).Step);
          if Assigned(tDet) then
          begin
            for p_d := 0 to tDet.m_list.Count - 1 do
            begin
              tJob := TSCProdSched(tDet.m_list[p_d]);
              tJob.m_isDeleted := true;
              tJob.m_deleteReason := 'StepRefresh - ChangeType deleted';
              DispoList.Add(_('Deleted step:') + ' ' + IntTostr(tJob.m_reqDet.m_code) + ' ,' + _('Sub step:') + ' ' + IntTostr(tJob.m_code) + ' ' + _('in Request:') + ' ' + tHdr.m_code);
            end;
            CheckIfActiveJobsExist(tDet,countRealJobs,PosFirstRealJob);
          end;
        end;
      end;
      dispose(PReqChanged(Changed_Req_List[I]));
    end;

    DBAppGlobals.LastUpdatNr := LastChange;
  end;

  SetPropListFlag(CSchedIDnull, true, true);
  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);

  Destroy_SchedContTime(false);
  for I := 0 to m_prodReqList.Count - 1 do
  begin
    if (I mod 20 = 0) then
    begin
      Application.ProcessMessages;
      if Assigned(ProgBar) then
        ProgBar.SetPosition(I);
    end;
    tHdr := TSCProdReqHdr(m_prodReqList[I]);
    for H_r := 0 to tHdr.m_list.Count - 1 do
    begin
      tDet := tHdr.m_list[H_r];
      for P_d := 0 to tDet.m_list.Count - 1 do
      begin
        tJob := TSCProdSched(tDet.m_list[P_d]);
        SetCalculatedTime(tJob.m_Id, false, CSchedIDnull);
      end;
    end;
  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);

  Changed_Req_List.free;
  ProgReqStepList.Free;


end;

