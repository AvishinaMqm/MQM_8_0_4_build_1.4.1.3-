procedure TMSchedCont.SetSharedComment(id: TSchedID; Comment : string);
var
  sc : TSCSchedOnPlan;
  Job : TSCProdSched;
  Group : TSCProdGroup;
  I : Integer;
  ChangedComment : boolean;
  LastSharedData : Integer;
begin
  ChangedComment := false;
  Group := nil;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if (sc is TSCProdSched) then
  begin
    Job := TSCProdSched(sc);
    if (trim(Job.m_SharedComment) <> trim(Comment)) then
    begin
      Job.m_SharedComment := Comment;
      ChangedComment := true
    end;
    if assigned(Job.m_grp) then
    begin
      Group := TSCProdGroup(Job.m_grp);
      if Job.m_SharedComment <> Comment then
      begin
        Group.m_SharedComment := Comment;
        ChangedComment := true
      end;
      for I := 0 to Group.m_List.Count - 1 do
        TSCProdSched(Group.m_list[I]).m_SharedComment := Comment;
    end;
  end
  else
  begin
    Group := TSCProdGroup(sc);
    if (Group.m_SharedComment <> Comment) then
    begin
      Group.m_SharedComment := Comment;
      ChangedComment := true
    end;

    for I := 0 to Group.m_List.Count - 1 do
      TSCProdSched(Group.m_list[I]).m_SharedComment := Comment;
  end;

  if ChangedComment then
  begin
    if Assigned(Group) then
    begin
      LastSharedData := GetLastSharedData;
      for I := 0 to Group.m_List.Count - 1 do
        p_pl.SaveSharedComment(TSCProdSched(Group.m_list[I]).m_Id,Comment, LastSharedData);
    end
    else
      p_pl.SaveSharedComment(Id, Comment, GetLastSharedData);
    GetPlanView.SendSharedData;
  end;

end;

