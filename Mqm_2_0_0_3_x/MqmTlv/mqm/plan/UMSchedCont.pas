function TMSchedCont.GetProperties(id: TSchedID; Father: Pointer): TProperties;
var
  sc      : TSCSchedOnPlan;
  actArea : TMqmActArea;
  WC, TempWc : TMqmWrkCtr;
  VisRes : TMqmVisibleRes;
  res    : TMqmRes;
  AWC    : TStringList;
  I : integer;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);

  if not (sc is TSCProdSched) then
  begin
    if Assigned(Father) then
      Result := m_GrpPropFunc(id, Father)
    else
    begin

      Result := m_GrpPropFunc(id, TSCProdGroup(sc).m_srvPtr);
      if (Result = nil) then
      begin
        WC := GetWrkCtrPtr(id);
        Res := TMqmRes(TMqmPlanObj(WC.p_Res[0]));
        if (Res = nil) then
        begin
          AWC := wc.GetAltWcList;
          begin
            for i := 0 to AWC.Count -1 do
            begin
              TempWc := p_pl.FindWrkCtrByCode(AWC.Strings[I]);
              if TempWc = nil then continue;
              Res := TMqmRes(TMqmPlanObj(TempWc.p_Res[0]));
              if (Res <> nil) then break;
            end;
          end;
        end;
        if (Res <> nil) then
        begin
          VisRes := res.p_VisRes[0];
          actArea := TMqmActArea(VisRes.p_ActArea[0]);
          Result := m_GrpPropFunc(id, actArea);
        end;
      end;

    end;

  end
  else
  begin
    if Assigned(TSCProdSched(sc).m_mtr) then
      result := TSCProdSched(sc).m_mtr.m_propList
    else
      Result := TSCProdSched(sc).m_reqDet.m_propList
  end;
end;

