procedure TMSchedCont.AttachSplitsToGroups;
var
  Hdr : TSCProdReqHdr;
  Job, JobG : TSCProdSched;
  det, DetG : TSCProdReqDet;
  grp : TSCProdGroup;
  I, J, k, L, M : integer;
  GroupFound : boolean;
begin

  for i := 0 to m_prodReqList.Count - 1 do
  begin
    Hdr := TSCProdReqHdr(m_prodReqList[i]);
    for J := 0 to Hdr.m_list.Count - 1 do
    begin
      det := TSCProdReqDet(Hdr.m_list[J]);
      if det.m_CanGroup <> '2' then continue;
      if det.m_forcedGrpNo >= 0 then continue;
      if TSCProdSched(det.m_list[0]).m_VisbleInBin <> CSB_Normal then continue;
      for K := 1 to det.m_list.Count - 1 do
      begin
        if Assigned(TSCProdSched(det.m_list[K]).m_grp) then continue;

        GroupFound := false; // avi

        grp := TSCProdSched(det.m_list[0]).m_grp;

        if assigned(grp) then // avi
          for L := 0 to grp.m_list.Count - 1 do
          begin
            DetG := TSCProdReqDet(TSCProdSched(grp.m_list[L]).m_reqDet);
            if DetG = det then continue;
            GroupFound := false;
            for M := 1 to DetG.m_list.Count - 1 do
            begin
              if TSCProdSched(DetG.m_list[M]).m_code <> TSCProdSched(det.m_list[K]).m_code then continue;
              if Assigned(TSCProdSched(DetG.m_list[M]).m_grp) then GroupFound := true;
              break;
            end;
            if GroupFound then break;
          end;
        if GroupFound then
          addJobToGroup(TSCProdSched(det.m_list[K]).m_Id ,TSCProdGroup(TSCProdSched(DetG.m_list[M]).m_grp).m_Id)
        else
          CreateGroup(TSCProdSched(det.m_list[K]).m_Id);   // create group
      end;
    end;
  end;
end;

