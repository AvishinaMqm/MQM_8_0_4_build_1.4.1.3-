  ///////////////////////////////////////////////////////////////////////////////
{
  procedure InsertProperties(qry: TMqmQuery; UpdateNr : integer; DispoList : TStringList);
  var
    Req, PrevReq, code, val, RscCode : string;
    j,StepId : Integer;
    FirstRow : boolean;
  begin
    tbiPP := @tblInfo[tbl_prop_prod];
    FirstRow := true;

    try

      with qry do
      begin
    //    Transaction.Active := true;
        Sql.Clear;
        Sql.Add('select');
        Sql.Add(' ' + tbiPP.GetTableName + '.*');
        Sql.Add(' from ' + tbiPP.GetTableName);
        Sql.Add(' inner join ' + tbiCR.GetTableName);
        Sql.Add(' on  ' + CreateFld(tbiCR.pfx, fli_pstepId) + '=' + '0');
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_updCode) + '=' + IntToStr(UpdateNr));
        Sql.Add(' and ' + CreateFld(tbiCR.pfx, fli_preqNo) + '=' + CreateFld(tbiPP.pfx, fli_preqNo));
        Sql.Add(' order by ');
        Sql.Add(CreateFld(tbiPP.pfx, fli_preqNo)  + ',');
        Sql.Add(CreateFld(tbiPP.pfx, fli_pstepId));
        Prepare;
        Open;
        Application.ProcessMessages;

        while not EOF do
        begin
          Application.ProcessMessages;
          Req := FieldByName(CreateFld(tbiPP.pfx, fli_preqno)).AsString;

          try

            code := FieldByName(CreateFld(tbiPP.pfx, fli_PropertyCode)).AsString;
            val :=  FieldByName(CreateFld(tbiPP.pfx, fli_PropValue)).AsString;
            StepId := FieldByName(CreateFld(tbiPP.pfx, fli_pstepId)).AsInteger;
            RscCode := trim(FieldByName(CreateFld(tbiPP.pfx, fli_Rsc)).AsString);

            if FirstRow or (Req <> PrevReq) then
              tHdr := FindHdrFromCode(self, Req);
            FirstRow := false;
            PrevReq := Req;

            if not Assigned(tHdr) then
            begin
              Next;
              Continue;
            end;

            if (StepId > 0) then
            begin
              tdet := tHdr.FindDetFromCode(StepId);
              if Assigned(tdet) then
              begin
                tdet.m_propList.AddProperty(code, RscCode, val);
                // if not tdet.m_propList.AddProperty(code, RscCode, val) then
                //  DispoList.Add(_('Request:') + ' ' + tHdr.m_code + ' ' + _('Step:') + ' ' + intToStr(tdet.m_code) + ': ' + _('Error loading property') + ' ' + code);
              end
            end
            else
            begin
              for j := 0 to thdr.m_list.Count-1 do
              begin
                tdet := tHdr.m_list[j];
                if Assigned(tdet) then
                begin
                  tdet.m_propList.AddProperty(code, RscCode, val);
                end
              end;
            end;

          except
            if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Insert Properties:') +
                ' ' + Req + '  ' + ' Technical code: UMSchedCont:InsertProperties' , mtConfirmation, [mbOk], 0) = idOk then
            begin
              next;
              continue;
            end;
          end;

          Next;
        end;
      end;

    except
      if MessageDlg(_('A sever error occured while inserting properties') + #13#10 +
         ' Technical code: UMSchedCont:InsertProperties' , mtConfirmation, [mbOk], 0) = idOk then
      begin
        qry.Close;
        Exit;
      end;
    end;

    qry.Close;

  end;
}
