procedure TMSchedCont.SetProgressStatus(id: TSchedId; fLoad: TLinkJobFunc; ReApply : boolean);
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  actArea : TMqmActArea;
  grp : TSCProdGroup;
  I : Integer;
  Cal: TPGCALObj;
  ProgInfo: TSQProgInfo;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if not (id = sc.m_Id) then Exit;

  if sc is TSCProdSched then
    job := TSCProdSched(sc)
  else
    if sc is TSCProdGroup then
    begin
      grp := TSCProdGroup(sc);
      for i := 0 to TSCProdGroup(sc).m_list.Count-1 do
      begin
        job := TSCProdSched(TSCProdGroup(sc).m_list[i]);
        SetProgressStatus(Job.m_id, fLoad,ReApply)
      end;
      exit;  // Group handled via recursive calls - do not fall through to single-job logic
    end;

  if not ReApply then
  begin
    Job.m_ProgressOverride := Prg_Ignored;
    p_sc.GetprogInfo(Id, progInfo);
    if progInfo.ProgressStatus = prg_Starting then
      Job.m_ProgressIgnoredType := Ign_Ignored_Initial
    else if progInfo.ProgressStatus = prg_General then
      Job.m_ProgressIgnoredType := Ign_Ignored_Generic
    else if progInfo.ProgressStatus = prg_Final then
      Job.m_ProgressIgnoredType := Ign_Ignored_Final;

    // Always save current progress values to Orig before clearing
    // so that re-apply can restore them correctly (even after multiple toggles)
    if Job.m_ProgType <> '' then
    begin
      Job.m_ProgTypeOrig      := Job.m_ProgType;
      Job.m_PrgStOrig         := Job.m_PrgSt;
      Job.m_PrgCurDtOrig      := Job.m_PrgCurDt;
      Job.m_PrgEdOrig         := Job.m_PrgEd;
      Job.m_PrgQtyOrig        := Job.m_PrgQty;
      Job.m_PrgStartingQtyOrig := Job.m_PrgStartingQty;
      Job.m_PrgRemTimeOrig    := Job.m_PrgRemTime;
      Job.m_ProgRscOrig       := Job.m_ProgRsc;
    end;
    if (Job.m_PrgEdOrig = 0) then
        Job.m_PrgEdOrig := Job.p_schedEnd;
    Job.m_ProgType := '';
    Job.m_PrgSt := 0;
    Job.m_PrgEd := 0;
    Job.m_PrgQty := 0;
    job.m_ProgSaved := false
  end
  else
  begin
    Job.m_ProgressOverride := Prg_ReApplied;
    Job.m_ProgType := Job.m_ProgTypeOrig;
    Job.m_PrgSt := Job.m_PrgStOrig;
    // Restore the calculated progressed end, not the raw m_PrgEdOrig field which can hold a
    // stale value (the no-progress end). GetProgEndOrig recomputes for type '2' so CSC_ProgEnd
    // (which reads m_PrgEd directly) shows the real progressed end after re-apply.
    Job.m_PrgEd := Job.GetProgEndOrig;
    Job.m_PrgQty := Job.m_PrgQtyOrig;
    Job.m_PrgStartingQty := Job.m_PrgStartingQtyOrig;
    Job.m_ProgRsc := Job.m_ProgRscOrig;
  //  Job.m_PrgQty := Job.m_PrgQtyOrig;
    job.m_ProgSaved := false
  end;

  Job.m_status := CSS_modi;

end;

