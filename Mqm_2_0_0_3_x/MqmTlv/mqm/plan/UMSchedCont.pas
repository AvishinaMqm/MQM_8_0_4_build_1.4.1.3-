procedure TMSchedCont.GetStepLimitDates(ProdReq: string; StepNr: integer; var LowSt: TDateTime; var HighEd: TDateTime);
var
  i: integer;
  tHdr: TSCProdReqHdr;
  tDet: TSCProdReqDet;
  tJob:  TSCProdSched;
  RscCode : string;
begin
  LowSt := 0;
  HighEd := 0;

  tHdr := FindHdrFromCode(self, ProdReq);
  if not Assigned(tHdr) then exit;

  tDet := tHdr.FindDetFromCode(StepNr);
  if not Assigned(tDet) then exit;

  for i := 0 to tDet.m_list.Count-1 do
  begin
    tJob := tDet.m_list[i];
    RscCode := p_sc.GetFldDescr(TJob.m_Id, CSC_Rsc, false);
    if RscCode <> '' then
    begin
      if (LowSt = 0) or ((tJob.p_schedStart <> 0) and (tJob.p_schedStart < LowSt)) then
        LowSt := tJob.p_schedStart;
      if tJob.p_schedEnd > HighEd then
        HighEd := tJob.p_schedEnd;
    end;
  end;

end;

//----------------------------------------------------------------------------//

procedure TMSchedCont.GetStepLimitEndDate(Id: TSchedId; var LowEd: TDateTime; var HighEd: TDateTime);
var
  i: integer;
  tJob, Job :  TSCProdSched;
  ps : TSCSchedOnPlan;
begin
  LowEd := 0;
  HighEd := 0;
  ps := m_codeList[id];
  if not (ps is TSCProdSched) then exit;
  tJob := TSCProdSched(ps);

  for i := 0 to tJob.m_reqDet.m_list.Count - 1 do
  begin
    Job := tJob.m_reqDet.m_list[i];
    if not Assigned(GetExtLinkPtr(Job.m_id)) then continue;
    if (LowEd = 0) or ((Job.p_schedEnd <> 0) and (Job.p_schedEnd < LowEd)) then
        LowEd := Job.p_schedEnd;
    if Job.p_schedEnd > HighEd then
        HighEd := Job.p_schedEnd;
  end;

end;

