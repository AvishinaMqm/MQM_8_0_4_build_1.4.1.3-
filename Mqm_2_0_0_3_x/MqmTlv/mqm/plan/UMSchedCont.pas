procedure TMSchedCont.GetPrevConnReqSteps(Id: TSchedId; StepList : TList);
var
  i,D : integer;
  tHdr, StrHdr: TSCProdReqHdr;
  tDet: TSCProdReqDet;
  tJob:  TSCProdSched;
  ps : TSCSchedOnPlan;
begin
  ps := m_codeList[id];
  if not (ps is TSCProdSched) then exit;

  tJob := TSCProdSched(ps);
  if not Assigned(tJob.m_reqDet) then exit;

  StrHdr := TSCProdReqHdr(tJob.m_reqDet.m_hdr);
  if not Assigned(StrHdr) then exit;

  for i := 0 to StrHdr.m_PrecLinkedReqList.Count-1 do
  begin
    tHdr := PTLinkReqRec(StrHdr.m_PrecLinkedReqList[i]).Request;
    for D := tHdr.m_list.Count - 1 downto 0 do
    begin
      tDet := tHdr.m_list[D];
      if not Assigned(tDet) then continue;
      if not tDet.m_StepToSched then continue;
      StepList.Add(tDet);
      break;
    end;
  end;
end;

