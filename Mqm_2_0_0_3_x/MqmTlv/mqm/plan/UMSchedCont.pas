procedure TMSchedCont.SetSavedScheudleDate(id:TSchedId; Clean : boolean);
var
  sc:  TSCSchedOnPlan;
  ActArea : TMqmActArea;
  prevID : TSchedId;
  overlap, DummyDbl1, DummyDbl2, RealSetup : double;
  DummyStr, LearningCurveCode : string;
  planInfo:   TSQplanInfo;
  LowOvlopLimit, HighOvlpLimit : TDateTime;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if Clean then
    sc.p_SavedScheudleDate := 0
  else
  begin
    sc.p_SavedScheudleDate := sc.p_OrigSchedStart;
    if Assigned(TMQMActArea(TSCSchedOnPlan(m_codeList[Id]).m_srvPtr)) and (sc.p_SavedScheudleDate > 0) then
    begin
      p_sc.GetPlanInfo(id, planInfo);
      ActArea := TMQMActArea(TSCSchedOnPlan(m_codeList[Id]).m_srvPtr);
      prevID := ActArea.GetPrecObj(sc.p_SavedScheudleDate , id);
      if prevID <> CSchedIDnull then
      begin
        CalcSetup(id, prevID, actArea , planInfo.supMinBase, planInfo.supMinReal, planInfo.supMinOvlp, DummyStr, DummyDbl1, DummyDbl2, LearningCurveCode);
        RealSetup := planInfo.supMinReal - planInfo.supMinOvlp;
      end;

      p_pl.EnterCompatModeInPlanForAutoSeq(Id, TMqmRes(ActArea.p_Res));
      p_sc.CalcOvlpLimits(id, TMQMVisibleRes(ActArea.p_Father) , LowOvlopLimit, HighOvlpLimit, OvlpChk_OptimumLimits, RealSetup, -1);
      p_pl.ExitCompatModeInPlanForAutoSeq;

      if sc.p_SavedScheudleDate < HighOvlpLimit then
         sc.p_SavedScheudleDate := HighOvlpLimit;
    end;
  end;
end;

