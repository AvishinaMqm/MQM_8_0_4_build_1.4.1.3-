function TMSchedCont.SetPlanInfo(id: TSchedID; var planInfo: TSQplanInfo): boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
  ActArea : TMqmActArea;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    job.m_GroupAutomaticInternalSortingSequence := planInfo.GroupAutomaticInternalSortingSequence;
    job.p_SchedStartOfJobInContGroup := planInfo.SchedStarttOfJobInContGroup;
    job.p_SchedEndOfJobInContGroup := planInfo.SchedEndtOfJobInContGroup;
    job.p_CurveCodeByOccToOcc := planInfo.CurveOccToOcc;
    job.P_Grp_Sequence := planInfo.GrpSequence;
    job.m_TimeDescr  := planInfo.TmgDescr;
    job.m_MachSetupCode := planInfo.MSC;
    job.m_GenericPlanWC := planInfo.GenericPlanWC;
    job.m_GenericPlanDur := planInfo.GenericPlanDur;
    job.m_GenericPlanLeadTime := planInfo.GenericPlanLeadTime;
    job.m_GenericPlanMachineNum := planInfo.GenericPlanMachineNum;
    job.m_GenericPlanStartDate  := planInfo.GenericPlanStartDate;
    job.m_GenericPlanEndDate    := planInfo.GenericPlanEndDate;
    ActArea := TMqmActArea(sc.m_srvptr);
   { if Assigned(actArea) and (Job.m_status = CSS_new) then
    begin
      job.P_FirstScheduleResource := TmqmRes(TMqmVisibleRes(actArea.p_Father).p_Father).p_ResCode;
      job.P_FirstScheduleStart := planInfo.startDate;
      job.P_FirstScheduleEnd := planInfo.endDate;
    end;  }

    if Assigned(FAutoSched) and Assigned(actArea) then
    begin
      job.m_subLinRscId := TMqmVisibleRes(actArea.p_Father).p_SubCode;
      if p_sc.GetRscComponentFromJobOrStep(job.m_id) > 0 then
        job.m_numOfRscComp := p_sc.GetRscComponentFromJobOrStep(job.m_id)
      //if job.m_reqDet.p_RscComp > 0 then
      //  job.m_numOfRscComp := job.m_reqDet.p_RscComp
      else
        job.m_numOfRscComp := TMqmVisibleRes(actArea.p_Father).p_ResComp
    end;
  end
  else
  begin
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      job.p_CurveCodeByOccToOcc := planInfo.CurveOccToOcc;
      job.m_TimeDescr  := planInfo.TmgDescr;
      job.m_MachSetupCode := planInfo.MSC;
      job.m_GenericPlanWC := planInfo.GenericPlanWC;
      job.m_GenericPlanDur := planInfo.GenericPlanDur;
      job.m_GenericPlanLeadTime := planInfo.GenericPlanLeadTime;
      job.m_GenericPlanMachineNum := planInfo.GenericPlanMachineNum;
      job.m_GenericPlanStartDate  := planInfo.GenericPlanStartDate;
      job.m_GenericPlanEndDate    := planInfo.GenericPlanEndDate;

      ActArea := TMqmActArea(sc.m_srvptr);

    {  if Assigned(actArea) and (Job.m_status = CSS_new) then
      begin
        job.P_FirstScheduleResource := TmqmRes(TMqmVisibleRes(actArea.p_Father).p_Father).p_ResCode;
        job.P_FirstScheduleStart := planInfo.startDate;
        job.P_FirstScheduleEnd := planInfo.endDate;
      end;  }

      if Assigned(FAutoSched) and Assigned(actArea) then
      begin
        job.m_subLinRscId := TMqmVisibleRes(actArea.p_Father).p_SubCode;
        if p_sc.GetRscComponentFromJobOrStep(job.m_id) > 0 then
          job.m_numOfRscComp := p_sc.GetRscComponentFromJobOrStep(job.m_id)
        //if job.m_reqDet.p_rscComp > 0 then
        //  job.m_numOfRscComp := job.m_reqDet.p_rscComp
        else
          job.m_numOfRscComp := TMqmVisibleRes(actArea.p_Father).p_ResComp
      end;
    end
  end;

  sc.p_schedStart := planInfo.startDate;
  sc.p_schedEnd   := planInfo.endDate;
  sc.p_exeMin     := planInfo.exeMin;
  sc.p_supMinBase := planInfo.supMinBase;
  sc.p_supMinReal := planInfo.supMinReal;
  sc.p_supMinOvlp := planInfo.supMinOvlp;
  sc.p_quantSched := planInfo.quant;

  Result := true
end;

