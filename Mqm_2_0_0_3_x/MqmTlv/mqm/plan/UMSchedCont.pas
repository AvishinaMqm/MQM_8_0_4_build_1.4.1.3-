function FindHdrFromCode(sc: TMSchedCont; hdrCode: string): TSCProdReqHdr;
var
  i: integer;
//  L, H: integer;
//  Found: boolean;
Multiplier, NumberOfEntries : integer; // Eran25062010
begin
{  Result := nil;
  if sc.m_prodReqList.Count = 0 then exit;


//  Binary search we have to sort the list before uing it
  if not sc.m_prodReqListSorted then
  begin
    sc.m_prodReqList.Sort(HdrOrderGrowing);
    sc.m_prodReqListSorted := true;
  end;

  L := 0;
  H := sc.m_prodReqList.Count-1;
  Found := false;

  while (L <= H) and not Found do
  begin

    i := (H-L) div 2;
    if i < L then i := L+i;
    if i > H then i := H-i;

    if (hdrCode < TSCProdReqHdr(sc.m_prodReqList[i]).m_code) then
      H := i - 1
    else
      if (hdrCode > TSCProdReqHdr(sc.m_prodReqList[i]).m_code) then
        L := i + 1
      else
      begin
        Result := TSCProdReqHdr(sc.m_prodReqList[i]);
        Found := true
      end;
  end;
}
// Eran25062010 - Start
{
  for i := 0 to sc.m_prodReqList.Count-1 do
    if TSCProdReqHdr(sc.m_prodReqList[i]).m_code = hdrCode then
    begin
      Result := TSCProdReqHdr(sc.m_prodReqList[i]);
      exit
    end
}

Result := nil;

NumberOfEntries := sc.m_prodReqList.Count;
if NumberOfEntries = 0 then exit;

if not sc.m_prodReqListSorted then
begin
  sc.m_prodReqList.Sort(HdrOrderGrowing);
  sc.m_prodReqListSorted := true;
end;

Multiplier := 1;
while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
i := Multiplier - 1;

while (Multiplier > 0) do
begin

  if  (i < NumberOfEntries)
  and (TSCProdReqHdr(sc.m_prodReqList[i]).m_code = hdrCode) then break;

  Multiplier := trunc(Multiplier / 2);

  if  (i < NumberOfEntries)
  and (TSCProdReqHdr(sc.m_prodReqList[i]).m_code < hdrCode) then
    i := i + Multiplier
  else
    i := i - Multiplier;

end;

if Multiplier > 0 then Result := TSCProdReqHdr(sc.m_prodReqList[i]);

 // Eran25062010 - End

end;

