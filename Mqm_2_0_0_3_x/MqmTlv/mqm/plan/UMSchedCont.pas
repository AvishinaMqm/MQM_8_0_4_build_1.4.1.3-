function TMSchedCont.CanMoveToBin(job: TSchedID;  ErrList: TStrings; IncludeClosed : boolean): boolean;
var
  progInfo: TSQprogInfo;
  StepInfo: TSQStepInfo;
  planInfo: TSQplanInfo;
  ProdNo, StepNo: String;
  SonId : TSchedId;
  j, G: Integer;
  FieldVal : variant;
  dataType: CBinColValType;
begin
  Result := false;

  if Assigned(p_sc.GetExtLinkPtr(job)) and TMqmWrkCtr(TMqmActArea(p_sc.GetExtLinkPtr(job)).p_WrkCtr).p_ReadOnly then
  begin
    if Assigned(ErrList) then
      ErrList.Add(_('Can''t move jobs on a read only resource'));
    exit
  end;

  GetProgInfo(Job, progInfo);

  if (progInfo.ProgType <> '') then
  begin
    if Assigned(ErrList) then
      ErrList.Add(_('Can''t move a progressed job or group'));
    exit
  end
  else
  begin

    GetPlanInfo(job, planInfo);

    if planInfo.isGroup then
    begin
      for G := 0 to p_sc.GetGrpNumSons(Job) - 1 do
      begin
        SonId := p_sc.GetGrpSon(Job, G);
        p_sc.GetFldValue(SonId, CSC_Closed, FieldVal, dataType);
        if FieldVal then Break;
      end;
    end
    else
    begin
      StepNo := p_sc.GetFldDescr(Job, CSC_ProdStep, false);
      ProdNo := p_sc.GetFldDescr(Job, CSC_ProdReq, false);

      for j := 0 to p_sc.StepCount(ProdNo) -1 do
      begin
        StepInfo := p_sc.GetStepByIndex(ProdNo, j);
        if StepInfo.StepNo = StrToInt(StepNo) then break;
      end;
    end;

    if (StepInfo.StepClosed = true) or FieldVal then
    begin
      if (CProgress(p_sc.IsProgressed(job)) = prg_none) then
      begin                                                                                                          //  mrCancel
        if Assigned(ErrList) and (MessageDlg(_('The step is closed, please press OK to confirm your request.'), mtWarning, [mbOk, mbCancel], 0) <> mrok) then
        begin
          exit
        end;
        if not IncludeClosed then
          exit;
      end;
    end;

  end;

  Result := true;
end;

//----------------------------------------------------------------------------//

function TMSchedCont.CanMoveTo(job: TSchedID; ToDate: TDateTime): boolean;
var
  ActArea:  TMqmActArea;
  planInfo: TSQplanInfo;
  Cal: TPGCALObj;
begin
  Result := false;
  ActArea := GetExtLinkPtr(job);

  if not Assigned(ActArea) then
    exit;

  if not CanDetach(job, nil, false) then
    exit;

  if not GetPlanInfo(job, planInfo) then
    exit;

  planInfo.startDate := ToDate;
  Cal := ActArea.GetCalendar;
  if not assigned(Cal)
  or not Cal.OfsByWH((planInfo.supMinReal + planInfo.exeMin)/60, true,
                      planInfo.startDate, planInfo.endDate, ActArea.m_CrossDownTmList) then
    exit;

  if (ActArea.p_end < planInfo.endDate) then
    exit;

  if (ActArea.FindDwTimeCovering(planInfo.startDate, planInfo.endDate, job) <> nil) then
    exit;

  Result := true;
end;

