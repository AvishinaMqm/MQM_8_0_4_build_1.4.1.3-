      fPD_NextLeadTime_mqm             := FieldByName(CreateFld(tbiPD.pfx, fli_NextLeadTime_mqm));
      fPD_PrevLeadTimeBatch_mqm        := FieldByName(CreateFld(tbiPD.pfx, fli_PrevLeadTimeBatch_mqm));
      fPD_NextLeadTimeBatch_mqm        := FieldByName(CreateFld(tbiPD.pfx, fli_NextLeadTimeBatch_mqm));
