function TMSchedCont.CheckHostLeadStepSplit(tDet :TSCProdReqDet; UserRequestForSplit : boolean; StartingNbr : integer) : integer;
var
  I, pd, ps   : Integer;
  Det : TSCProdReqDet;
  Job, tjob : TSCProdSched;
  NewRequestNumber : integer;
begin
  Result := 0;

  // Block split of leading step if any sibling steps are already scheduled or split
  if UserRequestForSplit and (tDet.m_hdr.m_LeadStepForSplit = tDet.m_code) then
  begin
    for pd := 0 to tDet.m_hdr.m_list.Count - 1 do
    begin
      Det := TSCProdReqDet(tDet.m_hdr.m_list[pd]);
      if Det.m_code = tDet.m_code then continue;  // skip self
      // Check if step is split (more than 1 substep)
      if Det.p_Count > 1 then
      begin
        ShowMessage(_('Cannot split leading step - step') + ' ' + IntToStr(Det.m_code) + ' ' + _('is already split. Unschedule and merge all steps first.'));
        Exit;
      end;
      // Check if step is scheduled
      for ps := 0 to Det.m_list.Count - 1 do
      begin
        tjob := TSCProdSched(Det.m_list[ps]);
        if tjob.m_isDeleted then continue;
        if Assigned(tjob.m_srvPtr) then
        begin
          ShowMessage(_('Cannot split leading step - step') + ' ' + IntToStr(Det.m_code) + ' ' + _('is already scheduled. Unschedule all steps first.'));
          Exit;
        end;
      end;
    end;
  end;

  for I := 0 to tDet.m_list.Count - 1 do
  begin
    Job := TSCProdSched(tDet.m_list[I]);
    if Job.m_isDeleted then continue;
    if (Job.m_VisbleInBin = CSB_ReadOnly) then continue;
    if (Job.m_status in [CSS_none,CSS_del,CSS_From_PG]) then continue;
    if not (Job.m_status in [CSS_new,CSS_modi]) then continue;
    if not Assigned(GetExtLinkPtr(Job.m_id)) then continue;
    if (CProgress(p_sc.IsProgressed(Job.m_id)) <> prg_none) then continue;

    if not UserRequestForSplit then
    begin
      if (GetSchedType(Job.m_id) <> '2')
      and (GetSchedType(Job.m_id) < tDet.m_hdr.m_ConfLevels) then continue;
//      if (GetSchedType(Job.m_id) = '2') then
//      begin
//        if GetSchedType(Job.m_id) <> tDet.m_hdr.m_ConfLevels then continue;
//      end
//      else
//      begin
//        if GetSchedType(Job.m_id) < tDet.m_hdr.m_ConfLevels then continue;
//      end;
    end
    else
    begin
      if not Job.m_UserReqSplitOnHost then continue;
    end;

    if (Job.m_code > 0) and (Job.m_NewReqUniqId = '') then
    begin
       // no progress for this request

      for pd := 0 to Job.m_reqDet.m_hdr.m_list.Count-1 do
      begin
        Det := TSCProdReqDet(Job.m_reqDet.m_hdr.m_list[pd]);
        Application.ProcessMessages;
        for ps := 0 to Det.m_list.Count - 1 do
        begin
          tjob := TSCProdSched(Det.m_list[ps]);
          if tJob.m_isDeleted then
            continue;
          if (CProgress(p_sc.IsProgressed(tJob.m_id)) <> prg_none) then
            Exit;
        end;
      end;

      Result := Result + 1;
      if StartingNbr > 0 then
      begin
        Job.m_NewReqUniqId := FloatToStr(StartingNbr);
        StartingNbr := StartingNbr + 1;
      end;
    end;
  end;
end;

//----------------------------------------------------------------------------//

function SortProgress(Item1, Item2: Pointer): integer;
var
  MQMSP1 : PTSQProgInfo;
  MQMSP2 : PTSQProgInfo;
begin
  MQMSP1 := PTSQProgInfo(Item1);
  MQMSP2 := PTSQProgInfo(Item2);

  if MQMSP1.preqNo < MQMSP2.preqNo then
     Result := -1
  else if (MQMSP1.preqNo = MQMSP2.preqNo) then
  begin
    if (MQMSP1.pstepId < MQMSP2.pstepId) then
       Result := -1
    else if (MQMSP1.pstepId = MQMSP2.pstepId) then
    begin
      if (MQMSP1.psubstId < MQMSP2.psubstId) then
        Result := -1
      else if (MQMSP1.psubstId = MQMSP2.psubstId) then
      begin
        if (MQMSP1.reprocNo < MQMSP2.reprocNo) then
          Result := -1
        else if (MQMSP1.reprocNo > MQMSP2.reprocNo) then
          Result := 1
        else
          Result := 0;
      end
      else
        Result := 1
    end
    else
      Result := 1;
  end
  else
    Result := 1;

end;

