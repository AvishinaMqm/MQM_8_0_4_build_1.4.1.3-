procedure TMSchedCont.SetOvlpUpdate(id: TSchedId; AllTheChain: boolean);
// Reset the flag m_DontCalcOvlp to cause the overlap limits to be updated
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  PrecStep, NextStep : TSCProdReqDet;
  i, stepnr: integer;
  CurrJobsList,
  NextJobsList,
  PrevJobsList,
  NextConnReqJobsList,
  PrevConnReqJobsList,
  PrevConnJobsList,
  NextConnJobsList: TMSchedList;
  TimingInfo: TSQtimingInfo;
  NextStepInfo, PrevStepInfo: TSQStepInfo;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;

  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := grp.m_list[i];
      SetOvlpUpdate(job.m_Id, AllTheChain)
    end;
  end else
  begin
    job := TSCProdSched(sc);
    job.m_DontCalcOvlp := false;
    if AllTheChain then
    begin
      GetTimingInfo(id, TimingInfo);

      CurrJobsList := TMSchedList.Create(self);
      GetStepJobs(TimingInfo.ProdReq, TimingInfo.Step, CurrJobsList);
      for i := 0 to CurrJobsList.GetLinkCount-1 do
        SetOvlpUpdate(CurrJobsList.GetLink(i), false);

      CurrJobsList.Free;

      NextJobsList := TMSchedList.Create(self);
      stepnr := Job.m_reqDet.m_code;
      while true do
      begin
        NextJobsList.ClearList;
        NextStep := Job.GetNextStepToSched(stepnr);
        if not Assigned(NextStep) then
          Break;
        if GetJobsOfNextStepOnPlan(TimingInfo.ProdReq, stepnr, NextStepInfo, NextJobsList) then
          for i := 0 to NextJobsList.GetLinkCount-1 do
            SetOvlpUpdate(NextJobsList.GetLink(i), false);

        stepnr := NextStep.m_code;
      end;

      NextJobsList.Free;

      PrevJobsList := TMSchedList.Create(self);
      stepnr := Job.m_reqDet.m_code;
      while true do
      begin
        PrevJobsList.ClearList;
        PrecStep := Job.GetPrevStepToSched(stepnr);
        if not Assigned(PrecStep) then
          Break;
        if GetJobsOfPrecStepOnPlan(TimingInfo.ProdReq, stepnr, PrevStepInfo, PrevJobsList) then
          for i := 0 to PrevJobsList.GetLinkCount-1 do
            SetOvlpUpdate(PrevJobsList.GetLink(i), false);

        stepnr := PrecStep.m_code;
      end;

      PrevJobsList.Free;

      NextConnJobsList := TMSchedList.Create(self);
      GetFwLinkedJobs(Id, NextConnJobsList);
      for i := 0 to NextConnJobsList.GetLinkCount-1 do
        SetOvlpUpdate(NextConnJobsList.GetLink(i), false);

      NextConnJobsList.Free;

      PrevConnJobsList := TMSchedList.Create(self);
      GetBwLinkedJobs(Id, PrevConnJobsList);
      for i := 0 to PrevConnJobsList.GetLinkCount-1 do
        SetOvlpUpdate(PrevConnJobsList.GetLink(i), false);
      PrevConnJobsList.Free;

      NextConnReqJobsList  := TMSchedList.Create(self);
      GetNextConnReqFirstStepJobs(Id, NextConnReqJobsList);
      for i := 0 to NextConnReqJobsList.GetLinkCount-1 do
        SetOvlpUpdate(NextConnReqJobsList.GetLink(i), false);
      NextConnReqJobsList.Free;

      PrevConnReqJobsList  := TMSchedList.Create(self);
      GetPrevConnReqLastStepJobs(Id, PrevConnReqJobsList);
      for i := 0 to PrevConnReqJobsList.GetLinkCount-1 do
        SetOvlpUpdate(PrevConnReqJobsList.GetLink(i), false);
      PrevConnReqJobsList.Free;
    end;
  end;
end;

