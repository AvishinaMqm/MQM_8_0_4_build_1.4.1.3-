    SQL.Add(' WHERE PD.' + CreateFld(tbInfoProdStep.pfx, fli_Identifier) + ' = ' + IniAppGlobals.Identifier);
    SQL.Add(' AND PD.' + CreateFld(tbInfoProdStep.pfx, fli_wkCtrCode) + ' IN (' + WorkCentersList + ')');
    SQL.Add(') ');
    SQL.Add('order by ');
    SQL.Add('PPP.' + CreateFld(tbInfoProp.pfx, fli_preqNo)  + ',');
    SQL.Add('PPP.' + CreateFld(tbInfoProp.pfx, fli_PropertyCode));

    FetchOptions.RowsetSize := 5000;
    Open;

    PP_preqNo       := FieldByName(CreateFld(tbInfoProp.pfx, fli_preqNo));
    PP_pstepId      := FieldByName(CreateFld(tbInfoProp.pfx, fli_pstepId));
    PP_PropertyCode := FieldByName(CreateFld(tbInfoProp.pfx, fli_PropertyCode));
    PP_PropValue    := FieldByName(CreateFld(tbInfoProp.pfx, fli_PropValue));

    OldHdr := nil;
    OldHdrCode := '';
    RowCnt := 0;

    while not eof do
    begin
      code := PP_PropertyCode.AsString;

      PropId := GetIdFromCode(Code);
      if PropId = nil then
      begin
        Qry.Next;
        continue;
      end;
      IsDateProp := IsPropAsDate(PropId);
      if IsDateProp then
      begin
        try
         // GetLocaleFormatSettings(LOCALE_SYSTEM_DEFAULT, formatSettings);
          val   := PP_PropValue.AsString;
         // val   := DateToStr(StrToDateTime(val, formatSettings));
        except
          val   := '';//PP_PropValue.AsString;
        end;
      end
      else if IsCalculatedDateProp(PropId) then
      begin
        try
          val   := PP_PropValue.AsString;
          PropDate := GetDateTimeFormatForStr(val);
          Val   := DateTimeToStr(PropDate);
        except
          val   := PP_PropValue.AsString;
        end;
      end
      else
        val :=  PP_PropValue.AsString;
      StepId := PP_pstepId.AsInteger;

      if (OldHdrCode <> PP_preqNo.AsString) then
      begin
        OldHdrCode := PP_preqNo.AsString;

        if Assigned(OldHdr) then
        begin
        for i := 0 to hdr.m_list.Count-1 do
          begin
            det := hdr.m_list[i];
            if Assigned(det) then det.m_propList.OrganizeProperties;
         end;
        end;

        hdr := FindHdrFromCode(self, OldHdrCode);
        OldHdr := hdr
      end else
        Hdr := OldHdr;

      if Assigned(hdr) then
      begin
        if (StepId > 0) then
        begin
          det := hdr.FindDetFromCode(StepId);
          if Assigned(det) then
          begin
            det.m_propList.AddProperty(code, '', val);
          end
        end else
        begin
          for i := 0 to hdr.m_list.Count-1 do
          begin
            det := hdr.m_list[i];
            if Assigned(det) then
            begin
              det.m_propList.AddProperty(code, '', val);
            end
          end;
        end;

        if assigned(det) and IsDateProp and IsApprovalDateProp(PropId) then
        begin
          det.m_Approvaldate := PropDate;
          det.m_Approvaldate_UserChanged := true;
        end;

        if assigned(det) and IsCalculatedDateProp(PropId) and (PropDate > 0) then
        begin
          p_sc.SetHighEndTimeLimitOverriden(TSCProdSched(det.m_list[0]).m_Id, true);
          Det.m_customerDate := CSD_Calculated;
          det.m_highEndTimeLimit := PropDate;
          det.m_highEndTimeLimit_orig := det.m_highEndTimeLimit
        end;
      end;

      Inc(RowCnt);
      if RowCnt mod 500 = 0 then Application.ProcessMessages;
      Next;

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          Application.ProcessMessages;
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;

    end;

    if Assigned(OldHdr) then
    begin
    for i := 0 to hdr.m_list.Count-1 do
      begin
        det := hdr.m_list[i];
        if Assigned(det) then det.m_propList.OrganizeProperties;
     end;
    end;

    Close;

  end;

  for I := 0 to PropertiesList.Count - 1 do
  begin
    PPropWorkCenters := PTPropWorkCenters(PropertiesList[I]);
    PPropWorkCenters.WorkCenters.Free;
    dispose(PPropWorkCenters);
  end;
  PropertiesList.Free;
  PropInTheList.Free;

  Application.ProcessMessages;
//  IniAppGlobals.Time_LoadJobsproperties := Now - IniAppGlobals.Time_LoadJobsproperties;
//  IniAppGlobals.LogTimes.Add('Time job properties : ' + FloatTostr(IniAppGlobals.Time_LoadJobsproperties * 60 * 60 *  24));
//  IniAppGlobals.LogTimes.SaveToFile(LocAppGlobals.AppDir + '\LoadJobsproperties.txt');

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);

end;

