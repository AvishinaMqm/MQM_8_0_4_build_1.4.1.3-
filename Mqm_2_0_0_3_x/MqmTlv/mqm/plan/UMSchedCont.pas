procedure TMSchedCont.BalanceQuantity(id: TSchedID; FromOrganize : boolean);
var
  I, J, NumOfJobs, IncludedJobs, NumberOfRealJobs : Integer;
  SumFinalQty, SumGenQty, ExcludedQty, AddEachQty, PrevAddEachQty : currency;
  sc:  TSCSchedOnPlan;
  tDet : TSCProdReqDet;
  tjob, tLastJob : TSCProdSched;
  grp : TSCProdGroup;
  ContinueToNext : boolean;
  TmpList : TList;
  DecMult : integer;
  TmpQty, LastJobQty : double;
  RequestVal, StepVal : variant;
  dataType: CBinColValType;
  AllJobsAreFinal : boolean;
  NewJob : TSCProdSched;
  JobsIdList: TMSchedList;
  apa : TMqmActArea;
  Cal: TPGCALObj;
  Duration, Setup, DurationIncludingCurve, ProgressMinutes : double;
begin
  tLastJob := nil;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    for I := 0 to grp.m_list.Count - 1 do
      BalanceQuantity(TSCProdSched(grp.m_list[I]).m_Id, FromOrganize);
  end
  else
  begin
    tjob := TSCProdSched(sc);
    tDet := TSCProdReqDet(tjob.m_reqDet);
    DecMult := Round(IntPower(10, tDet.m_hdr.m_NumOfDecimals));
    AllJobsAreFinal := true;

    SumGenQty := 0;
    SumFinalQty := 0;
    NumOfJobs := 0;
    NumberOfRealJobs := 0;
    for I := 0 to tDet.m_list.count - 1 do
    begin
      tJob := tDet.m_list[i];

      if (tJob.m_isDeleted) or (tJob.m_reprocNo > 0) then
        Continue;

      inc(NumberOfRealJobs);

      if (IsProgressed(tJob.m_Id) = prg_Final) or (IsProgressed(tJob.m_Id) = prg_FinalSplit) then
      begin
        apa := TMqmActArea(p_sc.GetExtLinkPtr(tJob.m_Id));
        if not assigned(apa) then continue;

        Cal := apa.GetCalendar;

        if (tJob.m_PrgQty = 0) then
        begin
        //  if tJob.p_quantSched <> tJob.CalcQtyFinnalProg then
        //    tJob.m_status := CSS_modi;
        //  tJob.p_quantSched := trunc(tJob.CalcQtyFinnalProg);
        end
        else
        begin
          if tJob.p_quantSched <> tJob.m_PrgQty then
            tJob.m_status := CSS_modi;
          tJob.p_quantSched := tJob.m_PrgQty;
          GetIdTimes(tJob.m_Id,'','','',false,Duration,Setup,true);
          ProgressMinutes := 0;
          if (p_sc.GetLearningCurveCode(tJob.m_Id) <> '') and (tJob.m_PrgEd > tJob.m_PrgSt) then
            ProgressMinutes := Cal.DiffWH(tJob.m_PrgSt, tJob.m_PrgEd , apa.m_CrossDownTmList)*60;
          tJob.p_exeMin := Duration + GetCurveTime(apa, tJob.m_PrgSt, tJob.m_Id, ProgressMinutes, true, 0);
        end;
        SumFinalQty := SumFinalQty + tJob.p_quantSched;
        Inc(NumOfJobs);
        continue;
      end;

      AllJobsAreFinal := false;

      if (IsProgressed(tJob.m_Id) = prg_General) then
      begin
        apa := TMqmActArea(p_sc.GetExtLinkPtr(tJob.m_Id));
        if not assigned(apa) then exit;

        Cal := apa.GetCalendar;
        SumGenQty := SumGenQty + tJob.m_PrgQty;
        if (tJob.m_PrgQty > tJob.p_quantSched) then
        begin
          if (tJob.p_quantSched <> tJob.m_PrgQty) and (not tJob.m_fromPD) then
            tJob.m_status := CSS_modi;
          tJob.p_quantSched := tJob.m_PrgQty;
          GetIdTimes(tJob.m_Id,'','','',false,Duration,Setup,true);
          ProgressMinutes := 0;
          if (p_sc.GetLearningCurveCode(tJob.m_Id) <> '') and (tJob.m_PrgCurDt > tJob.m_PrgSt) then
            ProgressMinutes := Cal.DiffWH(tJob.m_PrgSt, tJob.m_PrgCurDt , apa.m_CrossDownTmList)*60;
          tJob.p_exeMin := Duration + GetCurveTime(apa, tJob.m_PrgSt,tJob.m_Id, ProgressMinutes, true, 0);
        end;
      end;
    end;

    if NumberOfRealJobs = 0 then exit;

    if AllJobsAreFinal and (not tDet.m_stepClosed) and (tDet.m_quantInit > SumFinalQty) then
    begin
      //NewJob := CreateNewJob(tDet, GetNewCode(tDet) , CSnoGroupDef);
      NewJob := CreateNewJob(tDet, GetNewSubStep(tDet) , CSnoGroupDef);
      NewJob.p_quantSched := (tDet.m_quantInit - SumFinalQty);
      NewJob.m_status         := CSS_new;
      exit;
    end;

    if AllJobsAreFinal or (tDet.m_quantInit <= SumFinalQty) then exit;

    for I := 0 to tDet.m_list.count - 1 do
    begin
      tJob := tDet.m_list[i];
      if (IsProgressed(tJob.m_Id) = prg_General)
      and (tJob.m_PrgQty < tJob.p_quantSched) then
      begin
        apa := TMqmActArea(p_sc.GetExtLinkPtr(tJob.m_Id));
		if not assigned(apa) then continue;
        Cal := apa.GetCalendar;
        if (tJob.p_quantSched <> tJob.m_PrgQty) and (not tJob.m_fromPD) then
          tJob.m_status := CSS_modi;
        tJob.p_quantSched := tJob.m_PrgQty;
        GetIdTimes(tJob.m_Id,'','','',false,Duration,Setup,true);
        ProgressMinutes := 0;
        if (p_sc.GetLearningCurveCode(tJob.m_Id) <> '') and (tJob.m_PrgCurDt > tJob.m_PrgSt) then
          ProgressMinutes := Cal.DiffWH(tJob.m_PrgSt, tJob.m_PrgCurDt , apa.m_CrossDownTmList)*60;
        tJob.p_exeMin := Duration + GetCurveTime(apa, tJob.m_PrgSt,tJob.m_Id, ProgressMinutes, true, 0);
      end
    end;

    if (tDet.m_quantInit <= (SumFinalQty + SumGenQty)) then exit;

    ExcludedQty := SumFinalQty;
    AddEachQty := (tDet.m_quantInit - ExcludedQty)/(NumberOfRealJobs - NumOfJobs);
    AddEachQty := trunc(AddEachQty*DecMult)/DecMult;
    PrevAddEachQty := 0;
    TmpList := TList.create;
    JobsIdList := TMSchedList.Create(self);
    while AddEachQty <> PrevAddEachQty do
    begin
      TmpList.Clear;
      NumOfJobs := 0;
      IncludedJobs := 0;
      for I := 0 to tDet.m_list.count - 1 do
      begin
        tJob := tDet.m_list[i];
        if (tJob.m_isDeleted) or (tJob.m_reprocNo > 0) then
        begin
          TmpList.Add(tJob);
          continue;
        end;
        if (IsProgressed(tJob.m_Id) = prg_Final)  or (IsProgressed(tJob.m_Id) = prg_FinalSplit)
        or ((IsProgressed(tJob.m_Id) = prg_General) and (JobsIdList.IndexOf(tJob.m_Id) <> -1)) then
        begin
          Inc(NumOfJobs);
          TmpList.Add(tJob);
          continue;
        end;
        if ((IsProgressed(tJob.m_Id) = prg_General) and (tJob.m_PrgQty >= AddEachQty)) then
        begin
          JobsIdList.AddLink(tJob.m_Id);
          Inc(NumOfJobs);
          TmpList.Add(tJob);
          ExcludedQty := ExcludedQty + tJob.m_PrgQty;
          continue;
        end;
        inc(IncludedJobs);
        tLastJob := tJob;
      end;
      PrevAddEachQty := AddEachQty;
      AddEachQty := (tDet.m_quantInit - ExcludedQty)/(NumberOfRealJobs - NumOfJobs);
      AddEachQty := trunc(AddEachQty*DecMult)/DecMult;
    end;
    JobsIdList.free;

    LastJobQty := tDet.m_quantInit - ExcludedQty - ((IncludedJobs-1) * AddEachQty);

    for I := 0 to tDet.m_list.count - 1 do
    begin
      tJob := tDet.m_list[i];
      ContinueToNext := false;

      if TmpList.Count > 0 then
        for J := 0 to TmpList.Count - 1 do
        begin
          if tJob.m_Id = TSCProdSched(TmpList[J]).m_Id then
          begin
            ContinueToNext := true;
            break
          end;
        end;

      if ContinueToNext then continue;

      tmpqty := trunc(tJob.p_quantSched*DecMult)/DecMult;

      if tLastJob = tJob then
      begin
        if tmpqty = LastJobQty then continue;
        tjob.p_quantSched := LastJobQty;
      end
      else
      begin
        if tmpqty = AddEachQty then continue;
        tjob.p_quantSched := AddEachQty;
      end;
      tJob.m_status := CSS_modi;

      if (tDet.m_stepType = CST_continuous) then
      begin
        GetIdTimes(tJob.m_Id,'','','',false,Duration,Setup,true);
        if Assigned(tJob.m_srvPtr) then
        begin
          apa := TMqmActArea(p_sc.GetExtLinkPtr(tJob.m_Id));
          if (IsProgressed(tJob.m_Id) = prg_General) then
          begin
            ProgressMinutes := 0;
           if (p_sc.GetLearningCurveCode(tJob.m_Id) <> '') and (tJob.m_PrgCurDt > tJob.m_PrgSt) then
             ProgressMinutes := Cal.DiffWH(tJob.m_PrgSt, tJob.m_PrgCurDt , apa.m_CrossDownTmList)*60;
          end;
          if tjob.p_quantSched > tjob.m_PrgQty then
            ProgressMinutes := ProgressMinutes + ((tjob.p_quantSched - tjob.m_PrgQty) / tjob.p_quantSched * Duration);
          DurationIncludingCurve := Duration + GetCurveTime(apa, tJob.p_schedStart ,tJob.m_Id, ProgressMinutes , true, 0)
        end
        else
          DurationIncludingCurve := Duration + GetCurveTime(nil, tJob.p_schedStart ,tJob.m_Id,duration,false,0);

        if (DurationIncludingCurve < 0) or (DurationIncludingCurve > 1048320) then // 2 years
        begin
          GetFldValue(Id, CSC_ProdReq, RequestVal, dataType);
          GetFldValue(Id, CSC_ProdStep, StepVal, dataType);
          if not IsAutoRunMode and not FromOrganize then
          begin
            showmessage(' As a result of the balance, job : ' + RequestVal + ' ' + IntToStr(StepVal) + ' ' + IntToStr(tJob.m_code) + #13#10 +
                        ' execusion time is more then two years long - please check.');
          end
        end;
        tJob.p_exeMin := DurationIncludingCurve;
      end;
    end;

    if assigned(TmpList) then
    begin
      TmpList.Clear;
      TmpList.Free;
    end;

  end;
end;

