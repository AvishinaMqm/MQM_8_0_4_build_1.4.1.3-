procedure TMSchedCont.AutoSeqCheckMoveJobsToCorrectPlace(id: TSchedId; PrevHighDate : boolean);
var
  tDet : TSCProdReqDet;
  sc   : TSCSchedOnPlan;
  job  : TSCProdSched;
  grp  : TSCProdGroup;
  J, I : Integer;
  StepList : TList;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  //Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    if PrevHighDate then
      tDet := job.GetNextStepToSched(job.m_reqDet.m_code)
    else
      tDet := job.GetPrevStepToSched(job.m_reqDet.m_code);
    if Assigned(tDet) then
      AutoSeqMoveJobsToCorrectPlace(tDet)
    else
    begin
      StepList := TList.Create;
      if PrevHighDate then
        GetNextConnReqSteps(Id, StepList)
      else
        GetPrevConnReqSteps(Id, StepList);
      for I := 0 to StepList.Count - 1 do
          AutoSeqMoveJobsToCorrectPlace(TSCProdReqDet(StepList[I]));
      StepList.Free;
    end;
  end
  else
  begin
    grp := TSCProdGroup(sc);
    for J := 0 to grp.m_list.Count - 1 do
      AutoSeqCheckMoveJobsToCorrectPlace(TSCProdSched(grp.m_list[J]).m_Id, PrevHighDate);
  end;
end;

//----------------------------------------------------------------------------//

procedure TMSchedCont.AutoSeqMoveJobsToCorrectPlace(tDet : TSCProdReqDet);
var
  job : TSCProdSched;
  CurrentID : TSchedId;
  PrevId : TSchedId;
  PrevPrevID : TSchedId;
  NextID : TSchedId;
  NextNextID : TSchedId;
  TempPrevId : TSchedId;
  TempNextId : TSchedId;
  I : Integer;
  grp: TSCProdGroup;
  CompResult : Integer;
begin
  CompResult := -1;

  if not assigned(tDet) then exit;

  for I := 0 to tDet.m_list.Count - 1 do
  begin
    job := TSCProdSched(tDet.m_list[I]);

    if Assigned(job.m_grp) then
    begin
      grp := TSCProdGroup(job.m_grp);
      if not grp.m_AutoSeqHandled then continue;
      CurrentID := grp.m_Id;
      PrevID := grp.m_AutoSeqPrevID;
      NextID := grp.m_AutoSeqNextID;
    end
    else
    begin
      if not job.m_AutoSeqHandled then continue;
      CurrentID := job.m_Id;
      PrevID := job.m_AutoSeqPrevID;
      NextID := job.m_AutoSeqNextID;
    end;

    if GetAutoSeqHandled(PrevID) then
      CompResult := CompColValue(Pointer(CurrentID), Pointer(PrevID));

    if GetAutoSeqHandled(PrevID) and (CompResult = -1) then
    begin

      while True do
      begin
        PrevPrevID := TSCSchedOnPlan(m_codeList[PrevID]).m_AutoSeqPrevID;
        if not GetAutoSeqHandled(PrevPrevID) then break;
        CompResult := CompColValue(Pointer(CurrentID) , Pointer(PrevPrevID));
        if CompResult <> -1 then break;
        PrevID := PrevPrevID;
      end;

      TempPrevID := TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqPrevID;
      TempNextID := TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqNextID;
      TSCSchedOnPlan(m_codeList[TempPrevID]).m_AutoSeqNextID := TempNextID;

      if TempNextID <> -1 then
        TSCSchedOnPlan(m_codeList[TempNextID]).m_AutoSeqPrevID := TempPrevID;

    //  if GetAutoSeqHandled(PrevPrevID) then
      if (PrevPrevID <> -1) then
         TSCSchedOnPlan(m_codeList[PrevPrevID]).m_AutoSeqNextID := CurrentID;
      TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqPrevID := PrevPrevID;
      TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqNextID := PrevID;
      TSCSchedOnPlan(m_codeList[PrevID]).m_AutoSeqPrevID := CurrentID;
      continue;
    end;

    if NextID = -1 then continue;

    CompResult := CompColValue(Pointer(CurrentID), Pointer(NextID));
    if CompResult <> 1 then continue;

    while True do
    begin
      NextNextID := TSCSchedOnPlan(m_codeList[NextID]).m_AutoSeqNextID;
      if NextNextID = -1 then break;
      CompResult := CompColValue(Pointer(CurrentID) , Pointer(NextNextID));
      if CompResult <> 1 then break;
      NextID := NextNextID;
    end;

    TempPrevID := TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqPrevID;
    TempNextID := TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqNextID;
    TSCSchedOnPlan(m_codeList[TempPrevID]).m_AutoSeqNextID := TempNextID;
    TSCSchedOnPlan(m_codeList[TempNextID]).m_AutoSeqPrevID := TempPrevID;

    if (NextNextID <> -1) then
       TSCSchedOnPlan(m_codeList[NextNextID]).m_AutoSeqPrevID := CurrentID;
    TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqNextID := NextNextID;
    TSCSchedOnPlan(m_codeList[CurrentID]).m_AutoSeqPrevID := NextID;
    TSCSchedOnPlan(m_codeList[NextID]).m_AutoSeqNextID := CurrentID;

  end;

end;

