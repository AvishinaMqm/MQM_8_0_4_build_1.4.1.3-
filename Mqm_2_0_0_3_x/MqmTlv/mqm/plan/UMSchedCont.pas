procedure TMSchedCont.LinkRequests(ProgBar: TMqmProgBar; Status: TStaticText);
var
  tbiIC,tbiPH:      ^TTblInfo;
  tHdr, tHdrToAdd: TSCProdReqHdr;
  qry: TMqmQuery;

  oldHdrCode: string;
  MachSetupCode: string;
  PrgHour, PrgMinute, PrgSecond, PrgMilliSecond, PrgPrevSecond : Word;
  PrgIndex, PrgBlock : integer;
begin
  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(2000);
    PrgBlock := trunc(2000/100) + 1;
    PrgIndex := 0;
    PrgPrevSecond := 0;
  end;

  if Assigned(Status) then
    Status.Caption := _('Linking requests...');

  Application.ProcessMessages;

  tbiIC := @tblInfo[tbl_prod_reqConnection];
  tbiPH := @tblInfo[tbl_prod_reqHdr];
//  SetFldPfx(tbiIC.pfx);

  qry := CreateQuery(Main_DB);

//  qry.Transaction.Active := true;

  with qry do
  begin

    SQL.Clear;
    SQL.Add('select * from ' + tbiIC.GetTableName);
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbiIC.pfx, fli_Identifier)));

    oldHdrCode := '';
    tHdr := nil;
    Open;

    Application.ProcessMessages;

    while not EOF do
    begin
      Application.ProcessMessages;

      if not Assigned(tHdr)
      or (tHdr.m_code <> FieldByName(CreateFld(tbiIC.pfx, fli_preqNo)).AsString) then
        tHdr := FindHdrFromCode(self, FieldByName(CreateFld(tbiIC.pfx, fli_preqNo)).AsString);

      if Assigned(tHdr) then
      begin
        tHdrToAdd := FindHdrFromCode(self, FieldByName(CreateFld(tbiIC.pfx, fli_PrevProdNum)).AsString);
        MachSetupCode := '';

        if Assigned(tHdrToAdd) then
          tHdr.AddLinkedRequest(tHdrToAdd, MachSetupCode);
      end;

      Next;

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;

      Application.ProcessMessages;
    end;
    Close;
  end;

  with qry do
  begin

    SQL.Clear;
{    SQL.Add('select ph1.'+CreateFld(tbiPH.pfx, fli_preqNo)+' PH1, ph2.'+CreateFld(tbiPH.pfx, fli_preqNo)+' PH2 ' +
            ' from ' + tbiPH.GetTableName + ' ph1 ' +
            ' join ' + tbiPH.GetTableName + ' ph2 on ph2.'+ CreateFld(tbiPH.pfx, fli_Identifier) +' = ph1.'+CreateFld(tbiPH.pfx, fli_Identifier)+' ' +
            ' and ph2.'+CreateFld(tbiPH.pfx, fli_Serving_Code)+' = ph1.'+CreateFld(tbiPH.pfx, fli_Served_Code) +
            ' where ph1.'+CreateFld(tbiPH.pfx, fli_Identifier)+' = '+IniAppGlobals.Identifier+' AND ph1.'+CreateFld(tbiPH.pfx, fli_Served_Code)+' <> ' + QuotedStr('') +
            ' and not exists '+
            ' (select 1 from '+ tbiIC.GetTableName +' where '+CreateFld(tbiIC.pfx, fli_Identifier)+' = ph1.'+CreateFld(tbiPH.pfx, fli_Identifier)+
            ' and '+CreateFld(tbiIC.pfx, fli_preqNo)+' = ph1.'+CreateFld(tbiPH.pfx, fli_preqNo)+' and '+CreateFld(tbiIC.pfx, fli_PrevProdNum)+' = ph2.'+CreateFld(tbiPH.pfx, fli_preqNo)+')');   }

    SQL.Add('select ph1.'+CreateFld(tbiPH.pfx, fli_preqNo)+' PH1, ph2.'+CreateFld(tbiPH.pfx, fli_preqNo)+' PH2 ' +
            ' from ' + tbiPH.GetTableName + ' ph1 ' +
            ' left join ' + tbiPH.GetTableName + ' ph2 on ph2.'+ CreateFld(tbiPH.pfx, fli_Identifier) +' = ph1.'+CreateFld(tbiPH.pfx, fli_Identifier)+' ' +
            ' and ph2.'+CreateFld(tbiPH.pfx, fli_Serving_Code)+' = ph1.'+CreateFld(tbiPH.pfx, fli_Served_Code) +
            ' where ph1.'+CreateFld(tbiPH.pfx, fli_Identifier)+' = '+IniAppGlobals.Identifier+' AND ph1.'+CreateFld(tbiPH.pfx, fli_Served_Code)+' <> ' + QuotedStr('') +
            ' and ph2.'+CreateFld(tbiPH.pfx, fli_preqNo) + ' is not null ' +
            ' and not exists '+
            ' (select 1 from '+ tbiIC.GetTableName +' where '+CreateFld(tbiIC.pfx, fli_Identifier)+' = ph1.'+CreateFld(tbiPH.pfx, fli_Identifier)+
            ' and '+CreateFld(tbiIC.pfx, fli_preqNo)+' = ph1.'+CreateFld(tbiPH.pfx, fli_preqNo)+' and '+CreateFld(tbiIC.pfx, fli_PrevProdNum)+' = ph2.'+CreateFld(tbiPH.pfx, fli_preqNo)+')');

    Open;

    tHdr := nil;

    while not EOF do
    begin
      Application.ProcessMessages;

      if not Assigned(tHdr)
      or (tHdr.m_code <> FieldByName('PH1').AsString) then
        tHdr := FindHdrFromCode(self, FieldByName('PH1').AsString);

//      tHdrToAdd := FindHdrFromCode(self, FieldByName(CreateFld(tbiPH.pfx, fli_preqNo) + '1').AsString);
      tHdrToAdd := FindHdrFromCode(self, FieldByName('PH2').AsString);
      if Assigned(tHdrToAdd) and Assigned(tHdr) then
         tHdr.AddLinkedRequest(tHdrToAdd, MachSetupCode);
      next;
    end;

  end;

  qry.Close;
  qry.Free;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';
  Application.ProcessMessages;
end;

