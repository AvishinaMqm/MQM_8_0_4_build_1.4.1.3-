function TMSchedCont.CheckItemAndProductForWarp(WarpId, Id : TSchedId; OnlyItem : boolean; var IdForItem : TSchedId; var MatQtyRequired : double) : boolean;
var
  ValWarpProduct, ValWarpItem, Request, step : variant;
  dataType: CBinColValType;
  J, I : integer;
  SonId : TSchedId;
  MachSetupCodeList :TMQMMacSetupList;
  TmpMacSetup: TMQMMachineSetup;
  IssuedAL: PTIssuedArt;
  MacSetupRec: TMacSetup;
  ArtList : TMQMIssuedArtList;
  ActArea : TMqmActArea;
  Warp    : TMqmWarp;
  WarpInfo: TPWarpInfo;
  MaterialSched : TSCMaterialSched;
  SameRequestStepLinked : boolean;
begin
  Result := false;
  p_sc.GetFldValue(WarpId, CSC_Mat_PRODUCT_CODE, ValWarpProduct, dataType);
  p_sc.GetFldValue(WarpId, CSC_Mat_Item_Type, ValWarpItem, dataType);

  p_sc.GetWarpInfo(WarpId, WarpInfo);
  MaterialSched := WarpInfo.MaterialSched;

  if WarpInfo.IsWarpLinkedToRequest and Assigned(MaterialSched) then
  begin
    p_sc.GetFldValue(Id, CSC_ProdReq, Request, dataType);
    p_sc.GetFldValue(Id, CSC_ProdStep, Step, dataType);
    SameRequestStepLinked := MaterialSched.CheckLinkRequest(Request, Step);
  end;

 // should be available on the new field in product table , so will be available for job id

  if p_sc.IsGroup(Id) then
  begin

    for I := 0 to GetGrpNumSons(id)-1 do
    begin
      SonId := p_sc.GetGrpSon(Id, I);
      if CheckItemAndProductForWarp(WarpId , SonId, OnlyItem, IdForItem, MatQtyRequired) then
      begin
        Result := true;
        Exit
      end;
    end;
    Exit;
  end;

  MachSetupCodeList := p_sc.GetStepIssMaterials(Id);

  if not assigned(MachSetupCodeList) then exit;

  for j:= 0 to MachSetupCodeList.p_count-1 do
  begin
    TmpMacSetup := MachSetupCodeList.p_Item[j];

    MacSetupRec.ResCat := TmpMacSetup.p_ResCatCode;
    MacSetupRec.ResCode := TmpMacSetup.p_ResCode;
    MacSetupRec.WrkCtrCode := TmpMacSetup.p_WrkCtrCode;

    ArtList := TmpMacSetup.m_IssuedArtList;
    for i:= 0 to ArtList.p_count - 1 do
    begin
      IssuedAL := ArtList.p_Item[i];
      if (ValWarpItem = IssuedAL.Article.p_ArtType.p_ArtTypeCode) and (Trim(ValWarpProduct) = IssuedAL.Article.p_ArtCode) then
      begin
        Result := true;
        MatQtyRequired := IssuedAL.RequiredQty;
        break
      end
      else if OnlyItem and (ValWarpItem = IssuedAL.Article.p_ArtType.p_ArtTypeCode) then
      begin
        IdForItem := Id;// not clear why i did it
        Result := true;
        break
      end;
    end;

  end;

  if result and WarpInfo.IsWarpLinkedToRequest then
     result := SameRequestStepLinked

end;

