        fWW_TypeOfUse                    := FieldByName(CreateFld(tbiww.pfx, fli_TypeOfUse));
        StepRefreshRow := 0;

        while not EOF do
        begin

          Req := fPH_preqNo.AsString;
          ReqStep := fPD_pstepId.AsInteger;

          if ChangeType = '4' then
            SignedStepRefreshHandled(Req, ReqStep, UpdateNr);
          try

            if fPH_ModulHandled.AsString = '1' then
            begin
              Next;
              Continue;
            end;

            if FirstRow or (Req <> PrevReq) then
              tHdr := FindHdrFromCode(self, Req);

            FirstRow := false;
            PrevReq := Req;

            if not Assigned(tHdr) then
            begin
              Next;
              Continue;
            end;

            tDet := tHdr.FindDetFromCode(ReqStep);
