procedure TMSchedCont.UpdateProgressStartTime(id: TSchedID; Start : TDateTime);
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    job.m_PrgSt := Start;
  end
  else
  begin
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      if not IsIdSimpleContinues(job.m_id) or ((job.m_ProgType <> '') and (job.m_PrgSt < Start)) then
      job.m_PrgSt := Start;
    end;
  end;
end;

