procedure TMSchedCont.UpdContGrpTimingsForAll(ProgBar: TMqmProgBar; Status: TStaticText);
var
  i,j:      integer;
  sc:     TSCSchedOnPlan;
  scProd: TSCProdSched;
begin
  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(m_codeList.Count);
  end;

  if Assigned(Status) then
    Status.Caption := _('Update group timing to all groups...');

  for i := 0 to m_codeList.Count-1 do
  begin
     Application.ProcessMessages;
    if Assigned(ProgBar) then
      ProgBar.SetPosition(i+1);
    if Assigned(m_codeList[i]) then
    begin
      sc := TSCSchedOnPlan(m_codeList[i]);
      if sc is TSCProdSched then
      begin
        scProd := TSCProdSched(sc);
        if Assigned(scProd.m_grp) then continue
      end
      else
      begin
        if TSCProdGroup(sc).m_isDeleted then continue;
        //Assert(TSCProdGroup(sc).m_list.Count > 0);
        if not (TSCProdGroup(sc).m_list.Count > 0) then exit;
        scProd := TSCProdSched(TSCProdGroup(sc).m_list[0]);
        if not assigned(sc.m_srvPtr) then continue;
        if not (sc is TSCProdSched) and (TSCProdSched(TSCProdGroup(sc).m_list[0]).m_reqDet.m_stepType = CST_Continuous) then
          UpdContGrpTimings(sc.m_Id, sc.m_Id);
      end;
    end
  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';
  Application.ProcessMessages;
end;

