function TMSchedCont.AddJobDet(det: pointer; code, grpCode: integer): pointer;
var
  job: TSCProdSched;
  grp: TSCProdGroup;
begin
  job := TSCProdSched.Create;
  job.m_code := code;
  job.m_Id   := m_codeList.Add(job);
  m_CloneCodeList.Add(job);

  job.m_reqDet := det;
  TSCProdReqDet(det).m_list.Add(job);

  // handle the group
  if grpCode <> CSnoGroupDef then
  begin
    grp := FindGroupFromCode(self, grpCode);
    if not Assigned(grp) then
    begin
      grp := TSCProdGroup.Create;
      grp.m_code := grpCode;
      grp.m_Id := m_codeList.Add(grp);
      m_CloneCodeList.Add(grp);
      m_grpList.Add(grp);
    end;

    job.m_grp := grp;
    grp.m_list.Add(job);
    grp.SortGroup;
  end;

  Result := job
end;

