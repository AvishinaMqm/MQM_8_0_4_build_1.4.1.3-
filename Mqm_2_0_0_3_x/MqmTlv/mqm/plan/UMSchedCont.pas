//  scGroup: TSCProdGroup;
  sc     : TSCSchedOnPlan;
begin
  Result := true;
  if id <> CSchedIdNull then
  begin
    sc := TSCSchedOnPlan(m_codeList[id]);
    sc := TSCProdSched(sc);
    sc.p_schedStart := 0;
