procedure TMSchedCont.UpdateBalanceQuantity(FromOrganize : boolean; SchedList : TMSchedList);
var
  I : integer;
  UpdateBalanceList : TMSchedList;
  ProdReq, OldProdReq : string;
  ProdStep, OldProdStep : integer;
  Id       : TSchedId;
  FieldVal : variant;
  dataType: CBinColValType;
begin
  if FromOrganize then
  begin
    SchedList := TMSchedList.create(self);
    for i := 0 to m_codeList.Count - 1 do
    begin
      if not IsProdSchedMaterial(TSCSchedOnPlan(m_codeList[i]).m_id) then
        SchedList.addLink(TSCSchedOnPlan(m_codeList[i]).m_id);
    end;
  end
  else
    UpdateBalanceList := TMSchedList.Create(self);

  OldProdReq := '';
  OldProdStep := 0;

  for i := 0 to SchedList.GetLinkCount-1 do
  begin
    Id := SchedList.GetLink(i);
    if (id <> CSchedIdNull) and (GetVisbleInBin(id) = CSB_ReadOnly) then continue;
    if TSCSchedOnPlan(m_codeList[id]).m_isDeleted then continue;
    p_sc.GetFldValue(Id, CSC_ProdReq, FieldVal, dataType);
    ProdReq := FieldVal;
    p_sc.GetFldValue(Id, CSC_ProdStep, FieldVal, dataType);
    ProdStep := FieldVal;
    if (ProdReq <> OldProdReq) or (ProdStep <> OldProdStep) then
    begin
      OldProdReq := ProdReq;
      OldProdStep := ProdStep;
      if ((p_sc.GetSchedObjStatus(id) = CSS_From_PG) or (p_sc.CheckSchedSumQty(id))) then
      begin
        p_sc.BalanceQuantity(Id, FromOrganize);
        if not FromOrganize then
        begin
          if Assigned(p_sc.GetExtLinkPtr(id)) then p_pl.RecalcTimings(id);
          UpdateBalanceList.AddLink(Id);
        end;
      end;
    end;
  end;

  if FromOrganize then
     SchedList.free
  else
  begin
    p_sc.UpdateBalancedQtyOnPlan(UpdateBalanceList);
    UpdateBalanceList.free;
  end;

end;

