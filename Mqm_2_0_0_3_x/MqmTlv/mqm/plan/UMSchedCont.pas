procedure TMSchedCont.UnscheduleClosedStepForDataChange(Hdr : TSCProdReqHdr ;Step : Integer; DispoList: TStringList);
var
  tDet    : TSCProdReqDet;
  tJob    : TSCProdSched;
  pd,ps   : Integer;
  actArea : TMqmActArea;
  extPtr  : TMqmActArea;
  Group_id   : TSchedId;
  Remove : boolean;
begin
  tJob := nil;
  tDet := nil;
  try
  for pd := 0 to Hdr.m_list.Count - 1 do
  begin
    Application.ProcessMessages;
    tDet := TSCProdReqDet(Hdr.m_list[pd]);
    if (tDet.m_code <> Step) then continue;

    for ps := 0 to tDet.m_list.Count - 1 do
    begin
      Application.ProcessMessages;
      Remove := false;
      tJob := TSCProdSched(tDet.m_list[ps]);
      if (DBAppGlobals.UnscheduleJobsOnStart = '2') and (tJob.m_ProgRsc = CSnoResCode) and (tJob.p_schedEnd < date) then continue;
      if assigned(tJob.m_grp) and (tJob.m_ProgRsc = CSnoResCode) then
      begin
        if GetGrpNumSons(tJob.m_grp.m_id) = 1 then
        begin
          Group_id := tJob.m_grp.m_id;
          extPtr := p_sc.GetExtLinkPtr(Group_id);
          if Assigned(extPtr) then
          begin
            actArea := TMqmActArea(extPtr);
            actArea.RemoveSchedObj(Group_id);
            Remove := true;
          end;
          RemoveJobFromGroup(tJob.m_id, 'Unscheduled on program start');
          DeleteGroup(Group_id);
        end
        else
        begin
          RemoveJobFromGroup(tJob.m_id, 'Unscheduled on program start');
        end;
      end
      else
      begin
        if Assigned(tJob.m_srvPtr) and (tJob.m_ProgRsc = CSnoResCode) then
        begin
          actArea := TMqmActArea(tJob.m_srvptr);
          if Assigned(actArea) then
          begin
            actArea.RemoveSchedObj(tjob.m_id);
            tJob.m_srvPtr := nil;
            tJob.m_ProgType := '';
            Remove := true;
          end;
        end
      end;
      if Remove then
      begin
        tJob.m_MsgFromHost := CSH_Jobs_unscheduled;
        DispoList.Add(_('Unschedule step:') + ' ' + IntTostr(tJob.m_reqDet.m_code) + ' ,' + _('Sub step:') + ' ' + IntTostr(tJob.m_code) + ' ' + _('in Request:') + ' ' + Hdr.m_code);
      end;
    end;
  end;

  except
    if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Unschedule Step Request For Data Changed:') +
              ' ' + _('Request:') + Hdr.m_code + ', ' + _('Step:') + IntToStr(tDet.m_code) + ', ' + _('Sub step:') + IntToStr(tJob.m_code) + '  ' + #13#10 +  ' Technical code: UMSchedCont:UnscheduleStepForDataChenge' , mtConfirmation, [mbOk], 0) = idOk then
    begin
      Exit;
    end;
  end;

end;

//----------------------------------------------------------------------------//

procedure TMSchedCont.UpdateClientForChanges(qry: TMqmQuery; findWC: TFindWrkCtrFunc;
                                             fLoad: TLinkJobFunc; DispoList: TStringList;
                                             ProgBar: TMqmProgBar);
//                                             ProgBar: TProgressBar);
type
  RecReqChanged = record
    ReqNo:  string;
    Step:   Integer;
    DwnNr:  Integer;
    ChangeType : string;
    Reactivate : Boolean;
    StepRefreshHandled : boolean;
  end;
  PReqChanged = ^RecReqChanged;
var
  tbiCR:      ^TTblInfo;
  tbiPD:      ^TTblInfo;
  tbiPH:      ^TTblInfo;
  tbiWW:      ^TTblInfo;
  tbiSP:      ^TTblInfo;
//  tbiPS:      ^TTblInfo;
  tbiPP:      ^TTblInfo;
  hdrCode   : string;
  tHdr:       TSCProdReqHdr;
  tDet:       TSCProdReqDet;
  PRecTiming : PTRecTiming;
  tJob, tJobFound :       TSCProdSched;
  tmpStr, ReqChecked, PrevRequest : string;
  I, P_d ,H_r, Index,  LastChange, StepChecked : Integer;
  ReqChanged : PReqChanged;
  Changed_Req_List : TList;
  TmpQty : double;
  OldJobUseType : CScBinView;
  countRealJobs , PosFirstRealJob : Integer;
  NewLastUpdatNr, PrevUpdatNr, CurrUpdateNr : integer;
  NewRequestExist, HistoricalRequestExist : boolean;
  HeaderFieldChangeExist, HeaderPropertyChangeExist, HeaderCosmeticChangeExist : boolean;
  NewStepExist : boolean;
  StepFieldChangeExist, StepPropertyChangeExist, StepCosmeticChangeExist : boolean;
//  WorkCentersHandledList, WorkCentersViewedList : String;
  ProgReqStepList : TStringlist;
  Rec : PReqChanged;
  ChangedReqInClause : string;
  UniqueReqCount : integer;

  procedure RefreshStepProgressTime(MainQry : TMqmQuery; UpdateNr : integer; ProgReq : string; ProgStep : integer);
  var
    tbiRS : ^TTblInfo;
    tbiST : ^TTblInfo;
    actArea : TMqmActArea;
//    oldHdrCode : string;
    ExecutionTime, SetupTime : double;
    IdGroup : TSchedId;
    IsGroup : boolean;
    ErrorReason : String;
    NewSubStep : integer;
    Req,PrevReq, step , substep, reprocess : string;
    FirstRow : boolean;
    hdrChecked: TSCProdReqHdr;
    detChecked: TSCProdReqDet;
    JobChecked: TSCProdSched;
    JobIndx, D : integer;
    SavedProgressEnd : TDateTime;
    SubStepList : TStringList;
    idx : Integer;
    RSPRowCount : Integer;
    fSP_preqno, fSP_pstepId, fSP_psubstId, fSP_reprocNo : TField;
    fSP_ProgressType, fSP_progrStart, fSP_prgCurrDate, fSP_progrEnd : TField;
    fSP_quant, fSP_prgRemTime, fSP_rsc, fSP_StartingQty : TField;
    fSP_ProgressTypeHost, fSP_progrStartHost, fSP_prgCurrDateHost : TField;
    fSP_progrEndHost, fSP_quantHost, fSP_prgRemTimeHost, fSP_rscHost : TField;
    fST_Exec0, fST_Setup0, fST_Exec1, fST_Setup1 : TField;
    fST_Exec2, fST_Setup2, fST_Exec3, fST_Setup3 : TField;
    fRS_NumOfRsc : TField;
    fWW_TypeOfUse : TField;

  begin
    tbiWW := @tblInfo[tbl_wkst_wkc];
    tbiSP := @tblInfo[tbl_sched_progress];
    tbiPD := @tblInfo[tbl_prod_step];
    tbiRS := @tblInfo[tbl_res];
    tbiST := @tblInfo[tbl_Step_times];
    FirstRow := true;

    try

      if ProgReq <> '' then
      begin
        if not ProgReqStepList.Find(ProgReq + IntToStr(ProgStep), idx) then
        begin
          hdrChecked := FindHdrFromCode(self, ReqChecked);
          if not Assigned(hdrChecked) then exit;
          detChecked := hdrChecked.FindDetFromCode(StepChecked);
          if not Assigned(detChecked) then exit;

          for JobIndx := 0 to detChecked.m_list.Count - 1 do
          begin
            JobChecked := TSCProdSched(detChecked.m_list[JobIndx]);
            if JobChecked.m_isDeleted then continue;
            if CProgress(p_sc.IsProgressed(JobChecked.m_id)) <> prg_none then
            begin
              JobChecked.m_PrgSt          := 0;
              JobChecked.m_PrgCurDt       := 0;
              JobChecked.m_PrgEd          := 0;
              JobChecked.m_PrgQty         := 0;
              JobChecked.m_PrgStartingQty := 0;
              JobChecked.m_PrgRemTime     := -1;
              JobChecked.m_ProgType       := '';
              JobChecked.m_ProgRsc        := '';
              JobChecked.m_ProgSaved      := false;
            end;
          end;
        end;
        Exit;
      end;

      SubStepList := TStringList.create;

      with MainQry.sql do
      begin
        Clear;
        Add('select');
        Add(' '     + tbiSP.GetTableName + '.*' + ',' + tbiRS.GetTableName + '.*' + ','  + tbiPD.GetTableName + '.*' + ','     + tbiWW.GetTableName + '.*,');
        Add('PST0.' + CreateFld(tbiST.pfx, fli_SetUpTimJob) + ' as ST_Setup0, ' + 'PST0.' + CreateFld(tbiST.pfx, fli_ExecTimeInitQty) + ' as ST_Exec0, ');
        Add('PST1.' + CreateFld(tbiST.pfx, fli_SetUpTimJob) + ' as ST_Setup1, ' + 'PST1.' + CreateFld(tbiST.pfx, fli_ExecTimeInitQty) + ' as ST_Exec1, ');
        Add('PST2.' + CreateFld(tbiST.pfx, fli_SetUpTimJob) + ' as ST_Setup2, ' + 'PST2.' + CreateFld(tbiST.pfx, fli_ExecTimeInitQty) + ' as ST_Exec2, ');
        Add('PST3.' + CreateFld(tbiST.pfx, fli_SetUpTimJob) + ' as ST_Setup3, ' + 'PST3.' + CreateFld(tbiST.pfx, fli_ExecTimeInitQty) + ' as ST_Exec3');
        if ChangedReqInClause <> '' then
        begin
          Add(' from ' + tbiSP.GetTableName + ' inner join ' + tbiRS.GetTableName);
        end
        else
        begin
          Add(' from ' + tbiSP.GetTableName + ' inner join ' + tbiCR.GetTableName);
          Add(' on  ' + CreateFld(tbiCR.pfx, fli_pstepId) + '=' + '0' + ' and ' + CreateFld(tbiCR.pfx, fli_updCode) + '=' + IntToStr(UpdateNr));
          Add(' and ' + CreateFld(tbiCR.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier));
          Add(' and ' + CreateFld(tbiCR.pfx, fli_preqNo) + '=' + CreateFld(tbiSP.pfx, fli_preqNo) + ' inner join ' + tbiRS.GetTableName);
        end;
        Add(' on ' + CreateFld(tbiRS.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier) + ' AND ' + CreateFld(tbiRS.pfx, fli_rsc) + '=' + CreateFld(tbiSP.pfx, fli_rsc) + ' inner join ' + tbiWW.GetTableName);
        Add(' on  ' + CreateFld(tbiWW.pfx, fli_wkstCode)  + '=' + QuotedStr(IniAppGlobals.WkstCode));
        Add(' and ' + CreateFld(tbiWW.pfx, fli_Identifier) + '=' + CreateFld(tbiRS.pfx, fli_Identifier));
        Add(' and ' + CreateFld(tbiWW.pfx, fli_wkCtrCode) + '=' + CreateFld(tbiRS.pfx, fli_wkCtrCode));
        Add(' and ' + CreateFld(tbiWW.pfx, fli_Visible)  + '<>' + QuotedStr('0') + ' inner join ' + tbiPD.GetTableName);
    //    Add(' on  ' + CreateFld(tbiPD.pfx, fli_ToBeSched) + '<>' + QuotedStr('0'));
        if DBAppGlobals.MCM_App then
          Add(' on  ' + CreateFld(tbiPD.pfx, fli_SchedulByMcm) + '=' + QuotedStr('1'))
        else
          Add(' on  ' + CreateFld(tbiPD.pfx, fli_SchedulByMqm) + '=' + QuotedStr('1'));

        Add(' and ' + CreateFld(tbiPD.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier));
        Add(' and ' + CreateFld(tbiPD.pfx, fli_preqNo) + '=' + CreateFld(tbiSP.pfx, fli_preqNo));
        Add(' and ' + CreateFld(tbiPD.pfx, fli_pstepId) + '=' + CreateFld(tbiSP.pfx, fli_pstepId) + ' left join ' + tbiST.GetTableName + ' PST0');
        Add(' on  ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier));
        Add(' and ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_preqNo) + '=' + CreateFld(tbiSP.pfx, fli_preqNo));
        Add(' and ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_pstepId) + '=' + CreateFld(tbiSP.pfx, fli_pstepId));
        Add(' and ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_wkCtrCode) + '=' + CreateFld(tbiRS.pfx, fli_wkCtrCode));
        Add(' and ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_RscCat) + '=' + QuotedStr(''));
      //  Add(' and ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_MachSetupCode) + '=' + QuotedStr(''));
        Add(' and ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_rsc) + '<>' + QuotedStr(''));
        Add(' and ' + 'PST0' + '.' + CreateFld(tbiST.pfx, fli_rsc) + '=' + CreateFld(tbiSP.pfx, fli_rsc) + ' left join ' + tbiST.GetTableName + ' PST1');
        Add(' on  ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier));
        Add(' and ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_preqNo) + '=' + CreateFld(tbiSP.pfx, fli_preqNo));
        Add(' and ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_pstepId) + '=' + CreateFld(tbiSP.pfx, fli_pstepId));
        Add(' and ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_wkCtrCode) + '=' + CreateFld(tbiRS.pfx, fli_wkCtrCode));
        Add(' and ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_RscCat) + '<>' + QuotedStr(''));
        Add(' and ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_RscCat) + '=' + CreateFld(tbiRS.pfx, fli_RscCat));
      //  Add(' and ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_MachSetupCode) + '=' + QuotedStr(''));
        Add(' and ' + 'PST1' + '.' + CreateFld(tbiST.pfx, fli_Rsc) + '=' + QuotedStr('') + ' left join ' + tbiST.GetTableName + ' PST2');
        Add(' on  ' + 'PST2' + '.' + CreateFld(tbiST.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier));
        Add(' and ' + 'PST2' + '.' + CreateFld(tbiST.pfx, fli_preqNo) + '=' + CreateFld(tbiSP.pfx, fli_preqNo));
        Add(' and ' + 'PST2' + '.' + CreateFld(tbiST.pfx, fli_pstepId) + '=' + CreateFld(tbiSP.pfx, fli_pstepId));
        Add(' and ' + 'PST2' + '.' + CreateFld(tbiST.pfx, fli_wkCtrCode) + '=' + CreateFld(tbiRS.pfx, fli_wkCtrCode));
        Add(' and ' + 'PST2' + '.' + CreateFld(tbiST.pfx, fli_RscCat) + '=' + QuotedStr(''));
      //  Add(' and ' + 'PST2' + '.' + CreateFld(tbiST.pfx, fli_MachSetupCode) + '=' + QuotedStr(''));
        Add(' and ' + 'PST2' + '.' + CreateFld(tbiST.pfx, fli_Rsc) + '=' + QuotedStr('') + ' left join ' + tbiST.GetTableName + ' PST3');
        Add(' on  ' + 'PST3' + '.' + CreateFld(tbiST.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier));
        Add(' and ' + 'PST3' + '.' + CreateFld(tbiST.pfx, fli_preqNo) + '=' + CreateFld(tbiSP.pfx, fli_preqNo));
        Add(' and ' + 'PST3' + '.' + CreateFld(tbiST.pfx, fli_pstepId) + '=' + CreateFld(tbiSP.pfx, fli_pstepId));
        Add(' and ' + 'PST3' + '.' + CreateFld(tbiST.pfx, fli_wkCtrCode) + '=' + QuotedStr(''));
        Add(' and ' + 'PST3' + '.' + CreateFld(tbiST.pfx, fli_RscCat) + '=' + QuotedStr(''));
      //  Add(' and ' + 'PST3' + '.' + CreateFld(tbiST.pfx, fli_MachSetupCode) + '=' + QuotedStr(''));
        Add(' and ' + 'PST3' + '.' + CreateFld(tbiST.pfx, fli_Rsc) + '=' + QuotedStr(''));
        Add(WHERE_IDF_Condition(CreateFld(tbiSP.pfx, fli_Identifier)));
        if ChangedReqInClause <> '' then
          Add(' AND ' + CreateFld(tbiSP.pfx, fli_preqNo) + ' IN (' + ChangedReqInClause + ') ');
        Add(' order by ' + CreateFld(tbiSP.pfx, fli_preqNo) + ',' + CreateFld(tbiSP.pfx, fli_pstepId) + ',' + CreateFld(tbiSP.pfx, fli_psubstId) + ',' + CreateFld(tbiSP.pfx, fli_reprocNo));
        ErrorReason := '02';
        MainQry.FetchOptions.RowsetSize := 5000;
        MainQry.open;
        Application.ProcessMessages;
      end;
      ErrorReason := ErrorReason + '03';
  //    oldHdrCode := '';
      if MainQry.EOF then Exit;
      fSP_preqno          := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_preqno));
      fSP_pstepId         := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_pstepId));
      fSP_psubstId        := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_psubstId));
      fSP_reprocNo        := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_reprocNo));
      fSP_ProgressType    := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_ProgressType));
      fSP_progrStart      := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_progrStart));
      fSP_prgCurrDate     := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_prgCurrDate));
      fSP_progrEnd        := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_progrEnd));
      fSP_quant           := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_quant));
      fSP_prgRemTime      := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_prgRemTime));
      fSP_rsc             := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_rsc));
      fSP_StartingQty     := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_StartingQty));
      fSP_ProgressTypeHost := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_ProgressTypeHost));
      fSP_progrStartHost  := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_progrStartHost));
      fSP_prgCurrDateHost := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_prgCurrDateHost));
      fSP_progrEndHost    := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_progrEndHost));
      fSP_quantHost       := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_quantHost));
      fSP_prgRemTimeHost  := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_prgRemTimeHost));
      fSP_rscHost         := MainQry.FieldByName(CreateFld(tbiSP.pfx, fli_rscHost));
      fST_Exec0  := MainQry.FieldByName('ST_Exec0');
      fST_Setup0 := MainQry.FieldByName('ST_Setup0');
      fST_Exec1  := MainQry.FieldByName('ST_Exec1');
      fST_Setup1 := MainQry.FieldByName('ST_Setup1');
      fST_Exec2  := MainQry.FieldByName('ST_Exec2');
      fST_Setup2 := MainQry.FieldByName('ST_Setup2');
      fST_Exec3  := MainQry.FieldByName('ST_Exec3');
      fST_Setup3 := MainQry.FieldByName('ST_Setup3');
      fRS_NumOfRsc := MainQry.FieldByName(CreateFld(tbiRS.pfx, fli_NumOfRsc));
      fWW_TypeOfUse := MainQry.FieldByName(CreateFld(tbiww.pfx, fli_TypeOfUse));
      RSPRowCount := 0;

      while not MainQry.EOF do
      begin

        try
          ErrorReason := '';
        Req := fSP_preqno.AsString;

        if FirstRow or (Req <> PrevReq) then
           tHdr := FindHdrFromCode(self, Req);
        FirstRow := false;
        PrevReq := Req;

        if not Assigned(tHdr) then
        begin
          MainQry.Next;
          Continue;
        end;

        ErrorReason := ErrorReason + '04';
        ExecutionTime := 0;
        SetupTime := 0;
        if not fST_Exec0.IsNull then
        begin
          SetupTime := fST_Setup0.AsFloat;
          ExecutionTime := fST_Exec0.AsFloat;
        end
        else
        begin
          if not fST_Exec1.IsNull then
          begin
            SetupTime := fST_Setup1.AsFloat;
            ExecutionTime := fST_Exec1.AsFloat;
          end
          else
          begin
            if not fST_Exec2.IsNull then
            begin
              SetupTime := fST_Setup2.AsFloat;
              ExecutionTime := fST_Exec2.AsFloat;
            end
            else
            begin
              if not fST_Exec3.IsNull then
              begin
                SetupTime := fST_Setup3.AsFloat;
                ExecutionTime := fST_Exec3.AsFloat;
              end;
            end;
          end;
        end;

        ErrorReason := ErrorReason + '05';
        tDet := tHdr.FindDetFromCode(fSP_pstepId.AsInteger);
        if not Assigned(tDet) then
        begin
          MainQry.Next;
          Continue;
        end;
        step := IntToStr(fSP_pstepId.AsInteger);
        substep := IntToStr(fSP_psubstId.AsInteger);
        reprocess := IntToStr(fSP_reprocNo.AsInteger);
        SubStepList.add(substep);

        if Assigned(tDet) then
        begin
          ErrorReason := ErrorReason + '06';
          tjob := tDet.FindJobFromCode(fSP_psubstId.AsInteger, fSP_reprocNo.AsInteger);
          if Assigned(tjob) and (tJob.p_GetStepType <> '') then//and (not tjob.m_fromPD) (tJob.p_GetStepType <> '0') then
          begin
              ErrorReason := ErrorReason + '07';
            if (tjob.m_ProgressOverride = Prg_Ignored) or (tjob.m_ProgressOverride = Prg_IgnoredAndSave) then
            begin
              if (tJob.m_ProgTypeHost   = fSP_ProgressType.AsString) and
                 (tJob.m_PrgStHost      = fSP_progrStart.AsDateTime) and
                 (tJob.m_PrgCurDtHost   = fSP_prgCurrDate.AsDateTime) and
                 (tJob.m_PrgEdHost      = fSP_progrEnd.AsDateTime) and
                 (tJob.m_PrgQtyHost     = fSP_quant.AsFloat) and
                 (tJob.m_PrgRemTimeHost = fSP_prgRemTime.AsFloat) and
                 (tJob.m_ProgRscHost    = trim(fSP_rsc.AsString)) then
              begin
                MainQry.next;
                continue;
              end;
            end;
            tJob.m_PrgSt          := fSP_progrStart.AsDateTime;
            tJob.m_PrgCurDt       := fSP_prgCurrDate.AsDateTime;
            tJob.m_PrgEd          := fSP_progrEnd.AsDateTime;
            tJob.m_PrgQty         := fSP_quant.AsFloat;
            tJob.m_PrgStartingQty := fSP_StartingQty.AsFloat;
            tJob.m_PrgRemTime     := fSP_prgRemTime.AsFloat;
            tJob.m_ProgType       := fSP_ProgressType.AsString;
            tJob.m_ProgRsc        := trim(fSP_rsc.AsString);
            tJob.m_ProgTypeHost   := fSP_ProgressTypeHost.AsString;
            tJob.m_PrgStHost      := fSP_progrStartHost.AsDateTime;
            tJob.m_PrgCurDtHost   := fSP_prgCurrDateHost.AsDateTime;
            tJob.m_PrgEdHost      := fSP_progrEndHost.AsDateTime;
            tJob.m_PrgQtyHost     := fSP_quantHost.AsFloat;
            tJob.m_PrgRemTimeHost := fSP_prgRemTimeHost.AsFloat;
            tJob.m_ProgRscHost    := trim(fSP_rscHost.AsString);
            tJob.m_ProgTypeOrig   := fSP_ProgressType.AsString;
            tJob.m_PrgStOrig      := fSP_progrStart.AsDateTime;
            tJob.m_PrgCurDtOrig   := fSP_prgCurrDate.AsDateTime;
            tJob.m_PrgEdOrig      := fSP_progrEnd.AsDateTime;
            tJob.m_PrgQtyOrig     := fSP_quant.AsFloat;
            tJob.m_PrgStartingQtyOrig := fSP_StartingQty.AsFloat;
            tJob.m_PrgRemTimeOrig := fSP_prgRemTime.AsFloat;
            tJob.m_ProgRscOrig    := trim(fSP_rsc.AsString);
            tJob.m_ProgSaved      := false;

            tJob.m_ProgressOverride := Prg_NotIgnored;
              ErrorReason := ErrorReason + '08';
            if ExecutionTime = 0 then ExecutionTime := 1 / 60;
            tJob.p_supMinBase := SetupTime;

          //  if (p_sc.GetLearningCurveType(tjob.m_Id) <> CSC_No) and (p_sc.GetLearningCurveCode(tjob.m_Id) <> '') then
          //     ExecutionTime := ExecutionTime + GetAddtionalTimeExeForCurve(tjob.m_Id ,ExecutionTime, 0);

            if (tDet.m_stepType = CST_continuous) then
              tJob.p_exeMin := ExecutionTime * tJob.p_quantSched / tDet.m_quantInit
            else
              tJob.p_exeMin := ExecutionTime;  // batch

            tJob.m_updateLearningCurve := true;

            if (tJob.m_numOfRscComp <> 0) and (tJob.m_subLinRscId > 0) then
              tJob.p_exeMin := tJob.p_ExeMinIgnoreProgress/tJob.m_numOfRscComp;

            ErrorReason := ErrorReason + '09';

            NewSubstep := -1;
            TmpQty := tJob.p_quantSched + tJob.p_quantManualChg;
            if ((tJob.m_ProgType = '4') or (tJob.m_ProgType = '5'))
            and (TmpQty > tJob.m_PrgQty) //if it is a progress with split
            and not (CheckSchedSumQty(tJob.m_Id)) then
              NewSubstep := GetNewSubStep (tJob.m_reqDet);

            if NewSubstep >= 0 then
            begin
              tJob.m_status := CSS_modi;
              if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_exeMin > 0) then
                 tJob.p_exeMin := tJob.m_PrgQty / tJob.p_quantSched * tJob.p_exeMin;
              if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_supMinBase > 0) then
                 tJob.p_supMinBase :=  tJob.m_PrgQty / tJob.p_quantSched * tJob.p_supMinBase;
              tJob.p_quantSched := tJob.m_PrgQty;
              tJob.p_quantManualChg := 0;
              TmpQty := TmpQty - tJob.m_PrgQty;
              OldJobUseType := tJob.m_VisbleInBin;
              if (tJob.m_VisbleInBin = CSB_ReadOnly) then
                tJob.m_status := CSS_none;

              //Create a new job because of a final progress with split
              tDet.m_list.Sort(SortSubStep);
              if (tJob.m_ProgType = '4') then
                tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef)
              else if (tJob.m_ProgType = '5') then
              begin
                SavedProgressEnd := tJob.m_PrgEd;
                tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef);
                tJob.p_schedStart := SavedProgressEnd;
                tJob.p_SetStepType    := '2';
                tJob.p_rscCode := Trim(fSP_rsc.AsString);
                tJob.p_exeMin := ExecutionTime;
              end;

              tJob.m_VisbleInBin  := OldJobUseType;
              tJob.m_status := CSS_new;
              tJob.p_quantSched := TmpQty;
            end;

            if Assigned(tJob.m_srvPtr) and not Assigned(tJob.m_grp) then
            begin
              actArea := TMqmActArea(tJob.m_srvptr);
              if Assigned(actArea) then
              begin
                actArea.RemoveSchedObj(tjob.m_id);
                tJob.m_srvPtr := nil;
              end;
            end

            else if Assigned(tJob.m_srvPtr) and Assigned(tJob.m_grp) then
            begin
              actArea := TMqmActArea(tJob.m_grp.m_srvPtr);
              if Assigned(actArea) then
              begin
                actArea.RemoveSchedObj(tJob.m_grp.m_Id);
                tJob.m_srvPtr := nil;
              end;
            end;

            IdGroup := p_sc.LinesBelongToGroup(tjob.m_id, isGroup);
            if isGroup then
            begin
              fLoad(tJob.m_ProgRsc, IdGroup, nil);
              if (tJob.m_reqDet.m_stepType = CST_Continuous) and Assigned(tJob.m_grp) then
                 UpdContGrpTimings(tJob.m_grp.m_Id, tJob.m_Id);
              SortGroup(IdGroup);
            end
            else
              fLoad(tJob.m_ProgRsc, tJob.m_Id, nil);
            if (tJob.m_VisbleInBin = CSB_ReadOnly) then
              tJob.m_status := CSS_none;

//            Result := true;
            SetOvlpUpdate(tjob.m_Id, true);
            MainQry.next;
            continue;
          end;
        end;
          ErrorReason := ErrorReason + '10';

        if (ExecutionTime = 0) then
        begin
          MainQry.Next;
          continue;
        end;
          ErrorReason := ErrorReason + '11';
        if ((fSP_psubstId.AsInteger > 0) or
            (fSP_reprocNo.AsInteger > 0)) then
        begin
            ErrorReason := ErrorReason + '12';
          tjob := tDet.FindJobFromCode(fSP_psubstId.AsInteger, fSP_reprocNo.AsInteger);
        end;
          ErrorReason := ErrorReason + '13';
        if (tjob = nil) and
           ((fSP_psubstId.AsInteger > 0) or
            (fSP_reprocNo.AsInteger > 0)) then
        begin
            ErrorReason := ErrorReason + '14';
          tJob := AddJobDet(tDet, fSP_psubstId.AsInteger, CSnoGroupDef);
          tJob.m_reprocNo := fSP_reprocNo.AsInteger;
          if (fWW_TypeOfUse.AsString = '2') then
            tJob.m_VisbleInBin := CSB_ReadOnly
          else
            tJob.m_VisbleInBin := CSB_Normal;
          tJob.m_fromPD         := true;
          tJob.m_status         := CSS_From_PG;
          tJob.m_subLinRscId    := 0;
          tJob.m_srvPtr         := nil;
         // tJob.m_reprocNo       := 0;
          tJob.p_SetStepType    := '2';
          tJob.m_comment        := '';
          tJob.p_WorkCenter     := '';
          tJob.p_Process        := '';
          tJob.p_NewSetup  := -1;
          if (fSP_quant.AsFloat > 1) then
            tJob.p_quantSched  := fSP_quant.AsFloat
          else
            tJob.p_quantSched  := 1;
          tJob.p_supMinBase     := 0;
          tJob.p_supMinReal     := 0;
          tJob.p_supMinOvlp     := 0;
          tJob.m_fwdConnSubStp  := -2;
          tJob.m_fwdConnReProcs := -2;
          tJob.m_bkwConnSubStp  := -2;
          tJob.m_bkwConnReProcs := -2;
          tJob.m_TimeDescr      := '';
          tJob.m_MachSetupCode  := '';
          tJob.p_quantManualChg := 0;
        end
        else
        begin
          if not assigned(tDet) then ErrorReason := ErrorReason + '15x' else ErrorReason := ErrorReason + '15';
            tjob := tDet.FindJobFromCode(fSP_psubstId.AsInteger, fSP_reprocNo.AsInteger);
          if (tjob = nil) and assigned(tDet) then
          begin
            tJob := AddJobDet(tDet, fSP_psubstId.AsInteger, CSnoGroupDef);
            tJob.m_reprocNo := fSP_reprocNo.AsInteger;
            if (fWW_TypeOfUse.AsString = '2') then
              tJob.m_VisbleInBin := CSB_ReadOnly
            else
              tJob.m_VisbleInBin := CSB_Normal;
            tJob.m_fromPD         := true;
            tJob.m_status         := CSS_From_PG;
            tJob.m_subLinRscId    := 0;
            tJob.m_srvPtr         := nil;
           // tJob.m_reprocNo       := 0;
            tJob.p_SetStepType    := '2';
            tJob.m_comment        := '';
            tJob.p_WorkCenter     := '';
            tJob.p_Process        := '';
            tJob.p_NewSetup  := -1;
            if (fSP_quant.AsFloat > 1) then
              tJob.p_quantSched  := fSP_quant.AsFloat
            else
              tJob.p_quantSched  := 1;
            tJob.p_supMinBase     := 0;
            tJob.p_supMinReal     := 0;
            tJob.p_supMinOvlp     := 0;
            tJob.m_fwdConnSubStp  := -2;
            tJob.m_fwdConnReProcs := -2;
            tJob.m_bkwConnSubStp  := -2;
            tJob.m_bkwConnReProcs := -2;
            tJob.m_TimeDescr      := '';
            tJob.m_MachSetupCode  := '';
            tJob.p_quantManualChg := 0;
          end
          else
          begin
            MainQry.Next;
            continue;
          end;

        end;
        ErrorReason := ErrorReason + '16';
        tJob.m_PrgSt          := fSP_progrStart.AsDateTime;
        tJob.m_PrgCurDt       := fSP_prgCurrDate.AsDateTime;
        tJob.m_PrgEd          := fSP_progrEnd.AsDateTime;
        tJob.m_PrgQty         := fSP_quant.AsFloat;
        tJob.m_PrgStartingQty := fSP_StartingQty.AsFloat;
        tJob.m_PrgRemTime     := fSP_prgRemTime.AsFloat;
        tJob.m_ProgType       := fSP_ProgressType.AsString;
        tJob.m_ProgRsc        := fSP_rsc.AsString;
        tJob.m_ProgTypeHost   := fSP_ProgressTypeHost.AsString;
        tJob.m_PrgStHost      := fSP_progrStartHost.AsDateTime;
        tJob.m_PrgCurDtHost   := fSP_prgCurrDateHost.AsDateTime;
        tJob.m_PrgEdHost      := fSP_progrEndHost.AsDateTime;
        tJob.m_PrgQtyHost     := fSP_quantHost.AsFloat;
        tJob.m_PrgRemTimeHost := fSP_prgRemTimeHost.AsFloat;
        tJob.m_ProgRscHost    := fSP_rscHost.AsString;
        tJob.m_ProgTypeOrig   := fSP_ProgressType.AsString;
        tJob.m_PrgStOrig      := fSP_progrStart.AsDateTime;
        tJob.m_PrgCurDtOrig   := fSP_prgCurrDate.AsDateTime;
        tJob.m_PrgEdOrig      := fSP_progrEnd.AsDateTime;
        tJob.m_PrgQtyOrig     := fSP_quant.AsFloat;
        tJob.m_PrgStartingQty := fSP_StartingQty.AsFloat;
        tJob.m_PrgStartingQtyOrig := fSP_StartingQty.AsFloat;
        tJob.m_PrgRemTimeOrig := fSP_prgRemTime.AsFloat;
        tJob.m_ProgRscOrig    := fSP_rsc.AsString;
        tJob.m_ProgSaved      := false;

        tjob.m_ProgressOverride := Prg_NotIgnored;

          ErrorReason := ErrorReason + '17';
      //  if (p_sc.GetLearningCurveType(tjob.m_Id) <> CSC_No) and (p_sc.GetLearningCurveCode(tjob.m_Id) <> '') then
      //     ExecutionTime := ExecutionTime + GetAddtionalTimeExeForCurve(tjob.m_Id ,ExecutionTime, 0);

        if (tjob.m_reqDet.m_stepType = CST_continuous) then
          tJob.p_exeMin := (tJob.p_quantSched * ExecutionTime/tDet.m_quantInit)
        else
          tJob.p_exeMin := ExecutionTime;

       /// avi
        if fRS_NumOfRsc.AsFloat > 0 then
        begin
          tjob.m_subLinRscId := 1;
          if tJob.m_numOfRscComp > 0 then
            tJob.p_exeMin := tJob.p_exeMin/tJob.m_numOfRscComp
          else
          begin
            tJob.p_exeMin := tJob.p_exeMin/fRS_NumOfRsc.AsFloat;
            tJob.m_numOfRscComp := fRS_NumOfRsc.AsInteger;
          end;
        end;
       // avi

        tJob.m_updateLearningCurve := true;

        if tJob.p_exeMin = 0 then
           tJob.p_exeMin := 1;

        if Assigned(tJob.m_srvPtr) then
        begin
          actArea := TMqmActArea(tJob.m_srvptr);
          if Assigned(actArea) then
          begin
            actArea.RemoveSchedObj(tjob.m_id);
            tJob.m_srvPtr := nil;
          end;
        end;

        IdGroup := p_sc.LinesBelongToGroup(tjob.m_id, isGroup);
        if isGroup then
          fLoad(tJob.m_ProgRsc, IdGroup, nil)
        else
          fLoad(tJob.m_ProgRsc, tJob.m_Id, nil);

        if (tJob.m_VisbleInBin = CSB_ReadOnly) then
          tJob.m_status := CSS_none;
   //     Result := true;
          ErrorReason := ErrorReason + '18';

        NewSubstep := -1;
        TmpQty := tJob.p_quantSched + tJob.p_quantManualChg;
        if ((tJob.m_ProgType = '4') or (tJob.m_ProgType = '5'))
        and (TmpQty > tJob.m_PrgQty) //if it is a progress with split
        and not (CheckSchedSumQty(tJob.m_Id)) then
           NewSubstep := GetNewSubStep(tJob.m_reqDet);

        if NewSubstep >= 0 then
        begin
          if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_exeMin > 0) then
                tJob.p_exeMin := tJob.m_PrgQty / tJob.p_quantSched * tJob.p_exeMin;
          if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_supMinBase > 0) then
               tJob.p_supMinBase :=  tJob.m_PrgQty / tJob.p_quantSched * tJob.p_supMinBase;
          tJob.p_quantSched := tJob.m_PrgQty;
          tJob.p_quantManualChg := 0;
          TmpQty := TmpQty - tJob.m_PrgQty;
          OldJobUseType := tJob.m_VisbleInBin;

            //Create a new job because of a final progress with split
          tDet.m_list.Sort(SortSubStep);
          if (tJob.m_ProgType = '4') then
            tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef)
          else if (tJob.m_ProgType = '5') then
          begin
            SavedProgressEnd := tJob.m_PrgEd;
            tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef);
            tJob.p_schedStart := SavedProgressEnd;
            tJob.p_SetStepType    := '2';
            tJob.p_rscCode := Trim(fSP_rsc.AsString);
            tJob.p_exeMin := ExecutionTime;
          end;

          tJob.m_VisbleInBin  := OldJobUseType;

          tJob.m_status := CSS_new;
          tJob.p_quantSched := TmpQty;
          if (tJob.m_VisbleInBin = CSB_ReadOnly) then
            tJob.m_status := CSS_none;
        end;
        ErrorReason := ErrorReason + '19';
        MainQry.next;
        Inc(RSPRowCount);
        if (RSPRowCount mod 200 = 0) then Application.ProcessMessages;

    except

      if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Refresh Step Progress & Time:') +
                     ' ' + 'Req : ' + Req + ' - Step : ' + step + ' - Sup Step : ' + substep + ' - ReProcess : ' + reprocess + '  ' +
                        ' Technical code: UMSchedCont:RefreshStepProgressTime Code : ' + ErrorReason + ' ' + #13#10 + MainQry.SQL.Text , mtConfirmation, [mbOk], 0) = idOk then
          begin
            MainQry.next;
            continue;
          end;
        end;
      end;
    except
      if MessageDlg(_('An general rror occured while refreshing.') +
         ' Technical code: UMSchedCont:RefreshStepProgressTime: ' + #13#10 + MainQry.SQL.Text , mtConfirmation, [mbOk], 0) = idOk then
      begin
        Exit;
      end;
    end;

    // We commented this part because of 2 reasons // version '8 0 4 build 1.2.5.8';
    // 1. It is done only for the last step update - very strange.
    // 2. It supposes to unschedule only those that had progress and it unschedule all.
    // It is the safest to simply comment it all , the maximum that will happen is that progressed job that its progress was deleted - will stay on gantt.

    {try
    if Assigned(tDet) then
    begin
      for D := 0 to tDet.m_list.Count - 1 do
      begin
        tJob := TSCProdSched(tDet.m_list[D]);
        if tJob.m_isdeleted then continue;
        if (SubStepList.indexof(IntToStr(tJob.m_code)) <> - 1) then continue;

        if (CProgress(p_sc.IsProgressed(tJob.m_id)) <> prg_none) then
        begin
          tJob.m_PrgSt          := 0;
          tJob.m_PrgCurDt       := 0;
          tJob.m_PrgEd          := 0;
          tJob.m_PrgQty         := 0;
          tJob.m_PrgStartingQty := 0;
          tJob.m_PrgRemTime     := -1;
          tJob.m_ProgType       := '';
          tJob.m_PrgStHost      := 0;
          tJob.m_PrgCurDtHost   := 0;
          tJob.m_PrgEdHost      := 0;
          tJob.m_PrgQtyHost     := 0;
          tJob.m_PrgRemTimeHost := -1;
          tJob.m_ProgTypeHost   := '';
          tJob.m_ProgSaved      := false;
        end;

        if Assigned(tJob.m_srvPtr) and not Assigned(tJob.m_grp) then
        begin
          actArea := TMqmActArea(tJob.m_srvptr);
          if Assigned(actArea) then
          begin
            actArea.RemoveSchedObj(tjob.m_id);
            tJob.m_srvPtr := nil;
          end;
        end

        else if Assigned(tJob.m_srvPtr) and Assigned(tJob.m_grp) then
        begin
          actArea := TMqmActArea(tJob.m_grp.m_srvPtr);
          if Assigned(actArea) then
          begin
            actArea.RemoveSchedObj(tJob.m_grp.m_Id);
            tJob.m_srvPtr := nil;
          end;
        end;

        IdGroup := p_sc.LinesBelongToGroup(tjob.m_id, isGroup);
        if tJob.p_rscCode <> '' then
        begin
          if isGroup then
          begin
            fLoad(tJob.p_rscCode, IdGroup, nil);
            SortGroup(IdGroup);
          end
          else
            fLoad(tJob.p_rscCode, tJob.m_Id, nil);
        end;

      end;


    end;

    except

    end;    }

    SubStepList.free;

    MainQry.Close;
  end;

