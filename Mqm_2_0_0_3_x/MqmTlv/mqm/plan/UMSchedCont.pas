function TMSchedCont.GetJobQtyAtDate(Id: TSchedId; Res: TObject; AtDate: TDateTime): double;
var
  Job:  TSCProdSched;
  grp: TSCProdGroup;
  DurDateToStart, DurEndToStart, DurCurrToStart: double;
  Cal: TPGCALObj;
  ActArea:  TMqmActArea;
  sc : TSCSchedOnPlan;
  I : integer;
  StartSched, StartExecusion : TDateTime;
begin
  Result := 0;

  sc := TSCSchedOnPlan(m_codeList[Id]);

  if sc is TSCProdSched then
  begin

    Job := TSCProdSched(sc);
//    if Assigned(Job.m_grp) then exit;

    if (AtDate <= job.p_schedStart) then exit;

    if (AtDate >= job.p_schedEnd) then
    begin
      Result := job.p_quantSched;
      exit
    end;

    if job.m_reqDet.m_stepType = CST_batch then exit;

    if (Job.m_ProgType = '2') and (AtDate = Job.m_PrgCurDt) then
    begin
      Result := Job.m_PrgQty;
      exit;
    end;

    ActArea := GetExtLinkPtr(id);

    Cal := nil;

    if Assigned(Res) then
    begin
      //Assert(Res is TMqmVisibleRes);
      if not (Res is TMqmVisibleRes) then Exit;
      if Assigned(ActArea) and (ActArea.p_Father = Res) then
        Cal := ActArea.GetCalendar
      else
        Cal := TMqmVisibleRes(Res).GetCalendar;
    end
    else
    begin
      if Assigned(ActArea) then
        Cal := ActArea.GetCalendar;
    end;

    if not Assigned(Cal) then
      exit;

    StartSched := Job.p_schedStart;
    if Assigned(ActArea) then
      cal.OfsByWH(job.p_supMinReal/60, true, StartSched, StartExecusion, ActArea.m_CrossDownTmList)
    else
      cal.OfsByWH(job.p_supMinReal/60, true, StartSched, StartExecusion, nil);

    if Assigned(ActArea) then
      DurDateToStart := cal.DiffWH(StartExecusion, AtDate, ActArea.m_CrossDownTmList)*60
    else
      DurDateToStart := cal.DiffWH(StartExecusion, AtDate, nil)*60;
    DurDateToStart := GetMinutesExcludeLearningCurveAffect(Id, 0, DurDateToStart);

    if (Job.m_ProgType = '2') then
    begin

      if (AtDate < Job.m_PrgCurDt) then
      begin
        if Assigned(ActArea) then
          DurEndToStart := cal.DiffWH(StartExecusion, Job.m_PrgCurDt, ActArea.m_CrossDownTmList)*60
        else
          DurEndToStart := cal.DiffWH(StartExecusion, Job.m_PrgCurDt, nil)*60;
        DurEndToStart := GetMinutesExcludeLearningCurveAffect(Id, 0, DurEndToStart);
        Result := Job.m_PrgQty/DurEndToStart*DurDateToStart;
        exit;
      end;

      if Job.m_PrgQty >= Job.p_quantSched then  // No sense this can be but to cover any unexpected scenario
      begin
        Result := Job.m_PrgQty;
        exit;
      end;

      if Assigned(ActArea) then
        DurCurrToStart := cal.DiffWH(StartExecusion, Job.m_PrgCurDt, ActArea.m_CrossDownTmList)*60
      else
        DurCurrToStart := cal.DiffWH(StartExecusion, Job.m_PrgCurDt, nil)*60;
      DurCurrToStart := GetMinutesExcludeLearningCurveAffect(Id, 0, DurCurrToStart);

      if Assigned(ActArea) then
        DurEndToStart := cal.DiffWH(StartExecusion, Job.p_schedEnd, ActArea.m_CrossDownTmList)*60
      else
        DurEndToStart := cal.DiffWH(StartExecusion, Job.p_schedEnd, nil)*60;
      DurEndToStart := GetMinutesExcludeLearningCurveAffect(Id, 0, DurEndToStart);

      Result := (Job.p_quantSched-Job.m_PrgQty) / (DurEndToStart-DurCurrToStart) * (DurDateToStart-DurCurrToStart);
      Result := Result + Job.m_PrgQty;
      exit;

    end;

    if (Job.m_ProgType > '1') then
    begin
      if Assigned(ActArea) then
        DurEndToStart := cal.DiffWH(StartExecusion, Job.p_schedEnd, ActArea.m_CrossDownTmList)*60
      else
        DurEndToStart := cal.DiffWH(StartExecusion, Job.p_schedEnd, nil)*60;
    end
    else
      DurEndToStart := job.p_exeMin;

    Result := job.p_quantSched/DurEndToStart*DurDateToStart;

  end

  else

  begin
    grp := TSCProdGroup(sc);

    if (AtDate <= grp.p_schedStart) then exit;

    if (AtDate >= grp.p_schedEnd) then
    begin
      Result := grp.p_quantSched;
      exit
    end;

    job := TSCProdSched(grp.m_list[0]);
    if job.m_reqDet.m_stepType = CST_batch then exit;

    for I := 0 to grp.m_list.Count - 1 do
    begin
      job := TSCProdSched(grp.m_list[I]);
      result := result + GetJobQtyAtDate(job.m_Id, Res, AtDate);
    end;

  end;

end;
