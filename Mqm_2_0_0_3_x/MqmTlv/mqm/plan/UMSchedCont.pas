function TMSchedCont.CheckGroupValues(id: TSchedID; fld: CBinColId; valueTo: variant; valueFrom: variant): boolean;
var
  sc:     TSCSchedOnPlan;
  scP :   TSCProdSched;
  scG:    TSCProdGroup;
  dataType: CBinColValType;
  i: integer;
  val   : variant;
begin
  Result := false;
  sc := TSCSchedOnPlan(m_codeList[id]);

  if not (sc is TSCProdGroup) then
    Exit;

  scG := TSCProdGroup(m_codeList[id]);
  //Assert(scG.m_list.Count > 0);
  if not (scG.m_list.Count > 0) then Exit;
  case fld of

    CSC_ReprocNo :
    begin
      for i := 0 to scG.m_list.Count-1 do
      begin
        scP := TSCProdSched(scG.m_list[i]);
        GetFldSupport(scP.m_Id, fld, Val, dataType, false);
        if val <= 0 then
        begin
          Result := true;
          Exit;
        end;
      end;
    end;

    CSC_ProdReq :
    begin
      for i := 0 to scG.m_list.Count-1 do
      begin
        scP := TSCProdSched(scG.m_list[i]);
        GetFldSupport(scP.m_Id, fld, Val, dataType, false);
        if (ValueFrom = '') then
        begin
          if Val = UpperCase(valueTo) then
          begin
            Result := true;
            Exit;
          end;
        end
        else
        begin
          if (Val >= UpperCase(valueTo)) and (Val <= UpperCase(valueFrom)) then
          begin
            Result := true;
            Exit;
          end;
        end;
      end;

    end;

    CSC_ProdStep, CSC_ProdSubStep :
    begin
      for i := 0 to scG.m_list.Count-1 do
      begin
        scP := TSCProdSched(scG.m_list[i]);
        GetFldSupport(scP.m_Id, fld, Val, dataType, false);
        if (ValueFrom = -1) then
        begin
          if Val = UpperCase(valueTo) then
          begin
            Result := true;
            Exit;
          end;
        end
        else
        begin
          if (Val >= UpperCase(valueTo)) and (Val <= UpperCase(valueFrom)) then
          begin
            Result := true;
            Exit;
          end;
        end;
      end;
    end;

    CSC_GroupNo :
    begin
      for i := 0 to scG.m_list.Count-1 do
      begin
        scP := TSCProdSched(scG.m_list[i]);
        GetFldSupport(scP.m_Id, fld, Val, dataType, false);
        if (ValueFrom = 1234) then
        begin
          if Val = IntToStr(valueTo) then
          begin
            Result := true;
            Exit;
          end;
        end
        else
        begin
          if (((StrToInt(Val) >= valueTo) and (StrToInt(Val) <= valueFrom))) then
          begin
            Result := true;
            Exit;
          end;
        end;

      end;


    end

    else

      for i := 0 to scG.m_list.Count-1 do
      begin
        scP := TSCProdSched(scG.m_list[i]);
        GetFldSupport(scP.m_Id, fld, Val, dataType, false);
        if (ValueFrom = '') then
        begin
          if Val = valueTo then
          begin
            Result := true;
            Exit;
          end;
        end
        else
        begin
          if (Val >= (valueTo)) and (Val <= (valueFrom)) then
          begin
            Result := true;
            Exit;
          end;
        end;
      end;

  end;

end;

