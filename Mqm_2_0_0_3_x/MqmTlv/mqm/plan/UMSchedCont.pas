procedure TMSchedCont.LoadProdArt(OnStart : boolean; qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText; ErrList: TStringList; UpdateNr : integer;
                                 WorkCentersHandledList, WorkCentersViewedList : String; ChangedReqInClause: string = '');
