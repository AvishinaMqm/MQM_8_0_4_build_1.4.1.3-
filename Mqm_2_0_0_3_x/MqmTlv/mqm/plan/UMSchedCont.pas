    SqlStr := SqlStr + ' LEFT JOIN ' + tbiWW.GetTableName + ' WKSPD ON (' + 'WKSPD.' + CreateFld(tbiWW.pfx, fli_wkstCode) + '=' + QuotedStr(IniAppGlobals.WkstCode) + ' AND ';
