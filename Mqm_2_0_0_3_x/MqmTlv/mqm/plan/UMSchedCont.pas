procedure TMSchedCont.RemoveJobFromGroup(job: TSchedID; Reason: string = '');
var
  jobSc: TSCProdSched;
  grpSc: TSCProdGroup;
  pos:   integer;
begin
  jobSc := TSCProdSched(m_codeList[job]);
//  Assert(Assigned(jobSc.m_grp));
  if Assigned(jobSc.m_grp) then
  begin
    grpSc := jobSc.m_grp;
    if assigned(grpSc.m_list) then
    begin
      pos := grpSc.m_list.IndexOf(jobSc);
      //Assert(pos>-1);
      if (pos>-1) then
        grpSc.m_list.Delete(pos);
    end;
  end;
  jobSc.m_grp := nil;
  jobSc.m_grpRemovedReason := Reason;
  jobSc.m_PrgSt          := 0;
  jobSc.m_PrgCurDt       := 0;
  jobSc.m_PrgEd          := 0;
  jobSc.m_PrgQty         := 0;
  jobSc.m_PrgStartingQty := 0;
  jobSc.m_PrgRemTime     := -1;
  jobSc.m_ProgType       := '';
  jobSc.m_ProgRsc        := '';
  jobSc.m_PrgStHost      := 0;
  jobSc.m_PrgCurDtHost   := 0;
  jobSc.m_PrgEdHost      := 0;
  jobSc.m_PrgQtyHost     := 0;
  jobSc.m_PrgRemTimeHost := -1;
  jobSc.m_ProgTypeHost   := '';
  jobSc.m_ProgRscHost    := '';
  SetExtLinkPtr(jobSc.m_id, nil);
 // jobSc.m_srvPtr := nil
end;

