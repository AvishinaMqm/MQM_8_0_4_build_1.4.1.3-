function TMSchedCont.CheckPosition(id: TSchedID; ErrList: TStringList): CScMovementResult;
var
  ForcesInfo: TSQForcesInfo;
  DatesInfo: TSQDatesInfo;
  sc : TSCSchedOnPlan;  // ERAN19101963
begin

  GetForcesInfo(id, ForcesInfo);
  GetDatesInfo(id, DatesInfo);

  Result := CSM_Yes;

  sc := TSCSchedOnPlan(m_codeList[id]);  // ERAN19101963
//  Assert(id = sc.m_Id);                  // ERAN19101963
  if not (id = sc.m_Id) then Exit;

  if (ForcesInfo.FrcDelDate > CSF_No) and
     (DatesInfo.endDate > DatesInfo.DeliveryDate) then
  begin
    case ForcesInfo.FrcDelDate of
      CSF_Yes,
      CSF_Yes2: begin
                  if Assigned(ErrList) then ErrList.Add(_('This job should not cross the delivery date.'));
                  if Result in [CSM_Yes, CSM_Forced] then Result := CSM_No;
                end;
      CSF_Forceable,
      CSF_Forceable2: begin
                        if Assigned(ErrList) then ErrList.Add(_('This job should not cross the delivery date. Do you want to force it?'));
                        if Result = CSM_Yes then Result := CSM_Forced;
                      end;
    end;
  end;

  if (ForcesInfo.FrcMatDate > CSF_No) and
 //    (DatesInfo.MatArrDate > 0) and (DatesInfo.StartWithMat < DatesInfo.MatArrDate) then  // ERAN19101963
       (DatesInfo.MatArrDate > 0) and (sc.p_StartWithMat < DatesInfo.MatArrDate) then  // ERAN19101963
  begin
    case ForcesInfo.FrcMatDate of
      CSF_Yes:  begin
                  if Assigned(ErrList) then ErrList.Add(_('This job should not cross the material arriving date'));
                  if Result in [CSM_Yes, CSM_Forced] then Result := CSM_No;
                end;
      CSF_Forceable:  begin
                        if Assigned(ErrList) then ErrList.Add(_('This job should not cross the material arriving date. Do you want to force it?'));
                        if Result = CSM_Yes then Result := CSM_Forced;
                      end;
    end;
  end;

  if (ForcesInfo.FrcLowestDate > CSF_No) and
     (DatesInfo.startDate < DatesInfo.LowStrDate) then
  begin
   case ForcesInfo.FrcLowestDate of
      CSF_Yes:  begin
                  if Assigned(ErrList) then ErrList.Add(_('This job should not cross the lowest start date'));
                  if Result in [CSM_Yes, CSM_Forced] then Result := CSM_No;
                end;
      CSF_Forceable:  begin
                        if Assigned(ErrList) then ErrList.Add(_('This job should not cross the lowest start date?'));
                        if Result = CSM_Yes then Result := CSM_Forced;
                      end;
    end;
  end;

  if (ForcesInfo.FrcHighestDate > CSF_No) and
     (DatesInfo.endDate > DatesInfo.HighEndDate) then
  begin
    case ForcesInfo.FrcHighestDate of
      CSF_Yes:  begin
                  if Assigned(ErrList) then ErrList.Add(_('This job should not cross the highest end date'));
                  if Result in [CSM_Yes, CSM_Forced] then Result := CSM_No;
                end;
      CSF_Forceable:  begin
                        if Assigned(ErrList) then ErrList.Add(_('This job should not cross the highest end date. Do you want to force it?'));
                        if Result = CSM_Yes then Result := CSM_Forced;
                      end;
    end;
  end;

  //if (ForcesInfo.FrcOverlap > CSF_No) and
  if Assigned(ErrList) and (DBAppSettings.ForceOverlap > FOL_No) and
     (((DatesInfo.MinOvlpDate > 0) and (DatesInfo.startDate < DatesInfo.MinOvlpDate))
     or ((DatesInfo.MaxOvlpDate > 0) and (DatesInfo.endDate > DatesInfo.MaxOvlpDate))) then
  begin
  // case ForcesInfo.FrcOverlap of
    case DBAppSettings.ForceOverlap of
      FOL_Yes:  begin
                  if Assigned(ErrList) then ErrList.Add(_('This job is in overlap'));
                  if Result in [CSM_Yes, CSM_Forced] then Result := CSM_No;
                end;
      FOL_Forceable:  begin
                        if Assigned(ErrList) then ErrList.Add(_('This job is in overlap. Do you want to force it?'));
                        if Result = CSM_Yes then Result := CSM_Forced;
                      end;
    end;
  end;

end;

