   // SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_ProdType) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_sequenceChar) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_netGroupCode) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_AllocReq) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_settled) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_reqQuant) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_qtyProduced) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_AllocQty) + ' ');
    SQL.Add(' from ' + tbInfoPArt.GetTableName + ' PA ');
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbInfoPArt.pfx, fli_Identifier)));

    if not OnStart then
    begin
      if ChangedReqInClause <> '' then
        SQL.Add('AND PA.' + CreateFld(tbInfoPArt.pfx, fli_preqNo) + ' IN (' + ChangedReqInClause + ') ')
      else
      begin
        SQL.Add('AND exists (');
        SQL.Add('select 1 from ' + tbiCR.GetTableName + ' CR ');
        SQL.Add('where CR.' + CreateFld(tbiCR.pfx, fli_updCode) + ' = ' + IntToStr(UpdateNr) + ' ');
        SQL.Add('and CR.' + CreateFld(tbiCR.pfx, fli_Identifier) + ' = PA.' + CreateFld(tbInfoPArt.pfx, fli_Identifier));
        SQL.Add('and CR.' + CreateFld(tbiCR.pfx, fli_preqNo) + ' = PA.' + CreateFld(tbInfoPArt.pfx, fli_preqNo));
        if (IniAppGlobals.External_Database_Update = '1') then
          SQL.Add(' and CR.' + CreateFld(tbiCR.pfx, fli_wkstCode) + '=''' + IniAppGlobals.WkstCode + '''');
        SQL.Add(') ');
