function TMSchedCont.SearchFatherOrSonForSplitFamily(SplitFamily : string; var BrothersList : TMSchedList; skipId : TSchedId) : boolean;
var
  I,J,Ps : Integer;
  tHdr: TSCProdReqHdr;
  tDet, SkiptDet: TSCProdReqDet;
  job: TSCProdSched;
  sc : TSCSchedOnPlan;
begin
  Result := false;
  sc := TSCSchedOnPlan(m_codeList[skipid]);
//  Assert (sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  job := TSCProdSched(sc);
  SkiptDet := TSCProdReqDet(job.m_reqDet);

  for I := 0 to m_prodReqList.Count - 1 do
  begin
    tHdr := TSCProdReqHdr(m_prodReqList[i]);
    for j := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[j]);
      if (SkiptDet = tDet) then continue;
      if (tDet.m_SplitAllow = CSB_Son) or (tDet.m_SplitAllow = CSB_Father) then
      begin
        for Ps := 0 to tDet.m_list.Count - 1 do
        begin
          Job := TSCProdSched(tDet.m_list[Ps]);
          if Job.m_isDeleted then
            Continue;
          if (SplitFamily = Job.m_SplitFamilyCode) then
          begin
            Result := true;
            if not Assigned(BrothersList) then
              BrothersList := TMSchedList.Create(self);
            BrothersList.AddLink(TSCProdSched(tDet.m_list[Ps]).m_id);
          end;
        end;
      end;
    end;
  end;
end;

