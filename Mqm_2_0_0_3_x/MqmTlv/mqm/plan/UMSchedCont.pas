procedure TMSchedCont.GetFwLinkedJobs(id: TSchedID; var ConnJobsList: TMSchedList);
var
  sc:  TSCSchedOnPlan;
  tJob, ConnJob: TSCProdSched;
  tDet, NextDet: TSCProdReqDet;
  tHdr: TSCProdReqHdr;
  i: integer;
begin
  ConnJobsList.ClearList;
  sc := TSCSchedOnPlan(m_codeList[id]);

  if not (sc is TSCProdSched) then
    exit;

  tjob := TSCProdSched(sc);
  tDet := tJob.m_reqDet;
  tHdr := tDet.m_hdr;

  NextDet := tHdr.FindDetFromCode(tDet.m_nextRealStep);
  if not Assigned(NextDet) then exit;

  if (tjob.m_fwdConnSubStp = -2)
  and (tjob.m_fwdConnReProcs = -2) then
  begin
    for i := 0 to NextDet.m_list.Count-1 do
    begin
      ConnJob := TSCProdSched(NextDet.m_list[i]);
      if (ConnJob.m_bkwConnSubStp = -2)
      and (ConnJob.m_bkwConnReProcs = -2) then
        ConnJobsList.AddLink(ConnJob.m_Id)
    end;
    exit
  end;

  //0=no 1=many 2=one 3=one to one
  if NextDet.m_connTypeToPrevious = '0' then exit;

  if NextDet.m_connTypeToPrevious = '1' then
  begin
    ConnJob := NextDet.FindJobFromCode(tjob.m_fwdConnSubStp, tjob.m_fwdConnReProcs);
    if Assigned(ConnJob) then
      ConnJobsList.AddLink(ConnJob.m_Id)
  end;

  if NextDet.m_connTypeToPrevious = '2' then
  begin
    for i := 0 to NextDet.m_list.Count-1 do
    begin
      ConnJob := TSCProdSched(NextDet.m_list[i]);
      if (ConnJob.m_bkwConnSubStp = tJob.m_code)
      and (ConnJob.m_bkwConnReProcs = tJob.m_reprocNo) then
        ConnJobsList.AddLink(ConnJob.m_Id)
    end;
  end;

  if NextDet.m_connTypeToPrevious = '3' then
  begin
    ConnJob := NextDet.FindJobFromCode(tjob.m_fwdConnSubStp, tjob.m_fwdConnReProcs);
    if Assigned(ConnJob)
    and (ConnJob.m_bkwConnSubStp = tjob.m_code)
    and (ConnJob.m_bkwConnReProcs = tjob.m_reprocNo) then
      ConnJobsList.AddLink(ConnJob.m_Id)
  end;
end;

//----------------------------------------------------------------------------//

procedure TMSchedCont.GetBwLinkedJobs(id: TSchedID; var ConnJobsList: TMSchedList);
var
  sc:  TSCSchedOnPlan;
  tJob, ConnJob: TSCProdSched;
  tDet, PrevDet: TSCProdReqDet;
  tHdr: TSCProdReqHdr;
  i: integer;
begin
  ConnJobsList.ClearList;
  sc := TSCSchedOnPlan(m_codeList[id]);

  if not (sc is TSCProdSched) then
    exit;

  tjob := TSCProdSched(sc);
  tDet := tJob.m_reqDet;
  tHdr := tDet.m_hdr;

  PrevDet := tHdr.FindDetFromCode(tDet.m_prevRealStep);
  if not Assigned(PrevDet) then exit;

  if (tjob.m_bkwConnSubStp = -2)
  and (tjob.m_bkwConnReProcs = -2) then
  begin
    for i := 0 to PrevDet.m_list.Count-1 do
    begin
      ConnJob := TSCProdSched(PrevDet.m_list[i]);
      if (ConnJob.m_fwdConnSubStp = -2)
      and (ConnJob.m_fwdConnReProcs = -2) then
        ConnJobsList.AddLink(ConnJob.m_Id)
    end;
    exit
  end;

  //0=no 1=many 2=one 3=one to one
  if tdet.m_connTypeToPrevious = '0' then exit;

  if tdet.m_connTypeToPrevious = '1' then
  begin
    for i := 0 to PrevDet.m_list.Count-1 do
    begin
      ConnJob := TSCProdSched(PrevDet.m_list[i]);
      if (ConnJob.m_fwdConnSubStp = tJob.m_code)
      and (ConnJob.m_fwdConnReProcs = tJob.m_reprocNo) then
        ConnJobsList.AddLink(ConnJob.m_Id)
    end;
  end;

  if tdet.m_connTypeToPrevious = '2' then
  begin
    ConnJob := PrevDet.FindJobFromCode(tjob.m_bkwConnSubStp, tjob.m_bkwConnReProcs);
    if Assigned(ConnJob) then
      ConnJobsList.AddLink(ConnJob.m_Id)
  end;

  if tdet.m_connTypeToPrevious = '3' then
  begin
    ConnJob := PrevDet.FindJobFromCode(tjob.m_bkwConnSubStp, tjob.m_bkwConnReProcs);
    if Assigned(ConnJob)
    and (tjob.m_code = ConnJob.m_fwdConnSubStp)
    and (tjob.m_reprocNo = ConnJob.m_fwdConnReProcs) then
      ConnJobsList.AddLink(ConnJob.m_Id)
  end;
end;

