procedure TMSchedCont.SetOrigVersioningback(m_sched : TMSchedList);
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  Id, ChildId : TSchedId;
  JobsInBinCount, g, i : Integer;
  planInfo: TSQplanInfo;
begin
  JobsInBinCount := m_sched.GetLinkCount;

  for i := 0 to JobsInBinCount - 1 do
  begin
    id := m_sched.GetLink(I);

    if id = CSchedIdNull then
      exit;

    p_sc.GetPlanInfo(id, planInfo);

    if planInfo.isGroup then
    begin
      for G := 0 to p_sc.GetGrpNumSons(Id) - 1 do
      begin
        ChildId := p_sc.GetGrpSon(Id, G);

        sc := TSCSchedOnPlan(m_codeList[ChildId]);
        if sc is TSCProdSched then
        begin
          job := TSCProdSched(sc);
          RemoveVersionIdFromList(job.P_VersionIdentifier);
          if (job.P_VersionIdentifier_ORIGINAL <> '') and not IsVersionIdExists(job.P_VersionIdentifier_ORIGINAL) then
            AddVersionIdtoList(job.P_VersionIdentifier_ORIGINAL);
          job.P_VersionIdentifier       := job.P_VersionIdentifier_ORIGINAL;
          job.P_VersionScheduleResource := job.P_VersionScheduleResource_ORIGINAL;
          job.P_VersionScheduleStart    := job.P_VersionScheduleStart_ORIGINAL;
          job.P_VersionScheduleEnd      := job.P_VersionScheduleEnd_ORIGINAL;
        end;
      end;
    end else
    begin
      sc := TSCSchedOnPlan(m_codeList[Id]);
      if sc is TSCProdSched then
      begin
        job := TSCProdSched(sc);
        RemoveVersionIdFromList(job.P_VersionIdentifier);
        if (job.P_VersionIdentifier_ORIGINAL <> '') and not IsVersionIdExists(job.P_VersionIdentifier_ORIGINAL) then
          AddVersionIdtoList(job.P_VersionIdentifier_ORIGINAL);
        job.P_VersionIdentifier       := job.P_VersionIdentifier_ORIGINAL;
        job.P_VersionScheduleResource := job.P_VersionScheduleResource_ORIGINAL;
        job.P_VersionScheduleStart    := job.P_VersionScheduleStart_ORIGINAL;
        job.P_VersionScheduleEnd      := job.P_VersionScheduleEnd_ORIGINAL;
      end;
    end;
  end;
end;

