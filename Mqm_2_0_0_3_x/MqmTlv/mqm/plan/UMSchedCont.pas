function TMSchedCont.CheckSplitedJobsOfLeaderStep : boolean;
var
  tbiPS:      ^TTblInfo;
  tHdr:       TSCProdReqHdr;
  tDet:       TSCProdReqDet;
  Job, tJobActive:       TSCProdSched;
  ph, pd, ps, I, NumberOfjobs  : integer;
  FoundGoodConfLevl, FoundWrongConfLevl, FoundNotscheduled, FirstMsg : boolean;
  W : word;
begin
  Result := true;
  FirstMsg := true;
  for ph := 0 to m_prodReqList.Count-1 do
  begin
    tHdr := TSCProdReqHdr(m_prodReqList[ph]);
    for pd := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[pd]);
      if tDet.m_stepClosed then continue;
      tDet.m_list.Sort(SortSubStep);
      Application.ProcessMessages;

      NumberOfjobs := 0;

      if tDet.p_Count > 1 then
      begin
        FoundGoodConfLevl := false;
        FoundWrongConfLevl := false;
        FoundNotscheduled  := false;
        for I := 0 to tDet.m_list.Count - 1 do
        begin
          Job := TSCProdSched(tDet.m_list[I]);
          if Job.m_isDeleted then continue;
          if (Job.m_VisbleInBin = CSB_ReadOnly) then continue;
          if (Job.m_status in [CSS_del,CSS_From_PG]) then continue;
          if (Job.m_code = 0) then continue;
      //    if (Job.m_NewReqUniqId = '') then continue;
          if (CProgress(p_sc.IsProgressed(Job.m_id)) <> prg_none) then continue;

          if (tHdr.m_LeadStepForSplit <> -1) and (tHdr.m_ConfLevels <> '') and (tHdr.m_LeadStepForSplit = tDet.m_code) then
          begin
            Inc(NumberOfjobs);
          //  if (GetSchedType(Job.m_id) <> '2') then
            begin
              if not Assigned(GetExtLinkPtr(Job.m_id)) then
                 FoundNotscheduled := true
              else
              begin
                if (Job.m_NewReqUniqId <> '') and (GetSchedType(Job.m_id) >= tDet.m_hdr.m_ConfLevels) then
                  FoundGoodConfLevl := true
                else
                  FoundWrongConfLevl := true;
              end;

            end;
          end;

        end;

        if (NumberOfjobs <> 0) and (FoundGoodConfLevl and FoundNotscheduled) and (NumberOfjobs <> tDet.p_Count) then
        begin
          showmessage(_('Request/step : ' + tHdr.m_code + ' : ' + IntToStr(tDet.m_code) + ' has some jobs to split in host ' + #13#10 + 'and some not scheduled - Save can not be done.'));
          result := false;
          exit;
        end;

        if FirstMsg and (FoundGoodConfLevl and FoundWrongConfLevl) and not FoundNotscheduled then
        begin
          FirstMsg := false;
          w := MessageDlg(_('If one sub step must split in host then all sub steps of the same step must be either. ' + #13#10 + ' Change all those to the split confirmation level ?'), mtConfirmation, [mbYes, mbNo], 0);// = idYes then
          if (w = mrYes) then
          begin

          end
          else
          begin
            Result := false;
            exit;
          end;
        end;

        if not ((FoundGoodConfLevl and FoundWrongConfLevl) and not FoundNotscheduled) then break;

        for I := 0 to tDet.m_list.Count - 1 do
        begin
          Job := TSCProdSched(tDet.m_list[I]);
          if Job.m_isDeleted then continue;
          if (Job.m_VisbleInBin = CSB_ReadOnly) then continue;
          if (Job.m_status in [CSS_del,CSS_From_PG]) then continue;
        //  if not (Job.m_status in [CSS_new,CSS_modi]) then continue;
          if not Assigned(GetExtLinkPtr(Job.m_id)) then continue;
          if (CProgress(p_sc.IsProgressed(Job.m_id)) <> prg_none) then continue;

          if (tHdr.m_LeadStepForSplit <> -1) and (tHdr.m_ConfLevels <> '') and (tHdr.m_LeadStepForSplit = tDet.m_code) then
          begin
            if (GetSchedType(Job.m_id) <> '2') and (GetSchedType(Job.m_id) < tDet.m_hdr.m_ConfLevels) then
               p_sc.SetSchedType(Job.m_id, tDet.m_hdr.m_ConfLevels);
          end;

        end;
      end;
    end;

  end;


end;

