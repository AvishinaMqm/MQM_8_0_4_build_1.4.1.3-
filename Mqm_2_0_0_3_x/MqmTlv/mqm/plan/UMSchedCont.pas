  else if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    for I := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      job.m_fromPD := FromPD;
      if DeleteFromSchedList and (m_ProdSchedDatabase.count > 0) and (job.m_ProdSched_ID_FromDatabase > -1) then
