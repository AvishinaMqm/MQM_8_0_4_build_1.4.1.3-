function TMSchedCont.GetFldSupportMat(id: TSchedID; fld: CBinColId; out Value: variant;
                           out dataType: CBinColValType): boolean;
var
  sc:     TSCSchedOnPlan;
  scP:    TSCProdSched;
  num : integer;
  pId:    TPropId;
  SpeedInminute : double;
begin
  Result := true;

  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdSched then
  begin
    scP := TSCProdSched(m_codeList[id]);

      case fld of

        CSC_Mat_Item_Type:
        begin
          dataType := CBT_string;
          value    := scP.m_mtr.m_ITEM_TYPE;
        end;

        CSC_Mat_PRODUCT_CODE:
        begin
          dataType := CBT_string;
          value    := scP.m_mtr.m_PRODUCT_CODE;
        end;

        CSC_Mat_NET_GROUP_CODE:
        begin
          dataType := CBT_string;
          value    := scP.m_mtr.m_NET_GROUP_CODE;
        end;

        CSC_Mat_Detail_Code:
        begin
          dataType := CBT_string;
          value    := scP.m_mtr.m_Material_Code_DET;
        end;

        CSC_Mat_MATERIAL_CODE_SUB_DET:
        begin
          dataType := CBT_string;
          value    := scP.m_mtr.m_MATERIAL_CODE_SUB_DET;
        end;

        CSC_Mat_Request_number:
        begin
          dataType := CBT_string;
          value    := scP.m_mtr.m_RequestNo;
        end;

        CSC_Mat_Resource_code:
        begin
          dataType := CBT_string;
          if (p_sc.GetExtLinkPtr_Material(Id) = nil) then
            result := false
          else
            value    := scP.m_mtr.m_ResCode
        end;

        CSC_Mat_Execution_Time:
        begin
          dataType := CBT_dur;
          if (p_sc.GetExtLinkPtr_Material(Id) <> nil) then
          begin
            if scP.m_mtr.m_MATERIAL_Overriden_Speed > 0 then
              SpeedInminute := scP.m_mtr.m_MATERIAL_Overriden_Speed
            else
              SpeedInminute := scP.m_mtr.m_SpeedInminutePerUoM;
            if (SpeedInminute > 0) and (scP.m_mtr.m_qty > 0) then
              value := scP.m_mtr.m_qty * SpeedInminute
            else
              result := false;
          end
          else
            result := false;
        end;

        CSC_Mat_Quantity:
        begin
          dataType := CBT_float;
          value    := scP.m_mtr.m_qty
