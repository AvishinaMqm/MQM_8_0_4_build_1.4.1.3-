function TMSchedContIterator.GetNext: TSchedID;
begin
  if m_cnt = CSchedIDnull then
    m_cnt := 0
  else
    Inc(m_cnt);

  while (m_cnt < m_sc.m_codeList.Count)        and
        (not Assigned(m_sc.m_codeList[m_cnt])) do
    Inc(m_cnt);

  if m_cnt < m_sc.m_codeList.Count then
    Result := m_cnt
  else
    Result := CSchedIDnull
end;

