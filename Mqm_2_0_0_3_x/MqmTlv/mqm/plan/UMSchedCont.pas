  SP_progrStart   := qry.FieldByName(CreateFld(tbiSP.pfx, fli_progrStart));
  SP_prgCurrDate  := qry.FieldByName(CreateFld(tbiSP.pfx, fli_prgCurrDate));
  SP_progrEnd     := qry.FieldByName(CreateFld(tbiSP.pfx, fli_progrEnd));
  SP_quant        := qry.FieldByName(CreateFld(tbiSP.pfx, fli_quant));
  SP_StartQty     := qry.FieldByName(CreateFld(tbiSP.pfx, fli_StartingQty));
  SP_prgRemTime   := qry.FieldByName(CreateFld(tbiSP.pfx, fli_prgRemTime));
  SP_rsc          := qry.FieldByName(CreateFld(tbiSP.pfx, fli_rsc));
  SP_ProgressTypeHost := qry.FieldByName(CreateFld(tbiSP.pfx, fli_ProgressTypeHost));
  SP_progrStartHost   := qry.FieldByName(CreateFld(tbiSP.pfx, fli_progrStartHost));
  SP_prgCurrDateHost  := qry.FieldByName(CreateFld(tbiSP.pfx, fli_prgCurrDateHost));
  SP_progrEndHost     := qry.FieldByName(CreateFld(tbiSP.pfx, fli_progrEndHost));
  SP_quantHost        := qry.FieldByName(CreateFld(tbiSP.pfx, fli_quantHost));
  SP_prgRemTimeHost   := qry.FieldByName(CreateFld(tbiSP.pfx, fli_prgRemTimeHost));
  SP_rscHost          := qry.FieldByName(CreateFld(tbiSP.pfx, fli_rscHost));
  WW_TypeOfUse1       := qry.FieldByName(CreateFld(tbiWW.pfx, fli_TypeOfUse));
  PS_preqNo       := qry.FieldByName(CreateFld(tbiPS.pfx, fli_preqNo));

  PrgRowCount := 0;
  Application.ProcessMessages;
  oldHdrCode := '';

  if Assigned(Status) then
    Status.Caption := _('Loading Progresses from database...');

  Application.ProcessMessages;
  while not Qry.EOF do
  begin
    try

    if oldHdrCode <> SP_preqNo.AsString then
    begin
      oldHdrCode := SP_preqNo.AsString;
      tHdr := FindHdrFromCode(self, oldHdrCode);
    end;

    if not assigned(tHdr) then
    begin;
      qry.next;
      Inc(PrgRowCount);
      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;
      if PrgRowCount mod 500 = 0 then Application.ProcessMessages;
      continue;
    end;

    tDet := tHdr.FindDetFromCode(SP_pstepId.AsInteger);

    ProgressReApplied := FindInProgressOverride(qry);

    if ProgressReApplied = '0' then // progress override was found and not reApplied
    begin
      if not PS_preqNo.IsNull then
      begin
        tjob := tDet.FindJobFromCode(SP_psubstId.AsInteger, SP_reprocNo.AsInteger);
        tjob.m_ProgressOverride := Prg_IgnoredAndSave;

        if (tJob.p_GetStepType <> '') and (tJob.p_GetStepType <> '0') then
        begin
          PTProgInfo := FindProgressData(ProgInfoList, tJob.m_reqDet.m_hdr.m_code,tJob.m_reqDet.m_code, tJob.m_code, tJob.m_reprocNo);
          if Assigned(PTProgInfo) then
          begin
            tJob.m_ProgTypeOrig := PTProgInfo.ProgType;
            tJob.m_PrgStOrig    := PTProgInfo.PrgSt;
            tJob.m_PrgCurDtOrig := PTProgInfo.PrgCurDt;
            tJob.m_PrgEdOrig    := PTProgInfo.PrEd;
            tJob.m_ProgRscOrig  := PTProgInfo.ProgRsc;
            tJob.m_PrgQtyOrig   := PTProgInfo.PrgQty
          end;
        end;
      end;
      qry.next;
      Inc(PrgRowCount);
      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;
      if PrgRowCount mod 500 = 0 then Application.ProcessMessages;
      continue;
    end;
    if ProgressReApplied = '1' then // progress override was found and reApplied
    begin
      if not PS_preqNo.IsNull then
      begin
        tjob := tDet.FindJobFromCode(SP_psubstId.AsInteger, SP_reprocNo.AsInteger);
        tjob.m_ProgressOverride := Prg_ReAppliedAndSave;
      end;
    end;

    if not PS_preqNo.IsNull then
    begin
      tjob := tDet.FindJobFromCode(SP_psubstId.AsInteger, SP_reprocNo.AsInteger);

      if ProgressReApplied = '' then // progress override was not found
        tjob.m_ProgressOverride := Prg_NotIgnored;

      if (tJob.p_GetStepType <> '') and (tJob.p_GetStepType <> '0') then
      begin
        tJob.m_ProgType       := SP_ProgressType.AsString;
        tJob.m_PrgSt          := SP_progrStart.AsDateTime;
        tJob.m_PrgCurDt       := SP_prgCurrDate.AsDateTime;
        tJob.m_PrgEd          := SP_progrEnd.AsDateTime;
        tJob.m_PrgQty         := SP_quant.AsFloat;
        tJob.m_PrgStartingQty := SP_StartQty.AsFloat;
        tJob.m_PrgRemTime     := SP_prgRemTime.AsFloat;
        tJob.m_ProgRsc        := Trim(SP_rsc.AsString);
        tJob.m_ProgTypeHost   := SP_ProgressTypeHost.AsString;
        tJob.m_PrgStHost      := SP_progrStartHost.AsDateTime;
        tJob.m_PrgCurDtHost   := SP_prgCurrDateHost.AsDateTime;
        tJob.m_PrgEdHost      := SP_progrEndHost.AsDateTime;
        tJob.m_PrgQtyHost     := SP_quantHost.AsFloat;
        tJob.m_PrgRemTimeHost := SP_prgRemTimeHost.AsFloat;
        tJob.m_ProgRscHost    := SP_rscHost.AsString;
        tJob.m_ProgTypeOrig   := SP_ProgressType.AsString;
        tJob.m_PrgStOrig      := SP_progrStart.AsDateTime;
        tJob.m_PrgCurDtOrig   := SP_prgCurrDate.AsDateTime;
        tJob.m_PrgEdOrig      := SP_progrEnd.AsDateTime;
        tJob.m_PrgQtyOrig     := SP_quant.AsFloat;
        tJob.m_PrgRemTimeOrig := SP_prgRemTime.AsFloat;
        tJob.m_ProgRscOrig    := trim(SP_rsc.AsString);
        tJob.m_PrgStartingQtyOrig := SP_StartQty.AsFloat;
       { if RS_NumOfRsc.AsFloat > 0 then
        begin
          if tJob.m_numOfRscComp > 0 then
            tJob.p_exeMin := tJob.p_exeMin/tJob.m_numOfRscComp
          else
          begin
            tJob.p_exeMin := tJob.p_exeMin/RS_NumOfRsc.AsFloat;
            tJob.m_numOfRscComp := RS_NumOfRsc.AsInteger;
          end;
        end; }

        PTProgInfo := FindProgressData(ProgInfoList, tJob.m_reqDet.m_hdr.m_code,tJob.m_reqDet.m_code, tJob.m_code, tJob.m_reprocNo);
        if Assigned(PTProgInfo) then
        begin
          tJob.m_ProgType := PTProgInfo.ProgType;
          tJob.m_PrgSt    := PTProgInfo.PrgSt;
          tJob.m_PrgCurDt := PTProgInfo.PrgCurDt;
          tJob.m_PrgEd    := PTProgInfo.PrEd;
          tJob.m_ProgTypeOrig := PTProgInfo.ProgType;
          tJob.m_PrgStOrig    := PTProgInfo.PrgSt;
          tJob.m_PrgCurDtOrig := PTProgInfo.PrgCurDt;
          tJob.m_PrgEdOrig    := PTProgInfo.PrEd;
        end;

        if assigned(tJob.m_grp) and (tJob.m_ProgRsc <> '') then
          TSCProdGroup(tJob.m_grp).SetSchedResourceAsProgress(tJob.m_ProgRsc);

        NewSubstep := -1;
        TmpQty := tJob.p_quantSched + tJob.p_quantManualChg;
        if ((tJob.m_ProgType = '4') or (tJob.m_ProgType = '5'))
        and (TmpQty > tJob.m_PrgQty) //if it is a progress with split
        and not (CheckSchedSumQty(tJob.m_Id)) then
          NewSubstep := GetNewSubStep(tJob.m_reqDet);

        if NewSubstep >= 0 then
        begin
          tJob.m_status :=  CSS_modi;
          if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_exeMin > 0) then
              tJob.p_exeMin := tJob.m_PrgQty / tJob.p_quantSched * tJob.p_exeMin;
          if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_supMinBase > 0) then
             tJob.p_supMinBase :=  tJob.m_PrgQty / tJob.p_quantSched * tJob.p_supMinBase;

       //   tJob.p_exeMin_ORIGINAL := tJob.p_exeMin; // must update the original after read/write
       //   tJob.p_supMinBase_ORIGINAL := tJob.p_supMinBase; // must update the original after read/write
          tJob.p_quantSched := tJob.m_PrgQty;
          tJob.p_quantManualChg := 0;
          TmpQty := TmpQty - tJob.m_PrgQty;

          //Create a new job because of a final progress with split
          tDet.m_list.Sort(SortSubStep);

          if (tJob.m_ProgType = '4') then
            tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef)
          else if (tJob.m_ProgType = '5') then
          begin
            SavedProgressEnd := tJob.m_PrgEd;
            tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef);
            tJob.p_schedStart := SavedProgressEnd;
            tJob.p_SetStepType    := '2';
            tJob.p_rscCode := Trim(SP_rsc.AsString);
            if not (ST_Exec0.IsNull) then
              tJob.p_exeMin := ST_Exec0.AsFloat
            else
            begin
              if not (ST_Exec1.IsNull) then
                tJob.p_exeMin := ST_Exec1.AsFloat
              else
              begin
                if not (ST_Exec2.IsNull) then
                  tJob.p_exeMin := ST_Exec2.AsFloat
                else
                begin
                  if not (ST_Exec3.IsNull) then
                    tJob.p_exeMin := ST_Exec3.AsFloat
                  else
                  begin
                    if not (ST_Exec4.IsNull) then
                      tJob.p_exeMin := ST_Exec4.AsFloat
                    else
                    begin
                      if not (ST_Exec5.IsNull) then
                        tJob.p_exeMin := ST_Exec5.AsFloat
                      else
                      begin
                        if not (ST_Exec6.IsNull) then
                        tJob.p_exeMin := ST_Exec6.AsFloat;
                      end;
                    end;
                  end;
                end;
              end;
            end;

            if tdet.p_IsSpeedChanged then
               tJob.p_exeMin := tdet.m_quantInit * tdet.p_NewSpeed;

            if (tjob.m_reqDet.m_stepType = CST_continuous) then
            begin
              if tdet.m_quantInit = 0 then
                tJob.p_exeMin := 0
              else
                tJob.p_exeMin := TmpQty / tdet.m_quantInit * tJob.p_exeMin;
            end;
          end;

          if (WW_TypeOfUse1.AsString = '2') then
            tJob.m_VisbleInBin := CSB_ReadOnly
          else
            tJob.m_VisbleInBin  := CSB_Normal;

          tJob.m_status := CSS_new;

          tJob.p_quantSched := TmpQty;
          if (tJob.m_VisbleInBin = CSB_ReadOnly) then
            tJob.m_status := CSS_none;

        end;

        qry.next;
        Inc(PrgRowCount);
        if Assigned(ProgBar) then
        begin
          DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
          if PrgPrevSecond <> PrgSecond then
          begin
            PrgPrevSecond := PrgSecond;
            PrgIndex := PrgIndex + PrgBlock;
            ProgBar.SetPosition(PrgIndex);
          end;
        end;
        if PrgRowCount mod 500 = 0 then Application.ProcessMessages;
        continue;
      end;
    end;

    ExecutionTime := 0;
    if not (ST_Exec0.IsNull) then
      ExecutionTime := ST_Exec0.AsFloat
    else
    begin
      if not (ST_Exec1.IsNull) then
        ExecutionTime := ST_Exec1.AsFloat
      else
      begin
        if not (ST_Exec2.IsNull) then
          ExecutionTime := ST_Exec2.AsFloat
        else
        begin
          if not (ST_Exec3.IsNull) then
            ExecutionTime := ST_Exec3.AsFloat
          else
          begin
            if not (ST_Exec4.IsNull) then
              ExecutionTime := ST_Exec4.AsFloat
            else
            begin
              if not (ST_Exec5.IsNull) then
                ExecutionTime := ST_Exec5.AsFloat
              else
              begin
                ExecutionTime := ST_Exec6.AsFloat;
              end;
            end;
          end;
        end;
      end;
    end;

    if tdet.p_IsSpeedChanged then
       ExecutionTime := tdet.m_quantInit * tdet.p_NewSpeed;

    if (ExecutionTime = 0) then
        ExecutionTime := 1;

    if PS_preqNo.IsNull and
       ((SP_psubstId.AsInteger > 0) or (SP_reprocNo.AsInteger > 0)) then
    begin
      tjob := tDet.FindJobFromCode(SP_psubstId.AsInteger, SP_reprocNo.AsInteger);
    end;

    if PS_preqNo.IsNull and (tjob = nil) and
       ((SP_psubstId.AsInteger > 0) or
        (SP_reprocNo.AsInteger > 0)) then
    begin
      tJob := CreateNewJob(tDet, SP_psubstId.AsInteger , CSnoGroupDef);
      tJob.m_reprocNo := SP_reprocNo.AsInteger;

      if (WW_TypeOfUse1.AsString = '2') then
        tJob.m_VisbleInBin := CSB_ReadOnly
      else
        tJob.m_VisbleInBin  := CSB_Normal;

      tJob.m_status := CSS_From_PG;
      if (SP_quant.AsFloat < 1) and (SP_quant.AsFloat > 0) then
        tJob.p_quantSched  := SP_quant.AsFloat
      else
        tJob.p_quantSched  := 1;
    end
    else
      tjob := tDet.FindJobFromCode(SP_psubstId.AsInteger, SP_reprocNo.AsInteger);

    if (tjob = nil) and (SP_psubstId.AsInteger = 0) and (SP_reprocNo.AsInteger = 0) then // avi 20.11.2017
    begin
      tJob := CreateNewJob(tDet, SP_psubstId.AsInteger , CSnoGroupDef);
      tJob.m_reprocNo := SP_reprocNo.AsInteger;

      if (WW_TypeOfUse1.AsString = '2') then
        tJob.m_VisbleInBin := CSB_ReadOnly
      else
        tJob.m_VisbleInBin  := CSB_Normal;

      tJob.m_status := CSS_From_PG;
      if (SP_quant.AsFloat < 1) and (SP_quant.AsFloat > 0) then
        tJob.p_quantSched  := SP_quant.AsFloat
      else
        tJob.p_quantSched  := 1;
       tjob := tDet.FindJobFromCode(SP_psubstId.AsInteger, SP_reprocNo.AsInteger);
    end;

    tJob.m_PrgSt          := SP_progrStart.AsDateTime;
    tJob.m_PrgCurDt       := SP_prgCurrDate.AsDateTime;
    tJob.m_PrgEd          := SP_progrEnd.AsDateTime;
    tJob.m_PrgQty         := SP_quant.AsFloat;
    tJob.m_PrgStartingQty := SP_StartQty.AsFloat;
    tJob.m_PrgRemTime     := SP_prgRemTime.AsFloat;
    tJob.m_ProgType       := SP_ProgressType.AsString;
    tJob.m_ProgRsc        := trim(SP_rsc.AsString);
    tJob.m_ProgTypeHost   := SP_ProgressTypeHost.AsString;
    tJob.m_PrgStHost      := SP_progrStartHost.AsDateTime;
    tJob.m_PrgCurDtHost   := SP_prgCurrDateHost.AsDateTime;
    tJob.m_PrgEdHost      := SP_progrEndHost.AsDateTime;
    tJob.m_PrgQtyHost     := SP_quantHost.AsFloat;
    tJob.m_PrgRemTimeHost := SP_prgRemTimeHost.AsFloat;
    tJob.m_ProgRscHost    := trim(SP_rscHost.AsString);
    tJob.m_ProgTypeOrig   := SP_ProgressType.AsString;
    tJob.m_PrgStOrig      := SP_progrStart.AsDateTime;
    tJob.m_PrgCurDtOrig   := SP_prgCurrDate.AsDateTime;
    tJob.m_PrgEdOrig      := SP_progrEnd.AsDateTime;
    tJob.m_PrgQtyOrig     := SP_quant.AsFloat;
    tJob.m_PrgStartingQtyOrig := SP_StartQty.AsFloat;
    tJob.m_PrgRemTimeOrig := SP_prgRemTime.AsFloat;
    tJob.m_ProgRscOrig    := trim(SP_rsc.AsString);
    tjob.m_ProgressOverride := Prg_NotIgnored;
    if RS_NumOfRsc.AsFloat > 0 then
      tjob.m_subLinRscId := 1;

    PTProgInfo := FindProgressData(ProgInfoList, tJob.m_reqDet.m_hdr.m_code,tJob.m_reqDet.m_code, tJob.m_code, tJob.m_reprocNo);
    if Assigned(PTProgInfo) then
    begin
      tJob.m_ProgType := PTProgInfo.ProgType;
      tJob.m_PrgSt    := PTProgInfo.PrgSt;
      tJob.m_PrgCurDt := PTProgInfo.PrgCurDt;
      tJob.m_PrgEd    := PTProgInfo.PrEd;
      tJob.m_ProgTypeOrig := PTProgInfo.ProgType;
      tJob.m_PrgStOrig    := PTProgInfo.PrgSt;
      tJob.m_PrgCurDtOrig := PTProgInfo.PrgCurDt;
      tJob.m_PrgEdOrig    := PTProgInfo.PrEd;
    end
    else
    begin
      if TMqmRes(p_pl.FindResByCode(Trim(SP_rsc.AsString))) = nil then
      begin
        tJob.m_PrgSt          := 0;
        tJob.m_PrgCurDt       := 0;
        tJob.m_PrgEd          := 0;
        tJob.m_PrgQty         := 0;
        tJob.m_PrgStartingQty := 0;
        tJob.m_PrgRemTime     := -1;
        tJob.m_ProgType       := '';
        tJob.m_ProgRsc        := '';
        tJob.m_PrgStHost      := 0;
        tJob.m_PrgCurDtHost   := 0;
        tJob.m_PrgEdHost      := 0;
        tJob.m_PrgQtyHost     := 0;
        tJob.m_PrgRemTimeHost := -1;
        tJob.m_ProgTypeHost   := '';
        tJob.m_ProgRscHost    := '';
        tJob.m_PrgStOrig      := 0;
        tJob.m_PrgCurDtOrig   := 0;
        tJob.m_PrgEdOrig      := 0;
        tJob.m_PrgQtyOrig     := 0;
        tJob.m_PrgStartingQtyOrig := 0;
        tJob.m_PrgRemTimeOrig := -1;
        tJob.m_ProgTypeOrig   := '';
        tJob.m_ProgRscOrig    := '';
      end;
    end;

    if (tjob.m_reqDet.m_stepType = CST_continuous) then
        tJob.p_exeMin := (tJob.p_quantSched * ExecutionTime/tDet.m_quantInit)
    else
        tJob.p_exeMin := ExecutionTime;

 //////  AVIIIIIII
    if RS_NumOfRsc.AsFloat > 0 then
    begin
      if tJob.m_numOfRscComp > 0 then
        tJob.p_exeMin := tJob.p_exeMin/tJob.m_numOfRscComp
      else
      begin
        tJob.p_exeMin := tJob.p_exeMin/RS_NumOfRsc.AsFloat;
        tJob.m_numOfRscComp := RS_NumOfRsc.AsInteger;
      end;

   //   tJob.m_numOfRscComp := 1;
    end;


    if tJob.p_exeMin = 0 then
       tJob.p_exeMin := 1;
    tJob.m_updateLearningCurve := true;

  //  tJob.p_exeMin_ORIGINAL := tJob.p_exeMin; // must update the original after read/write
    NewSubstep := -1;
    TmpQty := tJob.p_quantSched + tJob.p_quantManualChg;
    if ((tJob.m_ProgType = '4') or (tJob.m_ProgType = '5')) //if it is a progress with split
    and (TmpQty > tJob.m_PrgQty)
    and not (CheckSchedSumQty(tJob.m_Id)) then
      NewSubstep := GetNewSubStep (tJob.m_reqDet);

    if NewSubstep >= 0 then
    begin
      if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_exeMin > 0) then
          tJob.p_exeMin := tJob.m_PrgQty / tJob.p_quantSched * tJob.p_exeMin;
    //  tJob.p_exeMin_ORIGINAL := tJob.p_exeMin; // must update the original after read/write
      if (tJob.m_PrgQty > 0) and (tJob.p_quantSched > 0) and (tJob.p_supMinBase > 0) then
          tJob.p_supMinBase :=  tJob.m_PrgQty / tJob.p_quantSched * tJob.p_supMinBase;
    //  tJob.p_supMinBase_ORIGINAL := tJob.p_supMinBase; // must update the original after read/write
      tJob.p_quantSched := tJob.m_PrgQty;

      tJob.p_quantManualChg := 0;
      TmpQty := TmpQty - tJob.m_PrgQty;
      if (tJob.m_VisbleInBin = CSB_ReadOnly) then
        tJob.m_status := CSS_none;

      //Create a new job because of a final progress with split
      tDet.m_list.Sort(SortSubStep);
      if (tJob.m_ProgType = '4') then
        tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef)
      else if (tJob.m_ProgType = '5') then
      begin
        SavedProgressEnd := tJob.m_PrgEd;
        tJob := CreateNewJob(tDet, NewSubstep, CSnoGroupDef);
        tJob.p_schedStart := SavedProgressEnd;
        tJob.p_SetStepType    := '2';
        tJob.p_rscCode := Trim(SP_rsc.AsString);
        tJob.p_exeMin := ExecutionTime;
      end;

      if (WW_TypeOfUse1.AsString = '2') then
        tJob.m_VisbleInBin := CSB_ReadOnly
      else
        tJob.m_VisbleInBin  := CSB_Normal;

      tJob.m_status := CSS_new;
      tJob.p_quantSched := TmpQty;
      if (tJob.m_VisbleInBin = CSB_ReadOnly) then
        tJob.m_status := CSS_none;
      tjob.m_ProgressOverride := Prg_NotIgnored;
    end;

    qry.next;
    Inc(PrgRowCount);
    if Assigned(ProgBar) then
    begin
      DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
      if PrgPrevSecond <> PrgSecond then
      begin
        PrgPrevSecond := PrgSecond;
        PrgIndex := PrgIndex + PrgBlock;
        ProgBar.SetPosition(PrgIndex);
      end;
    end;
    if PrgRowCount mod 500 = 0 then Application.ProcessMessages;
    except
      if ParamCount = 0 then
        showmessage(_('Problem in loading progress for request') + ' : ' + qry.fieldByName(CreateFld(tbiSP.pfx,fli_preqNo)).AsString
                  + ' , ' +  _('Step') + ' : ' + IntToStr(qry.fieldByName(CreateFld(tbiSP.pfx,fli_pstepId)).AsInteger)
                  + ' , ' + _('Sub Step:') + ' ' + IntTostr(qry.fieldByName(CreateFld(tbiSP.pfx,fli_psubstId)).AsInteger)
                  + ' : ' + _('Progress is ignored'));
      qry.next;
      continue;
    end;

  end;

  //----------------------------------------------------------------------------

  for I := 0 to ProgInfoList.Count - 1 do
    Dispose(PTSQProgInfo(ProgInfoList[I]));
  ProgInfoList.Free;

  qry.close;
  qryST.Close;
  qryWW.Close;

  qryST.Free;
  qryWW.Free;
  WwTypeOfUseCache.Free;

  if Assigned(OverrProgressList) then
  begin
    for i := OverrProgressList.Count - 1 downto 0 do
        Dispose(PSQProgOverInfo(OverrProgressList[i]));
    OverrProgressList.Clear;
    OverrProgressList.Free;
  end;

  with qry do
  begin
    close;
    sql.Clear;
    sql.Add(' select * from ' + tbiPS_Share_Data.GetTableName);
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbiPS_Share_Data.pfx, fli_Identifier)));
    open;
    while not Eof do
    begin
      Application.ProcessMessages;
      UpdateSharedData(FieldByName(CreateFld(tbiPS_Share_Data.pfx, fli_preqNo)).AsString,
                       fieldByName(CreateFld(tbiPS_Share_Data.pfx,fli_pstepId)).AsInteger,
                       fieldByName(CreateFld(tbiPS_Share_Data.pfx,fli_psubstId)).AsInteger,
                       fieldByName(CreateFld(tbiPS_Share_Data.pfx,fli_reprocNo)).AsInteger,
                       FieldByName(CreateFld(tbiPS_Share_Data.pfx, fli_Comment)).AsString);
      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;
      Next;
    end;
  end;

//  UpdateExecutionWithLearningCurve(ProgBar);
  qry.close;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);

end;

