function TMSchedCont.GetNewSubStep(Det : TSCProdReqDet) : integer;
var
 PreviousSubStep, CurrentSubStep, I, SubStepTopLimit : integer;
begin
  SubStepTopLimit := 900;
  Result := -1;
  PreviousSubStep := -1;

  Det.m_list.Sort(SortSubStep);

  for I := 0 to Det.m_list.Count - 1 do
  begin
    CurrentSubStep := TSCProdSched(Det.m_list[I]).m_code;
//    if we will want to reuse isdeleted jobs - we will need to chabge the AddJobDet procedure
//    if  (CurrentSubStep < SubStepTopLimit)
//    and (TSCProdSched(Det.m_list[I]).m_isDeleted)
//    and (TSCProdSched(Det.m_list[I]).m_fromPD) then
//    begin
//      Result := CurrentSubStep;
//      break;
//    end;
    if CurrentSubStep > (SubStepTopLimit - 2) then
      break;
    if ((CurrentSubStep - PreviousSubStep) > 1) then
    begin
      Result := PreviousSubStep + 1;
      break;
    end;
    PreviousSubStep := CurrentSubStep;
    result := CurrentSubStep + 1;
  end;

  if (Result = -1) and (Det.m_list.Count > 0) then
    showmessage('Request: ' + Det.m_hdr.m_code + ' Step: ' + IntToStr(Det.m_code) + ' has more then 900 sub steps - please check your setup');


{  if ProgType = '4' then
  begin
    Det.m_list.Sort(SortSubStep);
    for I := Det.m_list.Count - 1 downto 0 do
    begin
      if TSCProdSched(Det.m_list[I]).m_code >= 600 then continue;
      result := TSCProdSched(Det.m_list[I]).m_code + 1;
      break;
    end;
    exit;
  end;

  if ProgType = '5' then
  begin
    Det.m_list.Sort(SortSubStep);
    for I := 0 to Det.m_list.Count - 1 do
    begin
      if TSCProdSched(Det.m_list[I]).m_code < (Job.m_code + 600) then continue;
      if TSCProdSched(Det.m_list[I]).m_code > (Job.m_code + 600) then
        result := TSCProdSched(Det.m_list[I]).m_code + 600;
      // If the Job.m_code + 300 = , it means we already have our m_code + 300 and we can not assign this substep
      break;
    end;
  end;     }

end;

