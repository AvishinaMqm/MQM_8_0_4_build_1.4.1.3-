function TMSchedCont.IsClosedForDetach(job: TSchedID): boolean;
var
  progInfo: TSQprogInfo;
  StepInfo: TSQStepInfo;
  ProdNo, StepNo: String;
  SonId : TSchedId;
  j: Integer;
  FieldValClose : variant;
  dataType: CBinColValType;
begin
  StepInfo.StepClosed := false;

  if p_sc.IsGroup(job) then
  begin
    GetFldSupport(Job, CSC_Closed, FieldValClose, dataType, false);
    if FieldValClose then
      StepInfo.StepClosed := true;
  end
  else
  begin
    StepNo := p_sc.GetFldDescr(Job, CSC_ProdStep, false);
    ProdNo := p_sc.GetFldDescr(Job, CSC_ProdReq, false);
    for j := 0 to p_sc.StepCount(ProdNo) -1 do
    begin
      StepInfo := p_sc.GetStepByIndex(ProdNo, j);
      if StepInfo.StepNo = StrToInt(StepNo) then break;
    end;
  end;

  Result := StepInfo.StepClosed;

end;

//----------------------------------------------------------------------------//

function TMSchedCont.CanDetach(job: TSchedID;  ErrList: TStrings; OrganizeOnStart : boolean): boolean;
var
  progInfo: TSQprogInfo;
  StepInfo: TSQStepInfo;
  ProdNo, StepNo: String;
  FieldVal, FieldValClose : variant;
  dataType: CBinColValType;
  linkInfo : TSQMCMlinkInfo;
begin
  StepInfo.StepClosed := false;
  Result := false;
  FieldVal := false;
  linkInfo.From_Mqm_Env := false;
  if DBAppGlobals.MCM_App then
    p_sc.GetMcmLinkInfo(job, linkInfo, true);

  if Assigned(p_sc.GetExtLinkPtr(job)) and TMqmWrkCtr(TMqmActArea(p_sc.GetExtLinkPtr(job)).p_WrkCtr).p_ReadOnly and not OrganizeOnStart then
  begin
    if Assigned(ErrList) then
      ErrList.Add(_('Can''t move jobs on a read only resource'));
    exit
  end;

  GetProgInfo(Job, progInfo);

  if (progInfo.ProgType <> '') then
  begin
    if Assigned(ErrList) then
      ErrList.Add(_('Can''t move a progressed job or group'));
    exit
  end;

  if p_sc.IsClosedForDetach(job) then
  begin
    if (CProgress(p_sc.IsProgressed(job)) = prg_none) then
    begin
      if Assigned(ErrList) and (MessageDlg(_('The step is closed, please press OK to confirm your request.'), mtWarning, [mbOk, mbCancel], 0) = mrCancel) then
      begin
        ErrList.Add(_('Can''t move a closed job or group'));
        exit
      end
      else
      if not Assigned(ErrList) then
        exit
    end
    else
    begin
      if Assigned(ErrList) then
        ErrList.Add(_('Can''t move a closed job or group'));
      exit
    end;
  end;

  if linkInfo.From_Mqm_Env then
  begin
    if Assigned(ErrList) then
      ErrList.Add(_('Can''t move an Mqm environment scheduled'));
    exit
  end;

  Result := true;
end;

