function ServingCode(Item1, Item2: Pointer): integer;
var
  ServingCode1, ServingCode2: PTServingCode;
begin
  ServingCode1 := PTServingCode(Item1);
  ServingCode2 := PTServingCode(Item2);
  if ServingCode1.code = ServingCode2.code then Result :=  0
  else if ServingCode1.code < ServingCode2.code then Result := -1
  else Result :=  1
end;

//----------------------------------------------------------------------------//

function OrderGrowing(Item1, Item2: Pointer): integer;
var
  id1, id2: TSchedID;
  schedStart1, schedStart2: TDateTime;
  FieldVal1, FieldVal2 : variant;
  dataType: CBinColValType;
begin
  id1 := TSchedID(Item1);
  id2 := TSchedID(Item2);

  Result :=  0;

  schedStart1 := p_sc.GetSchedStart(Id1);
  schedStart2 := p_sc.GetSchedStart(Id2);
  if schedStart1 < schedStart2 then
  begin
    Result := -1;
    Exit;
  end;
  if schedStart1 > schedStart2 then
  begin
    Result := 1;
    Exit;
  end;

  p_sc.GetFldValue(id1, CSC_ProdReq, FieldVal1, dataType);
  p_sc.GetFldValue(id2, CSC_ProdReq, FieldVal2, dataType);
  if FieldVal1 < FieldVal2 then
  begin
    Result := -1;
    Exit;
  end;
  if FieldVal1 > FieldVal2 then
  begin
    Result := 1;
    Exit;
  end;

  p_sc.GetFldValue(id1, CSC_ProdStep, FieldVal1, dataType);
  p_sc.GetFldValue(id2, CSC_ProdStep, FieldVal2, dataType);
  if FieldVal1 < FieldVal2 then
  begin
    Result := -1;
    Exit;
  end;
  if FieldVal1 > FieldVal2 then
  begin
    Result := 1;
    Exit;
  end;

  p_sc.GetFldValue(id1, CSC_ProdSubStep, FieldVal1, dataType);
  p_sc.GetFldValue(id2, CSC_ProdSubStep, FieldVal2, dataType);
  if FieldVal1 < FieldVal2 then
  begin
    Result := -1;
    Exit;
  end;
  if FieldVal1 > FieldVal2 then
  begin
    Result := 1;
    Exit;
  end;

end;

