procedure TMSchedCont.printReportForProperties(fileOut: string);
var
  strl:    TStringList;
  i,j,k:   integer;
  hdr:     TSCProdReqHdr;
  det:     TSCProdReqDet;
  grp:     TSCProdGroup;
  prop:    TPropID;
  propVal: variant;
  propRscCode: string;
begin
  strl := TStringList.Create;

  // properties for production requests details
  for i := 0 to m_prodReqList.Count-1 do
  begin
    hdr := TSCProdReqHdr(m_prodReqList[i]);

    for k := 0 to hdr.m_list.Count-1 do
    begin
      det := TSCProdReqDet(hdr.m_list[k]);

      strl.Add(Format('%6d', [i]) + ') ' + det.GetStrId);

      for j := 0 to det.m_propList.p_PropCount - 1 do
      begin
        propVal := det.m_propList.GetProperty(j, prop, propRscCode);
        strl.Add('          ' + GetPropCodeFromID(prop) + ' - ' + propRscCode + ' : ' + FormatToShow(prop, propVal))
      end
    end
  end;

  strl.Add('');
  strl.Add('');

  for i := 0 to m_grpList.Count-1 do
  begin
    grp := TSCProdGroup(m_grpList[i]);

    strl.Add(Format('%6d', [i]) + ') ' + grp.GetStrId);
{
    grp.BuildPropertyList;
    for j := 0 to grp.m_propList.p_PropCount - 1 do
    begin
      propVal := grp.m_propList.GetProperty(j, prop);
      strl.Add('          ' + GetPropCodeFromID(prop) + ' : ' + FormatToShow(prop, propVal))
    end
}
  end;

  strl.SaveToFile(fileOut);
  strl.Free
end;

