           // end;
            tJob.m_fromPD := false;
            tJob.m_status := CSS_AfterInsert;

            FindOrAddProdSchedFromDatabase('1', tHdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo);

            AddToListLogLines(LogListInfo, 'P', tHdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo,'Ins', 'S' ,tJob.GetRscCode, tJob.p_schedStart, tJob.p_schedEnd, tJob.p_quantSched, tjob.p_GetStepType, tJob.m_grpRemovedReason);
          end
        end
      end
    end;

    Unsechedule := false;

  end;

  if arraysize >= 0 then
  begin
    try
      qry.execute(arraysize + 1);
    except
     on E: EFDDBEngineException do
      begin
      //  Qry.Transaction.Rollback;
       { showmessage(E.Message + '  ' + _('Saving of') + ' ' + _('Request:') + ' ' + qry.params[3].AsStrings[E.Errors[0].RowIndex] + #13#10 +
         _('Step:') + qry.params[4].AsStrings[E.Errors[0].RowIndex] + ' ' +
         _(' sub Step:') + qry.params[5].AsStrings[E.Errors[0].RowIndex] + ' ' +   'was ignored');  }
       // raise;
      end;
    end;
  end;

  with qry do
  begin

    // work on the modified PSs
    Application.ProcessMessages;

    SqlUpdate := '';

    if DBAppGlobals.MCM_App then
    begin
      SqlUpdate :=  SqlUpdate + 'update ' + tbiPS.GetTableName + ' set ';
