      job.m_subLinRscId := TMqmVisibleRes(actArea.p_Father).p_SubCode;
    job.m_numOfRscComp    := moveChg.numOfRscComp;

    for i := 1 to grp.m_list.Count-1 do
    begin
      Job := TSCProdSched(grp.m_list[i]);
      Job.p_SetStepType := moveChg.SchedType;
      ActArea := TMqmActArea(sc.m_srvptr);
      if Assigned(actArea) then
        job.m_subLinRscId := TMqmVisibleRes(actArea.p_Father).p_SubCode;
      job.m_numOfRscComp    := moveChg.numOfRscComp
    end;
  end
  else
  begin
    job := TSCProdSched(sc);
    job.p_rscCode         := moveChg.RscCode;

//    job.p_supMinOvlp      := moveChg.supMinOvlp;
  //  sc.p_schedStart      := moveChg.startDate;
  //  sc.p_schedEnd        := moveChg.endDate;
  //  sc.p_exeMin          := moveChg.exeMin;
  //  sc.p_supMinBase      := moveChg.supMinBase;
  //  sc.p_supMinReal      := moveChg.supMinReal;
  //  sc.p_supMinOvlp      := moveChg.supMinOvlp;
    job.m_comment         := moveChg.comment;
    Job.p_SetStepType    := moveChg.SchedType;

    ActArea := TMqmActArea(sc.m_srvptr);
    if Assigned(actArea) then
      job.m_subLinRscId := TMqmVisibleRes(actArea.p_Father).p_SubCode
    else
      job.m_subLinRscId   := moveChg.subLinRscId;
    job.m_numOfRscComp    := moveChg.numOfRscComp
  end;

end;

