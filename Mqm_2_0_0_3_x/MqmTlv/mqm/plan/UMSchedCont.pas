procedure UpdateOverrideProgress(qry: TMqmQuery; tJob : TSCProdSched);
var
  tbiSP_OVER : ^TTblInfo;
begin
  tbiSP_OVER := @tblInfo[tbl_sched_progress_override];
  try

    with qry do
    begin
      // ===================== DELETE =====================
      Unprepare;
      Params.Clear;
      SQL.Clear;

      SQL.Add('Delete from ' + tbiSP_OVER.GetTableName);
      SQL.Add(' where ');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_Identifier) + ' = :' + CreateFld(tbiSP_OVER.pfx, fli_Identifier) + ' and ');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_preqNo)     + ' = :' + CreateFld(tbiSP_OVER.pfx, fli_preqNo)     + ' and ');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_pstepId)    + ' = :' + CreateFld(tbiSP_OVER.pfx, fli_pstepId)    + ' and ');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_psubstId)   + ' = :' + CreateFld(tbiSP_OVER.pfx, fli_psubstId)   + ' and ');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_reprocNo)   + ' = :' + CreateFld(tbiSP_OVER.pfx, fli_reprocNo));

      // Prepare removed — FireDAC: causes data type error on DB2/Oracle/InterBase

