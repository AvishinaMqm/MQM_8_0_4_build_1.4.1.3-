function TMSchedCont.LimitGroupByCount(LimitGrpCountPropId, LimitGrpCompValPropId : TpropId; ValueLimitGrpCountProp : integer; ValueLimitGrpCompValProp : string) : boolean;
var
  I, J : Integer;
  Grp : TSCProdGroup;
  Job : TSCProdSched;
  Properties : TProperties;
  FoundLimitGrpCountProp, FoundLimitGrpCompValProp : boolean;
  ValueLimitGrpCount, ValueLimitGrpCompVal : variant;
  LimitCounter : Integer;
begin
  result := false;
  LimitCounter := 0;
  for I := 0 to m_grpList.Count - 1 do
  begin
    Grp := TSCProdGroup(m_grpList[I]);
    begin
      for J := 0 to Grp.m_list.Count - 1 do
      begin
        job := TSCProdSched(Grp.m_list[J]);
        Properties := p_sc.GetProperties(job.m_Id,nil);
        if Assigned(Properties) then
        begin
          FoundLimitGrpCountProp := Properties.GetValforProp(LimitGrpCountPropId,ValueLimitGrpCount);
          FoundLimitGrpCompValProp := Properties.GetValforProp(LimitGrpCompValPropId,ValueLimitGrpCompVal);
          if FoundLimitGrpCountProp and FoundLimitGrpCompValProp and
             (ValueLimitGrpCountProp = ValueLimitGrpCount) and (ValueLimitGrpCompValProp = ValueLimitGrpCompVal) then
          begin
            Inc(LimitCounter);
            if LimitCounter = ValueLimitGrpCountProp then
            begin
              Result := true;
              Exit
            end;
            break;
          end;
        end;
      end;
    end;
  end;
end;

