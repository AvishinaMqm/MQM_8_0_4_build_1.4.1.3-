function TMSchedCont.GetDateToCompleteQty(Id: TSchedId; Res: TObject; QtyToComplete: double): TDateTime;
var
  Job:  TSCProdSched;
  TmpDur: double;
  Cal: TPGCALObj;
  ActArea:  TMqmActArea;
  SetupMin, Duration: double;
  TmgDescr: string;
  MSC: string;
  startDate, StartExecusion: TDateTime;
begin
  Result := 0;
  Cal := nil;
  TmgDescr := '';
  MSC := '';
  Job    := m_codeList[id];
//  if QtyToComplete > job.p_quantSched then exit;
  if QtyToComplete > job.p_quantSched then
     QtyToComplete := job.p_quantSched;
  if job.p_quantSched = 0 then exit;

  if job.m_reqDet.m_stepType = CST_batch then
  begin
    Result := Job.p_schedEnd;
    exit;
  end;

  if (Job.m_ProgType = '2') and (Job.m_PrgQty = QtyToComplete) then
  begin
    Result := Job.m_PrgCurDt;
    exit;
  end;

  startDate := Job.p_schedStart;

  ActArea := GetExtLinkPtr(id);
  if Assigned(Res) then
  begin
    //Assert(Res is TMqmVisibleRes);
    if not (Res is TMqmVisibleRes) then Exit;
    if Assigned(ActArea) and (ActArea.p_Father = Res) then
    begin
      Cal := ActArea.GetCalendar;
      SetupMin := job.p_supMinReal;
      Duration := job.p_exeMin;
    end
    else
    begin
      Cal := TMqmVisibleRes(Res).GetCalendar;
      p_pl.SetTmgTargetRes(TMqmRes(TMqmVisibleRes(Res).p_Father));
      p_pl.GetMainTimings(SetupMin, Duration, TmgDescr, MSC);
      CalcDur(TMqmActArea(p_sc.GetExtLinkPtr(Id)) ,startDate, id, duration, 1, true)
    end
  end else
  begin
    if Assigned(ActArea) then
    begin
      Cal := ActArea.GetCalendar;
      SetupMin := job.p_supMinReal;
      Duration := job.p_exeMin;
    end;
  end;

  if not Assigned(Cal) then
    exit;
  if not assigned(ActArea) then
    ActArea := TMqmActArea(TMqmVisibleRes(Res).p_ActArea[0]);

  cal.OfsByWH(SetupMin/60, true, startDate, StartExecusion, ActArea.m_CrossDownTmList);

  if (Job.m_ProgType = '2') and (Job.m_PrgQty > QtyToComplete) then
  begin
    TmpDur := cal.DiffWH(StartExecusion, Job.m_PrgCurDt, ActArea.m_CrossDownTmList)*60;
    TmpDur := TmpDur*QtyToComplete/Job.m_PrgQty;
    cal.OfsByWH(TmpDur/60, true, StartExecusion, Result, ActArea.m_CrossDownTmList);
    exit;
  end;

  if (Job.m_ProgType = '2') and (Job.m_PrgQty < QtyToComplete) then
  begin
    TmpDur := cal.DiffWH(Job.m_PrgCurDt, Job.p_schedEnd, ActArea.m_CrossDownTmList)*60;
    TmpDur := TmpDur*(QtyToComplete-Job.m_PrgQty)/(job.p_quantSched-Job.m_PrgQty);
    cal.OfsByWH(TmpDur/60, true, Job.m_PrgCurDt, Result, ActArea.m_CrossDownTmList);
    exit;
  end;

  if (Job.m_ProgType > '2') then
    TmpDur := cal.DiffWH(StartExecusion, Job.p_schedEnd, ActArea.m_CrossDownTmList)*60
  else
    TmpDur := Duration;

  TmpDur := TmpDur*QtyToComplete/job.p_quantSched;

  cal.OfsByWH(TmpDur/60, true, StartExecusion, Result, ActArea.m_CrossDownTmList);

end;

