procedure TMSchedCont.ClearSchedObj(id: TSchedID; Reason: string = 'ClearSchedObj');
var
  sc: TSCSchedOnPlan;
  grpSc: TSCProdGroup;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert((sc is TSCProdSched));
  if not (sc is TSCProdSched) then Exit;

 // if (sc is TSCProdSched) then
  //  TSCProdSched(sc).m_reqDet.m_list.Remove(sc);
  sc.m_isDeleted := true;
  TSCProdSched(sc).m_deleteReason := Reason;

  while True do
  begin
    if m_codeList.Count = 0 then break;
    if m_PhisicallyDelete_LimitIndex = -1 then break;
    if m_codeList.Count = m_PhisicallyDelete_LimitIndex then break;
    sc := TSCSchedOnPlan(m_codeList[m_codeList.Count - 1]);
    if (sc is TSCProdGroup) then
    begin
      grpSc := TSCProdGroup(m_codeList[m_codeList.Count - 1]);
      if not grpSc.m_isDeleted then break;
      m_codeList.delete(m_codeList.Count - 1);
      m_CloneCodeList.Remove(grpSc);
      grpSc.Free;
      continue;
    end;
    if not sc.m_isDeleted then break;
    TSCProdSched(sc).m_reqDet.m_list.Remove(sc);
    m_codeList.delete(m_codeList.Count - 1);
    m_CloneCodeList.Remove(sc);
    sc.Free;
  end;
end;

