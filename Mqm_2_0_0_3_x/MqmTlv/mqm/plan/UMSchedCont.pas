function TMSchedCont.CheckSchedSumQty(id: TSchedID): boolean;
var
  I : Integer;
  TotAllJobs, CurrJobQty : currency;
  sc:  TSCSchedOnPlan;
  tDet : TSCProdReqDet;
  job, tjob : TSCProdSched;
  grp : TSCProdGroup;
  AtLeastOneJobQtyGreaterThenProgress : boolean;
  AllFinal : boolean;
  FoundProgNotAssigned : boolean;
begin
  Result := false;
  FoundProgNotAssigned := false;
  AtLeastOneJobQtyGreaterThenProgress := false;
  AllFinal := true;
  TotAllJobs := 0;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc = nil then exit;
  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    job := grp.m_list[0];
    Result := CheckSchedSumQty(job.m_id);
  end
  else
  begin
    job := TSCProdSched(sc);
    tDet := TSCProdReqDet(job.m_reqDet);

    for I := tDet.m_list.count -1 downto 0 do
    begin
      tJob := tDet.m_list[i];
      if (tJob.m_isDeleted) or (tJob.m_reprocNo > 0) then Continue;

      if (IsProgressed(tJob.m_Id) <> prg_Final) and (IsProgressed(tJob.m_Id) <> prg_FinalSplit) then
        AllFinal := false;
                                                                // avi eran 0903/2022
      if tJob.m_PrgQty >= (tJob.p_qtySchdWithoutChg) then //+ tJob.p_quantManualChg) then
        TotAllJobs := TotAllJobs +  tJob.m_PrgQty
      else
      begin
        TotAllJobs := TotAllJobs +  tJob.p_qtySchdWithoutChg; //+ tJob.p_quantManualChg;
        AtLeastOneJobQtyGreaterThenProgress := true;
      end;

      if ((IsProgressed(tJob.m_Id) = prg_Final) or (IsProgressed(tJob.m_Id) = prg_FinalSplit))
          and not Assigned(tJob.m_srvPtr) then
             FoundProgNotAssigned := true;

    end;

    CurrJobQty := tDet.m_quantInit;

    if (CurrJobQty <> TotAllJobs) then
      Result := true;

    if Result and AtLeastOneJobQtyGreaterThenProgress and not FoundProgNotAssigned then
       Result := true
    else
       Result := false;

    if AllFinal and (CurrJobQty <= TotAllJobs) then
      result := false;
  end;
end;

