procedure TMSchedCont.UpdateBalanceForAllJobs(ProgBar: TMqmProgBar; Status: TStaticText);
var
  i : integer;
  job : TSCProdSched;
  grp:  TSCProdGroup;
  sc:   TSCSchedOnPlan;
begin

///////////// NEW

  m_CloneCodeList.clear;

  for I := 0 to m_codeList.Count - 1 do
    m_CloneCodeList.Add(m_codeList[I]);

  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(m_CloneCodeList.Count);
  end;

  if Assigned(Status) then
    Status.Caption := _('Update balances...');

  try
    m_CloneCodeList.Sort(SortCloneCodeListByDate);
  except
  end;

  for i := 0 to m_CloneCodeList.Count -1 do
  begin
    if Assigned(ProgBar) then
      ProgBar.SetPosition(i+1);

    Application.ProcessMessages;
    sc := TSCSchedOnPlan(m_CloneCodeList[i]);
    if sc is TSCProdSched then
    begin
      Application.ProcessMessages;
      job := TSCProdSched(m_CloneCodeList[i]);
      if not Assigned(job.m_srvPtr) or Assigned(job.m_grp) then
        continue; // interesting job are finished

      job.UpdateBalance(nil, true);
    end else
    begin
      grp := TSCProdGroup(m_CloneCodeList[i]);

      if not Assigned(grp.m_srvPtr) then //or Assigned(job.m_grp) then
        continue;

      grp.UpdateBalance(nil,true);
    end;

  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';

{
 //////////// OLD

  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(m_codeList.Count);
  end;

  if Assigned(Status) then
    Status.Caption := _('Update balances...');

  for i := 0 to m_codeList.Count -1 do
  begin
    sc := TSCSchedOnPlan(m_codeList[i]);
    if sc is TSCProdSched then
    begin
      job := TSCProdSched(m_codeList[i]);
      if not Assigned(job.m_srvPtr)
      or Assigned(job.m_grp) then
        continue;

      job.UpdateBalance;
    end else
    begin
      grp := TSCProdGroup(m_codeList[i]);
      grp.UpdateBalance;
    end;

    if Assigned(ProgBar) then
      ProgBar.SetPosition(i);
  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';
}
end;

