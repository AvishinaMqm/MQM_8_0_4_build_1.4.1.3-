    // job data (PS)
    Add(CreateFld(tbiPS.pfx, fli_rsc)                   + ','); // resource
    Add(CreateFld(tbiPS.pfx, fli_psubstId)              + ','); // prod Sub Step
    Add(CreateFld(tbiPS.pfx, fli_reprocNo)              + ','); // re- Process Num
    Add(CreateFld(tbiPS.pfx, fli_schedType)             + ','); // schedual Type
    Add(CreateFld(tbiPS.pfx, fli_Comment)               + ','); // comment for Split
    Add(CreateFld(tbiPS.pfx, fli_stGroup)               + ','); // step group
    Add(CreateFld(tbiPS.pfx, fli_wkCtrCode)             + ','); // should be from dispm ??
    Add(CreateFld(tbiPS.pfx, fli_wkcProc)               + ','); // workcenter process
    Add(CreateFld(tbiPS.pfx, fli_quant)                 + ','); // split quant
    Add(CreateFld(tbiPS.pfx, fli_exeMin)                + ','); // split exc time
    Add(CreateFld(tbiPS.pfx, fli_supMinBase)            + ','); // split base Set Up Time
    Add(CreateFld(tbiPS.pfx, fli_supMinReal)            + ','); // split real Set Up Time
    Add(CreateFld(tbiPS.pfx, fli_supMinOvlp)            + ','); // split real Set Up Time
    Add(CreateFld(tbiPS.pfx, fli_subLinRscId)           + ','); // sub line rsc
    Add(CreateFld(tbiPS.pfx, fli_schedStart)            + ','); // Sched Start
    Add(CreateFld(tbiPS.pfx, fli_schedEnd)              + ','); // Sched End
    Add(CreateFld(tbiPS.pfx, fli_NumSubRscComponents)   + ','); // No Of resource components
    Add(CreateFld(tbiPS.pfx, fli_ConnForwardSubStep)    + ','); // forward connected sub step (16) PS
    Add(CreateFld(tbiPS.pfx, fli_ConnForwardReProcess)  + ','); // forward connected Re-Process (17) PS
    Add(CreateFld(tbiPS.pfx, fli_ConnBackwardSubStep)   + ','); // backward connected sub step (18) PS
    Add(CreateFld(tbiPS.pfx, fli_ConnBackwardReProcess)      ); // backward connected Re-Process(19) PS

    Add(' from ');
    Add(tbiPH.GetTableName + ',' + tbiPD.GetTableName + ',' + tbiPS.GetTableName);

    Add(WHERE_IDF_Condition(CreateFld(tbiPH.pfx, fli_Identifier)) + ' AND' );
    Add(CreateFld(tbiPH.pfx, fli_preqNo)   + '=''' + ProdReqNo + ''' and ');

    Add(CreateFld(tbiPH.pfx, fli_Identifier) + '=' + CreateFld(tbiPD.pfx, fli_Identifier) + ' and ');
    Add(CreateFld(tbiPH.pfx, fli_preqNo)   + '=' + CreateFld(tbiPD.pfx, fli_preqNo) + ' and ');

    Add(CreateFld(tbiPD.pfx, fli_Identifier)   + '=' + CreateFld(tbiPS.pfx, fli_Identifier) + ' and ');
    Add(CreateFld(tbiPD.pfx, fli_preqNo)   + '=' + CreateFld(tbiPS.pfx, fli_preqNo) + ' and ');
    Add(CreateFld(tbiPD.pfx, fli_pstepId)  + '=' + CreateFld(tbiPS.pfx, fli_pstepId)); //+ ' and ');

    Add(' order by');
    Add(CreateFld(tbiPD.pfx, fli_preqNo)  + ',');
    Add(CreateFld(tbiPD.pfx, fli_pstepId) + ',');
    Add(CreateFld(tbiPS.pfx, fli_psubstId))
