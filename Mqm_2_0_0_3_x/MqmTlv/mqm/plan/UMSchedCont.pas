begin
  Result := true;
  AtLeastOneSched := false;
  FoundPlant := '';
  sc := TSCSchedOnPlan(m_codeList[Id]);
  //assert(sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  scP := TSCProdSched(m_codeList[id]);
  tHdr := scP.m_reqDet.m_hdr;
  for I := 0 to tHdr.m_list.Count - 1 do
  begin
    if not result then break;
    ProdReqDet := TSCProdReqDet(tHdr.m_list[I]);
    for J := 0 to ProdReqDet.m_list.Count - 1 do
    begin
      scP := TSCProdSched(ProdReqDet.m_list[J]);
      if not Assigned(GetExtLinkPtr(scP.m_id)) then continue;
      objWkc := TMqmWrkCtr(p_pl.FindWrkCtrByCode(GetFldDescr(scP.m_id, CSC_WkctCode, false)));
      if not assigned(objWkc) then continue;
      if objWkc.p_PlantCode = '' then continue;
      if AtLeastOneSched and (FoundPlant <> objWkc.p_PlantCode) then
      begin
        result := false;
        break;
      end;
      FoundPlant := objWkc.p_PlantCode;
      AtLeastOneSched := true;
    end;
  end;
  if not AtLeastOneSched then result := false;
  if result then Plant_WC := FoundPlant;
end;

