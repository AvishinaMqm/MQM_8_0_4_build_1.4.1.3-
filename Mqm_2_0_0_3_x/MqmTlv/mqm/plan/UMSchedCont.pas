function TMSchedCont.SetWCProcessInfo(id: TSchedID): boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  PlanWrkCrt,
  WrkCtr : TMqmWrkCtr;
  AltProces : string;
  i: integer;

  procedure SetWCProcess(JobToSet: TSCProdSched);
  begin
    if Assigned(JobToSet.m_srvPtr) then
    begin
      WrkCtr := TMqmWrkCtr(TMqmActArea(JobToSet.m_srvPtr).p_WrkCtr);
      if Assigned(WrkCtr) then
      begin
//        JobToSet.m_SchedwkCtrCode := WrkCtr.p_WrkCtrCode;
//        JobToSet.m_SchedWkCtrPtr := WrkCtr;

        if WrkCtr.p_WrkCtrCode = JobToSet.m_reqDet.m_planWkctr then
          // JobToSet.m_SchedwkcProc := JobToSet.m_reqDet.m_planWkctrProc
        else
        begin
          PlanWrkCrt := TMqmWrkCtr(JobToSet.m_reqDet.m_PlanWrkCtrPtr);
          //PlanWrkCrt := TMqmWrkCtr(p_pl.FindWrkCtrByCode(JobToSet.m_reqDet.m_planWkctr));
          PlanWrkCrt.GetAltProcForAltWrkCtr(JobToSet.m_reqDet.m_planWkctrProc, WrkCtr.p_WrkCtrCode, AltProces);
//          JobToSet.m_SchedwkcProc := AltProces
        end
      end;
    end else
    begin
//      JobToSet.m_SchedwkCtrCode := '';
//      JobToSet.m_SchedwkcProc := '';
//      JobToSet.m_SchedWkCtrPtr := nil;
    end;
  end;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    SetWCProcess(job);
  end else
  begin
    grp := TSCProdGroup(sc);
    if Assigned(grp) and not (grp.m_list.Count > 0) then Exit;
//    Assert(grp.m_list.Count > 0);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      SetWCProcess(job);
    end
  end;

  Result := true
end;

