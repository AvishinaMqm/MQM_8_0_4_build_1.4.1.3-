function TMSchedCont.GetStatuseMsgForJob(id: TSchedID; var IsGroup : boolean; var SignGetMsg : boolean; var SignSentMsg : boolean) : boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  I : Integer;
  Temp : boolean;
begin
  Result := false;
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    SignGetMsg := job.m_JobMsgGet;
    SignSentMsg := job.m_JobMsgSent;
    if SignGetMsg or SignSentMsg then
       Result := true;
  end else
  begin
    grp := TSCProdGroup(sc);
    //Assert(Assigned(grp));
    if not Assigned(grp) then Exit;
    //Assert(grp.m_list.Count > 0);
    if not (grp.m_list.Count > 0) then Exit;
    IsGroup := true;

    job := TSCProdSched(grp.m_list[0]);
    if GetStatuseMsgForJob(job.m_Id,Temp,SignGetMsg,SignSentMsg) then
    begin
      Result := true;
      Exit;
    end;

    for i := 1 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      if GetStatuseMsgForJob(job.m_Id,Temp,SignGetMsg,SignSentMsg) then
      begin
        Result := true;
        Exit;
      end;
    end;
  end;

end;

