function TMSchedCont.CanDetachGroup(id: TSchedID) : boolean;
var
  sc    : TSCSchedOnPlan;
  Group : TSCProdGroup;
  jobSc : TSCProdSched;
  I : Integer;
  Progress : CProgress;
  FoundProgressed , FoundNotProgressed : boolean;
begin
  Result := false;
  FoundProgressed := false;
  FoundNotProgressed := false;
  sc := TSCSchedOnPlan(m_codeList[id]);
  //assert(sc is TSCProdGroup);
  if not (sc is TSCProdGroup) then exit;
  Group := TSCProdGroup(sc);
  for I := 0 to Group.m_list.Count - 1 do
  begin
    jobSc := TSCProdSched(Group.m_list[I]);
    Progress := IsProgressed(jobSc.m_Id);
    if (Progress = prg_starting) or (Progress = prg_general) or (Progress = prg_Final) then
      FoundProgressed := true
    else if Progress = prg_none then
      FoundNotProgressed := true;
  end;
  if FoundProgressed and FoundNotProgressed then
    Result := true
end;

//----------------------------------------------------------------------------//

function TMSchedCont.CanDetachJobOrGroup(id: TSchedID) : boolean;
var
  SonId : TSchedID;
  planInfo: TSQplanInfo;
  I : Integer;
begin
  Result := true;
  GetPlanInfo(Id, planInfo);

  if (not planInfo.isGroup) and (CProgress(p_sc.IsProgressed(Id)) <> prg_none) then
    Result := false;

  if planInfo.isGroup then
  begin
    for I := 0 to p_sc.GetGrpNumSons(Id) - 1 do
    begin
      SonId := p_sc.GetGrpSon(Id, I);
      if (CProgress(p_sc.IsProgressed(SonId)) <> prg_none) then
      begin
        Result := false;
        Break;
      end;
    end;
  end;

end;

