function FindMaterialSched(MtrList : TList; TYPE_PROD, PRODUCT_CODE, RequestNo, SUB_DETAIL, DETAIL_CODE : string) : TSCMaterialSched;
var
  i: integer;
  Multiplier, NumberOfEntries, NumberOfEntriesMinusOne : integer;
begin
  Result := nil;

  NumberOfEntries := MtrList.Count;
  if NumberOfEntries = 0 then exit;
  NumberOfEntriesMinusOne := NumberOfEntries - 1;

  Multiplier := 1;
  while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
    i := Multiplier - 1;

  while (Multiplier > 0) do
  begin
    Multiplier := trunc(Multiplier / 2);

    if (i > NumberOfEntriesMinusOne)
    or ((TSCMaterialSched(MtrList[i]).m_ITEM_TYPE > TYPE_PROD)) then
    begin
      i := i - Multiplier;
      Continue;
    end;

    if (TSCMaterialSched(MtrList[i]).m_ITEM_TYPE < TYPE_PROD) then
    begin
      i := i + Multiplier;
      Continue;
    end;

    if (TSCMaterialSched(MtrList[i]).m_PRODUCT_CODE < PRODUCT_CODE) then
    begin
      i := i + Multiplier;
      Continue;
    end;

    if  (TSCMaterialSched(MtrList[i]).m_PRODUCT_CODE > PRODUCT_CODE) then
    begin
      i := i - Multiplier;
      Continue;
    end;

    if (TSCMaterialSched(MtrList[i]).m_MATERIAL_CODE_SUB_DET < SUB_DETAIL) then
    begin
      i := i + Multiplier;
      Continue;
    end;

    if  (TSCMaterialSched(MtrList[i]).m_MATERIAL_CODE_SUB_DET > SUB_DETAIL) then
    begin
      i := i - Multiplier;
      Continue;
    end;

    if (TSCMaterialSched(MtrList[i]).m_Material_Code_DET < DETAIL_CODE) then
    begin
      i := i + Multiplier;
      Continue;
    end;

    if  (TSCMaterialSched(MtrList[i]).m_Material_Code_DET > DETAIL_CODE) then
    begin
      i := i - Multiplier;
      Continue;
    end;

    Result := TSCMaterialSched(MtrList[i]);
    Break;

  end;

end;

