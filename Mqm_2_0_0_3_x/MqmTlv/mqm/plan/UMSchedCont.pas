    tJob.m_ActualEndDate_ORIGINAL_Saved       := tJob.P_ActualEndDate_ORIGINAL
  end
  else
  begin
    if tJob.m_Backup_Saved then
    begin
      tJob.m_fromPD := tJob.m_fromPD_Saved;
      tJob.m_status := tJob.m_status_Saved;
      tJob.P_LastScheudleChange_ORIGINAL  := tJob.m_LastScheudleChange_ORIGINAL_Saved;
      tJob.P_rscCode_ORIGINAL             := tJob.m_rscCode_ORIGINAL_Saved;
      tJob.P_AlternativeCode_ORIGINAL     := tJob.m_AlternativeCode_ORIGINAL_Saved;
      tJob.P_WorkCenterCode_ORIGINAL      := tJob.m_WorkCenterCode_ORIGINAL_Saved;
      tJob.P_ProcessCode_ORIGINAL         := tJob.m_ProcessCode_ORIGINAL_Saved;
      tJob.P_GroupCode_ORIGINAL           := tJob.m_GroupCode_ORIGINAL_Saved;
      tJob.P_SchedType_ORIGINAL           := tJob.m_SchedType_ORIGINAL_Saved;
      tJob.P_NumSubRscComponents_ORIGINAL := tJob.m_NumSubRscComponents_ORIGINAL_Saved;
      tJob.P_SubLinRscId_ORIGINAL         := tJob.m_SubLinRscId_ORIGINAL_Saved;
      tJob.P_MachSetupCode_ORIGINAL       := tJob.m_MachSetupCode_ORIGINAL_Saved;
      tJob.P_schedStart_ORIGINAL          := tJob.m_schedStart_ORIGINAL_Saved;
      tJob.P_schedEnd_ORIGINAL            := tJob.m_schedEnd_ORIGINAL_Saved;
      tJob.P_exeMin_ORIGINAL              := tJob.m_exeMin_ORIGINAL_Saved;
      tJob.P_supMinBase_ORIGINAL          := tJob.m_supMinBase_ORIGINAL_Saved;
      tJob.P_supMinReal_ORIGINAL          := tJob.m_supMinReal_ORIGINAL_Saved;
      tJob.P_supMinOvlp_ORIGINAL          := tJob.m_supMinOvlp_ORIGINAL_Saved;
      tJob.P_quantSched_ORIGINAL          := tJob.m_quantSched_ORIGINAL_Saved;
      tJob.p_quantManualChg_ORIGINAL      := tJob.m_quantManualChange_ORIGINAL_Saved;
      tJob.P_Comment_ORIGINAL             := tJob.m_Comment_ORIGINAL_Saved;
      tJob.p_LearningCurve_ORIGINAL       := tJob.m_LearningCurve_ORIGINAL_Saved;
      tJob.p_ActualStartDate_ORIGINAL     := tJob.m_ActualStartDate_ORIGINAL_Saved;
      tJob.p_ActualEndDate_ORIGINAL       := tJob.m_ActualEndDate_ORIGINAL_Saved;
      tJob.m_Backup_Saved := false;
    end;
  end;

end;

//----------------------------------------------------------------------------//

function TMSchedCont.GetFldSupport(id: TSchedID; fld: CBinColId; out value: variant;
                                   out dataType: CBinColValType; RealValueInCell : boolean): boolean;
var
  sc:     TSCSchedOnPlan;
  scP:    TSCProdSched;
  scG:    TSCProdGroup;
  pId:    TPropId;
  PrevId: TSchedId;
  supRec: TSetupRec;
  fwdConnSubStp, bckConnSubStp : integer;
  compBack: TCompatVal;
  res :   TMqmRes;
  IsSameGroup: boolean;
  prop :  TProperties;
  WrkCtr :TMqmWrkCtr;
  AltProces, LearningCurveCode : string;
  num, i : integer;
  dt:     TDateTime;
  Req, PlanWc, PlanProcess, ProdType, ProdFamily : string;
  MaterialFamily, Um, Cal, ConnType : string;
  StepType : CScSchedType;
  MsgFromHost : CScMsgFromHost;
  UserReqSplitOnHost,MsgSplit : boolean;
  Step, SubStep, RepNr, Components :  Integer;
  tfl :    double;
  tflCurrecy:    currency;
  FoundProg, IsDur, IsAbs : boolean;
  PropIp_CustomDate : TPropId;
  DateFieldSupport, BinDateColumn : CBinColId;
  FoundPropVal : boolean;
  AddTime : double;
  Propvalue, temp : Variant;
  TempDateTime, TempDateTime2, TempLeadTime, HighestEnd, HighestEnd_WithoutLeadTime, LowestStart, LowestStart_WithoutLeadTime : TDateTime;
  FoundVal : boolean;
  ProdReqDet : TSCProdReqDet;
  LowestDateTime, HighestDateTime, ValueDateTime : TDateTime;
  ServingGroupCode : string;
  FoundGroupedById : boolean;
  CountClosedInGrp : integer;
  Article: TMQMArticle;
begin
  Result := true;

  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdGroup then
  begin

    scG := TSCProdGroup(m_codeList[id]);
    //Assert(scG.m_list.Count > 0);
    if not (scG.m_list.Count > 0) then exit;
    scP := TSCProdSched(scG.m_list[0]);

    if fld in [CSC_WkctCode,CSC_WkctGrp,CSC_WkctPlant,CSC_WkctDivision,CSC_WkctCodeDesc,CSC_WkctProc,CSC_WkctProcDesc,CSC_MsgFromHost,CSC_CurveCode,
               CSC_ProdLine,CSC_Comment,CSC_ProgType,CSC_ProgType_Host,CSC_ProgRsc,CSC_ProgRscDesc,
               CSC_FwdConnSubStp,CSC_FwdConnReProcs,CSC_BkwConnSubStp,CSC_BkwConnReProcs, CSC_SplitFamily,
               CSC_Overlapping, CSC_Rsc,CSC_RscDesc,CSC_GenericPlanWC,CSC_GenericPlanDur, CSC_GenericPlanLeadTime,
               CSC_GenericPlanMachineNum, CSC_GenericPlanStartDate, CSC_GenericPlanEndDate, CSC_CustomerDate, CSC_Customized_column2, CSC_Customized_column3, CSC_batch_ContinuesTime,
               CSC_Continues_parallel,CSC_ProductDescription, CSC_JobComponents, CSC_MachineComponents] then
      Result := GetFldSupport(scP.m_Id, fld, Value, dataType, RealValueInCell)
    else

      case fld of

      CSC_SchedSeq:
        begin
          dataType := CBT_Integer;
          Value := 0;
        end;

      CSC_SeqCB:
        begin
          dataType := CBT_Integer;
          Value := 0;
        end;

        CSC_ProdReq:
          begin
            dataType := CBT_string;
            Req := scP.m_reqDet.m_hdr.m_code;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if Req <> scP.m_reqDet.m_hdr.m_code then
                  Result := false;
              end;
            end;
            value := Req
          end;

        CSC_SharedComment:
        begin
          dataType := CBT_string;
          value    := scG.m_SharedComment
        end;

        CSC_ProdStep:
          begin
            dataType := CBT_integer;
            Step := scP.m_reqDet.m_code;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if Step <> scP.m_reqDet.m_code then
                  Result := false;
              end;
            end;
            value := Step
          end;

        CSC_ProdSubStep:
          begin
            dataType := CBT_integer;
            SubStep := scP.m_code;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if SubStep <> scP.m_code then
                  Result := false;
              end;
            end;
            value := SubStep
          end;

        CSC_ReprocNo:
          begin
            dataType := CBT_integer;
            RepNr := scP.m_reprocNo;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if RepNr <> scP.m_reprocNo then
                  Result := false;
              end;
            end;
            value := RepNr
          end;
        CSC_GroupNo:
          begin
            dataType := CBT_String;
            num    := scG.m_code;
            if num < 0 then
              value := intToStr((-1) * num) + '(-Host)'
            else
              value := intToStr(num);
          end;
       CSC_PlanWkctCode:
          begin
            dataType := CBT_String;
            PlanWc := scP.p_WorkCenter;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if PlanWc <> scP.p_WorkCenter then
                  Result := false;
              end;
            end;
            value := PlanWc
          end;

        CSC_PlanWkctDesc:
          begin
            dataType := CBT_string;
            PlanWc := scP.p_WorkCenter;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if PlanWc <> scP.p_WorkCenter then
                  Result := false;
              end;
            end;
            if Result then
            begin
              value := PlanWc;
              WrkCtr := TMqmWrkCtr(scP.p_WrkCtrPtr);
              if Assigned(WrkCtr) then
                value := WrkCtr.p_WrkCtrSDesc;
            end;
          end;

        CSC_PlanWkctProc:
          begin
            dataType := CBT_String;
            PlanProcess := scP.p_Process;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if PlanProcess <> scP.p_Process then
                  Result := false;
              end;
            end;
            value := PlanProcess
          end;

        CSC_PlanWkctProcDesc:
          begin
            dataType := CBT_String;
            PlanProcess := scP.p_Process;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if PlanProcess <> scP.p_Process then
                  Result := false;
              end;
            end;
            if Result then
            begin
              value := scP.p_WorkCenter;
              WrkCtr := TMqmWrkCtr(scP.p_WrkCtrPtr);
              //WrkCtr := TMqmWrkCtr(p_pl.FindWrkCtrByCode(value));
              if Assigned(WrkCtr) then
              value := WrkCtr.GetProcDesc(scP.p_Process);
            end;
          end;

        CSC_ProdType:
          begin
            dataType := CBT_string;
            ProdType := scP.m_reqDet.m_hdr.m_prodType;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if ProdType <> scP.m_reqDet.m_hdr.m_prodType then
                  Result := false;
              end;
            end;
            value := ProdType
          end;

        CSC_ProdTypeDesc:
          begin
            dataType := CBT_string;
            ProdType := scP.m_reqDet.m_hdr.m_prodType;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if ProdType <> scP.m_reqDet.m_hdr.m_prodType then
                  Result := false;
              end;
            end;
            if Result then
              value := TSCProdSched(scG.m_list[0]).m_reqDet.m_hdr.m_prodTypeDesc;  //p_ArtType.GetSDesc(ProdType);
          end;

        CSC_ProdFamily:
          begin
            dataType := CBT_String;
            ProdFamily := scP.m_reqDet.m_hdr.m_prodFamily;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if ProdFamily <> scP.m_reqDet.m_hdr.m_prodFamily then
                  Result := false;
              end;
            end;
            value := ProdFamily
          end;

        CSC_ProdMatFamily:
          begin
            dataType := CBT_String;
            MaterialFamily := scP.m_reqDet.m_hdr.m_matFamily;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if MaterialFamily <> scP.m_reqDet.m_hdr.m_matFamily then
                  Result := false;
              end;
            end;
            value := MaterialFamily
          end;

        CSC_ProdUM:
          begin
            dataType := CBT_String;
            Um := scP.m_reqDet.m_hdr.m_prodUMCode;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if Um <> scP.m_reqDet.m_hdr.m_prodUMCode then
                  Result := false;
              end;
            end;
            value := Um
          end;

        CSC_ProdUMDesc:
          begin
            dataType := CBT_String;
            Um := scP.m_reqDet.m_hdr.m_prodUMCode;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if Um <> scP.m_reqDet.m_hdr.m_prodUMCode then
                  Result := false;
              end;
            end;
            if Result then
            begin
              value := GetSUmDesc(Um)
            end;
          end;

        CSC_StepType:
          begin
            dataType := CBT_integer;
            StepType := scP.m_reqDet.m_stepType;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if StepType <> scP.m_reqDet.m_stepType then
                  Result := false;
              end;
            end;
            value := StepType;
          end;

        CSC_Calendar:
          begin
            dataType := CBT_String;
            cal := scP.m_reqDet.m_calCod;
            if Assigned(FBin) and FBin.ShowFirstGrplineInBin then
            begin
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if cal <> scP.m_reqDet.m_calCod then
                  Result := false;
              end;
            end;
            value := cal;
          end;

        CSC_ApprovalDate :
          begin
            dataType := CBT_date;
            dt := scP.p_ApprovalDate;
            for i := 1 to scG.m_list.Count-1 do
            begin
              scP := TSCProdSched(scG.m_list[i]);
              if dt <> scP.p_ApprovalDate then
              begin
                Result := false;
                break
              end;
            end;
            value := dt
          end;

        CSC_LowStartTimeLimit:
          begin
            dataType := CBT_date;
            dt := scP.m_reqDet.m_hdr.m_prodLowDateTime;
            for i := 1 to scG.m_list.Count-1 do
            begin
              scP := TSCProdSched(scG.m_list[i]);
              if dt < scP.m_reqDet.m_hdr.m_prodLowDateTime then
                dt := scP.m_reqDet.m_hdr.m_prodLowDateTime
            end;
            value := dt
          end;

       CSC_LastScheudleChange:
       begin
         dataType := CBT_date;
         value    := scG.p_LastScheudleChange;
       end;

       CSC_SchedStart:
        begin
          dataType := CBT_date;
          if TSCProdSched(scG.m_list[0]).m_reqDet.m_stepType = CST_Continuous then
            value := scG.p_SchedStartOfJobInContGroup //scG.p_OrigSchedStart;
          else
            value    := scG.p_OrigSchedStart;
          if not Assigned(scP.m_srvPtr) then Result := false
        end;

       CSC_SchedEnd:
       begin
         dataType := CBT_date;
         if TSCProdSched(scG.m_list[0]).m_reqDet.m_stepType = CST_Continuous then
           value    := scG.p_SchedEndOfJobInContGroup // scG.p_OrigSchedEnd;
         else
           value    := scG.p_OrigSchedEnd;
         if not Assigned(scP.m_srvPtr) then Result := false
       end;

       CSC_SavedScheduleDate:
        begin
          dataType := CBT_date;
          value    := scG.p_SavedScheudleDate;
        end;

       CSC_ProgStart:
         begin
           value := 0;
           dataType := CBT_date;
           FoundProg := false;
           if not Assigned(scG.m_srvPtr) then
           begin
             Result := false;
             exit;
           end;

           for i := 0 to scG.m_list.Count-1 do
           begin
             scP := TSCProdSched(scG.m_list[i]);
             if (scP.m_PrgSt <> 0) then
             begin
               FoundProg := true;
               break;
             end;
           end;

           if FoundProg then
           begin
             value := scP.m_PrgSt;
             for i := 1 to scG.m_list.Count-1 do
             begin
               scP := TSCProdSched(scG.m_list[i]);
               if (scP.m_PrgSt <> 0) and ((value = 0) or (scP.m_PrgSt < value)) then
                  value := scP.m_PrgSt;
             end;
           end
           else
             value := scG.p_OrigSchedStart
       end;

       CSC_ProgEnd:
         begin
           value := 0;
           dataType := CBT_date;
           FoundProg := false;
           if not Assigned(scG.m_srvPtr) then
           begin
             Result := false;
             exit;
           end;

           if scP.m_reqDet.m_stepType = CST_batch then
           begin
             for i := 0 to scG.m_list.Count-1 do
             begin
               scP := TSCProdSched(scG.m_list[i]);
               if (scP.m_PrgEd <> 0) or (IsProgressed(scP.m_id) <> prg_none) then
               begin
                 FoundProg := true;
                 break;
               end;
             end;

             if FoundProg then
             begin
               value := scP.m_PrgEd;
               for i := 1 to scG.m_list.Count-1 do
               begin
                 scP := TSCProdSched(scG.m_list[i]);
                 if (IsProgressed(scP.m_id) <> prg_none) then
                 begin
                  if scP.m_PrgEd <> 0 then
                    value    := scP.m_PrgEd
                  else
                    value    := scP.p_schedEnd;
                 end;
               end;
             end
             else
               value := scG.p_OrigschedEnd
           end
           else
           begin
             for i := 0 to scG.m_list.Count-1 do
             begin
               scP := TSCProdSched(scG.m_list[i]);
               if (scP.m_PrgEd <> 0) then
               begin
                 FoundProg := true;
                 break;
               end;
             end;

             if FoundProg then
             begin
               value := scP.m_PrgEd;
               for i := 1 to scG.m_list.Count-1 do
               begin
                 scP := TSCProdSched(scG.m_list[i]);
                  if (scP.m_PrgEd <> 0) and ((value = 0) or (scP.m_PrgEd > value)) then
                     value := scP.m_PrgEd;
               end;
             end
             else
             begin
               value := scG.p_OrigschedEnd;                 // non-ignored: exact 1.3.0.17 behavior
               // Ignored continuous group: p_OrigschedEnd is empty for continuous groups, so show
               // the scheduled end (same field CSC_SchedEnd uses). Gated on the ignore flag so
               // non-ignored groups are completely unaffected.
               if (scG.m_list.Count > 0)
               and (TSCProdSched(scG.m_list[0]).m_ProgressOverride in [Prg_Ignored, Prg_IgnoredAndSave]) then
                 value := scG.p_SchedEndOfJobInContGroup;
             end
           end;

       end;

      CSC_ProdDlvDate:
          begin
            dataType := CBT_date;
            value := scP.p_DeliveryDate;
          end;

      CSC_MatArrivalDate:
          begin
            dataType := CBT_date;
            value := scP.p_MatArrDate
          end;

      CSC_PlanStartDate:
          begin
            dataType := CBT_date;
            value := scP.p_PlannedStrDate
          end;

      CSC_LowStartDate:
          begin
            dataType := CBT_date;
            value := scP.p_LowStartDate
          end;

      CSC_PlanEndDate:
          begin
            dataType := CBT_date;
            value := scP.p_PlannedEndDate
          end;

      CSC_HighEndLimit:
          begin
            dataType := CBT_date;
            value := scP.p_HighEndDate
          end;

      CSC_OrigHighEndLimit:
          begin
            dataType := CBT_date;
            value := scP.p_HighEndDateTemp
          end;

      CSC_IniQty:
          begin
            dataType := CBT_float;
            tfl      := 0.0;
            Um := scP.m_reqDet.m_hdr.m_prodUMCode;
            for i := 1 to scG.m_list.Count-1 do
            begin
            //  scP := TSCProdSched(scG.m_list[i]);
            //  if Um <> scP.m_reqDet.m_hdr.m_prodUMCode then
            //    Result := false;
            end;
            if Result then
            begin
              for i := 0 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                tfl := tfl + scP.m_reqDet.m_quantInit
              end;
              value := tfl
            end;
          end;

      CSC_FinQty:
          begin
            dataType := CBT_float;
            tfl      := 0.0;
            Um := scP.m_reqDet.m_hdr.m_prodUMCode;
            for i := 1 to scG.m_list.Count-1 do
            begin
             // scP := TSCProdSched(scG.m_list[i]);
             // if Um <> scP.m_reqDet.m_hdr.m_prodUMCode then
             //   Result := false;
            end;
            if Result then
            begin
              for i := 0 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                tfl := tfl + scP.m_reqDet.m_quantFinl
              end;
              value := tfl
            end;
          end;

    {  CSC_WeightUM:
          begin
            dataType := CBT_float;
            tfl      := 0.0;

            Um := scP.m_reqDet.m_hdr.m_prodUMCode;
            for i := 1 to scG.m_list.Count-1 do
            begin
              scP := TSCProdSched(scG.m_list[i]);
              if Um <> scP.m_reqDet.m_hdr.m_prodUMCode then
                Result := false;
            end;
            if Result then
            begin


              for i := 0 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                tfl := tfl + scP.m_reqDet.m_weight
              end;
              value := tfl
            end;
          end;  }

      CSC_WeightWithUM:
        begin
          dataType := CBT_string;
          tfl      := 0.0;
          Um := scP.m_reqDet.m_hdr.m_prodUMCode;
          for i := 1 to scG.m_list.Count-1 do
          begin
            scP := TSCProdSched(scG.m_list[i]);
              if Um <> scP.m_reqDet.m_hdr.m_prodUMCode then
                Result := false;
          end;
          if Result then
          begin
            for i := 0 to scG.m_list.Count-1 do
            begin
              scP := TSCProdSched(scG.m_list[i]);
              tfl := tfl + scP.m_reqDet.m_weight
            end;
            value  := FloatToStr(tfl) + '    ' + scP.m_reqDet.m_weightUM;
          end;

        end;

      CSC_PlanSetup:
        begin
          dataType := CBT_dur;
          value    := scP.m_reqDet.m_SetupTimeStep
        end;

      CSC_PlanSetup_Float:
        begin
          dataType := CBT_float;
          value    := scP.m_reqDet.m_SetupTimeStep
        end;

      CSC_ExeTime:
          begin
            dataType := CBT_dur;
            tfl      := 0.0;
            if scP.m_reqDet.m_Continues_Parallel
            or ((scP.m_reqDet.m_stepType = CST_batch)) then
            begin
              tfl := scP.m_reqDet.m_ExeTimeStep;
              for i := 1 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
                if scP.m_reqDet.m_ExeTimeStep > tfl then
                   tfl := scP.m_reqDet.m_ExeTimeStep;
              end;
            end
            else
              for i := 0 to scG.m_list.Count-1 do
              begin
                scP := TSCProdSched(scG.m_list[i]);
