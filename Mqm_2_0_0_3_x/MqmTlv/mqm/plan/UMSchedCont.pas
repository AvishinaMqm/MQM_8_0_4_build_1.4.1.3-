function TMSchedCont.GetMcmLinkInfo(id: TSchedID; var linkInfo: TSQMCMlinkInfo; Check_From_Mqm_environment : boolean): boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  linkInfo.isOnPlan := Assigned(sc.m_srvPtr);
  linkInfo.From_Mqm_Env := sc.m_Mqm_environment;
  if Check_From_Mqm_environment then exit;

  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    job := grp.m_list[0];
  end else
  begin
    job := TSCProdSched(sc);
  end;

  linkInfo.id       := sc.m_Id;
  linkInfo.ProgType := job.m_ProgType;
  if assigned(TMqmWrkCtr(TMqmActArea(sc.m_srvPtr).p_WrkCtr)) then
  begin
    linkInfo.WorkCenter := TMqmWrkCtr(TMqmActArea(sc.m_srvPtr).p_WrkCtr).p_WrkCtrCode;
    linkInfo.Resource    := TMqmRes(TMqmActArea(sc.m_srvPtr).p_Res).p_ResCode;
    linkInfo.ActArea     := sc.m_srvPtr;
  end;
  linkInfo.SchedStart  := sc.p_schedStart;
  linkInfo.schedEnd    := sc.p_schedEnd;
  linkInfo.NumRscComponent := GetJobComponents(Id, true);

  Result := true
end;

