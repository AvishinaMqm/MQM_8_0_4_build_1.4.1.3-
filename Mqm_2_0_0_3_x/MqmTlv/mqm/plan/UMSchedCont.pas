function TMSchedCont.GetWorkCentersList(qry: TMqmQuery; HandleType : String; Status: TStaticText) : String;
var
  tbiWW, tbiALT : ^TTblInfo;
  Comma : string;
  step, I    : integer;
  PRecTiming : PTRecTiming;
  List : TList;
begin

  Result := '';

  // HandleType = '1' - Handle, HandleType = '2' - View
  if (HandleType <> '1') and (HandleType <> '2') then exit;

  if Assigned(Status) then
    Status.Caption := _('Read work centers list from database...');

  Application.ProcessMessages;

  tbiWW := @tblInfo[tbl_wkst_wkc];
  tbiALT := @tblInfo[tbl_wkc_alt];

  Comma := '';
  with qry.SQL do
  begin
    Clear;
    Add('select ');
    Add('WW_WKCNTER WORKCENTERCODE ');
    Add('from ');
    Add(tbiWW.GetTableName + ' ');
    Add(WHERE_IDF_Condition(CreateFld(tbiWW.pfx, fli_Identifier)));
    Add(' AND ');
    Add('WW_WKST_CODE = ' + QuotedStr(IniAppGlobals.WkstCode) + ' and WW_TYPEUSED = ' + QuotedStr(HandleType) + ' ');
    Add('union ');
    Add('select distinct ');
    Add('ALT.AW_WKCNTER WORKCENTERCODE ');
    Add('from ');
    Add(tbiALT.GetTableName + ' ALT ');
    Add(WHERE_IDF_Condition(CreateFld(tbiALT.pfx, fli_Identifier)));
    Add(' AND exists ');
    Add('(select 1 from ' + tbiWW.GetTableName + ' WKS ');
    Add('where WKS.WW_WKST_CODE = ' + QuotedStr(IniAppGlobals.WkstCode) + ' ');
    Add(AND_IDF_Condition('WKS.WW_IDENTIFIER'));
    Add('and WKS.WW_WKCNTER = ALT.AW_ALTERN_WC AND WKS.WW_IDENTIFIER = ALT.AW_IDENTIFIER and WW_TYPEUSED = ' + QuotedStr(HandleType) + ')');
    qry.open;

    while not Qry.Eof do
    begin
      Application.ProcessMessages;
      Result := Result + comma + QuotedStr(qry.FieldByName('WORKCENTERCODE').AsString);
      Comma := ',';
      Qry.Next;
    end;

    qry.close;

  end;
end;

