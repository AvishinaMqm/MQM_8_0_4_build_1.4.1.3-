Procedure TMSchedCont.UpdateBalancedQtyOnPlan(UpdateBalanceList : TMSchedList);
var
  ActList : TList;
  Id : TSchedId;
  I, D : Integer;
  sc  : TSCSchedOnPlan;
  job : TSCProdSched;
  tDet : TSCProdReqDet;
  ActArea : TMqmActArea;
  Listds : TMSchedList;
  grp : TSCProdGroup;
  function CheckInList(Ptr : Pointer) : boolean;
  var
    J : Integer;
  begin
    Result := false;
    for J := 0 to ActList.Count - 1 do
    begin
      if Ptr = Pointer(ActList[J]) then
      begin
        Result := true;
        Exit
      end;
    end;
  end;

begin

  ActList := nil;
  for D := 0 to UpdateBalanceList.GetLinkCount - 1 do
  begin
    id := UpdateBalanceList.GetLink(D);
    sc := TSCSchedOnPlan(m_codeList[id]);
    if sc is TSCProdGroup then
    begin
      grp := TSCProdGroup(sc);
      job := TSCProdSched(grp.m_list[0]);
    end
    else
      job := TSCProdSched(sc);

    tDet := TSCProdReqDet(job.m_reqDet);
    ActList := TList.Create;
    for I := tDet.m_list.count -1 downto 0 do
    begin
      Job := tDet.m_list[i];
      ActArea := GetExtLinkPtr(Job.m_Id);
      if (ActArea <> nil) and not CheckInList(ActArea) then
          ActList.Add(Pointer(ActArea));
    end;
  end;

  if Assigned(ActList) then
  begin
    for I := 0 to ActList.Count - 1 do
    begin
      ActArea := TMqmActArea(Pointer(ActList[I]));
      ActArea.ReorganizeAllOcc(true);
    end;
    ActList.Free;
  end;
end;

