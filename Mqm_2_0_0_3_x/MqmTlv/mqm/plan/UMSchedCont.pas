///   old function
{
procedure TMSchedCont.BalanceQuantity(id: TSchedID);
var
  I, NumOfJobs : Integer;
  SumFinalGenQty, AddEachQty, SumAddEachQty : currency;
  sc:  TSCSchedOnPlan;
  tDet : TSCProdReqDet;
  job, tjob : TSCProdSched;
  grp : TSCProdGroup;
  TmpList : TList;
  NoProgress : boolean;
  TmpQty : double;
  RequestVal, StepVal : variant;
  dataType: CBinColValType;
  AtLeastOneJob : boolean;
begin
  TmpList := nil;
  tJob := nil;
  NoProgress := true;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    for I := 0 to grp.m_list.Count - 1 do
      BalanceQuantity(TSCProdSched(grp.m_list[I]).m_Id);
  end
  else
  begin
    job := TSCProdSched(sc);
    tDet := TSCProdReqDet(job.m_reqDet);
    AtLeastOneJob := false;
    for I := tDet.m_list.count -1 downto 0 do
    begin
      tJob := tDet.m_list[i];
      if (tJob.m_isDeleted) or (tJob.m_reprocNo > 0) then
        Continue;

      AtLeastOneJob := true;
      if (IsProgressed(tJob.m_Id) = prg_Final) or (IsProgressed(tJob.m_Id) = prg_FinalSplit) then
      begin
        if (tJob.m_PrgQty = 0) then
        begin
          if tJob.p_quantSched <> tJob.CalcQtyFinnalProg then
            tJob.m_status := CSS_modi;
          tJob.p_quantSched := trunc(tJob.CalcQtyFinnalProg);
        end
        else
        begin
          if tJob.p_quantSched <> tJob.m_PrgQty then
            tJob.m_status := CSS_modi;
          tJob.p_quantSched := tJob.m_PrgQty;
        end;
      end;

      if (IsProgressed(tJob.m_Id) = prg_General)
      and (tJob.m_PrgQty > tJob.p_quantSched)
      and ( not tJob.m_fromPD) then
      begin
        if tJob.p_quantSched <> tJob.m_PrgQty then
          tJob.m_status := CSS_modi;
        tJob.p_quantSched := tJob.m_PrgQty;
      end
    end;

    if not AtLeastOneJob then exit;

    SumFinalGenQty := 0;
    NumOfJobs      := 0;

    while true and NoProgress do
    begin

      NoProgress := true;

      for I := tDet.m_list.count -1 downto 0 do
      begin
        tJob := tDet.m_list[i];
        if (tJob.m_isDeleted) or (tJob.m_reprocNo > 0) then
           continue;

        if (IsProgressed(tJob.m_Id) = prg_Final)  or (IsProgressed(tJob.m_Id) = prg_FinalSplit)
        or ((IsProgressed(tJob.m_Id) = prg_General) and (tJob.m_PrgQty = tJob.p_quantSched) and not tJob.m_fromPD) then
        begin
          SumFinalGenQty := SumFinalGenQty + tJob.p_quantSched;
          Inc(NumOfJobs);
        end;

      end;

      if ((tDet.p_Count - NumOfJobs) = 0) or (tDet.m_quantInit < SumFinalGenQty) then
         break;

      AddEachQty := (tDet.m_quantInit - SumFinalGenQty)/(tDet.p_Count - NumOfJobs);

      AddEachQty := trunc(AddEachQty*100)/100;

      if not assigned(TmpList) then
        TmpList := TList.create;
      TmpList.Clear;

      for I := tDet.m_list.count -1 downto 0 do
      begin
        tJob := tDet.m_list[i];
        if (tJob.m_isDeleted) or (tJob.m_reprocNo > 0) then
           continue;

        if not ((IsProgressed(tJob.m_Id) = prg_Final) or (IsProgressed(tJob.m_Id) = prg_FinalSplit)
        or ((IsProgressed(tJob.m_Id) = prg_General) and (tJob.m_PrgQty = tJob.p_quantSched) and not tJob.m_fromPD)) then
          TmpList.Add(tJob);
      end;

      SumAddEachQty := 0;
      if TmpList.Count = 1 then
      begin
        job := TSCProdSched(TmpList[0]);
        if job.p_quantSched <> AddEachQty then
          tJob.m_status := CSS_modi;
        job.p_quantSched := AddEachQty;

        if not ((IsProgressed(tJob.m_Id) = prg_General) and (tJob.m_PrgQty = tJob.p_quantSched) and not tJob.m_fromPD) then
           NoProgress := false;
      end
      else
      begin
        for I := 1 to TmpList.Count - 1 do
        begin
          job := TSCProdSched(TmpList[I]);
          tmpqty := Job.p_quantSched;
          if (job.p_quantSched <> AddEachQty) then
            tJob.m_status := CSS_modi;
          job.p_quantSched := AddEachQty;

          if (tDet.m_stepType = CST_continuous)
          and (Job.p_quantSched <> tmpqty) and (tmpqty > 0) then
          begin
            if ((Job.p_ExeMinIgnoreProgress * Job.p_quantSched / tmpqty) < 0) or
               ((Job.p_ExeMinIgnoreProgress * Job.p_quantSched / tmpqty) > 999999) then
            begin
              GetFldValue(Id, CSC_ProdReq, RequestVal, dataType);
              GetFldValue(Id, CSC_ProdStep, StepVal, dataType);
              if not IsAutoRunMode then
              begin
                showmessage(' A problem occured while Balance Imbalanced Request : ' + RequestVal + ' Step : ' + IntToStr(StepVal) +  #13#10 +
                         'Please print this message ,save a backup for the current DB and inform datatex.');
                exit;
              end
              else
                continue
            end;
            Job.p_exeMin := Job.p_ExeMinIgnoreProgress * Job.p_quantSched / tmpqty;
          end;

          SumAddEachQty := SumAddEachQty + AddEachQty;
          if not ((IsProgressed(tJob.m_Id) = prg_General) and (tJob.m_PrgQty = tJob.p_quantSched) and not tJob.m_fromPD) then
            NoProgress := false;
        end;
      end;

      // for the last Job

      if TmpList.Count > 1 then
      begin
        job := TSCProdSched(TmpList[0]);
        tmpqty := Job.p_quantSched;

        if job.p_quantSched <> (tDet.m_quantInit - SumAddEachQty) then
           tJob.m_status := CSS_modi;

        job.p_quantSched := tDet.m_quantInit - SumFinalGenQty - SumAddEachQty;

        if (tDet.m_stepType = CST_continuous)
        and (Job.p_quantSched <> tmpqty) and (tmpqty > 0) then
        begin
          if ((Job.p_ExeMinIgnoreProgress * Job.p_quantSched / tmpqty) < 0) or
             ((Job.p_ExeMinIgnoreProgress * Job.p_quantSched / tmpqty) > 999999) then
          begin
            if not IsAutoRunMode then
            begin
              GetFldValue(Id, CSC_ProdReq, RequestVal, dataType);
              GetFldValue(Id, CSC_ProdStep, StepVal, dataType);
              showmessage(' A problem occured while Balance Imbalanced Request : ' + RequestVal + ' Step : ' + IntToStr(StepVal) +  #13#10 +
                       'Please print this message ,save a backup for the current DB and inform datatex.');
              exit;
            end
            else
              continue
          end;
          Job.p_exeMin := Job.p_ExeMinIgnoreProgress * Job.p_quantSched / tmpqty;
        end;

        if not ((IsProgressed(tJob.m_Id) = prg_General) and (tJob.m_PrgQty = tJob.p_quantSched) and not tJob.m_fromPD) then
           NoProgress := false;
      end;

    end;

    if assigned(TmpList) then
    begin
      TmpList.Clear;
      TmpList.Free;
    end;

  end;
end;

}

