      CSC_PrvHighestDate:
        begin
          dataType := CBT_date;
          ProdReqDet := TSCProdReqDet(scP.GetPrevStepToSched(scP.m_reqDet.m_code));
          value := 0;
          HighestEnd := 0;
          HighestEnd_WithoutLeadTime := 0;
          if not Assigned(ProdReqDet) then
          begin
            scP.CheckPrevConnReqLastStepJobs(HighestEnd, HighestEnd_WithoutLeadTime, false, nil, false);
            value := HighestEnd;
          end
          else
          begin
            bckConnSubStp := scP.m_bkwConnSubStp;
            for i := 0 to ProdReqDet.m_list.Count - 1 do
            begin
              scP := TSCProdSched(ProdReqDet.m_list[i]);
              if scP.m_isDeleted then continue;
              if (bckConnSubStp > -2) and (scP.m_code <> bckConnSubStp) then continue;
              if (scP.p_rscCode = '') then continue;
              HighestEnd := scP.p_schedEnd;
              if (scP.m_reqDet.p_LeadTimeNext + scP.m_reqDet.p_LeadTimeNextBatch) > 0 then
              begin
                TempLeadTime := scP.m_reqDet.p_LeadTimeNext * scP.p_quantSched + scP.m_reqDet.p_LeadTimeNextBatch;
                HighestEnd := HighestEnd + TempLeadTime/60/24;
              end;
              if value < HighestEnd then value := HighestEnd;
            end;
          end;
          if value = 0 then Result := false;
        end;

