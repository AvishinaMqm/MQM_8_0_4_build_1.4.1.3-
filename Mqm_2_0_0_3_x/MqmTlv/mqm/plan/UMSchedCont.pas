procedure TMSchedCont.AddJobToGroup(job, grp: TSchedID);
var
  jobSc: TSCProdSched;
  grpSc: TSCProdGroup;
begin
  jobSc := TSCProdSched(m_codeList[job]);
  grpSc := TSCProdGroup(m_codeList[grp]);

  if Assigned(jobSc.m_grp) then Exit;

  grpSc.m_isDeleted := false;

//  Assert(not Assigned(jobSc.m_grp));
  grpSc.m_list.Add(jobSc);
  jobSc.m_grp := grpSc;
  jobSc.m_grpRemovedReason := '';
  jobSc.m_srvPtr := grpSc.m_srvPtr;
  grpSc.SortGroup;

  if (GetJobType(jobSc.m_id) = CST_Continuous) and (jobSc.p_Grp_Sequence <> '') then
  begin
    if not Assigned(grpSc.m_ListOfSequence) then
       grpSc.m_ListOfSequence := TStringlist.Create;
  end;

end;

