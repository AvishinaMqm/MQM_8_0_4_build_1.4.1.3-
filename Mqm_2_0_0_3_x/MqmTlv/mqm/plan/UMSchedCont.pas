      SqlUpdate :=  SqlUpdate + 'MS_ACTUAL_END = :MS_ACTUAL_END,';
      SqlUpdate :=  SqlUpdate + 'MS_COMMENT = :MS_COMMENT,';
      SqlUpdate :=  SqlUpdate + 'MS_CHANGED_QUANTITY = :MS_CHANGED_QUANTITY,';
      SqlUpdate :=  SqlUpdate + 'MS_USR_NAMECG = :MS_USR_NAMECG,';
      SqlUpdate :=  SqlUpdate + 'MS_USR_TIMECG = :MS_USR_TIMECG,';
      SqlUpdate :=  SqlUpdate + 'MS_WKCNTER_KEY_ST = :MS_WKCNTER_KEY_ST,';
      SqlUpdate :=  SqlUpdate + 'MS_WC_PROCESS_KEY_ST = :MS_WC_PROCESS_KEY_ST,';
