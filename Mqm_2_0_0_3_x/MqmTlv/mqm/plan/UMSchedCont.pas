procedure TMSchedCont.UpdateFromDB(qry: TMqmQuery; updNum: integer;
                                   fUpdate: TUpdLinkJobFunc; ptr: pointer; ProgBar: TMqmProgBar; EventFromHost : TGetEventType);
var
  tbiPS:   ^TTblInfo;
  tbiPD:   ^TTblInfo;
  tbiPH:   ^TTblInfo;
  tbiWW:   ^TTblInfo;
  SqlStr: string;
begin
  tbiPH := @tblInfo[tbl_prod_reqHdr];
  tbiPD := @tblInfo[tbl_prod_step];
  tbiPS := @tblInfo[tbl_prod_sched];
  tbiWW := @tblInfo[tbl_wkst_wkc];
  SqlStr := '';

  with qry do
  begin
    Application.ProcessMessages;
 //   Transaction.Active := true;
    SQL.Clear;
    SqlStr := SqlStr + 'select ';

    // production request header data (PH)
    SqlStr := SqlStr + CreateFld(tbiPH.pfx,fli_ProdLine)            + ','; // Prod Line
    SqlStr := SqlStr + CreateFld(tbiPH.pfx,fli_ProdType)            + ','; // Prod Type
    SqlStr := SqlStr + CreateFld(tbiPH.pfx,fli_ProdFamily)          + ','; // ProdFamily
    SqlStr := SqlStr + CreateFld(tbiPH.pfx,fli_MaterialFamily)      + ','; // MaterialFamily
    SqlStr := SqlStr + CreateFld(tbiPH.pfx,fli_ProdUMCode)          + ','; // Um Code
    SqlStr := SqlStr + CreateFld(tbiPH.pfx,fli_ProdLowDataTime)     + ','; // Low Start Day Limit
    SqlStr := SqlStr + CreateFld(tbiPH.pfx,fli_ProdDelivDate)       + ','; // Delivery Line
    SqlStr := SqlStr + CreateFld(tbiPH.pfx, fli_HistoriclReq)       + ','; // Historical request
    SqlStr := SqlStr + CreateFld(tbiPH.pfx, fli_FrcDelDate)         + ','; // Force delivery date

    // production request detail data (PD)
    SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_preqNo)            + ','; // prod Req number
    SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_pstepId)           + ','; // prod Step
//    SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_ToBeSched)         + ','; // To Be Sched
    if DBAppGlobals.MCM_App then
    begin
      SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_SchedulByMcm)      + ',';
      SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_prevStepSched_Mcm)     + ','; // previous Step
      SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_NextStepSched_Mcm)     + ','; // next Step
    end
    else
    begin
      SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_SchedulByMqm)      + ',';
      SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_prevStepSched_Mqm)     + ','; // previous Step
