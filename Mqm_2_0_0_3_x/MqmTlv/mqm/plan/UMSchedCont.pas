function TMSchedCont.GetNewTimeIfSpeedChanged(id: TSchedId; var NewTime : double; var NewSetup : double; var NewJobSetup : double; var IsSpeedChanged : boolean; var IsSetUpChanged : boolean;var IsJobSetUpChanged : boolean) : boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  value: variant;
  dataType: CBinColValType;
  Qty : double;
begin
  NewTime := 0;
  NewSetup := 0;
  NewJobSetup := 0;
  IsSpeedChanged := false;
  IsSetUpChanged := false;
  IsJobSetUpChanged := false;
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  Result := false;

  if sc is TSCProdGroup then
  begin
    if TSCProdGroup(sc).p_IsSpeedChanged then
    begin
      Result := true;
      p_sc.GetFldValue(Id, CSC_IniQty, value, dataType);
      Qty := value;
      NewTime := Qty*(TSCProdGroup(sc).p_NewSpeed);
      IsSpeedChanged := true
    end;
    if TSCProdGroup(sc).p_IsSetupChanged then
    begin
      Result := true;
      NewSetup := TSCProdGroup(sc).p_NewSetup;
      IsSetUpChanged := true
    end;
    if TSCProdGroup(sc).p_IsJobSetupChanged then
    begin
      Result := true;
      NewJobSetup := TSCProdGroup(sc).p_NewJobSetup;
      IsJobSetUpChanged := true
    end;

  end
  else
  begin
    job := TSCProdSched(sc);
    if job.m_reqDet.p_IsSpeedChanged then
    begin
      Result := true;
      p_sc.GetFldValue(Id, CSC_IniQty, value, dataType);
      Qty := value;
      NewTime := Qty*(job.m_reqDet.p_NewSpeed);
      IsSpeedChanged := true
    end;
    if job.m_reqDet.p_IsSetupChanged then
    begin
      Result := true;
      NewSetup := job.m_reqDet.p_NewSetup;
      IsSetUpChanged := true
    end;
    if job.p_NewSetupChanged then
    begin
      Result := true;
      NewJobSetup := Job.p_NewSetup;
      IsJobSetUpChanged := true
    end;
  end;
end;

