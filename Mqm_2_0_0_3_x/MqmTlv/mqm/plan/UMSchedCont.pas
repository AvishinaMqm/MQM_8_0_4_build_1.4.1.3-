procedure TMSchedCont.GetCompatWithOccTwoIds(FromRank : boolean; ResPtr : Pointer; id_Prev : TSchedId; id_Next : TSchedId; var compFore, compBack: TCompatVal);
var
  sc: TSCSchedOnPlan;
  res_Prev, res_Next : TMqmRes;
  supRec: TSetupRec;
  IsSameGroup : boolean;
  LearningCurveCode : string;
begin
  sc := TSCSchedOnPlan(m_codeList[id_Prev]);
  //Assert(Assigned(sc));
  if not assigned(sc) then Exit;

  if (sc.m_compFore = CompValNotCached)
  or (sc.m_compBack = CompValNotCached) then
  begin
    //Calculate compatibility values
    if not assigned(GetExtLinkPtr(id_Prev)) then
    begin
      compFore := CompValNotValid;
      compBack := CompValNotValid;
      exit
    end;
  end;

  sc := TSCSchedOnPlan(m_codeList[id_Next]);
  //Assert(Assigned(sc));
  if not Assigned(sc) then Exit;

  if (sc.m_compFore = CompValNotCached)
  or (sc.m_compBack = CompValNotCached) then
  begin
    //Calculate compatibility values
    if not assigned(GetExtLinkPtr(id_Prev)) then
    begin
      compFore := CompValNotValid;
      compBack := CompValNotValid;
      exit
    end;
  end;

  if not FromRank then
  begin
    res_Prev := TMqmRes(ResPtr);
    res_Next := TMqmRes(ResPtr);
  end
  else
  begin
    res_Prev := TMqmRes(TMqmActArea(GetExtLinkPtr(id_Prev)).p_res);
    res_Next := TMqmRes(TMqmActArea(GetExtLinkPtr(id_Next)).p_res);
  end;
  if not (assigned(res_Prev) or assigned(res_Next)) then exit;

  if (id_Prev = id_Next) or (not res_Prev.p_occCanAttach) or (not res_Next.p_occCanAttach) then
  begin
    compFore := CompValNotValid;
    compBack := CompValNotValid
  end
  else
  begin
    if not res_Prev.GetSetupParms(id_Prev, id_Next, supRec, compFore, IsSameGroup, LearningCurveCode) then
      compFore := CompValNotDef;
    if not res_Next.GetSetupParms(id_Next, id_Prev, supRec, compBack, IsSameGroup, LearningCurveCode) then
      compBack := CompValNotDef
  end;

end;

//----------------------------------------------------------------------------//

procedure TMSchedCont.GetCompatWithOcc(id: TSchedId; var compFore, compBack: TCompatVal);
var
  sc: TSCSchedOnPlan;
  res: TMqmRes;
  compId, PrevId, CurrentId, NextCurrentId, NextId : TSchedID;
  supRec: TSetupRec;
  IsSameGroup : boolean;
  IndexCompId, IndexId : integer;
  ListPropertyInstanceValMain, ListPropertyInstanceValPrev : TStringList;
  LearningCurveCode : string;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
 // Assert(Assigned(sc));
  if not Assigned(sc) then exit;
  NextId := CSchedIDnull;
  IndexCompId := CSchedIDnull;
  IndexId     := CSchedIDnull;

  if (sc.m_compFore = CompValNotCached)
  or (sc.m_compBack = CompValNotCached) then
  begin
    //Calculate compatibility values
    compId := p_pl.GetCompatModeInPlanId;
    if not assigned(GetExtLinkPtr(id)) then
    begin
      compFore := CompValNotValid;
      compBack := CompValNotValid;
      SetCompatWithOcc(id, compFore, compBack);
      exit
    end;
    res := TMqmRes(TMqmActArea(GetExtLinkPtr(id)).p_res);
    if (compId = id) or (not res.p_occCanAttach) then
    begin
      compFore := CompValNotValid;
      compBack := CompValNotValid
    end else
    begin

      ListPropertyInstanceValMain := res.GetPropertyInstanceCounterValList(compId);
      ListPropertyInstanceValPrev := res.GetPropertyInstanceCounterValList(Id);

      if assigned(GetExtLinkPtr(compId)) and Assigned(ListPropertyInstanceValMain) then
      begin
        IndexCompId := TMqmActArea(GetExtLinkPtr(id)).GetObjIndex(CompId);
        if IndexCompId > -1 then  // CompId is on the same active area as Id
        begin
          IndexId := TMqmActArea(GetExtLinkPtr(id)).GetObjIndex(Id);
          if IndexId > IndexCompId then
          begin
            NextId := TMqmActArea(GetExtLinkPtr(id)).GetSchedObj(IndexId + 1);
            CurrentId := TMqmActArea(GetExtLinkPtr(id)).GetPrecObjByIndex(compId);
            while True do
            begin
              if CurrentId = CSchedIDnull then
                NextCurrentId := TMqmActArea(GetExtLinkPtr(id)).GetNextObjByIndex(compId)
              else
                NextCurrentId := TMqmActArea(GetExtLinkPtr(id)).GetNextObjByIndex(CurrentId);
              if (NextCurrentId = compId) then
                NextCurrentId := TMqmActArea(GetExtLinkPtr(id)).GetNextObjByIndex(NextCurrentId);
              if (NextCurrentId = CSchedIDnull) or (NextCurrentId = NextId) then break;
              res.UpdateInstanceCounterProperty(NextCurrentId, CurrentId);
              CurrentId := NextCurrentId;
            end;
          end;
        end;
      end;

      res.UpdateInstanceCounterProperty(compId, Id);
      if not res.GetSetupParms(compId, id, supRec, compFore, IsSameGroup, LearningCurveCode) then
        compFore := CompValNotDef;

      PrevId := TMqmActArea(GetExtLinkPtr(id)).GetPrecObjByIndex(id);
      if PrevId = compId then
        PrevId := TMqmActArea(GetExtLinkPtr(id)).GetPrecObjByIndex(PrevId);
      res.UpdateInstanceCounterProperty(compId, PrevId);
      res.UpdateInstanceCounterProperty(Id, compId);
      if not res.GetSetupParms(id, compId, supRec, compBack, IsSameGroup, LearningCurveCode) then
        compBack := CompValNotDef;

      if Assigned(ListPropertyInstanceValMain) then
      begin
        res.SetPropertyInstanceCounterValList(compId, ListPropertyInstanceValMain);
        ListPropertyInstanceValMain.Free;
      end;
      if Assigned(ListPropertyInstanceValPrev) then
      begin
        res.SetPropertyInstanceCounterValList(Id, ListPropertyInstanceValPrev);
        ListPropertyInstanceValPrev.Free;
      end;

      if assigned(GetExtLinkPtr(compId)) and Assigned(ListPropertyInstanceValMain)
      and (IndexId > IndexCompId) and (IndexCompId > -1) then
      begin
        res.UpdateInstanceCounterProperty(CompId, PrevId);
        res.UpdateInstanceCounterProperty(Id, CompId);
        CurrentId := Id;
        while True do
        begin
          NextCurrentId := TMqmActArea(GetExtLinkPtr(id)).GetNextObjByIndex(CurrentId);
          if (NextCurrentId = CSchedIDnull) or (NextCurrentId = NextId) then break;
          res.UpdateInstanceCounterProperty(NextCurrentId, CurrentId);
          CurrentId := NextCurrentId;
        end;
      end;

    end;
    SetCompatWithOcc(id, compFore, compBack)
  end;

  compFore := sc.m_compFore;
  compBack := sc.m_compBack
end;

