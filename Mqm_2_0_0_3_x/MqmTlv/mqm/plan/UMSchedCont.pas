function TMSchedCont.CheckWarningStatistic(id: TSchedID; var errSet: SetOfErrors): boolean;
var
  DatesInfo: TSQDatesInfo;
  sc:  TSCSchedOnPlan;
  i:   integer;
  MinOvlpLimit, MaxOvlpLimit : TDateTime;
  Lst, DummyList: TList;
begin
  Result := false;
  MinOvlpLimit := 0;
  MaxOvlpLimit := 0;
  DummyList := nil;
  if not GetDatesInfo(id, DatesInfo) then exit;
  if not Assigned(GetExtLinkPtr(id)) then exit;

  Result := true;

  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  Lst := TList.Create;
  if Assigned(sc.m_srvPtr) then
  begin
    if not sc.CheckEnoughMatAtDateMain(sc.m_srvPtr, [Ar_MatWithDet, Ar_Material],
                                        DatesInfo.startDate, Lst, DummyList) then
      include(errSet, CSE_Materials);

    if not sc.CheckEnoughMatAtDateMain(sc.m_srvPtr, [Ar_AddRes], DatesInfo.startDate, Lst, DummyList) then
      include(errSet, CSE_AddRes);

    if not sc.CheckEnoughMatAtDateMain(sc.m_srvPtr, [Ar_AddRes_ManPower], DatesInfo.startDate, Lst, DummyList) then
      include(errSet, CSE_AddRes_ManPower);
  end;

  if Assigned(Lst) then
    Lst.Free;

end;

