procedure TMSchedCont.LoadBchUm(OnStart : boolean; qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText; UpdateNr : integer;
                                WorkCentersHandledList, WorkCentersViewedList : String; ChangedReqInClause: string = '');
var
  tbInfoBchUM, tbInfoProdStep : ^TTblInfo;
  tbiCR: ^TTblInfo;
  Hdr, OldHdr:  TSCProdReqHdr;
  Det, OldDet:  TSCProdReqDet;
  OldHdrCode : String;
  PrgHour, PrgMinute, PrgSecond, PrgMilliSecond, PrgPrevSecond : Word;
  PrgIndex, PrgBlock, BchUMRowCount : integer;
  fBchUM_preqNo, fBchUM_pstepId, fBchUM_BchUM, fBchUM_multipToBatchUm : TField;
begin
  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(2000);
    PrgBlock := trunc(2000/100) + 1;
    PrgIndex := 0;
    PrgPrevSecond := 0;
  end;

  if WorkCentersHandledList = '' then exit;

  if Assigned(Status) then
    Status.Caption := _('Reading products conversion to resources batch um...');
  Application.ProcessMessages;

  tbInfoBchUM := @tblInfo[tbl_step_batchSize];
  tbInfoProdStep := @tblInfo[tbl_prod_step];
  tbiCR := @tblInfo[tbl_Req_Change];

  with qry do
  begin
    SQL.Clear;
    SQL.Add('select ');
    SQL.Add('SB.' + CreateFld(tbInfoBchUM.pfx, fli_preqNo) + ',');
    SQL.Add('SB.' + CreateFld(tbInfoBchUM.pfx, fli_pstepId) + ',');
    SQL.Add('SB.' + CreateFld(tbInfoBchUM.pfx, fli_BchUM) + ',');
    SQL.Add('SB.' + CreateFld(tbInfoBchUM.pfx, fli_multipToBatchUm) + ' ');
    SQL.Add('from ' + tbInfoBchUM.GetTableName + ' SB ');
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbInfoBchUM.pfx, fli_Identifier)));
    if not OnStart then
    begin
      if ChangedReqInClause <> '' then
        SQL.Add('AND SB.' + CreateFld(tbInfoBchUM.pfx, fli_preqNo) + ' IN (' + ChangedReqInClause + ') ')
      else
      begin
        SQL.Add('AND exists (');
        SQL.Add('Select 1 from ' + tbiCR.GetTableName + ' CR ');
        SQL.Add('where CR.' + CreateFld(tbiCR.pfx, fli_updCode) + ' = ' + IntToStr(UpdateNr) + ' ');
        SQL.Add('and CR.' + CreateFld(tbiCR.pfx, fli_Identifier) + ' = SB.'  + CreateFld(tbInfoBchUM.pfx, fli_Identifier));
        SQL.Add('and CR.' + CreateFld(tbiCR.pfx, fli_preqNo) + ' = SB.'  + CreateFld(tbInfoBchUM.pfx, fli_preqNo));
        if (IniAppGlobals.External_Database_Update = '1') then
          SQL.Add(' and CR.' + CreateFld(tbiCR.pfx, fli_wkstCode) + '=''' + IniAppGlobals.WkstCode + '''');
        SQL.Add(') ');
      end;
    end;
    SQL.Add('AND exists (');
    SQL.Add('select 1 from ' + tbInfoProdStep.GetTableName + ' PD ');
    SQL.Add('where PD.' + CreateFld(tbInfoProdStep.pfx, fli_Identifier) + '=SB.' + CreateFld(tbInfoBchUM.pfx, fli_Identifier) + ' ');
    SQL.Add('and PD.' + CreateFld(tbInfoProdStep.pfx, fli_preqNo)   + '=SB.' + CreateFld(tbInfoBchUM.pfx, fli_preqNo) + ' ');
    SQL.Add('and PD.' + CreateFld(tbInfoProdStep.pfx, fli_pstepId)  + '=SB.' + CreateFld(tbInfoBchUM.pfx, fli_pstepId) + ' ');
    SQL.Add('and PD.' + CreateFld(tbInfoProdStep.pfx,fli_wkCtrCode) + ' IN ' + '(' + WorkCentersHandledList + ') ');
    SQL.Add(') ');
    SQL.Add('order by ');
    SQL.Add(CreateFld(tbInfoBchUM.pfx, fli_preqNo) + ',');
    SQL.Add(CreateFld(tbInfoBchUM.pfx, fli_pstepId));

    FetchOptions.RowsetSize := 5000;
    Open;
    if Assigned(ProgBar) then
      ProgBar.SetMax(2000);
    OldHdr := nil;
    OldHdrCode := '';
    OldDet := nil;
    fBchUM_preqNo          := FieldByName(CreateFld(tbInfoBchUM.pfx, fli_preqNo));
    fBchUM_pstepId         := FieldByName(CreateFld(tbInfoBchUM.pfx, fli_pstepId));
    fBchUM_BchUM           := FieldByName(CreateFld(tbInfoBchUM.pfx, fli_BchUM));
    fBchUM_multipToBatchUm := FieldByName(CreateFld(tbInfoBchUM.pfx, fli_multipToBatchUm));
    BchUMRowCount := 0;
    while not EOF do
    begin
      Inc(BchUMRowCount);
      if BchUMRowCount mod 200 = 0 then Application.ProcessMessages;
      if (OldHdrCode <> fBchUM_preqNo.AsString) then
      begin
        OldHdrCode := fBchUM_preqNo.AsString;
        hdr := FindHdrFromCode(self, fBchUM_preqNo.AsString);
        OldHdr := hdr;
        OldDet := nil
      end
      else
        Hdr := OldHdr;
      if Assigned(hdr) then
      begin
        if not Assigned(OldDet)
        or (OldDet.m_code <> fBchUM_pstepId.AsInteger) then
        begin
          Det := hdr.FindDetFromCode(fBchUM_pstepId.AsInteger);
          OldDet := Det
        end
        else
          Det := OldDet;
        if Assigned(det) then
        begin
          Det.m_BchUMList.AddItem(Trim(fBchUM_BchUM.AsString),
                                  fBchUM_multipToBatchUm.AsFloat);
        end;

        if Assigned(ProgBar) then
        begin
          DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
          if PrgPrevSecond <> PrgSecond then
          begin
            PrgPrevSecond := PrgSecond;
            PrgIndex := PrgIndex + PrgBlock;
            ProgBar.SetPosition(PrgIndex);
          end;
        end;

      end;

      Next;

    end;
    Close;
//    if OnStart then
//      Transaction.Commit;
  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';
  Application.ProcessMessages;
end;

