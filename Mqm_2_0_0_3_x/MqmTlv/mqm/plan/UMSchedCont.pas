function TMSchedCont.CheckErrors(id: TSchedID; ErrToCheck: CScErrGroups; var errSet: SetOfErrors; var PurchaseOrderLeadTimeList : TList): boolean;
var
  DatesInfo: TSQDatesInfo;
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
  MinOvlpLimit, MaxOvlpLimit : TDateTime;
  Lst, DummyList : TList;
  ChkMaterials, ChkAddRes : boolean;
begin
  Result := false;
  MinOvlpLimit := 0;
  MaxOvlpLimit := 0;
  DummyList := nil;
  if not GetDatesInfo(id, DatesInfo) then exit;
  if Assigned(GetExtLinkPtr(id)) then
  // ERAN19101963 start
  // if not GetOvlpLimits(id, MinOvlpLimit, MaxOvlpLimit) then exit; ERAN19101963
  begin
    if not DatesInfo.ResultOvrlp then exit;
    MinOvlpLimit := DatesInfo.MinOvlpDate;
    MaxOvlpLimit := DatesInfo.MaxOvlpDate;
  end;
  // ERAN19101963 end

  Result := true;

  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  Lst := TList.Create;
  if Assigned(sc.m_srvPtr) then
  begin
    if (ErrToCheck = CSEG_Materials) or (ErrToCheck = CSEG_All) then
    begin
      if DBAppSettings.ChkMaterials
      and not sc.CheckEnoughMatAtDateMain(sc.m_srvPtr, [Ar_MatWithDet, Ar_Material],
                                       DatesInfo.startDate, Lst, PurchaseOrderLeadTimeList) then
         include(errSet, CSE_Materials);
      if DBAppSettings.ChkAddRes
      and not sc.CheckEnoughMatAtDateMain(sc.m_srvPtr, [Ar_AddRes, Ar_AddRes_ManPower,Ar_AddRes_Capacity], DatesInfo.startDate, Lst, DummyList) then
         include(errSet, CSE_AddRes);
    end;
  end;
  if Assigned(Lst) then
    Lst.Free;


  if not DatesInfo.isGroup then
  begin
//    sc := TSCSchedOnPlan(m_codeList[id]);
    job := TSCProdSched(m_codeList[id]);

    if Assigned(job.m_srvPtr) then
    begin
      {if Trim(job.m_ProgType) <> '' then
      begin
        Lst.Free;
        include(errSet, CSE_NoError);
        exit
      end else
      begin    }
        if (ErrToCheck = CSEG_Materials) or (ErrToCheck = CSEG_All) then
        begin

          if  DBAppSettings.ChkPrevStpQty then
          begin
            if (MinOvlpLimit > 0)
      //      and (MinOvlpLimit > DatesInfo.StartWithMat + CSGupTimeDef) then  // ERAN19101963
            and (MinOvlpLimit > job.p_StartWithMat + CSGupTimeDef) then  // ERAN19101963
            begin
              if  (MaxOvlpLimit > 0)
              and (MaxOvlpLimit < DatesInfo.EndDate - CSGupTimeDef) then
                include(errSet, CSE_BothOvlp)
              else
                include(errSet, CSE_LeftOvlp);
            end else
              if (MaxOvlpLimit > 0)
              and (MaxOvlpLimit < DatesInfo.EndDate - CSGupTimeDef) then
                include(errSet, CSE_RightOvlp);
          end;

        end;
      //end;
    end;

    if (ErrToCheck = CSEG_Dates) or (ErrToCheck = CSEG_All) then
    begin
      if (DatesInfo.startDate = 0) or (DatesInfo.EndDate = 0) then
        Exit;

      if DBAppSettings.ChkDelDate
{$ifdef ARO}
      and (GetSchedType(id) <> '5')
{$endif}
      and (DatesInfo.DeliveryDate < DatesInfo.EndDate - CSGupTimeDef) then
        include(errSet, CSE_DelDate);

      if DBAppSettings.ChkHighEnd
      and (DatesInfo.HighEndDate < DatesInfo.EndDate - CSGupTimeDef)  then
        include(errSet, CSE_HighEndDate);

      if DBAppSettings.ChkLowStart
      and (DatesInfo.LowStrDate > DatesInfo.StartDate + CSGupTimeDef) then
        include(errSet, CSE_LowStrDate);

      if (DatesInfo.ApprovalDate > DatesInfo.StartDate + CSGupTimeDef) then
        include(errSet, CSE_ApprovalDate);

    end;

    if errSet = [] then
      include(errSet, CSE_NoError);

  end else
  begin
    grp := TSCProdGroup(sc);
    ChkMaterials := DBAppSettings.ChkMaterials;
    ChkAddRes := DBAppSettings.ChkAddRes;
    DBAppSettings.ChkMaterials := false;
    DBAppSettings.ChkAddRes := false;
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := grp.m_list[i];
      CheckErrors(job.m_Id, ErrToCheck, ErrSet, PurchaseOrderLeadTimeList);
    end;
    DBAppSettings.ChkMaterials := ChkMaterials;
    DBAppSettings.ChkAddRes := ChkAddRes;
  end;
end;

