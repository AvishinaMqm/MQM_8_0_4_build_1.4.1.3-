function TMSchedCont.GetOvlpLimits(id: TSchedId; var LowLimit, HighLimit: TDateTime): boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
//  ConnReqJobsList: TMSchedList;
begin
  Result := false;
  sc := TSCSchedOnPlan(m_codeList[id]);

//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  LowLimit := 0;
  HighLimit := 0;
  if not Assigned(GetExtLinkPtr(id)) then exit;

  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := grp.m_list[i];

      if not job.m_DontCalcOvlp then
      begin
        if not assigned(TMqmActArea(GetExtLinkPtr(job.m_Id))) then continue;
        m_SCcalcOvlp.SetMainId(job.m_Id);
        m_SCcalcOvlp.SetTargetRes(TMqmActArea(GetExtLinkPtr(job.m_Id)).p_Father, OvlpChk_OnSchedPoint, -1);
        m_SCcalcOvlp.GetMainOverlaps(LowLimit, HighLimit);
        SetOvlpLimits(job.m_Id, LowLimit, HighLimit);
        if P_ReorganizeAllEnd then
          job.m_DontCalcOvlp := true;

{
        ConnReqJobsList := TMSchedList.Create(self);
        p_sc.GetPrevConnReqLastStepJobs(job.m_Id, ConnReqJobsList);
        LowLimit := ConnReqJobsList.GetHighestEnd(true);
        ConnReqJobsList.ClearList;
        p_sc.GetNextConnReqFirstStepJobs(job.m_Id, ConnReqJobsList);
        HighLimit := ConnReqJobsList.GetLowestStart(true, true);
        ConnReqJobsList.Free;
        SetOvlpLimits(job.m_Id, LowLimit, HighLimit);
}
      end;

      if (LowLimit = 0)
      or (LowLimit < job.m_MinOvlpDate) then
        LowLimit  := job.m_MinOvlpDate;

      if (HighLimit = 0)
      or (HighLimit > job.m_MaxOvlpDate) then
      HighLimit := job.m_MaxOvlpDate
    end
  end else
  begin
    job := TSCProdSched(sc);

    if not job.m_DontCalcOvlp then
    begin
      m_SCcalcOvlp.SetMainId(job.m_Id);
      m_SCcalcOvlp.SetTargetRes(TMqmActArea(GetExtLinkPtr(job.m_Id)).p_Father, OvlpChk_OnSchedPoint, -1);
      m_SCcalcOvlp.GetMainOverlaps(LowLimit, HighLimit);
      SetOvlpLimits(job.m_Id, LowLimit, HighLimit);
      if P_ReorganizeAllEnd then
        job.m_DontCalcOvlp := true;
{
      ConnReqJobsList := TMSchedList.Create(self);
      p_sc.GetPrevConnReqLastStepJobs(job.m_Id, ConnReqJobsList);
      LowLimit := ConnReqJobsList.GetHighestEnd(true);
      ConnReqJobsList.ClearList;
      p_sc.GetNextConnReqFirstStepJobs(job.m_Id, ConnReqJobsList);
      HighLimit := ConnReqJobsList.GetLowestStart(true, true);
      ConnReqJobsList.Free;
      SetOvlpLimits(job.m_Id, LowLimit, HighLimit);
}
    end;

    LowLimit  := job.m_MinOvlpDate;
    HighLimit := job.m_MaxOvlpDate;
  end;

  Result := true
end;

