function TMSchedCont.IsAForcedGroup(job: TSchedID; isGroup: boolean): boolean;
var
  jobSc: TSCProdSched;
  grpSc: TSCProdGroup;
begin
  Result := false;
  if job = CSchedIdNull then exit;

  if isGroup then
    grpSc := TSCProdGroup(m_codeList[job])
  else
  begin
    jobSc := TSCProdSched(m_codeList[job]);
    //Assert(Assigned(jobSc.m_grp));
    if Assigned(jobSc.m_grp) then
      grpSc := jobSc.m_grp;
  end;

  if grpSc.m_code < 0 then
    result := true;
end;

