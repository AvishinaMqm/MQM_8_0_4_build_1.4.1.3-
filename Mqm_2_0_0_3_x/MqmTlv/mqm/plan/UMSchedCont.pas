procedure TMSchedCont.UpdateSetup(id: TSchedID; out Delta: double; UpdForward: boolean);
var
  act:        TMqmActArea;
  cal:        TPGCALObj;
  planInfo:   TSQplanInfo;
  OldSetup: double;
  Teoreticl_wc, LearningCurveCode : string;
  Dummy2, Dummy3 : double;
begin
  act := p_sc.GetExtLinkPtr(id);
  if (act <> nil) then
  begin
    cal := act.GetCalendar;
    p_sc.GetPlanInfo(id, planInfo);

    OldSetup := planInfo.supMinReal;

    CalcSetup(id, act.GetPrecObjByIndex(id), act, planInfo.supMinBase, planInfo.supMinReal, planInfo.supMinOvlp, Teoreticl_wc, Dummy2, Dummy3, LearningCurveCode);
    // change parameters of the next object
//    cal.OfsByWH((planInfo.supMinReal + planInfo.exeMin)/60, UpdForward,
//                planInfo.startDate, planInfo.endDate);

    if not UpdForward then
      cal.OfsByWH(-(planInfo.supMinReal + planInfo.exeMin)/60, UpdForward,
                planInfo.endDate, planInfo.startDate, act.m_CrossDownTmList)
    else
      cal.OfsByWH((planInfo.supMinReal + planInfo.exeMin)/60, UpdForward,
                planInfo.startDate, planInfo.endDate, act.m_CrossDownTmList);

    p_opStack.ChgOccDurData(id, planInfo);

    Delta := planInfo.supMinReal - OldSetup;

    if planInfo.GenericPlan and (act.GetPrecObjByIndex(id) = CSchedIDnull)
       and (planInfo.GenericPlanWC <> '') and (Trim(Teoreticl_wc) = '') then
    begin
      UnScheduleGenericPlan(id);
      planInfo.GenericPlanWC := '';
      p_opStack.ChgOccDurGenericPlan(id, planInfo);
    end;

  end;
end;

