procedure TMSchedCont.FillLinkedListIdsForeward(Id : TschedId; LinkedJobsList : TMSchedList);
var
  I, J, G, D: Integer;
  tjob, job: TSCProdSched;
  JobBrother : TSchedId;
  Group : TSCProdGroup;
  ReqHdr, tHdr : TSCProdReqHdr;
  Det : TSCProdReqDet;
  sc : TSCSchedOnPlan;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdSched then
  begin
    job := TSCProdSched(m_codeList[id]);
    ReqHdr := TSCProdReqHdr(job.m_reqDet.m_hdr);
    for J := 0 to ReqHdr.m_list.Count - 1 do
    begin
      Det := TSCProdReqDet(ReqHdr.m_list[J]);
      if Det.m_code < job.m_reqDet.m_code then continue;
      for I := 0 to Det.m_list.Count - 1 do
      begin
        tjob := Det.m_list[i];
        if LinkedJobsList.IndexOf(tJob.m_Id) = -1 then
           LinkedJobsList.AddLink(tJob.m_Id);
      end;
    end;

    for i := 0 to ReqHdr.m_NextLinkedReqList.Count-1 do
    begin
      tHdr := PTLinkReqRec(ReqHdr.m_NextLinkedReqList[i]).Request;
      for D := 0 to tHdr.m_list.Count - 1 do
      begin
        Det := TSCProdReqDet(tHdr.m_list[D]);
        for j := 0 to Det.m_list.count -1 do
        begin
          tJob := TSCProdSched(Det.m_list[j]);
          if LinkedJobsList.IndexOf(tJob.m_Id) = -1 then
            LinkedJobsList.AddLink(tJob.m_Id);
        end;
      end;
    end;
  end
  else if sc is TSCProdGroup then
  begin
    Group := TSCProdGroup(m_codeList[id]);
    for G := 0 to Group.m_list.Count - 1 do
    begin
      tjob := TSCProdSched(Group.m_list[G]);
      if LinkedJobsList.IndexOf(tJob.m_Id) = -1 then
         LinkedJobsList.AddLink(tJob.m_Id);
    end;
  end;
end;

