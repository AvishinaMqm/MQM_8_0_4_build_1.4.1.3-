function TMSchedCont.GetPropVal(id: TSchedID; pId: TPropId; var val: variant): boolean;
var
  sc: TSCSchedOnPlan;
  scProd : TSCProdSched;
  PropCode,
  RscCode, CodeProp: string;
  tbs : TBinTabSheet;
  i: integer;
  valFrom,valTo: variant;
begin
  Result := false;
  if pId = nil then exit;

  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdSched then
  begin
    scProd := TSCProdSched(sc);
    if Assigned(scProd.m_mtr) then
    begin
      // Result := GetMatPropVal
      exit;
    end;
  end;

  if sc is TSCProdGroup then exit;

  RscCode := TSCProdSched(sc).p_rscCode;
  PropCode := GetPropCodeFromID(pId);
  if (RscCode = '') and Assigned(FBin) then
  begin
    tbs := TBinTabSheet(FBin.GetActiveView);
    if Assigned(tbs) and tbs.p_IsDeleted then
//    if tbs.p_IsDeleted then
      Exit;
    if assigned(tbs) and Assigned(tbs.m_BinPanel) then
    begin
      for I := 0 to tbs.m_BinPanel.GetFiltParms.GetCountPropList - 1 do
      begin
        CodeProp := tbs.m_BinPanel.GetFiltParms.GetValCodeByIndex(I,RscCode,valFrom,valTo);
        if CodeProp = PropCode then
          break
        else
          RscCode := ''
      end;
    end;
  end;

//-prop  if TSCProdSched(sc).m_reqDet.m_propList.GetValforProp(pId, val) then
  if TSCProdSched(sc).m_reqDet.m_propList.GetValforCode(PropCode, RscCode, -1, val) then
    Result := true
end;

