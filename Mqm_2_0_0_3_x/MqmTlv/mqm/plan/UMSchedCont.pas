function TMSchedCont.GetStepQtyAtDate(Id: TSchedId; AtDate: TDateTime): double;
var
  Job:  TSCProdSched;
  JobsList: TMSchedList;
  JobId: TSchedId;
  i: integer;
begin
  Result := 0;
  Job := m_codeList[id];

  JobsList := TMSchedList.Create(self);
  GetStepJobs(job.m_reqDet.m_hdr.m_code, job.m_reqDet.m_code, JobsList);

  for i := 0 to JobsList.GetLinkCount-1 do
  begin
    JobId := JobsList.GetLink(i);
    Result := Result + GetJobQtyAtDate(JobId, nil, AtDate);
  end;

  JobsList.Free;
end;

