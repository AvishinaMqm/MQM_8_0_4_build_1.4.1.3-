  procedure SignedStepRefreshHandled(ProdReq : string; Step : Integer; UpdateNr : Integer);
  var
    I : Integer;
    Multiplier, NumberOfEntries : integer;
  begin
    NumberOfEntries := Changed_Req_List.Count;
    if NumberOfEntries = 0 then exit;
    Multiplier := 1;
    while Multiplier < NumberOfEntries do
      Multiplier := Multiplier * 2;
    i := Multiplier - 1;
    while (Multiplier > 0) do
    begin
      Multiplier := trunc(Multiplier/2);
      if (i >= NumberOfEntries) then
      begin
        i := i - Multiplier;
        continue;
      end;

      if (PReqChanged(Changed_Req_List[i]).ReqNo = ProdReq) and
         (PReqChanged(Changed_Req_List[i]).step = Step) and
         (PReqChanged(Changed_Req_List[i]).DwnNr = UpdateNr) then
      begin
        PReqChanged(Changed_Req_List[i]).StepRefreshHandled := false;
        break;
      end;
      if (PReqChanged(Changed_Req_List[i]).DwnNr < UpdateNr)
      or ((PReqChanged(Changed_Req_List[i]).DwnNr = UpdateNr) and
         (PReqChanged(Changed_Req_List[i]).ReqNo < ProdReq))
      or ((PReqChanged(Changed_Req_List[i]).DwnNr = UpdateNr) and
         (PReqChanged(Changed_Req_List[i]).ReqNo = ProdReq) and
         (PReqChanged(Changed_Req_List[i]).step < Step)) then
          i := i + Multiplier
      else
          i := i - Multiplier;
    end;
  end;

