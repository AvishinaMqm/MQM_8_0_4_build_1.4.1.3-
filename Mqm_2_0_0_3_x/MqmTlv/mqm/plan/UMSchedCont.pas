procedure TMSchedCont.ChangeWcPlanedToWcMain(id : TSchedId);
var
  TempStrList : TStringList;
  ps : TSCSchedOnPlan;
  scG : TSCProdGroup;
  scP :  TSCProdSched;
  ProdReqDet : TSCProdReqDet;
  objWkc, objWkcTmp, wc : TMqmWrkCtr;
  I : Integer;
  PlantWC : string;
  AltWcList : TStringList;

  procedure SetWcPlanedtoWcMain(tHdr: TSCProdReqHdr; PlantWC : string);
  var
    I, J, w : Integer;
    AltWcProcess : TWorkCenterInfo;
    AltProcess : string;
  begin
    for I := 0 to tHdr.m_list.Count - 1 do
    begin
      ProdReqDet := TSCProdReqDet(tHdr.m_list[I]);
      for J := 0 to ProdReqDet.m_list.Count - 1 do
      begin
        scP := TSCProdSched(ProdReqDet.m_list[J]);
      //  objWkc := TMqmWrkCtr(p_pl.FindWrkCtrByCode(GetFldDescr(scP.m_id, CSC_WkctCode)));
      //  WkcPlaned := objWkc.p_PlantCode;
        objWkc := TMqmWrkCtr(p_pl.FindWrkCtrByCode(scP.p_WorkCenter));
        if not assigned(objWkc) then continue;
        AltWcList := objWkc.GetAltWcList;
        if not assigned(AltWcList) then continue;
        for w := 0 to AltWcList.count - 1 do
        begin
          objWkcTmp := TMqmWrkCtr(p_pl.FindWrkCtrByCode(AltWcList.Strings[w]));
          if objWkcTmp.p_WcMain = '' then continue;
          if objWkcTmp.p_PlantCode <> PlantWC then Continue;

          wc := TMqmWrkCtr(p_pl.FindWrkCtrByCode(objWkcTmp.p_WcMain));
          if not assigned(wc) then continue;
          if objWkc.GetAltProcForAltWrkCtr(scP.p_Process, wc.p_WrkCtrCode, AltProcess) then
          begin
            AltWcProcess.AlterWorkCenter := objWkcTmp.p_WcMain;
            AltWcProcess.AlterProcess    := AltProcess;
            p_sc.SetWcProcessAlternative(scP.m_Id, wc, AltWcProcess, wc.p_ReadOnly);
          end;
          break
        end;
      end;
    end;

  end;

begin
  TempStrList := TStringList.Create;
  ps := TSCSchedOnPlan(m_codeList[id]);
  if ps is TSCProdGroup then
  begin
    scG := TSCProdGroup(m_codeList[id]);
    for I := 0 to scG.m_List.Count - 1 do
    begin
      PlantWC := '';
      if not CheckWcPlanedtoWcMain(TSCProdSched(scG.m_List[I]).m_id , PlantWC) then
      begin
        TempStrList.Free;
        exit
      end
      else
      begin
        if TempStrList.Count = 0 then
          TempStrList.Add(PlantWC)
        else
        begin
          if TempStrList.IndexOf(PlantWC) = -1 then
          begin
            TempStrList.Free;
            exit
          end;
        end;
      end;
    end;
  end
  else
  begin
    if not checkWcPlanedtoWcMain(Id, PlantWC) then
    begin
      TempStrList.Free;
      exit
    end;
  end;

  if ps is TSCProdGroup then
  begin
    scG := TSCProdGroup(m_codeList[id]);
    for I := 0 to scG.m_List.Count - 1 do
    begin
      scP := TSCProdSched(scG.m_List[I]);
      SetWcPlanedtoWcMain(scP.m_reqDet.m_hdr, PlantWC);
    end;
  end
  else
  begin
    scP := TSCProdSched(m_codeList[id]);
    SetWcPlanedtoWcMain(scP.m_reqDet.m_hdr, PlantWC);
  end;
end;

