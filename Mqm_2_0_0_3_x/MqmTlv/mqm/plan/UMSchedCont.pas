function TMSchedCont.HasPrevConnRequest(Id: TSchedId): boolean;
var
  tHdr: TSCProdReqHdr;
  tJob:  TSCProdSched;
  ps : TSCSchedOnPlan;
begin
  result := false;
  ps := m_codeList[id];
  if not (ps is TSCProdSched) then exit;

  tJob := TSCProdSched(ps);
  if not Assigned(tJob.m_reqDet) then exit;

  tHdr := TSCProdReqHdr(tJob.m_reqDet.m_hdr);
  if not Assigned(tHdr) then exit;

  result := tHdr.m_PrecLinkedReqList.Count > 0;
end;

