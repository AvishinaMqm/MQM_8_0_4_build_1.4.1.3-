    begin
      LastReq_INBuild := Rec.ReqNo;
      Inc(UniqueReqCount);
      if UniqueReqCount >= 1000 then
      begin
        ChangedReqInClause := '';
        break;
      end;
      if ChangedReqInClause <> '' then ChangedReqInClause := ChangedReqInClause + ',';
