procedure TMSchedCont.DeleteGroup(grp: TSchedID);
var
  grpSc: TSCProdGroup;
  sc: TSCSchedOnPlan;
  i: integer;
begin
//  Assert(TSCSchedOnPlan(m_codeList[grp]) is TSCProdGroup);
  if not (TSCSchedOnPlan(m_codeList[grp]) is TSCProdGroup) then Exit;
  grpSc := TSCProdGroup(m_codeList[grp]);
  if grpSc.m_list.Count > 0 then
    for i := grpSc.m_list.Count-1 downto 0 do
      RemoveJobFromGroup(TSCProdSched(grpSc.m_list[i]).m_Id, 'Group deleted');

  m_grpList.Remove(grpSc);
  grpSc.m_isDeleted := true;
  while True do
  begin
    if m_codeList.Count = 0 then break;
    if m_PhisicallyDelete_LimitIndex = -1 then break;
    if m_codeList.Count = m_PhisicallyDelete_LimitIndex then break;
    sc := TSCSchedOnPlan(m_codeList[m_codeList.Count - 1]);
    if (sc is TSCProdSched) then
    begin
      if not sc.m_isDeleted then break;
      TSCProdSched(sc).m_reqDet.m_list.Remove(sc);
      m_codeList.delete(m_codeList.Count - 1);
      m_CloneCodeList.Remove(sc);
      sc.Free;
      continue;
    end;
    grpSc := TSCProdGroup(m_codeList[m_codeList.Count - 1]);
    if not grpSc.m_isDeleted then break;
    m_codeList.delete(m_codeList.Count - 1);
    m_CloneCodeList.Remove(grpSc);
    grpSc.Free;
  end;

  {grpSc.Free;
  m_codeList[grp] := nil;
  m_CloneCodeList[grp] := nil;}

end;

