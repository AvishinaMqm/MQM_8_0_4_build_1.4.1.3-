procedure TMSchedCont.LoadMaterialSched(OnStart : boolean; qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText; ErrList: TStringList);
type
  TMatSched_link = Record
    Preq_No:    string;
    Pstep_id:	  SMALLINT;
    ITEM_TYPE    : string;
    PRODUCT_CODE : string;
    Code_DET  : string;
    CODE_SUB_DET : string;
  end;
  PTMatSched_link = ^TMatSched_link;
var
  tbiMatSched, tbiMatSched_link, tbiProductProperty : ^TTblInfo;
  tHdr : TSCProdReqHdr;
  tDet : TSCProdReqDet;
  tJob : TSCProdSched;
  mtr  : TSCMaterialSched;
  I, J, P, Index : Integer;
  Item_Id : TSchedId;
  FoundItemAndProduct, FoundInHost : boolean;
  timingInfo: TSQtimingInfo;
  DammyQty : double;
  Article: TMQMArticle;
  ProductProperties : PProductProperties;
  ProductPropertyList, MtrListFreshFromHost : TList;
  request : string;
  step : integer;
begin
  if Assigned(Status) then
    Status.Caption := _('Read material to schedule from database...');

  ProductPropertyList := TList.Create;
  tbiProductProperty := @tblInfo[tbl_ProductProperties];
  with qry.SQL do
  begin
    Clear;
    Add('select * from ');
    Add(tbiProductProperty.GetTableName + ' ');
    Add(WHERE_IDF_Condition(CreateFld(tbiProductProperty.pfx, fli_Identifier)));
    Add(' order by PDP_TYPE_PROD, PDP_PRODUCT_CODE, PDP_PROPERTY');
    qry.open;
    while not Qry.Eof do
    begin
      new(ProductProperties);
      ProductProperties.Item     := qry.FieldByName('PDP_TYPE_PROD').AsString;
      ProductProperties.Product  := qry.FieldByName('PDP_PRODUCT_CODE').AsString;
      ProductProperties.propCode := qry.FieldByName('PDP_PROPERTY').AsString;
      ProductProperties.Value    := qry.FieldByName('PDP_VALUE').AsString;
      ProductPropertyList.Add(ProductProperties);
      Qry.next
    end;
  end;

  Application.ProcessMessages;
  tbiMatSched := @tblInfo[tbl_MaterialDetailSchedule];

  with qry.SQL do
  begin
    Clear;
    Add('select * from ');
    Add(tbiMatSched.GetTableName + ' ');
    Add(WHERE_IDF_Condition(CreateFld(tbiMatSched.pfx, fli_Identifier)));
    Add(' order by MDS_TYPE_PROD, MDS_PRODUCT_CODE, MDS_PREQ_NO, MDS_SUB_DETAIL, MDS_DETAIL_CODE');
    qry.open;

    if not OnStart then
    begin
      MtrListFreshFromHost := TList.Create;

      while not Qry.Eof do
      begin

        Article := p_ArtTypeList.FindArticle(qry.FieldByName('MDS_TYPE_PROD').AsString ,trim(qry.FieldByName('MDS_PRODUCT_CODE').AsString));
        if not assigned(Article) then
        begin
          Qry.Next;
          continue
        end;

        mtr := TSCMaterialSched.Create;
        mtr.m_ITEM_TYPE := qry.FieldByName('MDS_TYPE_PROD').AsString;
        mtr.m_PRODUCT_CODE := qry.FieldByName('MDS_PRODUCT_CODE').AsString;
        mtr.m_RequestNo    := qry.FieldByName('MDS_PREQ_NO').AsString;
        mtr.m_NET_GROUP_CODE := qry.FieldByName('MDS_NET_GROUP_CODE').AsString;
        mtr.m_Material_Code_DET := qry.FieldByName('MDS_DETAIL_CODE').AsString;
        mtr.m_MATERIAL_CODE_SUB_DET := qry.FieldByName('MDS_SUB_DETAIL').AsString;
        mtr.m_MATERIAL_Overriden_Speed := qry.FieldByName('MDS_OVERRIDENSPEED').AsFloat;
        mtr.m_MATERIAL_Overriden_Setup_Time := qry.FieldByName('MDS_OVERRIDENSETUPTIME').AsFloat;
        mtr.m_qty                           := qry.FieldByName('MDS_QTY').AsFloat;
        mtr.m_FOUND_In_LOCALE := false;
        mtr.m_Is_Deleted := false;
        MtrListFreshFromHost.Add(mtr);
        Qry.Next
      end;

      for I := 0 to m_MtrList.Count - 1 do
      begin
        FoundInHost := false;
        for J := 0 to MtrListFreshFromHost.Count - 1 do
        begin
          if (TSCMaterialSched(m_MtrList[i]).m_ITEM_TYPE = TSCMaterialSched(MtrListFreshFromHost[J]).m_ITEM_TYPE) and
             (TSCMaterialSched(m_MtrList[i]).m_PRODUCT_CODE = TSCMaterialSched(MtrListFreshFromHost[J]).m_PRODUCT_CODE) and
             (TSCMaterialSched(m_MtrList[i]).m_RequestNo = TSCMaterialSched(MtrListFreshFromHost[J]).m_RequestNo) and
             (TSCMaterialSched(m_MtrList[i]).m_Material_Code_DET = TSCMaterialSched(MtrListFreshFromHost[J]).m_Material_Code_DET) and
             (TSCMaterialSched(m_MtrList[i]).m_MATERIAL_CODE_SUB_DET = TSCMaterialSched(MtrListFreshFromHost[J]).m_MATERIAL_CODE_SUB_DET) then
          begin
            TSCMaterialSched(MtrListFreshFromHost[J]).m_FOUND_In_LOCALE := true;
            FoundInHost := true;
            break
          end;
        end;

        if FoundInHost then
        begin
          TSCMaterialSched(m_MtrList[i]).m_qty := TSCMaterialSched(MtrListFreshFromHost[J]).m_qty;
          if Assigned(TSCMaterialSched(m_MtrList[i]).m_MqmActArea) and Assigned(TSCMaterialSched(m_MtrList[i]).m_WarpObj) then
             TMqmWarp(TSCMaterialSched(m_MtrList[i]).m_WarpObj).SetQuantity(TSCMaterialSched(m_MtrList[i]).m_qty);
        end
        else
        begin
          TSCMaterialSched(m_MtrList[i]).m_Is_Deleted := true;
          if Assigned(TSCMaterialSched(m_MtrList[i]).m_MqmActArea) and Assigned(TSCMaterialSched(m_MtrList[i]).m_WarpObj) then
             TMqmActArea(TSCMaterialSched(m_MtrList[i]).m_MqmActArea).RemoveWarp(TSCMaterialSched(m_MtrList[i]).m_WarpObj);
        end;
      end;

      for I := 0 to MtrListFreshFromHost.Count - 1 do
      begin
        if not TSCMaterialSched(MtrListFreshFromHost[i]).m_FOUND_In_LOCALE then
        begin
          mtr := MtrListFreshFromHost[i];
          mtr.m_Is_Deleted := false;
          tHdr := TSCProdReqHdr.Create;
          tHdr.m_code := 'MAT';
          tDet := TSCProdReqDet.Create;
          tDet.m_code := 0;
          tDet.m_hdr  := TSCProdReqHdr(tHdr);
          TSCProdReqHdr(tHdr).m_list.Add(tDet);
          tJob := TSCProdSched.Create;
          tJob.m_code := 0;
          tJob.m_Id   := m_codeList.Add(tJob);
          tJob.m_reqDet := tDet;
          TSCProdReqDet(tDet).m_list.Add(tJob);

          tJob.m_MsgFromHost    := CSH_New_request;

          tJob.m_mtr := mtr;
          tJob.m_mtr.m_Job       := tJob;
          Article := p_ArtTypeList.FindArticle(mtr.m_ITEM_TYPE , Trim(mtr.m_PRODUCT_CODE));
          if Assigned(Article) then
          begin
            tJob.m_mtr.m_warp_levl := Article.p_MaterialSchedule;
            tJob.m_mtr.m_Standard_Setup      := Article.p_MaterialStandardSetupMinutes;
            tJob.m_mtr.m_SpeedInminutePerUoM := Article.p_MaterialStandardSpeed
          end
          else
            mtr.m_Is_Deleted := true;
          m_MtrList.Add(mtr);
        end;
      end;

      for I := MtrListFreshFromHost.Count - 1 downto 0 do
      begin
        if TSCMaterialSched(MtrListFreshFromHost[i]).m_FOUND_In_LOCALE then
           TSCMaterialSched(MtrListFreshFromHost[i]).Free;
      end;
      MtrListFreshFromHost.Free;
    end
    else
    begin
      while not Qry.Eof do
      begin

        Article := p_ArtTypeList.FindArticle(qry.FieldByName('MDS_TYPE_PROD').AsString ,trim(qry.FieldByName('MDS_PRODUCT_CODE').AsString));
        if not assigned(Article) or (Article.p_MaterialSchedule = MT_No) then
        begin
          Qry.Next;
          continue
        end;

        tHdr := TSCProdReqHdr.Create;
        //tHdr := AddReqHdr('MAT');
        tHdr.m_code := 'MAT';//QuotedStr(qry.FieldByName('SD_BALANCEID').AsString);
        tDet := TSCProdReqDet.Create;
        tDet.m_code := 0;//qry.FieldByName('SD_BALANCEID').AsInteger;
        tDet.m_hdr  := TSCProdReqHdr(tHdr);
        TSCProdReqHdr(tHdr).m_list.Add(tDet);
        tJob := TSCProdSched.Create;
        tJob.m_code := 0;
        tJob.m_Id   := m_codeList.Add(tJob);
        tJob.m_reqDet := tDet;
        tJob.m_isDeleted := true;
        tJob.m_deleteReason := 'LoadMaterialSched - MaterialSched placeholder';
        TSCProdReqDet(tDet).m_list.Add(tJob);
        mtr  := TSCMaterialSched.Create;
        tJob.m_mtr := mtr;
        tJob.m_mtr.m_ID := tJob.m_Id;
        tJob.m_mtr.m_Is_Deleted := false;
        tJob.m_mtr.m_ITEM_TYPE := qry.FieldByName('MDS_TYPE_PROD').AsString;
        tJob.m_mtr.m_PRODUCT_CODE := qry.FieldByName('MDS_PRODUCT_CODE').AsString;
        tJob.m_mtr.m_NET_GROUP_CODE := qry.FieldByName('MDS_NET_GROUP_CODE').AsString;
        tJob.m_mtr.m_Material_Code_DET := qry.FieldByName('MDS_DETAIL_CODE').AsString;
        tJob.m_mtr.m_MATERIAL_CODE_SUB_DET := qry.FieldByName('MDS_SUB_DETAIL').AsString;
        tJob.m_mtr.m_MATERIAL_Overriden_Speed := qry.FieldByName('MDS_OVERRIDENSPEED').AsFloat;
        tJob.m_mtr.m_MATERIAL_Overriden_Setup_Time := qry.FieldByName('MDS_OVERRIDENSETUPTIME').AsFloat;
        tJob.m_mtr.m_RequestNo := qry.FieldByName('MDS_PREQ_NO').AsString;
        tJob.m_mtr.m_ResCode := trim(qry.FieldByName('MDS_RSC_CODE').AsString);
        tJob.m_mtr.m_start   := qry.FieldByName('MDS_SCH_START').AsDateTime;
        tJob.m_mtr.m_end     := qry.FieldByName('MDS_SCH_END').AsDateTime;
        tJob.m_mtr.m_UM      := qry.FieldByName('MDS_PROD_UM').AsString;
        tJob.m_mtr.m_Job       := tJob;
        tJob.m_mtr.m_warp_levl := Article.p_MaterialSchedule;
        tJob.m_mtr.m_qty := qry.FieldByName('MDS_QTY').AsFloat;  //RandomRange(150, 450);
        tJob.m_mtr.m_Standard_Setup      := Article.p_MaterialStandardSetupMinutes;
        tJob.m_mtr.m_SpeedInminutePerUoM := Article.p_MaterialStandardSpeed;

        m_MtrList.Add(mtr);
        Qry.Next;
      end;

    end;

    tbiMatSched_Link := @tblInfo[tbl_MaterialDetailchedule_Link];

    for I := 0 to m_MtrList.Count - 1 do
    begin
      mtr := TSCMaterialSched(m_MtrList[I]);
      mtr.m_LinkedRequestList.Clear;
      mtr.m_LinkedStepList.Clear;
    end;

    with qry.SQL do
    begin
      Clear;
      Add('select * from ');
      Add(tbiMatSched_link.GetTableName + ' ');
      Add(WHERE_IDF_Condition(CreateFld(tbiMatSched_Link.pfx, fli_Identifier)));
      Add(' and ' + CreateFld(tbiMatSched_Link.pfx, fli_preqNo) + ' <> ' + QuotedStr('0'));
      Add(' order by MDSL_TYPE_PROD, MDSL_PRODUCT_CODE, MDSL_SUB_DETAIL, MDSL_DETAIL_CODE, MDSL_PREQ_NO, MDSL_PSTEP_ID');
      qry.open;
    end;

    while not Qry.Eof do
    begin

      Article := p_ArtTypeList.FindArticle(qry.FieldByName('MDSL_TYPE_PROD').AsString ,trim(qry.FieldByName('MDSL_PRODUCT_CODE').AsString));
      if not assigned(Article) or (Article.p_MaterialSchedule = MT_No) then
      begin
        Qry.Next;
        continue
      end;

      mtr := FindMaterialSched(m_MtrList, qry.FieldByName('MDSL_TYPE_PROD').AsString, trim(qry.FieldByName('MDSL_PRODUCT_CODE').AsString),
                               '', trim(qry.FieldByName('MDSL_SUB_DETAIL').AsString), trim(qry.FieldByName('MDSL_DETAIL_CODE').AsString));

      if assigned(mtr) then
      begin
        request := trim(qry.FieldByName('MDSL_PREQ_NO').AsString);
        Step := qry.FieldByName('MDSL_PSTEP_ID').AsInteger;
        mtr.SetLinkedRequestToWarp(request,step);
      end;

      Qry.Next;
    end;

    // fill properties

    for I := 0 to m_MtrList.Count - 1 do
    begin
      mtr := TSCMaterialSched(m_MtrList[I]);
      mtr.m_propList.DeletAllNonPlannerProperties(false);
      mtr.m_propList.clear;
      ProductProperties := FindPropertyValue(mtr.m_ITEM_TYPE, mtr.m_PRODUCT_CODE, Index, ProductPropertyList);
      if ProductProperties = nil then continue;
      while (Index > - 1) and (Index <= ProductPropertyList.Count - 1) do
      begin
        if (mtr.m_ITEM_TYPE = PProductProperties(ProductPropertyList[Index]).Item) and
           (mtr.m_PRODUCT_CODE = PProductProperties(ProductPropertyList[Index]).Product) then
        begin
          mtr.m_propList.AddProperty(PProductProperties(ProductPropertyList[Index]).propCode , '', PProductProperties(ProductPropertyList[Index]).Value);
          Inc(Index)
        end
        else
          break
      end;

    end;

    qry.close;

    for I := ProductPropertyList.Count - 1 downto 0 do
      dispose(PProductProperties(ProductPropertyList[I]));
    ProductPropertyList.Free;

  end;
end;

