procedure TMSchedCont.UnscheduleStepForDataChange(Hdr: TSCProdReqHdr; Step: Integer; ChangeType : Integer;
                                                  SignedAsDeleted: boolean; ShowMsg: boolean; DelProgress : boolean;
                                                  DispoList: TStringList ;fLoad: TLinkJobFunc);
var
  tDet    : TSCProdReqDet;
  tJob    : TSCProdSched;
  pd,ps   : Integer;
  actArea : TMqmActArea;
  extPtr  : TMqmActArea;
  Group_id   : TSchedId;
  Remove : boolean;
  Qry : TMqmQuery;
  tbiSP : ^TTblinfo;

begin
  Qry := CreateQuery(Main_DB);
  tbiSP := @tblInfo[tbl_sched_progress];
  Qry.Transaction := CreateTransaction(Main_DB);
  Qry.Transaction.StartTransaction;

  Remove := false;

  tJob := nil;
  tDet := nil;
  try
  for pd := 0 to Hdr.m_list.Count - 1 do
  begin
    Application.ProcessMessages;
    tDet := TSCProdReqDet(Hdr.m_list[pd]);

    if (tDet.m_code <> Step) then continue;

    {with QryProgress.SQL do
    begin
      Clear;
      Add('select * from ' + tbiSP.GetTableName);
      Add(' where ' + CreateFld(tbiSP.pfx, fli_preqNo) + '=' + QuotedStr(Hdr.m_code));
      Add(' and   ' + CreateFld(tbiSP.pfx, fli_pstepId) + '=' + IntToStr(tDet.m_code));
      QryProgress.open;
      if not QryProgress.EOF then continue;
    end;}

    for ps := 0 to tDet.m_list.Count - 1 do
    begin
      Application.ProcessMessages;
      tJob := TSCProdSched(tDet.m_list[ps]);
      if assigned(tJob.m_grp) then
      begin
        if ChangeType = 5 then
          MoveToBin(tJob.m_grp.m_id, true)
        else
        begin
          if GetGrpNumSons(tJob.m_grp.m_id) = 1 then
          begin
            Group_id := tJob.m_grp.m_id;
            extPtr := p_sc.GetExtLinkPtr(Group_id);
            if Assigned(extPtr) then
            begin
              actArea := TMqmActArea(extPtr);
              actArea.RemoveSchedObj(Group_id);
              Remove := true;
            end;
            RemoveJobFromGroup(tJob.m_id, 'Unscheduled - data changed');
            DeleteGroup(Group_id);
          end
          else
          begin
            RemoveJobFromGroup(tJob.m_id, 'Unscheduled - data changed');
          end;
        end;
      end
      else
      begin
        if Assigned(tJob.m_srvPtr) and DelProgress then
        begin
          tJob.m_ProgType := '';
          tJob.m_PrgSt := 0;
          tJob.m_PrgEd := 0;
        end;
        if tJob.m_fromPD then
        begin
          DelProgress := false;
        end
        else
        begin
          if Assigned(tJob.m_srvPtr) then
          begin
            actArea := TMqmActArea(tJob.m_srvptr);
            if Assigned(actArea) then
            begin
              actArea.RemoveSchedObj(tjob.m_id);
              tJob.m_srvPtr := nil;
            end;
          end;
          fLoad(tJob.p_OldrscCode , tJob.m_Id, nil);
        end;

        if Assigned(tJob.m_srvPtr) and (not DelProgress) then
        begin
          actArea := TMqmActArea(tJob.m_srvptr);
          if Assigned(actArea) then
          begin
            actArea.RemoveSchedObj(tjob.m_id);
            tJob.m_srvPtr := nil;
            tJob.m_ProgType := '';
            Remove := true;
          end;
        end
      end;
      if SignedAsDeleted then
      begin
        tJob.m_isDeleted := true;
        tJob.m_deleteReason := 'UnscheduleStepForDataChange - SignedAsDeleted';
        tJob.m_status := CSS_del;
      end
      else if Remove then
      begin
        WriteLogLineToDB(Qry, 'P', Hdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo,'Uns', '' ,tJob.GetRscCode, 0, 0, tJob.p_quantSched, tjob.p_GetStepType, 'refresh-UnscheduleStepForDataChange');
        tJob.m_MsgFromHost := CSH_Jobs_unscheduled
      end
      else
        tJob.m_MsgFromHost := CSH_Minor_change;
      if ShowMsg then
        DispoList.Add(_('Deleted step:') + ' ' + IntTostr(tJob.m_reqDet.m_code) + ' ,' + _('Sub step:') + ' ' + IntTostr(tJob.m_code) + ' ' + _('in Request:') + ' ' + Hdr.m_code);
    end;
  end;

  except
    if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Unschedule Step Request For Data Changed:') +
              ' ' + _('Request:') + Hdr.m_code + ', ' + _('Step:') + IntToStr(tDet.m_code) + ', ' + _('Sub step:') + IntToStr(tJob.m_code) + '  ' + #13#10 +  ' Technical code: UMSchedCont:UnscheduleStepForDataChenge' , mtConfirmation, [mbOk], 0) = idOk then
    begin
      Exit;
      Qry.free;
    end;
  end;

  Qry.transaction.commit;
  Qry.free;

end;

