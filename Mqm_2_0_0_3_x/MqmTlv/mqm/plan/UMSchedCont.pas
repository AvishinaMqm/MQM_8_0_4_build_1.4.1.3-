            PPropWorkCenters := PTPropWorkCenters(PropertiesList[PropIdx]);
          for i := 0 to hdr.m_list.Count-1 do
          begin
            det := hdr.m_list[i];
            if Assigned(det) and (det.m_StepToSched) then
            begin
              if (PropIdx = -1) or (PPropWorkCenters.WorkCenters.IndexOf(det.m_planWkctr) > -1) then
                det.m_propList.AddPropertyOnly(code, RscCode, val);
            end
          end;
        end;
