function TMSchedCont.CreateGroupWithCode(id: TSchedID; newCode: integer): TSchedID;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
begin
  Result := CSchedIDnull;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdGroup then exit;
  job := TSCProdSched(sc);
//  Assert(not Assigned(job.m_grp));
  if Assigned(job.m_grp) then exit;

  grp := TSCProdGroup.Create;
  grp.m_code := newCode;
  grp.m_Id := m_codeList.Add(grp);
  m_CloneCodeList.Add(grp);
  m_grpList.Add(grp);

  job.m_grp := grp;
  grp.m_list.Add(job);

  if (GetJobType(Job.m_id) = CST_Continuous) and (job.p_Grp_Sequence <> '') then
  begin
    if not Assigned(grp.m_ListOfSequence) then
       grp.m_ListOfSequence := TStringlist.Create;
  end;

  Result := grp.m_Id
end;

