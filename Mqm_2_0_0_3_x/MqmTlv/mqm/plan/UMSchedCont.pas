          Sql.Add(' desc')
        else
          Sql.Add(' descending');
        Open;
        Application.ProcessMessages;
        while not EOF do
        begin
          NewLastUpdatNr := FieldByName(CreateFld(tbiCR.pfx, fli_updCode)).AsInteger;
          break;
          Application.ProcessMessages;
        end;
        qry.close;
      end;

      Sql.Clear;
