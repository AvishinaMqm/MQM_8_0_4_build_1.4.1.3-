procedure TMSchedCont.SetEarliestLatestPlanedStartEndDatesFromMcm(id: TSchedID; LowStrDate : TDateTime; HighEndDate : TDateTime; planStart : TDateTime; planEnd : TDateTime;  SetOrig : boolean);
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    if SetOrig then
    begin
      job.m_reqDet.m_planStart := job.m_reqDet.m_planStart_Orig;
      job.m_reqDet.m_planEnd   := job.m_reqDet.m_planEnd_Orig;
      job.m_reqDet.m_lowStartTimeLimit := job.m_reqDet.m_lowStartTimeLimit_Orig;
      job.m_reqDet.m_highEndTimeLimit  := job.m_reqDet.m_highEndTimeLimit_Orig
    end
    else
    begin
      job.m_reqDet.m_planStart := planStart;
      job.m_reqDet.m_planEnd   := planEnd;
      job.m_reqDet.m_lowStartTimeLimit := LowStrDate;
      job.m_reqDet.m_highEndTimeLimit  := HighEndDate
    end;
  end
  else
  begin
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      if SetOrig then
      begin
        job.m_reqDet.m_planStart := job.m_reqDet.m_planStart_Orig;
        job.m_reqDet.m_planEnd   := job.m_reqDet.m_planEnd_Orig;
        job.m_reqDet.m_lowStartTimeLimit := job.m_reqDet.m_lowStartTimeLimit_Orig;
        job.m_reqDet.m_highEndTimeLimit  := job.m_reqDet.m_highEndTimeLimit_Orig
      end
      else
      begin
        job.m_reqDet.m_planStart := planStart;
        job.m_reqDet.m_planEnd   := planEnd;
        job.m_reqDet.m_lowStartTimeLimit := LowStrDate;
        job.m_reqDet.m_highEndTimeLimit  := HighEndDate
      end;
    end
  end;
end;

