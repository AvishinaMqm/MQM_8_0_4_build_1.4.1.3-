function TMSchedCont.CanAddTwoJobsOnSameGroup(job1, job2 : TSchedID): boolean;
var
  sc:      TSCSchedOnPlan;
  tJob1, tJob2 : TSCProdSched;
  tDet1, tDet2 :TSCProdReqDet;
  tGrp:    TSCProdGroup;
  GroupingTypeGrp, GroupingTypeJob : CGroupingType;
  SChedListGroup, SChedListJob : TMSchedList;
  I : Integer;
  wkc : TMqmWrkCtr;
  supRec:    TSetupRec;
  compatVal: TCompatVal;
  SameGroup: boolean;
begin
  sc := TSCSchedOnPlan(m_codeList[job1]);
//  Assert(sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  tJob1 := TSCProdSched(sc);
  tDet1 := tJob1.m_reqDet;
  sc := TSCSchedOnPlan(m_codeList[job2]);
  tJob2 := TSCProdSched(sc);
  tDet2 := tJob1.m_reqDet;
  Result := false;

  if (tDet1.m_CanGroup <> '1') or (tDet2.m_CanGroup <> '1') then
    exit;

  if (tDet1.m_stepType <> tDet2.m_stepType) then
    exit;

  if tJob1.p_WorkCenter <> tJob2.p_WorkCenter then
    exit;

  if tJob1.p_Process <> tJob2.p_Process then
    exit;

  wkc := TMqmWrkCtr(p_sc.GetWrkCtrPtr(job1));

  if not Assigned(wkc) then exit;
  SameGroup := true;
  wkc.GetSetupParms(job1 ,Job2 , supRec, compatVal, SameGroup);
  if not SameGroup then
    exit;
  wkc.GetSetupParms(Job2, job1, supRec, compatVal, SameGroup);
  if not SameGroup then
    exit;

  Result := true
end;

