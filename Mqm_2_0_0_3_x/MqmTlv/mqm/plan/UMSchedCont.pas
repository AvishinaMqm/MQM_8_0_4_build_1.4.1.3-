function TMSchedCont.CompaireGroupsRequestStep(Group_Id1,Group_Id2 : TSchedID) : boolean;
var
  sc:    TSCSchedOnPlan;
  grpSc1, grpSc2 : TSCProdGroup;
  SonId1, SonId2 : TSchedId;
  Request1, Request2 : string;
  step1, step2, I : integer;
begin
  result := false;
  if (Group_Id1 = CSchedIdNull) or (Group_Id2 = CSchedIdNull) then
     exit;

  sc := TSCSchedOnPlan(m_codeList[Group_Id1]);
  //Assert(sc is TSCProdGroup);
  if not (sc is TSCProdGroup) then Exit;
  grpSc1 := TSCProdGroup(sc);

  sc := TSCSchedOnPlan(m_codeList[Group_Id2]);
  //Assert(sc is TSCProdGroup);
  if not (sc is TSCProdGroup) then exit;
  grpSc2 := TSCProdGroup(sc);

  if grpSc1.m_list.Count <> grpSc2.m_list.Count then exit;

  for I := 0 to GetGrpNumSons(Group_Id1) - 1 do
  begin
    SonId1 := p_sc.GetGrpSon(Group_Id1, i);
    SonId2 := p_sc.GetGrpSon(Group_Id2, i);

    Request1 := p_sc.GetFldDescr(SonId1, CSC_ProdReq, false);
    Request2 := p_sc.GetFldDescr(SonId2, CSC_ProdReq, false);

    Step1    := StrToInt(p_sc.GetFldDescr(SonId1, CSC_ProdStep, false));
    Step2    := StrToInt(p_sc.GetFldDescr(SonId2, CSC_ProdStep, false));

    if (Request1 <> Request2) or (step1 <> Step2) then exit;

  end;

  result := true;
end;

