procedure TMSchedCont.OrganizeIgnoredProgressOperation(SchedList : TMSchedList; ReApply : boolean);
var
  I : Integer;
  Id : TSchedId;
  planInfo: TSQplanInfo;
  ProgressStatus : CProgressIgnor;
  StartOrganize, ResCodeProg, StartProg, StartSched, EndSched : variant;
  dataType: CBinColValType;
  moveChgInfo: TSQmoveChgInfo;
  res : TMqmRes;
  linkInfo: TSQlinkInfo;
  ProgInfo: TSQProgInfo;
  visRes:  TMqmVisibleRes;
  act   : TMqmActArea;
begin
  // Make the whole Ignore-progress / Re-apply operation a single Undo step.
  if ReApply then
    p_opStack.MarkStackForButtonUndo('Re-apply progress')
  else
    p_opStack.MarkStackForButtonUndo('Ignore progress');

  for i := 0 to SchedList.GetLinkCount - 1 do
  begin
    Id := SchedList.GetLink(i);
    if (id <> CSchedIdNull) and (GetVisbleInBin(id) = CSB_ReadOnly) then continue;
    if TSCSchedOnPlan(m_codeList[id]).m_isDeleted then continue;

    // capture the current progress + position state for undo, BEFORE mutating
    p_opStack.ChgProgressStatus(Id);

    p_sc.GetFldValue(Id, CSC_SchedStart, StartSched, dataType);
    p_sc.GetFldValue(Id, CSC_SchedEnd, EndSched, dataType);

    if not ReApply then  //(ProgChangedType = Prg_Ignored) or (ProgChangedType = Prg_IgnoredAndSave) then
    begin
      p_sc.SetProgressStatus(Id, p_pl.PlanLinkJob, ReApply);
      p_sc.GetMoveChgInfo(Id, moveChgInfo);
      res := TMqmRes(p_pl.FindResByCode(moveChgInfo.OldResCode));
      if not Assigned(res) then exit;
      p_sc.GetLinkInfo(Id, linkInfo);
      if not res.p_isMultiRes then
        visRes := res.p_VisRes[0]
      else
      begin
        visRes := res.GetSubRes(linkInfo.subLinRscId);
        if not Assigned(visRes) then exit;
      end;
      act := TMqmActArea(VisRes.p_ActArea[0]);
      p_pl.EnterCompatModeInPlan(Id);
      act.ChangeTo_IgnorProgress(Id, StartSched);
      p_pl.ExitCompatModeInPlan;

    end
    else
    begin
      p_sc.SetProgressStatus(Id, p_pl.PlanLinkJob, ReApply);
      p_sc.GetFldValue(Id, CSC_ProgStart, StartProg, dataType);
      p_sc.GetFldValue(Id, CSC_Rsc, ResCodeProg, dataType);
      res := TMqmRes(p_pl.FindResByCode(ResCodeProg));
      if not Assigned(res) then exit;
      p_sc.GetLinkInfo(Id, linkInfo);
      p_sc.GetProgInfo(Id, ProgInfo);
      if not res.p_isMultiRes then
        visRes := res.p_VisRes[0]
      else
      begin
        visRes := res.GetSubRes(linkInfo.subLinRscId);
        if not Assigned(visRes) then exit;
      end;
      act := TMqmActArea(VisRes.p_ActArea[0]);
      p_pl.EnterCompatModeInPlan(Id);
      act.ChangeTo_IgnorProgress(Id, StartProg);
      p_pl.ExitCompatModeInPlan;
    end;

    DBAppGlobals.MAINPLAN_Ignore_Pain_When_refresh := true;
    // setStartEndSchedForIgnoredProgressHandling removed: ChangeTo_IgnorProgress already
    // set correct dates. Overwriting with stale ORIGINAL dates caused end < start in groups.
    // On Re-apply, skip the full-resource reorganize: ChangeTo_IgnorProgress already placed the
    // progressed job, and reorganizing here re-chained every other job around the progressed
    // anchor (jobs "jumping" after the progress). Skipping leaves the other jobs where they
    // were (like at program start). Ignore still reorganizes as before.
    if not ReApply then
      act.ReorganizeAllOcc(false);
    DBAppGlobals.MAINPLAN_Ignore_Pain_When_refresh := false;
  end;

end;

