function TMSchedCont.GetNextHighiestEndDate(Id:  TSchedId) : TDateTime;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  Grp : TSCProdGroup;
  I : integer;
  HighestEnd, HighestEnd_WithoutLeadTime, TempLeadTime : TDateTime;
  ProdReqDet : TSCProdReqDet;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  Result := 0;
  HighestEnd := 0;
  if sc is TSCProdGroup then
  begin
    Grp := TSCProdGroup(m_codeList[id]);
    //Assert(Grp.m_list.Count > 0);
    if Assigned(Grp) and not (Grp.m_list.Count > 0) then Exit;
    for i := 0 to Grp.m_list.Count-1 do
    begin
      job := TSCProdSched(Grp.m_list[i]);
      Result := GetNextHighiestEndDate(job.m_Id);
      if (HighestEnd < Result) or (HighestEnd = 0) then HighestEnd := Result;
    end;
    Result := HighestEnd;
  end
  else
  begin
    job := TSCProdSched(sc);
    ProdReqDet := TSCProdReqDet(job.GetNextStepToSched(job.m_reqDet.m_code));
    HighestEnd_WithoutLeadTime := 0;
    if not Assigned(ProdReqDet) then
    begin
      job.CheckConnReqHighestEnd(HighestEnd, HighestEnd_WithoutLeadTime, false, nil, false); // AVI
      Result := HighestEnd;   // AVI
    end
    else
    begin
      for i := 0 to ProdReqDet.m_list.Count - 1 do
      begin
        job := TSCProdSched(ProdReqDet.m_list[i]);
        if (job.p_rscCode = '') then continue;
        HighestEnd := job.p_schedEnd;
{        if (job.m_reqDet.p_LeadTimePrev + job.m_reqDet.p_LeadTimePrevBatch) > 0 then
        begin
          TempLeadTime := job.m_reqDet.p_LeadTimePrev * job.p_quantSched + job.m_reqDet.p_LeadTimePrevBatch;
          LowestStart := LowestStart + TempLeadTime/60/24;
        end;    }
        if Result < HighestEnd then Result := HighestEnd;
      end;
    end;
  end;
end;

