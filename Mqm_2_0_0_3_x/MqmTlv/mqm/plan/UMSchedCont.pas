  job := nil;
  //Assert(sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  job := TSCProdSched(sc);
  if Restore then
  begin
    job.m_PrgSt := job.m_PrgStSaved;
    job.m_PrgCurDt := job.m_PrgCurDtSaved;
    job.m_PrgEd := job.m_PrgEdSaved;
    job.m_ProgType := job.m_ProgTypeSaved;
    job.m_ProgSaved := false;
  end
  else
  begin
    job.m_PrgStSaved := job.m_PrgSt;
    job.m_PrgCurDtSaved := job.m_PrgCurDt;
    job.m_PrgEdSaved := job.m_PrgEd;
    job.m_ProgTypeSaved := job.m_ProgType;
    job.m_ProgSaved     := true;
  end;

end;

