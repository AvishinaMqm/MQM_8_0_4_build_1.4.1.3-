procedure TMSchedCont.LoadNewSplitRequets(Status: TStaticText);
var
  I, J : integer;
  SJOb : TSCProdSched;
  tHdr : TSCProdReqHdr;
  tdet : TSCProdReqDet;
  Group_id : TschedId;
  actArea : TMqmActArea;
begin
  if Assigned(Status) then
    Status.Caption := _('Loading new split requets...');
  Application.ProcessMessages;

  for I := 0 to m_prodReqList.Count - 1 do
  begin
    SJob := nil;

    tHdr := TSCProdReqHdr(m_prodReqList[I]);
    if (tHdr.m_NewReqUniqId <> '') then
       SJob := FindProdReqLeadStep(tHdr.m_NewReqUniqId);
    if Assigned(SJob) then
    begin
      for J := 0 to tHdr.m_list.Count - 1 do
      begin
        tDet := tHdr.m_list[J];
        if (tDet.m_code = SJob.m_reqDet.m_code) then
        begin
          SJob.CopyDataFromJobToJob(tDet.m_list[0]);
          TSCProdSched(tDet.m_list[0]).m_fromPD := true;
          TSCProdSched(tDet.m_list[0]).m_status := CSS_new;
          SJob.SetRscCode('');
          if assigned(SJob.m_grp) then
          begin
            if assigned(TSCProdSched(tDet.m_list[0]).m_grp) then
            begin
              if p_sc.GetGrpNumSons(TSCProdSched(tDet.m_list[0]).m_grp.m_Id) = 1 then
              begin
                Group_id := TSCProdSched(tDet.m_list[0]).m_grp.m_Id;
                p_sc.RemoveJobFromGroup(TSCProdSched(tDet.m_list[0]).m_id, 'Job replaced by server update');
                DeleteGroup(Group_id);
              end
              else
                p_sc.RemoveJobFromGroup(TSCProdSched(tDet.m_list[0]).m_id, 'Job replaced by server update');
            end;

          //  if assigned(TSCProdSched(tDet.m_list[0]).m_grp) then
          //     p_sc.RemoveJobFromGroup(TSCProdSched(tDet.m_list[0]).m_id);
            p_sc.AddJobToGroup(TSCProdSched(tDet.m_list[0]).m_id, SJob.m_grp.m_id);
            p_sc.RemoveJobFromGroup(SJob.m_Id, 'Job replaced by server update');
          end;
          if assigned(SJob.m_srvPtr) then
          begin
            actArea := TMqmActArea(SJob.m_srvPtr);
            actArea.AddSchedObj(TSCProdSched(tDet.m_list[0]).m_Id);
            actArea.RemoveSchedObj(SJob.m_id);
          end;
          SJob.m_srvPtr := nil;
          SJob.m_isDeleted := true;
          SJob.m_deleteReason := 'LoadNewSplitRequets - Replaced by split request';
        end;
      end;
    end;
  end;

end;
//----------------------------------------------------------------------------//

procedure TMSchedCont.LoadIssuedMaterials(OnStart : boolean; qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText; ErrList: TStringList; UpdateNr : integer;
                                          WorkCentersHandledList, WorkCentersViewedList : String; ChangedReqInClause: string = '');
type
  RecaltWarehouse = record
    WKCNTER :  string;
    ALTERN_WC : string;
    NET_GROUP_CODE :  string;
    ISSUE_ITEM_TYPE : string;
    ALTERN_NET_GROUP_CODE : string;
  end;
  PReqaltWarehouse = ^RecaltWarehouse;
var
  tbInfoMat, tbInfoProdStep, tblAltWrkCntr, tbInfoaltWarehouse : ^TTblInfo;
  tbiCR: ^TTblInfo;
  Hdr, OldHdr:  TSCProdReqHdr;
  Det, OldDet:  TSCProdReqDet;
  MacSetupRec:  TMacSetup;
  IssuedArtRec: TIssuedArt;
  ArtType: TMQMArticleType;
  ArticleRec: TRecArticle;
  MT_preqNo, MT_orgStep, MT_wkCtrCode, MT_ResCatcode, MT_rsc, MT_MachSetupCode, MT_ProdCode, MT_ProdType,
  MT_MatBalance, MT_netGroupCode, MT_AlternativCode, MT_issueCode, MT_seqIssued, MT_reqQuant, MT_quantityIssue,
  MT_AllocQty, MT_settled, MT_highDateAlloc, MT_pstepId, MT_SearchMatByAlloc, PD_wkCtrCode : TField;
  OldHdrCode : String;
  PrgHour, PrgMinute, PrgSecond, PrgMilliSecond, PrgPrevSecond : Word;
  PrgIndex, PrgBlock, I, LIMRowCount : integer;
  altWarehouseList : TList;
  ReqaltWarehouse: PReqaltWarehouse;
  AlternativeExists : boolean;
  wkCtrCode, netGroupCode, WorkCentersList : String;

  Procedure WriteMaterials;
  begin
    MacSetupRec.WrkCtrCode       := trim(wkCtrCode);
    MacSetupRec.ResCat           := trim(MT_ResCatcode.AsString);
    MacSetupRec.ResCode          := trim(MT_rsc.AsString);
    MacSetupRec.MachineSetupCode := trim(MT_MachSetupCode.AsString);

    if (Trim(MacSetupRec.WrkCtrCode) <> '') or (Trim(MacSetupRec.ResCat) <> '') or (Trim(MacSetupRec.ResCode) <> '') then
      det.m_SkipAutoSeqMatTest := false
    else
      det.m_SkipAutoSeqMatTest := true;

    if MT_MatBalance.AsString = '1' then
    begin
      IssuedArtRec.Article := p_ArtTypeList.FindArticle('REQUEST',
                                               trim(MT_ProdCode.AsString));
    end else
    begin
      IssuedArtRec.Article := p_ArtTypeList.FindArticle(trim(MT_ProdType.AsString), trim(MT_ProdCode.AsString));
    end;

    if not assigned(IssuedArtRec.Article)
    and (Trim(MT_MatBalance.AsString) = '1') then
    begin
      with ArticleRec do
      begin
        ArticleCode := Trim(MT_ProdCode.AsString);
        Nature      := Ar_Material;
        AddResStart := Ar_No;
        AddResEnd   := Ar_No;
        Description := '';
      end;
      ArtType := p_ArtTypeList.FindartType('REQUEST');
      IssuedArtRec.Article := ArtType.SearchAndAddArticle(ArticleRec);
    end;

    if not assigned(IssuedArtRec.Article) then
    begin
      if (MT_MatBalance.AsString = '1') then
      begin
         ErrList.Add( _('Error loading issued materials') + ': ' +
                   _('Request') + ' ' + hdr.m_code + ' ' +
                   _('Step')    + ' ' + intToStr(det.m_code) + ' ' +
                   _('Product type')  + ' ' + MT_ProdType.AsString + ' ' +
                   _('Product') + ' ' + MT_ProdCode.AsString)
      end;
    end else
    begin
      if IssuedArtRec.Article.p_Nature =  Ar_NotBalance then
      begin
//              Next;
        exit;
      end;

      IssuedArtRec.NetGroup := IssuedArtRec.Article.AddNetGroup(netGroupCode);
      if not assigned(IssuedArtRec.NetGroup) then
      begin
        ErrList.Add( _('Error loading issued materials') + ': ' +
                     _('Request')   + ' ' + hdr.m_code + ' ' +
                     _('Step')      + ' ' + intToStr(det.m_code) + ' ' +
                     _('Product type')  + ' ' + MT_ProdType.AsString + ' ' +
                     _('Product')   + ' ' + MT_ProdCode.AsString + ' ' +
                     _('Net group') + ' ' + netGroupCode)
      end else
      begin
        IssuedArtRec.AternativeCode   := trim(MT_AlternativCode.AsString);
        IssuedArtRec.IssueTransType   := trim(MT_issueCode.AsString);
        IssuedArtRec.SeqIssuedTo      := trim(MT_seqIssued.AsString);
        if trim(MT_MatBalance.AsString) = '1' then
          IssuedArtRec.ArtOnBalance := aob_ReqNumber
        else if trim(MT_MatBalance.AsString) = '9' then
          IssuedArtRec.ArtOnBalance := aob_DisplayOnly
        else
          IssuedArtRec.ArtOnBalance := aob_Normal;

        IssuedArtRec.RequiredQty      := MT_reqQuant.AsFloat;
        IssuedArtRec.IssuedQty        := MT_quantityIssue.AsFloat;
        IssuedArtRec.AllocatedQty     := MT_AllocQty.AsFloat;
        if MT_settled.AsString = '1' then
          IssuedArtRec.ClosedIssue := true
        else
          IssuedArtRec.ClosedIssue := false;
        IssuedArtRec.HighAllocDate    := MT_highDateAlloc.AsDateTime;
        IssuedArtRec.StepId           := MT_pstepId.AsInteger;
        if MT_SearchMatByAlloc.AsString = '1' then
          IssuedArtRec.SearchMatByAlloc := true
        else
          IssuedArtRec.SearchMatByAlloc := false;

        IssuedArtRec.lastTimeBalanceChecked := 0;
        IssuedArtRec.HaveEnoughBalance      := false;
       // IssuedArtRec.MaterialAlreadyChecked := false;
        det.m_MacSetupList.AddIssuedArt(MacSetupRec, IssuedArtRec);
        if IssuedArtRec.Article.p_MaterialSchedule = MT_BaseLvl then
        begin
          det.m_ProdTypeBaseLvl := IssuedArtRec.Article.p_ArtType.p_ArtTypeCode;
          det.m_ProductBaseLvl := IssuedArtRec.Article.p_ArtCode;
        end
        else if IssuedArtRec.Article.p_MaterialSchedule = MT_SecondLvl then
        begin
          det.m_ProdTypeSecondLvl := IssuedArtRec.Article.p_ArtType.p_ArtTypeCode;
          det.m_ProductSecondLvl := IssuedArtRec.Article.p_ArtCode;
        end;
      end;
    end;
  end;

begin

  if WorkCentersHandledList = '' then
  begin
    if WorkCentersViewedList = '' then
      WorkCentersList := ''
    else
      WorkCentersList := WorkCentersViewedList;
  end
  else
  begin
    if WorkCentersViewedList = '' then
      WorkCentersList := WorkCentersHandledList
    else
      WorkCentersList := WorkCentersHandledList + ',' + WorkCentersViewedList;
  end;

  if WorkCentersList = '' then exit;

  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(2000);
    PrgBlock := trunc(2000/100) + 1;
    PrgIndex := 0;
    PrgPrevSecond := 0;
  end;

  if Assigned(Status) then
    Status.Caption := _('Reading steps issued materials from database...');
  Application.ProcessMessages;

  tbInfoMat := @tblInfo[tbl_material];
  tbInfoProdStep := @tblInfo[tbl_prod_step];
  tbiCR := @tblInfo[tbl_Req_Change];
  tbInfoaltWarehouse := @tblInfo[tbl_alt_warehouse];
  tblAltWrkCntr          := @tblInfo[tbl_wkc_alt];
  altWarehouseList := TList.Create;

  with qry do
  begin
    SQL.Clear;
    SQL.Add('select * from ' + tblAltWrkCntr.GetTableName);
    SQL.Add(' join ' + tbInfoaltWarehouse.GetTableName);   //SQL.Add(' left join ' + tbInfoaltWarehouse.GetTableName);
    SQL.Add(' on  ' + CreateFld(tblAltWrkCntr.pfx, fli_wkCtrCode) + '=' + CreateFld(tbInfoaltWarehouse.pfx, fli_wkCtrCode));
    SQL.Add(' and ' + CreateFld(tblAltWrkCntr.pfx, fli_AlterWC)   + '=' + CreateFld(tbInfoaltWarehouse.pfx, fli_AlterWC));
    SQL.Add(' and ' + CreateFld(tblAltWrkCntr.pfx, fli_Identifier)  + '=' + CreateFld(tbInfoaltWarehouse.pfx, fli_Identifier));
    SQL.Add(WHERE_IDF_Condition(CreateFld(tblAltWrkCntr.pfx, fli_Identifier)));
    SQL.Add(' AND exists (select 1 from ' + tbInfoaltWarehouse.GetTableName);
    SQL.Add(' where ' + tbInfoaltWarehouse.GetTableName + '.IDENTIFIER = ' + tblAltWrkCntr.GetTableName + '.AW_IDENTIFIER');
    SQL.Add(' AND ' + tbInfoaltWarehouse.GetTableName + '.WKCNTER = ' + tblAltWrkCntr.GetTableName + '.AW_WKCNTER )');
    SQL.Add(' order by ');
    SQL.Add(CreateFld(tblAltWrkCntr.pfx, fli_wkCtrCode));

    FetchOptions.RowsetSize := 5000;
    Open;

    while not EOF do
    begin
      new(ReqaltWarehouse);
      ReqaltWarehouse.WKCNTER           := Trim(qry.FieldByName(CreateFld(tblAltWrkCntr.pfx, fli_wkCtrCode)).AsString);
      ReqaltWarehouse.ALTERN_WC         := Trim(qry.FieldByName(CreateFld(tblAltWrkCntr.pfx, fli_AlterWC)).AsString);
      ReqaltWarehouse.NET_GROUP_CODE    := Trim(qry.FieldByName(CreateFld(tbInfoaltWarehouse.pfx, fli_netGroupCode)).AsString);
      ReqaltWarehouse.ISSUE_ITEM_TYPE   := Trim(qry.FieldByName(CreateFld(tbInfoaltWarehouse.pfx, fli_IssueItemType)).AsString);
      ReqaltWarehouse.ALTERN_NET_GROUP_CODE := Trim(qry.FieldByName(CreateFld(tbInfoaltWarehouse.pfx, fli_AWHAltern_Net_Group_Code)).AsString);
      altWarehouseList.add(ReqaltWarehouse);
      Next;
    end;

  end;

  with qry do
  begin

    SQL.Clear;
    SQL.Add('select MT.*,PD.' + CreateFld(tbInfoProdStep.pfx, fli_wkCtrCode) + ' ');
    SQL.Add('from ' + tbInfoMat.GetTableName + ' MT ');
    SQL.Add('join ' + tbInfoProdStep.GetTableName + ' PD ');
    SQL.Add('on PD.' + CreateFld(tbInfoProdStep.pfx, fli_Identifier) + ' = MT.' + CreateFld(tbInfoMat.pfx, fli_Identifier) + ' ');
    SQL.Add('and PD.' + CreateFld(tbInfoProdStep.pfx, fli_preqNo) + ' = MT.' + CreateFld(tbInfoMat.pfx, fli_preqNo) + ' ');
    SQL.Add('and PD.' + CreateFld(tbInfoProdStep.pfx, fli_pstepId) + ' = MT.' + CreateFld(tbInfoMat.pfx, fli_pstepId) + ' ');
    SQL.Add('and PD.' + CreateFld(tbInfoProdStep.pfx,fli_wkCtrCode) + ' IN ' + '(' + WorkCentersList + ') ');
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbInfoMat.pfx, fli_Identifier)));
    if not OnStart then
    begin
      if ChangedReqInClause <> '' then
        SQL.Add('AND MT.' + CreateFld(tbInfoMat.pfx, fli_preqNo) + ' IN (' + ChangedReqInClause + ') ')
      else
      begin
        SQL.Add('AND exists (');
        SQL.Add('select 1 from ' + tbiCR.GetTableName + ' CR ');
        SQL.Add('where CR.' + CreateFld(tbiCR.pfx, fli_updCode) + ' = ' + IntToStr(UpdateNr) + ' ');
        SQL.Add('and CR.' + CreateFld(tbiCR.pfx, fli_Identifier) + ' = MT.' + CreateFld(tbInfoMat.pfx, fli_Identifier));
        SQL.Add('and CR.' + CreateFld(tbiCR.pfx, fli_preqNo) + ' = MT.' + CreateFld(tbInfoMat.pfx, fli_preqNo));
        if (IniAppGlobals.External_Database_Update = '1') then
          SQL.Add(' and CR.' + CreateFld(tbiCR.pfx, fli_wkstCode) + '=''' + IniAppGlobals.WkstCode + '''');
        SQL.Add(') ');
      end;
    end;
    SQL.Add('order by ');
    SQL.Add(CreateFld(tbInfoMat.pfx, fli_preqNo) + ',');
    SQL.Add(CreateFld(tbInfoMat.pfx, fli_orgStep));

    FetchOptions.RowsetSize := 5000;
    Open;

    if Assigned(Status) then
      Status.Caption := _('Loading steps issued materials in memory...');
    Application.ProcessMessages;

    OldHdr := nil;
    OldHdrCode := '';
    OldDet := nil;

    MT_preqNo := FieldByName(CreateFld(tbInfoMat.pfx, fli_preqNo));
    MT_orgStep := qry.FieldByName(CreateFld(tbInfoMat.pfx, fli_orgStep));
    MT_wkCtrCode := FieldByName(CreateFld(tbInfoMat.pfx, fli_wkCtrCode));
    MT_ResCatcode := FieldByName(CreateFld(tbInfoMat.pfx, fli_ResCatcode));
    MT_rsc        := FieldByName(CreateFld(tbInfoMat.pfx, fli_rsc));
    MT_MachSetupCode := FieldByName(CreateFld(tbInfoMat.pfx, fli_MachSetupCode));
    MT_ProdCode      := FieldByName(CreateFld(tbInfoMat.pfx, fli_ProdCode));
    MT_ProdType      := FieldByName(CreateFld(tbInfoMat.pfx, fli_ProdType));
    MT_MatBalance    := FieldByName(CreateFld(tbInfoMat.pfx, fli_MatBalance));
    MT_netGroupCode  := FieldByName(CreateFld(tbInfoMat.pfx, fli_netGroupCode));
    MT_AlternativCode := FieldByName(CreateFld(tbInfoMat.pfx, fli_AlternativCode));
    MT_issueCode      := FieldByName(CreateFld(tbInfoMat.pfx, fli_issueCode));
    MT_seqIssued      := FieldByName(CreateFld(tbInfoMat.pfx, fli_seqIssued));
    MT_reqQuant       := FieldByName(CreateFld(tbInfoMat.pfx, fli_reqQuant));
    MT_quantityIssue  := FieldByName(CreateFld(tbInfoMat.pfx, fli_quantityIssue));
    MT_AllocQty       := FieldByName(CreateFld(tbInfoMat.pfx, fli_AllocQty));
    MT_settled        := FieldByName(CreateFld(tbInfoMat.pfx, fli_settled));
    MT_highDateAlloc  := FieldByName(CreateFld(tbInfoMat.pfx, fli_highDateAlloc));
    MT_pstepId        := FieldByName(CreateFld(tbInfoMat.pfx, fli_pstepId));
    MT_SearchMatByAlloc := FieldByName(CreateFld(tbInfoMat.pfx, fli_SearchMatByAlloc));
    PD_wkCtrCode        := qry.FieldByName(CreateFld(tbInfoProdStep.pfx, fli_wkCtrCode));

    LIMRowCount := 0;
    while not EOF do
    begin
      Inc(LIMRowCount);
      if LIMRowCount mod 200 = 0 then Application.ProcessMessages;

      if (OldHdrCode <> MT_preqNo.AsString) then
      begin
        OldHdrCode := MT_preqNo.AsString;
        hdr := FindHdrFromCode(self, MT_preqNo.AsString);
        OldHdr := hdr;
        OldDet := nil
      end else
        Hdr := OldHdr;

      if Assigned(hdr) then
      begin
        if not Assigned(OldDet)
        or (OldDet.m_code <> MT_orgStep.AsInteger) then
        begin
          Det := hdr.FindDetFromCode(MT_orgStep.AsInteger);
          OldDet := Det
        end else
          Det := OldDet;

        if Assigned(det) then
        begin
          while True do
          begin
            if (Trim(MT_wkCtrCode.AsString) <> '') or (Trim(MT_ResCatcode.AsString) <> '')
            or (Trim(MT_rsc.AsString) <> '') or (Trim(MT_MachSetupCode.AsString) <> '') then
            begin
              wkCtrCode := Trim(MT_wkCtrCode.AsString);
              netGroupCode := Trim(MT_netGroupCode.AsString);
              writeMaterials;
              break;
            end;
            AlternativeExists := false;
            for I := 0 to altWarehouseList.Count - 1 do
            begin
              if trim(PReqaltWarehouse(altWarehouseList[I]).WKCNTER) <>  trim(PD_wkCtrCode.AsString) then continue;
              if trim(PReqaltWarehouse(altWarehouseList[I]).ISSUE_ITEM_TYPE) <> trim(MT_ProdType.AsString) then continue;
              if trim(PReqaltWarehouse(altWarehouseList[I]).NET_GROUP_CODE) <> trim(MT_netGroupCode.AsString) then continue;
              AlternativeExists := true;
            end;
            if not AlternativeExists then
            begin
              wkCtrCode := Trim(MT_wkCtrCode.AsString);
              netGroupCode := Trim(MT_netGroupCode.AsString);
              writeMaterials;
              break;
            end;
            wkCtrCode := Trim(PD_wkCtrCode.AsString);
            netGroupCode := Trim(MT_netGroupCode.AsString);
            writeMaterials;
            for I := 0 to altWarehouseList.Count - 1 do
            begin
              if trim(PReqaltWarehouse(altWarehouseList[I]).WKCNTER) <>  trim(PD_wkCtrCode.AsString) then continue;
              if trim(PReqaltWarehouse(altWarehouseList[I]).ISSUE_ITEM_TYPE) = '' then
              begin
                wkCtrCode := trim(PReqaltWarehouse(altWarehouseList[I]).ALTERN_WC);
                netGroupCode := MT_netGroupCode.AsString;
                writeMaterials;
              end;
              if trim(PReqaltWarehouse(altWarehouseList[I]).ISSUE_ITEM_TYPE) <> trim(MT_ProdType.AsString) then continue;
              if trim(PReqaltWarehouse(altWarehouseList[I]).NET_GROUP_CODE) <> trim(MT_netGroupCode.AsString) then continue;
              if trim(PReqaltWarehouse(altWarehouseList[I]).ALTERN_NET_GROUP_CODE) = '' then continue;
              wkCtrCode := trim(PReqaltWarehouse(altWarehouseList[I]).ALTERN_WC);
              netGroupCode := trim(PReqaltWarehouse(altWarehouseList[I]).ALTERN_NET_GROUP_CODE);
              writeMaterials;
            end;
            break;
          end;
        end;
      end;

      Next;

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
          Application.ProcessMessages;
        end;
      end;

    end;

    Close;
//    if AllReq then
//      Transaction.Commit;
  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';

  for I := 0 to altWarehouseList.Count - 1 do
    dispose(PReqaltWarehouse(altWarehouseList[I]));
  altWarehouseList.Free;

  Application.ProcessMessages;

end;

//----------------------------------------------------------------------------//

procedure TMSchedCont.LoadProcessForGroupByPropertyRules(OnStart : boolean; qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText);
var
  tbInfoProc, tbInfoGroupByPropRules : ^TTblInfo;
  PrgIndex, PrgBlock, I : integer;
  PrgHour, PrgMinute, PrgSecond, PrgMilliSecond, PrgPrevSecond : Word;
  ProcessList, GroupCodelist : TStringList;
  CodeRule : string;
  RecPROCESS_GROUP_BY : PTPROCESS_GROUP_BY;
  IndexRule : Integer;
begin
  ProcessList := TStringList.Create;
  GroupCodelist := TStringList.Create;
  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(2000);
    PrgBlock := trunc(2000/100) + 1;
    PrgIndex := 0;
    PrgPrevSecond := 0;
  end;

  if Assigned(Status) then
    Status.Caption := _('Reading processes for grouped by propery rules ...');
  Application.ProcessMessages;

  tbInfoProc := @tblInfo[tbl_Proc];

  with qry do
  begin
    SQL.Clear;
    SQL.Add('select * ');
    SQL.Add('from ' + tbInfoProc.GetTableName);
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbInfoProc.pfx, fli_Identifier)));
    Open;
    if Assigned(ProgBar) then
      ProgBar.SetMax(2000);
    while not EOF do
    begin
      if DBAppGlobals.MCM_App then
      begin
        if Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_RuleForGroupingMCM)).AsString) <> '' then
        begin
          ProcessList.Add(Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_wkcProc)).AsString));
          GroupCodelist.Add(Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_RuleForGroupingMCM)).AsString));
        end;
      end
      else
      begin
        if Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_RuleForGroupingMQM)).AsString) <> '' then
        begin
          ProcessList.Add(Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_wkcProc)).AsString));
          GroupCodelist.Add(Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_RuleForGroupingMQM)).AsString));
        end;
      end;

      if Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_Alternative_um_handled)).AsString) = '3' then
         m_UmAlternative_UserPackagingList.Add(Trim(FieldByName(CreateFld(tbInfoProc.pfx, fli_wkcProc)).AsString));

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;

      Application.ProcessMessages;

      next;
    end;
    close;
  end;

  if ProcessList.Count = 0 then
  begin
    ProcessList.free;
    GroupCodelist.free;
    exit;
  end;

  tbInfoGroupByPropRules := @tblInfo[tbl_GroupByPropertyRules];

  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(2000);
    PrgBlock := trunc(2000/100) + 1;
    PrgIndex := 0;
    PrgPrevSecond := 0;
  end;

  with qry do
  begin
    SQL.Clear;
    SQL.Add('select * ');
    SQL.Add('from ' + tbInfoGroupByPropRules.GetTableName);
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbInfoGroupByPropRules.pfx, fli_Identifier)));
    Open;
    if Assigned(ProgBar) then
      ProgBar.SetMax(2000);
    while not EOF do
    begin
      CodeRule := (Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_CodeRuleForGrouping)).AsString));

      for I := 0 to GroupCodelist.Count - 1 do
      begin
        if CodeRule <> GroupCodelist.Strings[I] then continue;
        new(RecPROCESS_GROUP_BY);
        RecPROCESS_GROUP_BY.Process := ProcessList.Strings[I];
        RecPROCESS_GROUP_BY.PropCodeForRule[0] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode1)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[0] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[0]);
        RecPROCESS_GROUP_BY.PropCodeForRule[1] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode2)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[1] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[1]);
        RecPROCESS_GROUP_BY.PropCodeForRule[2] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode3)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[2] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[2]);
        RecPROCESS_GROUP_BY.PropCodeForRule[3] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode4)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[3] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[3]);
        RecPROCESS_GROUP_BY.PropCodeForRule[4] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode5)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[4] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[4]);
        RecPROCESS_GROUP_BY.PropCodeForRule[5] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode6)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[5] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[5]);
        RecPROCESS_GROUP_BY.PropCodeForRule[6] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode7)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[6] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[6]);
        RecPROCESS_GROUP_BY.PropCodeForRule[7] := Trim(FieldByName(CreateFld(tbInfoGroupByPropRules.pfx, fli_PropertyCode8)).AsString);
        RecPROCESS_GROUP_BY.PropIdForRule[7] := GetIdFromCode(RecPROCESS_GROUP_BY.PropCodeForRule[7]);
        m_ProcessGroupedBy.Add(RecPROCESS_GROUP_BY);
      end;

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;

      Application.ProcessMessages;

      next;
    end;
    close;
  end;

  ProcessList.free;
  GroupCodelist.free;
  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';
  Application.ProcessMessages;

end;

