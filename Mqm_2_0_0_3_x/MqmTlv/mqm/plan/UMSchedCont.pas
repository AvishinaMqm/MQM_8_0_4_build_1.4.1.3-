function TMSchedCont.SearchProdReqLeadStepInSplitList(ReqHdr : TSCProdReqHdr) : boolean;
var
  I : Integer;
  tHdrLead : TSCProdReqHdr;
begin
  Result := false;
  for I := 0 to m_ProdReqLeadStepSplitList.Count - 1 do
  begin
    tHdrLead := TSCProdReqHdr(m_ProdReqLeadStepSplitList[I]);
    if (ReqHdr.m_code = tHdrLead.m_code) and (ReqHdr.m_LeadStepForSplit = tHdrLead.m_LeadStepForSplit) then
    begin
      Result := true;
      exit
    end;
  end;
end;

