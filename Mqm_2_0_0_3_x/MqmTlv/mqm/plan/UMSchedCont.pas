                                        GetFldSupport(id, BinDateColumn,temp,dataType,false);
                                        TempDateTime2 := temp;
                                      end;
                                      if (TempDateTime = 0) or (TempDateTime2 = 0) or ((TempDateTime - TempDateTime2) = 0) then
