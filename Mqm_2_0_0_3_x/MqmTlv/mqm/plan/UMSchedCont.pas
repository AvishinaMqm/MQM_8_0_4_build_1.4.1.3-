      begin
        SQL.Add('AND exists (');
        SQL.Add('Select 1 from ' + tbiCR.GetTableName + ' CR ');
        SQL.Add(' WHERE CR.' + CreateFld(tbiCR.pfx, fli_updCode) + ' = ' + IntToStr(UpdateNr) + ' ');
        SQL.Add(' and CR.' + CreateFld(tbiCR.pfx, fli_Identifier) + ' = PP.'  + CreateFld(tbInfoProp.pfx, fli_Identifier));
        SQL.Add(' and CR.' + CreateFld(tbiCR.pfx, fli_preqNo) + ' = PP.'  + CreateFld(tbInfoProp.pfx, fli_preqNo));
