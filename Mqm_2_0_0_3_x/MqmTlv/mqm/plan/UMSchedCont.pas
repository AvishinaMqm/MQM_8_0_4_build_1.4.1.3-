function FindGroupFromCode(sc: TMSchedCont; grpCode: integer): TSCProdGroup;
var
  i: integer;
begin
  Result := nil;

  for i := 0 to sc.m_grpList.Count-1 do
    if TSCProdGroup(sc.m_grpList[i]).m_code = grpCode then
    begin
      Result := TSCProdGroup(sc.m_grpList[i]);
      exit
    end
end;

