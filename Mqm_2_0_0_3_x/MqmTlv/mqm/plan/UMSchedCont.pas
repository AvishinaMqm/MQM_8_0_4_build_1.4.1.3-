function TMSchedCont.GetMaxStartingDateAutoSeq(id: TSchedID) : TDateTime;
var
  job : TSCProdSched;
  sc:  TSCSchedOnPlan;
  grp : TSCProdGroup;
  I   : Integer;
  dt  : TDateTime;
begin
  Result := 0;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    job := grp.m_list[0];
    Result := job.m_reqDet.p_MaxStartingDateAutoSeq;
    for i := 1 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      if Result < job.m_reqDet.p_MaxStartingDateAutoSeq then
        Result := job.m_reqDet.p_MaxStartingDateAutoSeq
    end;
  end
  else
  begin
    job := TSCProdSched(sc);
    Result := job.m_reqDet.p_MaxStartingDateAutoSeq
  end;

end;

