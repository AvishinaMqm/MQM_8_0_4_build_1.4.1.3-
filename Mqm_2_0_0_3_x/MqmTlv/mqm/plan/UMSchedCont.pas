function TMSchedCont.GetPlanInfo(id: TSchedID; var planInfo: TSQplanInfo): boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
begin
  Result := true;
  planInfo.isGroup := false;
  planInfo.VisibleInBin := CSB_Normal;
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  planInfo.isOnPlan := Assigned(sc.m_srvPtr);
  planInfo.is_MaterialSched := false;

  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    if Assigned(job.m_mtr) then
    begin
      planInfo.is_MaterialSched := true;
      exit;
    end
    else
      planInfo.is_MaterialSched := false;
    planInfo.isDeleted  := job.m_isDeleted;
    if planInfo.isDeleted then
    begin
      Result := false;
     // exit;
    end;
    planInfo.GroupAutomaticInternalSortingSequence := job.m_GroupAutomaticInternalSortingSequence;
    planInfo.SchedStarttOfJobInContGroup           := job.p_SchedStartOfJobInContGroup;
    planInfo.SchedEndtOfJobInContGroup           := job.p_SchedEndOfJobInContGroup;
    planInfo.SplitFromMcmToMqmAndAlterWorkCenter := job.m_reqDet.m_SplitFromMcmToMqmAndAlterWorkCenter;
    planInfo.CurveOccToOcc := job.p_CurveCodeByOccToOcc;
    planInfo.GrpSequence := job.P_Grp_Sequence;
    planInfo.StartProgressDate := job.m_PrgSt;
    planInfo.CurrentProgressDate := job.m_PrgCurDt;
    planInfo.EndProgressDate := job.m_PrgEd;
    planInfo.ProdUM      := job.m_reqDet.m_hdr.m_prodUMCode;
    planInfo.BatchSizePerStep := job.m_reqDet.m_BatchSizePerStep;
    planInfo.MinBatchSize     := job.m_reqDet.m_MinBatchSize;
    planInfo.OptimumBatchSize := job.m_reqDet.m_OptimumBatchSize;
    planInfo.MaxBatchSize     := job.m_reqDet.m_MaxBatchSize;
    PlanInfo.GenericPlan      := job.m_reqDet.m_GenericPlan = '1';
    planInfo.GenericPlanWC         := job.m_GenericPlanWC;
    planInfo.GenericPlanDur        := job.m_GenericPlanDur;
    planInfo.GenericPlanLeadTime   := job.m_GenericPlanLeadTime;
    planInfo.GenericPlanMachineNum := job.m_GenericPlanMachineNum;
    planInfo.GenericPlanStartDate  := job.m_GenericPlanStartDate;
    planInfo.GenericPlanEndDate    := job.m_GenericPlanEndDate;

    planInfo.IgnorExeTimeWhenGrp := job.P_IgnorExeTimeWhenGrp;
    planInfo.VisibleInBin := job.m_VisbleInBin;
    planInfo.FrcDelDate := job.m_reqDet.m_hdr.m_FrcDelDate;
    planInfo.isGroup    := false;
    planInfo.stepType   := job.m_reqDet.m_stepType;
    planInfo.Is_batch_ContinuesTime := job.m_reqDet.m_batch_ContinuesTime;
    planInfo.Is_Continues_Parallel := job.m_reqDet.m_Continues_Parallel;
    if (job.m_PlanWkCtrCode <> '') and (job.m_PlanWkCtrCode <> ' ') then
      planInfo.ChangedWC  := true
    else
      planInfo.ChangedWC  := false;
    planInfo.TmgDescr   := job.m_TimeDescr;
    planInfo.MSC        := job.m_MachSetupCode;
    planInfo.prodUMCode := job.m_reqDet.m_hdr.m_prodUMCode;
    if job.m_reqDet.m_SplitAllow = CSB_No then
      planInfo.SplitAllow    := false
    else
      planInfo.SplitAllow    := true;
  end else
  begin
    grp := TSCProdGroup(sc);

    planInfo.isDeleted := grp.m_isDeleted;
    if grp.m_isDeleted then
    begin
      Result := false;
      exit;
    end;

    planInfo.isGroup   := true;
    planInfo.BatchSizePerStep := false;

    job := TSCProdSched(grp.m_list[0]);

    planInfo.CurveOccToOcc := job.p_CurveCodeByOccToOcc;
    planInfo.stepType   := job.m_reqDet.m_stepType;
    planInfo.TmgDescr   := job.m_TimeDescr;
    planInfo.MSC        := job.m_MachSetupCode;
    planInfo.prodUMCode := job.m_reqDet.m_hdr.m_prodUMCode;
    PlanInfo.GenericPlan := job.m_reqDet.m_GenericPlan = '1';
    planInfo.GenericPlanWC         := job.m_GenericPlanWC;
    planInfo.GenericPlanDur        := job.m_GenericPlanDur;
    planInfo.GenericPlanLeadTime   := job.m_GenericPlanLeadTime;
    planInfo.GenericPlanMachineNum := job.m_GenericPlanMachineNum;
    planInfo.GenericPlanStartDate  := job.m_GenericPlanStartDate;
    planInfo.GenericPlanEndDate    := job.m_GenericPlanEndDate;
    planInfo.MinBatchSize  := job.m_reqDet.m_MinBatchSize;
    planInfo.Is_batch_ContinuesTime := job.m_reqDet.m_batch_ContinuesTime;
    planInfo.Is_Continues_Parallel := job.m_reqDet.m_Continues_Parallel;
    if job.m_reqDet.m_SplitAllow = CSB_No then
      planInfo.SplitAllow    := false
    else
      planInfo.SplitAllow    := true;

    if job.m_reqDet.m_stepType = CST_batch then
    begin
      for i := 0 to grp.m_list.Count-1 do
      begin
        if TSCProdSched(grp.m_list[i]).m_VisbleInBin > planInfo.VisibleInBin then
           planInfo.VisibleInBin := TSCProdSched(grp.m_list[i]).m_VisbleInBin;
      end
    end else
    begin
      planInfo.TmgDescr := TSCProdSched(grp.m_list[0]).m_TimeDescr;
      planInfo.MSC      := TSCProdSched(grp.m_list[0]).m_MachSetupCode;

      for i := 0 to grp.m_list.Count - 1 do
      begin
        if planInfo.VisibleInBin < TSCProdSched(grp.m_list[i]).m_VisbleInBin then
          planInfo.VisibleInBin := TSCProdSched(grp.m_list[i]).m_VisbleInBin;
      end
    end
  end;

  planInfo.AutoSeqMaxBefore := sc.m_AutoSeqMaxBefore;
  planInfo.startDate  := sc.p_schedStart;
  planInfo.endDate    := sc.p_schedEnd;
  planInfo.LastScheduleChanged := sc.p_LastScheudleChange;
  planInfo.exeMin     := sc.p_exeMin;
  planInfo.supMinBase := sc.p_supMinBase;
  planInfo.supMinReal := sc.p_supMinReal;
  planInfo.supMinOvlp := sc.p_supMinOvlp;
  planInfo.quant      := sc.p_quantSched;
  planInfo.FinQuant   := sc.p_FinalQuant;

  Result := true
end;

