function TMSchedCont.EnterServingCodeToList(Code : string; ReqHdr : TSCProdReqHdr) : TList;
var
  i, J: integer;
  Multiplier, NumberOfEntries, LowestHighestValue : integer;
  PServingCode : PTServingCode;
  List : TList;
  ExistInList, ServingCodeExists : boolean;
  TmpReqHdr : TSCProdReqHdr;
begin
  NumberOfEntries := m_ServingCodeList.Count;
  if NumberOfEntries = 0 then
  begin
    new(PServingCode);
    PServingCode.code := code;
    PServingCode.List := TList.Create;
    PServingCode.List.Add(ReqHdr);
    m_ServingCodeList.Add(PServingCode);
    Result := PServingCode.List;
    Exit
  end;
//  else
//    m_ServingCodeList.Sort(ServingCode);

 { Multiplier := 1;
  while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
  i := Multiplier - 1;

  while (Multiplier > 0) do
  begin

    if (i < NumberOfEntries)
      and (PTServingCode(m_ServingCodeList[i]).code = Code) then break;

    Multiplier := trunc(Multiplier / 2);

    if  (i < NumberOfEntries)
     and (PTServingCode(m_ServingCodeList[i]).code < Code) then
      i := i + Multiplier
    else
      i := i - Multiplier;

  end;   }

  LowestHighestValue := NumberOfEntries;
  ServingCodeExists := false;
  Multiplier := 1;
  while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
  I := Multiplier - 1;
  while (Multiplier > 0) do
  begin
    Multiplier := trunc(Multiplier / 2);
    if (i >= NumberOfEntries) then
    begin
      i := i - Multiplier;
      Continue;
    end;
    if (PTServingCode(m_ServingCodeList[i]).code < Code) then
    begin
      i := i + Multiplier;
      Continue;
    end;
    if (PTServingCode(m_ServingCodeList[i]).code > Code) then
    begin
      if I < LowestHighestValue then LowestHighestValue := I;
      i := i - Multiplier;
      Continue;
    end;
    ServingCodeExists := true;
    break;
  end;

//  if Multiplier > 0 then
  if ServingCodeExists then
  begin
    List := PTServingCode(m_ServingCodeList[i]).List;
    ExistInList := false;
    for J := 0 to List.Count - 1 do
    begin
      TmpReqHdr := TSCProdReqHdr(List[J]);
      if ReqHdr = TmpReqHdr then
      begin
        ExistInList := true;
        break
      end;
    end;
    if not ExistInList then
      PTServingCode(m_ServingCodeList[i]).List.Add(ReqHdr);
    Result := PTServingCode(m_ServingCodeList[i]).List;
  end
  else
  begin
    new(PServingCode);
    PServingCode.code := code;
    PServingCode.List := TList.Create;
    PServingCode.List.Add(ReqHdr);
//    m_ServingCodeList.Add(PServingCode);
    m_ServingCodeList.insert(LowestHighestValue, PServingCode);
    Result := PServingCode.List;
  end;
end;

