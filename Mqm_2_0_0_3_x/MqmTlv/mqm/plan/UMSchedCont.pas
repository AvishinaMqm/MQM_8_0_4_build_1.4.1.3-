function TMSchedCont.GetIdTimes(id: TSchedId; WCCode, ResCatCode, ResCode : string; STOriginalTime : boolean; var Duration : double; var Setup : double; WithComponents : boolean) : boolean;
var
  WcVal, ProcessVal: variant;
  dataType: CBinColValType;
  Res : TMqmRes;
  TimeList : TList;
  I : Integer;
  NewDuration, NewSetup, NewJobSetup : double;
  ByWc, ByCategory : boolean;
  StepInfo: TSQStepInfo;
  IniQty, QtyToSched: double;
  idSon: TSchedId;
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  SumAllJobsInGroup : boolean;
  SetupGroup, DurationGroup : double;
  IsSpeedChanged, IsSetUpChanged, IsJobSetUpChanged : boolean;
begin

  if IsGroup(Id) then
  begin
    idSon := p_sc.GetGrpSon(id, 0);
    sc := TSCSchedOnPlan(m_codeList[idSon]);
    job := TSCProdSched(sc);
    SumAllJobsInGroup := false;
    if (job.m_reqDet.m_stepType = CST_Continuous)
//       and (not job.m_reqDet.m_batch_ContinuesTime) Eran - 12/12/2025 - Also in H , the group time is a sum of all jobs
       and (not job.m_reqDet.m_Continues_Parallel) then
          SumAllJobsInGroup := true;
    SetupGroup := 0;
    DurationGroup := 0;
    for I := 0 to GetGrpNumSons(id)-1 do
    begin
      idSon := p_sc.GetGrpSon(Id, I);
      GetIdTimes(idSon, WCCode, ResCatCode, ResCode, STOriginalTime, Duration, Setup, WithComponents);
      if SetupGroup < Setup then
        SetupGroup := Setup;
      if SumAllJobsInGroup then
        DurationGroup := DurationGroup + Duration
      else
       if DurationGroup < Duration then
        DurationGroup := Duration;
    end;
    Setup := SetupGroup;
    Duration := DurationGroup;
    exit;
  end;

//  ResCatCode := '';
  Duration := 0;
  Setup    := 0;
  ByWc       := false;
  ByCategory := false;

  QtyToSched := GetQtyToSched(id);
  IniQty     := GetIniQty(id);

  if (ResCode = '') and Assigned(GetExtLinkPtr(id)) then
  begin
    Res := TMqmRes(TMqmActArea(p_sc.getExtLinkPtr(id)).p_res);
    ResCode := Res.p_ResCode;
    ResCatCode := '';
    WCCode := '';
    if Assigned(Res) then
    begin
      ResCatCode := Res.p_ResCat.p_ResCatCode;
      WCCode      := TMqmWrkCtr(Res.p_WrkCtr).p_WrkCtrCode;
    end;
  end;

  // Eran decided o 01/2021 when preparing the learning curve for Bhilwara that
  // there can be only one work center process to an id and there is no reason to compare it
  TimeList := p_sc.GetProdReqDetTimeList(id);

  for I := 0 to TimeList.count - 1 do
  begin
    if (PTRecTiming(TimeList[I]).resCode = ResCode) then
    begin
     Duration := PTRecTiming(TimeList[I]).exeTime;
     Setup    := PTRecTiming(TimeList[I]).supTime;
     break
    end;

    if (PTRecTiming(TimeList[I]).resCode = '') and (PTRecTiming(TimeList[I]).resCat = ResCatCode) and
       (PTRecTiming(TimeList[I]).wkcCode = WCCode) then
    begin
     Duration := PTRecTiming(TimeList[I]).exeTime;
     Setup    := PTRecTiming(TimeList[I]).supTime;
     ByCategory := true;
     continue
    end;

    if ByCategory then continue;

    if (PTRecTiming(TimeList[I]).resCode = '') and (PTRecTiming(TimeList[I]).resCat = '') and
       (PTRecTiming(TimeList[I]).wkcCode = WCCode) then
    begin
     Duration := PTRecTiming(TimeList[I]).exeTime;
     Setup    := PTRecTiming(TimeList[I]).supTime;
     ByWc := true;
     continue
    end;

    if ByWc then continue;

    if (PTRecTiming(TimeList[I]).resCode = '') and (PTRecTiming(TimeList[I]).resCat = '') and
       (PTRecTiming(TimeList[I]).wkcCode = '') then
    begin
     Duration := PTRecTiming(TimeList[I]).exeTime;
     Setup    := PTRecTiming(TimeList[I]).supTime;
     continue
    end;

  end;

  if not STOriginalTime then
  begin
    NewDuration := -1;
    NewSetup    := -1;
    NewJobSetup    := -1;
    if GetNewTimeIfSpeedChanged(id, NewDuration, NewSetup, NewJobSetup, IsSpeedChanged, IsSetUpChanged, IsJobSetUpChanged) then
    begin
      if IsSpeedChanged then
        Duration := NewDuration;
    end;
    if IniQty = 0 then
      Duration := 0
    else
    begin
      sc := TSCSchedOnPlan(m_codeList[id]);
      job := TSCProdSched(sc);
      if (job.m_reqDet.m_stepType = CST_Continuous) then
        Duration := Duration * QtyToSched / IniQty;
    end;

    if WithComponents then
    begin
      if Assigned(GetExtLinkPtr(id)) then
        Duration := Duration / GetJobComponents(Id, true);
    end;

    if IsSetUpChanged then
       Setup := NewSetup;

    if IsJobSetUpChanged then
       Setup := NewSetup

  end;
end;

