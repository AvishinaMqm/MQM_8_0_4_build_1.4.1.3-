function TMSchedCont.GetNextStepToSched(ProdReq: string; StepId: integer; var StepInfo: TSQStepInfo): boolean;
var
  tHdr: TSCProdReqHdr;
  tDet: TSCProdReqDet;
begin
  Result := false;
  tHdr := FindHdrFromCode(self, ProdReq);
  if not Assigned(tHdr) or not Assigned(tHdr.m_list) then exit;

  tDet := tHdr.GetNextStepToSched(StepId);

  if not Assigned(tDet) then
    exit;

  with tDet do
  begin
    StepInfo.StepNo     := m_code;
    StepInfo.stepType   := m_stepType;
//    StepInfo.Wrkst      := GetWorkStationForWc(m_planWkctr, true);
    StepInfo.wkCtrCode  := m_planWkctr;
    StepInfo.StepClosed := m_stepClosed;
    StepInfo.InitQty    := m_quantInit;
    StepInfo.planStart  := m_planStart;
    StepInfo.LowStart   := m_lowStartTimeLimit;
    StepInfo.planEnd    := m_planEnd;
    StepInfo.HighEnd    := m_highEndTimeLimit;
    StepInfo.NumResPlan := m_planNumRes;
    StepInfo.connTypeToPrevious := StrToInt(m_connTypeToPrevious);
    StepInfo.ProdUM     := tHdr.m_prodUMCode;
    StepInfo.FirstId    := TSCProdSched(tDet.m_list[0]).m_Id;
    StepInfo.ReqDet     := tDet
  end;

  Result := true;
end;

