procedure TMSchedCont.printReportHierarchic(fileOut: string);
var
  strl:               TStringList;
  hdr, det, job, grp: integer;
  tHdr:               TSCProdReqHdr;
  tDet:               TSCProdReqDet;
  tJob:               TSCProdSched;
  tGrp:               TSCProdGroup;
begin
  strl := TStringList.Create;

  // add the production schedule description
  for hdr := 0 to m_prodReqList.Count-1 do
  begin
    tHdr := TSCProdReqHdr(m_prodReqList[hdr]);
    strl.Add(tHdr.GetStrId);

    for det := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[det]);
      strl.Add('    ' + tDet.GetStrId);

      for job := 0 to tDet.m_list.Count-1 do
      begin
        tJob := TSCProdSched(tDet.m_list[job]);
        strl.Add('        ' + tJob.GetStrId)
      end
    end
  end;

  strl.Add('');
  strl.Add('--------------------------');
  strl.Add('');

  // add the groups description
  for grp := 0 to m_grpList.Count-1 do
  begin
    tGrp := TSCProdGroup(m_grpList[grp]);
    strl.Add(_('group:') + ' ' + IntToStr(tGrp.m_code));

    for job := 0 to tGrp.m_list.Count-1 do
    begin
      tJob := TSCProdSched(tGrp.m_list[job]);
      strl.Add('    ' + tJob.GetStrId);
    end
  end;

  strl.SaveToFile(fileOut);
  strl.Free
end;

