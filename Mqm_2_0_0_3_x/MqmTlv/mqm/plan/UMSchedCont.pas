  function CheckIfActiveJobsExist(tDet: TSCProdReqDet; var countRealJobs : Integer; var PosFirstRealJob : Integer) : boolean;
  var
    I : Integer;
    tJob : TSCProdSched;
  begin
    Result := false;
    countRealJobs := 0;
    PosFirstRealJob := 0;
    for I := 0 to tDet.m_list.Count - 1 do
    begin
      tJob := TSCProdSched(tDet.m_list[I]);
      if tJob.m_isDeleted then
      begin
        tJob.m_fromPD         := true;
        tJob.m_status         := CSS_none;
        tJob.m_subLinRscId    := 0;
        tJob.m_reprocNo       := 0;
        tJob.p_SetStepType    := '0';
        tJob.m_comment        := '';
        tJob.p_WorkCenter     := '';
        tJob.p_Process        := '';
        tJob.p_quantSched     := 0;
        tJob.p_exeMin         := 0;
        tJob.p_supMinBase     := 0;
        tJob.p_supMinReal     := 0;
        tJob.p_supMinOvlp     := 0;
        tJob.m_fwdConnSubStp  := -2;
        tJob.m_fwdConnReProcs := -2;
        tJob.m_bkwConnSubStp  := -2;
        tJob.m_bkwConnReProcs := -2;
        tJob.m_TimeDescr      := '';
        tJob.m_MachSetupCode  := '';
        tJob.m_PrgSt          := 0;
        tJob.m_PrgCurDt       := 0;
        tJob.m_PrgEd          := 0;
        tJob.m_PrgQty         := 0;
        tJob.m_PrgStartingQty := 0;
        tJob.m_PrgRemTime     := -1;
        tJob.m_ProgType       := '';
        tJob.m_ProgRsc        := '';
        tJob.m_PrgStHost      := 0;
        tJob.m_PrgCurDtHost   := 0;
        tJob.m_PrgEdHost      := 0;
        tJob.m_PrgQtyHost     := 0;
        tJob.m_PrgRemTimeHost := -1;
        tJob.m_ProgTypeHost   := '';
        tJob.m_ProgRscHost    := '';
        tJob.p_quantManualChg := 0;
        tJob.m_MsgFromHost := CSH_NO_Chg;
        tJob.p_NewSetup  := -1;
        Continue
      end
      else
      begin
        if not Result then PosFirstRealJob := I;
        Result := true;
        Inc(countRealJobs);
      end;
    end;
  end;

