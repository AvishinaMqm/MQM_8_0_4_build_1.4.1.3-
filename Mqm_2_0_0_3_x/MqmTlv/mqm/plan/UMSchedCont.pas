procedure TMSchedCont.DeletedNotNeededJobs;
var
  ph, pd, PS : integer;
  tbiPS:      ^TTblInfo;
  tHdr:       TSCProdReqHdr;
  tDet:       TSCProdReqDet;
  tJob:       TSCProdSched;
  TotalStepQty : double;
  ProgressExists : boolean;
begin
  for ph := 0 to m_prodReqList.Count-1 do
  begin
    tHdr := TSCProdReqHdr(m_prodReqList[ph]);

    for pd := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[pd]);
      Application.ProcessMessages;
      TotalStepQty := 0;

      ProgressExists := false;
      for ps := 0 to tDet.m_list.Count - 1 do
      begin
        tJob := TSCProdSched(tDet.m_list[ps]);
        if tJob.m_isDeleted then
          continue;
        if (CProgress(p_sc.IsProgressed(tJob.m_id)) <> prg_none) then
        begin
          TotalStepQty := TotalStepQty + tJob.m_PrgQty;
          ProgressExists := true;
          continue;
        end;
        if (tJob.m_code >= 900) then
        begin
          tJob.m_isDeleted := true;
          tJob.m_deleteReason := 'DeletedNotNeededJobs - code>=900';
        end;
      end;

      if (TotalStepQty > tDet.m_quantInit) or (tDet.m_stepClosed) then
      begin
        for ps := 0 to tDet.m_list.Count - 1 do
        begin
          tJob := TSCProdSched(tDet.m_list[ps]);
          if tJob.m_isDeleted then
            continue;
          if ProgressExists and (tJob.m_code = 0) then // Substep 0 must stay
            continue;
          if (CProgress(p_sc.IsProgressed(tJob.m_id)) = prg_none) then
          begin
            tJob.m_isDeleted := true;
            tJob.m_deleteReason := 'DeletedNotNeededJobs - no progress';
          end;
        end;
      end;

    end
  end;

end;

