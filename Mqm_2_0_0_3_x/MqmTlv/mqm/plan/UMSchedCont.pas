procedure TMSchedCont.UpdateSharedData(Request : string; Step : integer; SubStep : Integer; Reprocess : Integer; comment : string);
var
  tHdr : TSCProdReqHdr;
  tDet : TSCProdReqDet;
  tJob : TSCProdSched;
  Group : TSCProdGroup;
  I : Integer;
begin
  tHdr := FindHdrFromCode(self, Request);
  if not assigned(tHdr) then
    Exit;
  tDet := tHdr.FindDetFromCode(Step);
  if not assigned(tDet) then
    Exit;
  tjob := tDet.FindJobFromCode(SubStep , Reprocess);

  if assigned(tjob) then
  begin
    tjob.m_SharedComment := comment;
    if assigned(tjob.m_grp) then
    begin
      Group := tjob.m_grp;
      if Assigned(Group) then
      begin
        Group.m_SharedComment := Comment;
        for I := 0 to Group.m_List.Count - 1 do
          TSCProdSched(Group.m_list[I]).m_SharedComment := Comment;
      end;
    end;
  end;

end;

