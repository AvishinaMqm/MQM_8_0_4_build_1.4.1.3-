function TMSchedCont.loopAllJobsSchedType(OnRefreshStart : boolean) : boolean;
var
  Ph, Pd, Ps : integer;
  Hdr : TSCProdReqHdr;
  job : TSCProdSched;
  Det : TSCProdReqDet;
begin
  for Ph := 0 to m_prodReqList.Count-1 do
  begin
    Hdr := TSCProdReqHdr(m_prodReqList[Ph]);
    if Assigned(Hdr) then
    begin
      for Pd := 0 to Hdr.m_list.Count - 1 do
      begin
        Det := TSCProdReqDet(Hdr.m_list[pd]);
        for Ps := 0 to Det.m_list.Count -1 do
        begin
          Job := TSCProdSched(Det.m_list[Ps]);
          if OnRefreshStart then
          begin
            Job.m_schedTypeBackup := Job.p_GetStepType;
          end
          else
          begin
            if (not Job.m_fromPD) and (IsProgressed(job.m_Id) = prg_none) and (Job.p_rscCode <> '') and (Job.p_GetStepType = '0') then
            begin
              if Job.m_schedTypeBackup <> Job.p_GetStepType then
              begin
                Job.p_SetStepType := Job.m_schedTypeBackup;
                m_LogStr.Add('----------------------------------------');
                m_LogStr.Add(' XXXXXXXXXXXXXXXXXX   Sched Type Fixed on refresh from 0 type  XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX ');
                m_LogStr.Add('WkstCode : ' + IniAppGlobals.WkstCode);
                m_LogStr.Add('Req : ' + job.m_reqDet.m_hdr.m_code);
                m_LogStr.Add('Step : ' + IntToStr(job.m_reqDet.m_code));
                m_LogStr.Add('Job.p_GetStepType : ' + Job.p_GetStepType);
                m_LogStr.Add('Start sched : ' + DateTimeToStr(Job.p_schedStart));
                m_LogStr.Add('date and time ' + DateTimeToStr(NOW));
                m_LogStr.Add('----------------------------------------');
              end;
            end;
          end;

        end;
      end;
    end;
  end;
end;

