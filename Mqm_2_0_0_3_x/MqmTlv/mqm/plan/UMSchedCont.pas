function TMSchedCont.CheckAllowMovingJobsInServingGroup(Id : TschedId; var TestedServingCodeIdsList : TMSchedList;
           MoveInitialObjsAlwd, MoveFinalObjsAlwd, MoveLevel1ObjsAlwd, MoveLevel2ObjsAlwd, MoveLevel3ObjsAlwd,
           MoveLevel4ObjsAlwd, MoveLevel5ObjsAlwd : integer;
           var AtLeastOneScheduled : boolean; var PlantCode : string; var OtherIdsAreInTheFamily : boolean) : boolean;
var
  TypeSched : string;
  tHdr: TSCProdReqHdr;
  scP, scJ:  TSCProdSched;
  ProdReqDet : TSCProdReqDet;
  ps : TSCSchedOnPlan;
  scG : TSCProdGroup;
  I,J,H : Integer;
  objWkc, objWkcJ : TMqmWrkCtr;
  ListAltWcStr : TStringList;
  TempPlantCode, Templine : String;
begin
  Result := true;
  AtLeastOneScheduled := false;
  OtherIdsAreInTheFamily := false;
  PlantCode := '';
  ps := TSCSchedOnPlan(m_codeList[id]);
  if ps is TSCProdGroup then
  begin
    scG := TSCProdGroup(m_codeList[id]);
    scP := TSCProdSched(scG.m_list[0]);
  end
  else
    scP := TSCProdSched(m_codeList[id]);

  objWkc := TMqmWrkCtr(p_sc.GetWrkCtrPtr(scP.m_Id));
  if not assigned(objWkc) then exit;
  ListAltWcStr := objWkc.GetAltWcList;
  if not assigned(ListAltWcStr) then exit;

  if (scP.m_reqDet.m_hdr.m_ServingCode <> '') and Assigned(scP.m_reqDet.m_hdr.m_ServingCodeHdrList) then
  begin
    for H := 0 to scP.m_reqDet.m_hdr.m_ServingCodeHdrList.Count - 1 do
    begin
      tHdr := TSCProdReqHdr(scP.m_reqDet.m_hdr.m_ServingCodeHdrList[H]);
      for I := 0 to tHdr.m_list.Count - 1 do
      begin
        ProdReqDet := TSCProdReqDet(tHdr.m_list[I]);
        for J := 0 to ProdReqDet.m_list.Count - 1 do
        begin
          scJ := TSCProdSched(ProdReqDet.m_list[J]);
          objWkcJ := TMqmWrkCtr(p_sc.GetWrkCtrPtr(scJ.m_Id));
          if not assigned(objWkcJ) then continue;
          TempPlantCode := TMqmWrkCtr(objWkcJ).p_PlantCode;
//          if ListAltWcStr.IndexOf(objWkcJ.p_WrkCtrCode) = -1 then continue;
          if (scJ.p_rscCode <> '') then
          begin
            TempPlantCode := TMqmWrkCtr(TMqmRes(p_pl.FindResByCode(scJ.p_rscCode)).p_Father).p_PlantCode;
            Templine := TMqmRes(p_pl.FindResByCode(scJ.p_rscCode)).P_LineWithinPlant;
            TempPlantCode := TempPlantCode + Templine;
            if (TempPlantCode <> '') then
            begin
//             PlantCode := TMqmWrkCtr(TMqmRes(p_pl.FindResByCode(scJ.p_rscCode)).p_Father).p_PlantCode;
              PlantCode := TempPlantCode;
              AtLeastOneScheduled := true;
            end;
          end;
          if ListAltWcStr.IndexOf(objWkcJ.p_WrkCtrCode) = -1 then continue;
          if scJ.m_Id <> Id then
          begin
            if not assigned(scJ.m_grp) then OtherIdsAreInTheFamily := true;
            if not (ps is TSCProdGroup) then OtherIdsAreInTheFamily := true;
            if (assigned(scJ.m_grp)) and ((ps is TSCProdGroup)) and (scJ.m_grp <> scP.m_grp) then OtherIdsAreInTheFamily := true;
          end;
          if (scJ.p_rscCode = '') then continue;
          TypeSched := p_sc.GetSchedType(scJ.m_id);
          if ((TypeSched = '1') and (MoveInitialObjsAlwd = 0))
             or ((TypeSched = '2') and (MoveFinalObjsAlwd = 0))
             or ((TypeSched = '4') and (MoveLevel1ObjsAlwd = 0))
             or ((TypeSched = '5') and (MoveLevel2ObjsAlwd = 0))
             or ((TypeSched = '6') and (MoveLevel3ObjsAlwd = 0))
             or ((TypeSched = '7') and (MoveLevel4ObjsAlwd = 0))
             or ((TypeSched = '8') and (MoveLevel5ObjsAlwd = 0)) then
          begin
            Result := false;
            exit;
          end;

          if not p_sc.CanDetachJobOrGroup(scJ.m_Id) then
          begin
            Result := false;
            exit;
          end;

          if Assigned(scJ.m_grp)
          and not TestedServingCodeIdsList.IsIn(TSCProdGroup(scJ.m_grp).m_Id)then
             TestedServingCodeIdsList.AddLink(TSCProdGroup(scJ.m_grp).m_Id);
          if not Assigned(scJ.m_grp) then
             TestedServingCodeIdsList.AddLink(scJ.m_id);

        end;
      end;
    end;
  end;

  if assigned(TestedServingCodeIdsList) then
     TestedServingCodeIdsList.SortList(OrderGrowing);
end;

