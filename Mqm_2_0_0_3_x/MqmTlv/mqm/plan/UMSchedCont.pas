procedure TMSchedCont.GetLinks(id: TSchedId; var LinksList: TList);
var
  StSc:  TSCSchedOnPlan;
  grp: TSCProdGroup;
  job: TSCProdSched;
  CurrJobsList,
  NextJobsList,
  PrevJobsList,
  NextConnReqJobsList,
  PrevConnReqJobsList,
  PrevConnJobsList,
  NextConnJobsList: TMSchedList;
  TimingInfo: TSQtimingInfo;
  NextStepInfo, PrevStepInfo: TSQStepInfo;
  i: integer;
  LinkObjs: PTLink;
  Step : Integer;
  First : boolean;
  IdG : TSchedId;
begin
  StSc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = StSc.m_Id);
  if not (Id = StSc.m_Id) then exit;
  if IsProdSchedMaterial(id) then Exit;

  //Assert(Assigned(LinksList));
  if not Assigned(LinksList) then Exit;

  if StSc is TSCProdGroup then
  begin
    grp := TSCProdGroup(StSc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := grp.m_list[i];
      GetLinks(job.m_id, LinksList)
    end;

    //Redirect the links to the group
    for i := 0 to LinksList.Count-1 do
      PTLink(LinksList[i]).LK_StObj := Pointer(id);

  end else
  begin
    GetTimingInfo(id, TimingInfo);

    CurrJobsList := TMSchedList.Create(self);
    GetStepJobs(TimingInfo.ProdReq, TimingInfo.Step, CurrJobsList);
    for i := 0 to CurrJobsList.GetLinkCount-1 do
    begin
      if (id = CurrJobsList.GetLink(i)) then
        continue;
      new(LinkObjs);
      IdG := GetGroup(id);
      if IdG <> CSchedIDnull then
      begin
        if IdG <> CSchedIDnull then
        begin
          LinkObjs.LK_StObj := Pointer(IdG);
          IdG := GetGroup(CurrJobsList.GetLink(i));
          if IdG <> CSchedIDnull then
            LinkObjs.LK_EndObj := Pointer(IdG);
        end;
      end
      else
      begin
        LinkObjs.LK_StObj  := Pointer(id);
        LinkObjs.LK_EndObj := Pointer(CurrJobsList.GetLink(i));
      end;
      LinkObjs.LK_Type   := LT_SameStep;
      LinksList.Add(LinkObjs);
    end;
    CurrJobsList.Free;

    Step := TimingInfo.Step;
    NextJobsList := TMSchedList.Create(self);
    First := true;
    while true do
    begin
      if not GetNextStepToSched(TimingInfo.ProdReq, Step, NextStepInfo) then break;
      GetJobsOfNextStepOnPlan(TimingInfo.ProdReq, Step, NextStepInfo, NextJobsList);
      for i := 0 to NextJobsList.GetLinkCount-1 do
      begin
        new(LinkObjs);
        IdG := GetGroup(id);
        if IdG <> CSchedIDnull then
        begin
          LinkObjs.LK_StObj := Pointer(IdG);
          IdG := GetGroup(NextJobsList.GetLink(i));
          if IdG <> CSchedIDnull then
            LinkObjs.LK_EndObj := Pointer(IdG);
        end
        else
        begin
          LinkObjs.LK_StObj := Pointer(id);
          LinkObjs.LK_EndObj := Pointer(NextJobsList.GetLink(i));
        end;
        if First then
          LinkObjs.LK_Type := LT_ConnJob
        else
          LinkObjs.LK_Type := LT_DiffStep;
        LinksList.Add(LinkObjs);
      end;
      Step := NextStepInfo.StepNo;
      NextJobsList.ClearList;
      First := false;
    end;
    NextJobsList.Free;

    Step := TimingInfo.Step;
    PrevJobsList := TMSchedList.Create(self);
    First := true;
    while True do
    begin
      if not GetPrecStepToSched(TimingInfo.ProdReq, Step, PrevStepInfo) then break;
      GetJobsOfPrecStepOnPlan(TimingInfo.ProdReq, Step, PrevStepInfo, PrevJobsList);
      for i := 0 to PrevJobsList.GetLinkCount-1 do
      begin
        new(LinkObjs);
        IdG := GetGroup(id);
        if IdG <> CSchedIDnull then
        begin
          LinkObjs.LK_StObj := Pointer(IdG);
          IdG := GetGroup(PrevJobsList.GetLink(i));
          if IdG <> CSchedIDnull then
            LinkObjs.LK_EndObj := Pointer(IdG);
        end
        else
        begin
          LinkObjs.LK_StObj := Pointer(id);
          LinkObjs.LK_EndObj := Pointer(PrevJobsList.GetLink(i));
        end;
        if First then
          LinkObjs.LK_Type := LT_ConnJob
        else
          LinkObjs.LK_Type := LT_DiffStep;
        LinksList.Add(LinkObjs);
      end;
      Step := PrevStepInfo.StepNo;
      PrevJobsList.ClearList;
      First := false;
    end;
    PrevJobsList.Free;

    // this part was commente and we open it for big avi 08052017
    NextConnJobsList := TMSchedList.Create(self);
    GetFwLinkedJobs(Id, NextConnJobsList);
    for i := 0 to NextConnJobsList.GetLinkCount-1 do
    begin
      new(LinkObjs);
      LinkObjs.LK_StObj := Pointer(id);
      LinkObjs.LK_EndObj := Pointer(NextConnJobsList.GetLink(i));
      LinkObjs.LK_Type := LT_ConnJob;
      LinksList.Add(LinkObjs);
    end;
    NextConnJobsList.Free;

    PrevConnJobsList := TMSchedList.Create(self);
    GetBwLinkedJobs(Id, PrevConnJobsList);
    for i := 0 to PrevConnJobsList.GetLinkCount-1 do
    begin
      new(LinkObjs);
      LinkObjs.LK_StObj := Pointer(id);
      LinkObjs.LK_EndObj := Pointer(PrevConnJobsList.GetLink(i));
      LinkObjs.LK_Type := LT_ConnJob;
      LinksList.Add(LinkObjs);
    end;
    PrevConnJobsList.Free;

    NextConnReqJobsList  := TMSchedList.Create(self);
    GetNextConnReqFirstStepJobs(Id, NextConnReqJobsList);
    for i := 0 to NextConnReqJobsList.GetLinkCount-1 do
    begin
      new(LinkObjs);
      LinkObjs.LK_StObj := Pointer(id);
      LinkObjs.LK_EndObj := Pointer(NextConnReqJobsList.GetLink(i));
      LinkObjs.LK_Type := LT_ConnReq;
      LinksList.Add(LinkObjs);
    end;
    NextConnReqJobsList.Free;

    PrevConnReqJobsList  := TMSchedList.Create(self);
    GetPrevConnReqLastStepJobs(Id, PrevConnReqJobsList);
    for i := 0 to PrevConnReqJobsList.GetLinkCount-1 do
    begin
      new(LinkObjs);
      LinkObjs.LK_StObj := Pointer(id);
      LinkObjs.LK_EndObj := Pointer(PrevConnReqJobsList.GetLink(i));
      LinkObjs.LK_Type := LT_ConnReq;
      LinksList.Add(LinkObjs);
    end;
    PrevConnReqJobsList.Free;
  end;

end;

