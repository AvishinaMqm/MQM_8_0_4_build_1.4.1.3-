function TMSchedCont.GetAllBalanceList(var List : TList): boolean;
var
  I, J, A, B : Integer;
  ArtBalList: TMQMArtBalanceList;
  ArticleType : TMQMArticleType;
  MQMNetGroup : TMQMNetGroup;
  MQMArticle     : TMQMArticle;
  DetailRows     : PTDetailRows;
  ArtBalance     : PTArtBalance;
begin
  Result := true;

  for I := 0 to p_ArtTypeList.p_count - 1 do
  begin
    ArticleType := TMQMArticleType(p_ArtTypeList.p_Item[I]);
    for J := 0 to ArticleType.p_ArticleList.Count - 1 do
    begin
      MQMArticle := ArticleType.p_ArticleList[J];
      for A := 0 to MQMArticle.p_NetGroupList.p_count - 1 do
      begin
        MQMNetGroup := MQMArticle.p_NetGroupList.p_Item[A];
        ArtBalList :=  MQMNetGroup.m_BalanceList;

        if Assigned(ArtBalList) and (ArtBalList.p_count > 0) then
        begin
          for B := 0 to ArtBalList.p_count -1 do
          begin
            ArtBalance := PTArtBalance(ArtBalList.p_Item[B]);
            if ArtBalance.JobID <> CSchedIDnull then continue;
            new(DetailRows);
            DetailRows.NetGroupPtr := MQMNetGroup;
            DetailRows.ArtType     := MQMArticle.p_ArtType.p_ArtTypeCode;
            DetailRows.ProductCode := MQMArticle.p_ArtCode;
            DetailRows.Date        := DateTimeToStr(ArtBalance.DueDate);
            DetailRows.DateTime    := ArtBalance.DueDate;
            DetailRows.Quantity    := ArtBalance.Quantity;
            DetailRows.description := ArtBalance.Description;
            DetailRows.Artbalance  := ArtBalance;
            List.add(DetailRows);
          end;
        end;
      end;
    end;
  end;
end;

