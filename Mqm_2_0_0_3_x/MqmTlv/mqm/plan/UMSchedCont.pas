      begin
        // Fill the record with data to pass to the object for creation
        RecArt.Sequence := fPA_sequenceChar.AsString;
        if fPA_Prod_Balance.AsString = '1' then
        begin
          RecArt.Article := p_ArtTypeList.FindArticle('REQUEST',
                                fPA_ProdCode.AsString);
        end else
        begin
          RecArt.Article := p_ArtTypeList.FindArticle(hdr.m_prodType,
                                fPA_ProdCode.AsString);
          if Assigned(RecArt.Article) then
            hdr.m_ProductDescription := RecArt.Article.p_Description
        end;

        if not Assigned(RecArt.Article)
        and (fPA_Prod_Balance.AsString = '1') then
        begin
          with ArticleRec do
          begin
            ArticleCode := fPA_ProdCode.AsString;
            Nature      := Ar_Material;
            AddResStart := Ar_No;
            AddResEnd   := Ar_No;
            Description := '';
          end;
          ArtType := p_ArtTypeList.FindartType('REQUEST');
          RecArt.Article := ArtType.SearchAndAddArticle(ArticleRec);

        end;

        if not Assigned(RecArt.Article) then
        begin
          if (fPA_Prod_Balance.AsString = '1') then
          begin
            ErrList.Add( _('Error loading produced materials') + ': ' +
                       _('Request')      + ' ' + hdr.m_code + ' ' +
                       _('Product type') + ' ' + hdr.m_prodType + ' ' +
                       _('Product')      + ' ' + fPA_ProdCode.AsString);
          end;

        end else
        begin
          if RecArt.Article.p_Nature = Ar_NotBalance then
          begin
            Next;
            Continue;
          end;

          RecArt.NetGroup := RecArt.Article.AddNetGroup(
                  fPA_netGroupCode.AsString);

          if not Assigned(RecArt.NetGroup) then
              ErrList.Add( _('Error loading produced materials') + ': ' +
                           _('Request')      + ' ' + hdr.m_code + ' ' +
                           _('Product type') + ' ' + fPA_ProdType.AsString + ' ' +
                           _('Product')      + ' ' + fPA_ProdCode.AsString + ' ' +
                           _('Net group')    + ' ' + fPA_netGroupCode.AsString)

          else
          begin
            Det := TSCProdReqDet(hdr.m_list[hdr.m_list.Count-1]);

            if Det = OldDet then
              StartQty := EndQty
            else
            begin
              OldDet := Det;
              StartQtY := 0;
            end;

            RecArt.ToRequest := fPA_AllocReq.AsString;

            if fPA_Prod_Balance.AsString = '1' then
              RecArt.ArtOnBalance := aob_ReqNumber
            else
              if fPA_Prod_Balance.AsString = '9' then
                RecArt.ArtOnBalance := aob_DisplayOnly
              else
                RecArt.ArtOnBalance := aob_Normal;

            if fPA_settled.AsString = '1' then
              RecArt.Closed := true
            else
              RecArt.Closed := false;
            RecArt.RequiredQty  := fPA_reqQuant.AsFloat;
            RecArt.ProducedQty  := fPA_qtyProduced.AsFloat;
            RecArt.AllocatedQty := fPA_AllocQty.AsFloat;

            EndQty := StartQty + RecArt.RequiredQty;
            RecArt.StartQty := StartQty;
            RecArt.EndQty := EndQty;

            hdr.m_ProdArtList.AddProdArt(RecArt);
          end;
        end;
      end;

      Next;

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;

    end;

    Close;
  end;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';

  Application.ProcessMessages;
end;

