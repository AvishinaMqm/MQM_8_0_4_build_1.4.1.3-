function SortOnDates(Item1, Item2: Pointer): Integer;
var
  JobId1 ,JobId2 : TSchedId;
  info1, info2 :  TSQPlanInfo;
begin
  JobId1 := TSchedId(PTLink(Item1).LK_StObj);
  JobId2 := TSchedId(PTLink(Item2).LK_StObj);
  p_sc.GetPlanInfo(JobId1, info1);
  p_sc.GetPlanInfo(JobId2, info2);

  if info1.startDate < info2.startDate then
    Result := -1
  else if info1.startDate > info2.startDate then
    Result := 1
  else
    Result := 0;
end;

