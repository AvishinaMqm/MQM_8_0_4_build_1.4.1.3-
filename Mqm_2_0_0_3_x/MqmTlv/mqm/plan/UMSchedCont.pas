function TMSchedCont.FindProdReqLeadStep(MqmSplitId : string) : TSCProdSched;
var
  I, J, S : Integer;
  tHdrLeadStep : TSCProdReqHdr;
  tDetLead : TSCProdReqDet;
  tJob:  TSCProdSched;
begin
  Result := nil;
  for I := 0 to m_ProdReqLeadStepSplitList.Count - 1 do
  begin
    tHdrLeadStep := TSCProdReqHdr(m_ProdReqLeadStepSplitList[I]);
    for J := 0 to tHdrLeadStep.m_List.Count - 1 do
    begin
      tDetLead := TSCProdReqDet(tHdrLeadStep.m_List[J]);
      if (tHdrLeadStep.m_LeadStepForSplit = tDetLead.m_code) then
      begin
        if tDetLead.p_count > 1 then
        begin
          for S := 0 to tDetLead.m_list.count - 1 do
          begin
            tJob := TSCProdSched(tDetLead.m_list[S]);
            if tJob.m_isDeleted then continue;
            if (tJob.m_NewReqUniqId = MqmSplitId) then
            begin
              Result := tJob;
              exit;
            end;
          end;
        end;
      end;
    end;
  end;
end;

