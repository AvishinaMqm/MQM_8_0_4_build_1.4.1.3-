function TMSchedCont.GetSmallestDate: TDateTime;
const
  maxDate = 365 * 2000;
var
  i:      integer;
  sc:     TSCSchedOnPlan;
  scProd: TSCProdSched;
begin
  Result := maxDate;

  for i := 0 to m_codeList.Count-1 do
    if Assigned(m_codeList[i]) then
    begin
      sc := TSCSchedOnPlan(m_codeList[i]);
      if sc is TSCProdGroup then continue;
      scProd := TSCProdSched(sc);
      if (scProd.p_rscCode <> CSnoResCode) and (scProd.p_schedStart <> 0) and (scProd.p_schedStart < Result) then
        Result := scProd.p_schedStart
    end;

  if Result = maxDate then
    Result := 0.0
end;

