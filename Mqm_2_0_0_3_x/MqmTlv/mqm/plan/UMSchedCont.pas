function TMSchedCont.CheckPriorityTosched(Id: TSchedId; ErrList: TStrings): boolean;
var
//  tHdr: TSCProdReqHdr;
//  tDet, tPriorDet: TSCProdReqDet;
  tJob:  TSCProdSched;
  sc : TSCSchedOnPlan;
  grp: TSCProdGroup;
  i : integer;
  JobId: TschedId;
begin
  Result := true;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdSched then
  begin
    tJob := TSCProdSched(sc);
    if not Assigned(tJob.m_reqDet) then exit;
    Result := tJob.m_reqDet.CheckPriorityToSched(ErrList);
  end
  else
  begin
    grp := TSCProdGroup(sc);
    //Assert(Assigned(grp));
    if not assigned(Grp) then Exit;
    for I := p_sc.GetGrpNumSons(Id) - 1 downto 0 do
    begin
      JobId := p_sc.GetGrpSon(Id, I);
      sc := TSCSchedOnPlan(m_codeList[JobId]);
      tJob := TSCProdSched(sc);
      if not Assigned(tJob.m_reqDet) then exit;
      Result := tJob.m_reqDet.CheckPriorityToSched(ErrList);
      if not Result then break;
    end;
  end;

//  if not (ps is TSCProdSched) then exit;

//  tJob := TSCProdSched(ps);
//  if not Assigned(tJob.m_reqDet) then exit;

{  Result := tJob.m_reqDet.CheckPriorityToSched(ErrList);

  tHdr := TSCProdReqHdr(tJob.m_reqDet.m_hdr);
  if not Assigned(tHdr) then exit;

  tDet := TSCProdReqDet(tHdr.GetPrecStepToSched(tJob.m_reqDet.m_code));
  if not Assigned(tDet) then exit;

  OnPlan := false;
  for j := 0 to tDet.m_PriorStepList.Count-1 do
    begin
    tPriorDet := TSCProdReqDet(tHdr.FindDetFromCode(StrToInt(tDet.m_PriorStepList[j])));
    if not Assigned( tPriorDet) then continue;

    //What is this for ? Please tell Itzik
    if (not DBAppGlobals.CheckStepSeq and
      (p_Priorities.GetPriority(tPriorDet.m_planWkctr, tPriorDet.m_planWkctrProc) = -1)) then
      exit;

    for i := 0 to tPriorDet.m_list.Count-1 do
    begin
      tJob := TSCProdSched(tPriorDet.m_list[i]);
      if (tJob.p_rscCode = '')
        and (tJob.m_status <> CSS_del)
        and (not tJob.m_isDeleted )
      then
      begin
        OnPlan := true;
        if Assigned(ErrList) then
          ErrList.Add(_('Request') + ' ' + tHdr.m_code + ' ' + _('Step') + ' ' + IntToStr(tPriorDet.m_code) +
                      ' ' + _('SubStep') + ' '  + IntToStr(tJob.m_code) + ' ' + _('Reprocess') +
                      ' ' + IntToStr(tJob.m_reprocNo) + ' ' + _('must be scheduled before this job'));

     end
   end;
  end;

  if OnPlan then
    Result := false;
}
end;

//----------------------------------------------------------------------------//
{
 Checks for preceding Jobs that are scheduled and are dependant on our job to be scheduled
 Returns true when there is a job ALREADY scheduled that needs our Job to be
 Scheduled.
 Returns false when there is  no preceding job

 @param Id the step number we are checking for previous steps that are dependant upon it
 @return true = there is a job ALREADY scheduled or false = no dependant Job scheduled
}
function TMSchedCont.CheckPriorityToUnsched(Id: TSchedId): boolean;
var
//  tHdr: TSCProdReqHdr;
//  tDet, tPriorDet: TSCProdReqDet;
  tJob:  TSCProdSched;
  ps : TSCSchedOnPlan;
  grp : TSCProdGroup;
  i: integer;
//  OnPlan: boolean;
begin
  Result := false;
  ps := m_codeList[id];
  if (ps is TSCProdSched) then //exit;
  begin
    tJob := TSCProdSched(ps);
    if not Assigned(tJob.m_reqDet) then exit;

    Result := tJob.m_reqDet.CheckPriorityToUnsched(nil);
    exit;
  end;

  if ps is TSCProdGroup then
  begin
    grp := TSCProdGroup(ps);
    for i := 0 to grp.m_list.Count-1 do
    begin
      tJob := TSCProdSched(grp.m_list[i]);
      if not Assigned(tJob.m_reqDet) then exit;
      Result := tJob.m_reqDet.CheckPriorityToUnsched(nil);
      if Result = true then exit;
     end;
    exit;
  end;
 {
  tJob := TSCProdSched(ps);
  if not Assigned(tJob.m_reqDet) then exit;

  Result := tJob.m_reqDet.CheckPriorityToUnsched(nil);
 }
  {
  tHdr := TSCProdReqHdr(tJob.m_reqDet.m_hdr);
  if not Assigned(tHdr) then exit;

  tDet := TSCProdReqDet(tHdr.GetPrecStepToUNSched(tJob.m_reqDet.m_code));
  if not Assigned(tDet) then exit;

  OnPlan := false;
  for j := 0 to tDet.m_PriorStepList.Count-1 do
    begin
    tPriorDet := TSCProdReqDet(tHdr.FindDetFromCode(StrToInt(tDet.m_PriorStepList[j])));
    if not Assigned( tPriorDet) then continue;

    //We loop over all the steps of the Prod req if there is a job ALREADY
    //scheduled that needs our job to be sched first
    for i := 0 to tPriorDet.m_list.Count-1 do
    begin
      tJob := TSCProdSched(tPriorDet.m_list[i]);
      if (tJob.p_rscCode <> '') then
        OnPlan := true;
    end;
  end;

  if OnPlan then
    Result := true;  //we have a Job on the Gantt that needs our Job
}
end;

