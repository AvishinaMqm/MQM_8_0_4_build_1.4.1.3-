function TMSchedCont.ChangesMade : boolean;
var
  ph, pd, ps : Integer;
  tHdr : TSCProdReqHdr;
  tDet : TSCProdReqDet;
  tJob : TSCProdSched;
begin
  Result := false;

  for ph := 0 to m_prodReqList.Count-1 do
  begin
    tHdr := TSCProdReqHdr(m_prodReqList[ph]);

    for pd := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[pd]);

      for ps := 0 to tDet.m_list.Count-1 do
      begin
        tJob := TSCProdSched(tDet.m_list[ps]);
        if tJob.m_fromPD then
        begin
          if (tJob.m_status in [CSS_none,CSS_del,CSS_From_PG]) then continue
          else
          begin
            Result := true;
            Exit;
          end;
        end else
        begin
          if (tJob.m_status in [CSS_none,CSS_del,CSS_From_PG]) then continue
          else
          begin
            Result := true;
            Exit;
          end;
        end;
      end;
    end;
  end;
end;

