procedure TMSchedCont.CloseProgress(id: TSchedID; EndDate : TDateTime);
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
  ActArea : TMqmActArea;
  LowestProgressStart : TDateTime;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    job.p_CloseProgress := EndDate;
  end
  else
  begin
    // We need to do in a different way for Continutes not batch_ContinuesTime
    LowestProgressStart := 99999;
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      if (job.m_ProgType <> '') and (job.m_PrgSt < LowestProgressStart) then
        LowestProgressStart := job.m_PrgSt;
    end;
    if LowestProgressStart < 99999 then
    begin
      for i := 0 to grp.m_list.Count-1 do
      begin
        job := TSCProdSched(grp.m_list[i]);
        if (job.m_ProgType = '') then
          job.m_PrgSt := LowestProgressStart;
      end;
    end;

    job := grp.m_list[0];
    if IsIdSimpleContinues(job.m_id) then
    begin
      for i := 0 to grp.m_list.Count-1 do
      begin
        job := TSCProdSched(grp.m_list[i]);
        if job.m_ProgType = '' then
          job.p_CloseProgress := EndDate;
        if (job.m_ProgType = '1') then
        begin
          if job.m_PrgSt > EndDate then
            job.p_CloseProgress := EndDate
          else
            job.p_CloseProgress := job.m_PrgSt;
        end;
        if (job.m_ProgType = '2') then
        begin
          if job.m_PrgCurDt > EndDate then
            job.p_CloseProgress := EndDate
          else
            job.p_CloseProgress := job.m_PrgCurDt;
        end;
        if (job.m_ProgType <> '') and (job.m_ProgType <> '1') and (job.m_ProgType <> '2') and (job.m_PrgEd > EndDate) then
          job.p_CloseProgress := EndDate;
      end;
    end
    else
      sc.p_CloseProgress := EndDate;
  end;
end;

