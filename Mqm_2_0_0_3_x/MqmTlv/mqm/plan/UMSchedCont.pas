    SqlStr := SqlStr + 'WKSPD.' + CreateFld(tbiWW.pfx, fli_Identifier) + '=' + CreateFld(tbiPD.pfx, fli_Identifier) + ') ';
    SqlStr := SqlStr + WHERE_IDF_Condition(CreateFld(tbiPS.pfx, fli_Identifier)) + ' AND ';
    SqlStr := SqlStr + CreateFld(tbiPS.pfx, fli_updCode) + '>' + IntToStr(m_corrUpd) + ' and ';
    SqlStr := SqlStr + CreateFld(tbiPS.pfx, fli_updCode) + '<=' + IntToStr(updNum) + ' and ';

    if DBAppGlobals.MCM_App then
    begin
      SqlStr := SqlStr + CreateFld(tbiPS.pfx, fli_Mqm_environment) + '<>''' + '1' + ''' and ';
      SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_SchedulByMcm) + '=''' + '1' + ''' and '
    end
    else
      SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_SchedulByMqm) + '=''' + '1' + ''' and ';

    SqlStr := SqlStr + '(WKSPS.WW_WKST_CODE IS NOT NULL OR WKSPD.WW_WKST_CODE IS NOT NULL)';
    SqlStr := SqlStr + ' order by ';
    SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_preqNo)  + ',';
    SqlStr := SqlStr + CreateFld(tbiPD.pfx, fli_pstepId) + ',';
    SqlStr := SqlStr + CreateFld(tbiPS.pfx, fli_psubstId);
    qry.sql.Text := SqlStr;
    ProcessQryForUpdate(qry, fUpdate, ptr, ProgBar);
  end;

  if not EventFromHost then
    m_corrUpd := updNum;
  Application.ProcessMessages;
  UpdateBalanceForAllJobs(ProgBar,nil);
end;

