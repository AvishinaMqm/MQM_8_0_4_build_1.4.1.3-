Procedure TMSchedCont.CopyProdSchedToProdSchedMcm(WorkCentersHandledList : string);
var
  ConFirmLvl : string;
  NumDaysFromToday : TDateTime;
  SrvQry,qry : TMqmQuery;
  TempDateTime : TDateTime;
  SelectionDateTime, PROD_SCHED, PROD_SCHED_MCM,RES, PROD_STEP : string;
  Month, Day, Year, AHour, AMinute, ASecond, AMilliSecond : word;
  DndArchiveLocalName : TDndArchiveName;
  tbInfo : PTblInfo;
  CopiedSchedTypeFromMqm, CopiedBackwardFromMqmDays ,cbCopiedSchedTypeFromMqm, cbCopiedBackwardFromMqmDays, CBForceMqmScheduleDetails: String;
  tbiRS: ^TTblInfo;
begin
  if WorkCentersHandledList = '' then exit;

  CBForceMqmScheduleDetails := '';
  CopiedSchedTypeFromMqm :=    '';
  CopiedBackwardFromMqmDays := '';
  cbCopiedSchedTypeFromMqm := '';
  cbCopiedBackwardFromMqmDays := '';

  if IniAppGlobals.downloadTo = '2' then
  begin
    PROD_SCHED := 'PROD_SCHED';
    PROD_SCHED_MCM := 'PROD_SCHED_MCM';
    RES := 'RES';
    PROD_STEP := 'PROD_STEP'
  end
  else
  begin
    PROD_SCHED := 'SCDM_PROD_SCHED';
    PROD_SCHED_MCM := 'SCDM_PROD_SCHED_MCM';
    RES := 'SCDM_RES';
    PROD_STEP := 'SCDM_PROD_STEP'
  end;

  qry := CreateQuery(Cfg_DB);
  tbinfo := @tblInfo[tbl_cfg_appini];
  tbiRS := @tblInfo[tbl_res];

  qry.SQL.Text := 'Select * from ' + tbInfo.getTableName + ' where AI_WKST_CODE = ' + QuotedStr('MQMSRVLOAD')
    + ' and AI_IDENTIFIER = ' + IniAppGlobals.Identifier;
  qry.Open;

  if qry.RecordCount > 0 then
  begin
    while not qry.eof do
    begin
      if qry.FieldByName('AI_FIELDNAME').asString = 'cbCopiedSchedTypeFromMqm' then
        cbCopiedSchedTypeFromMqm := qry.FieldByName('AI_VALUE').asString
      else if qry.FieldByName('AI_FIELDNAME').asString = 'cbCopiedBackwardFromMqmDays' then
        cbCopiedBackwardFromMqmDays := qry.FieldByName('AI_VALUE').asString
      else if qry.FieldByName('AI_FIELDNAME').asString = 'CopiedSchedTypeFromMqm' then
        CopiedSchedTypeFromMqm := qry.FieldByName('AI_VALUE').asString
      else if qry.FieldByName('AI_FIELDNAME').asString = 'CopiedBackwardFromMqmDays' then
        CopiedBackwardFromMqmDays := qry.FieldByName('AI_VALUE').asString
      else if qry.FieldByName('AI_FIELDNAME').asString = 'CBForceMqmScheduleDetails' then
        CBForceMqmScheduleDetails := qry.FieldByName('AI_VALUE').asString;

      qry.Next;
    end;
  end else
  begin
    cbCopiedSchedTypeFromMqm := IniAppGlobals.CBCopiedSchedTypeFromMqm;
    cbCopiedBackwardFromMqmDays := IniAppGlobals.CBCopiedBackwardFromMqmDays;
    CopiedSchedTypeFromMqm := IniAppGlobals.CopiedSchedTypeFromMqm;
    CopiedBackwardFromMqmDays := IniAppGlobals.CopiedBackwardFromMqmDays;
  end;

  IniAppGlobals.CBForceMqmScheduleDetails := CBForceMqmScheduleDetails;

  if (cbCopiedSchedTypeFromMqm <> '1') and
     (cbCopiedBackwardFromMqmDays <> '1') then exit;

  SrvQry := CreateQuery(Main_DB);
  SrvQry.Transaction := CreateTransaction(Main_DB);

  SrvQry.Connection.StartTransaction;
  // Delete old prod_sched before write
  with SrvQry do
  begin

    SQL.Clear;

    SQL.Add('update ' + PROD_SCHED_MCM + ' psm set MS_MQM_ENV = ' + QuotedStr('0')
      + ' Where psm.MS_MQM_ENV = ' + QuotedStr('1') + ' and psm.MS_IDENTIFIER = ' +IniAppGlobals.Identifier
      + ' and exists (select 1 from '+ PROD_STEP +' S where S.PD_IDENTIFIER = psm.MS_IDENTIFIER and psm.MS_PREQ_NO = S.PD_PREQ_NO and psm.MS_PSTEP_ID = S.PD_PSTEP_ID and S.PD_WKCNTER in (' + WorkCentersHandledList+'))');
    ExecSQL;

    SQL.Clear;

    SQL.Add('delete from ' + PROD_SCHED_MCM + ' PSM '
            + ' where  PSM.MS_IDENTIFIER = ' +IniAppGlobals.Identifier
            + ' and exists (select PS.PS_PREQ_NO from ' + PROD_SCHED + ' PS '
            + 'where PS.PS_SCHED_TYPE ' + ' <> ' + QuotedStr('0') + ' and PS.PS_IDENTIFIER = PSM.MS_IDENTIFIER AND PS.PS_PREQ_NO = PSM.MS_PREQ_NO and PS.PS_PSTEP_ID = PSM.MS_PSTEP_ID AND');

    if CBCopiedSchedTypeFromMqm = '1' then
    begin

      if CopiedSchedTypeFromMqm = '0' then
        ConFirmLvl := QuotedStr('2')
      else if CopiedSchedTypeFromMqm = '1' then
        ConFirmLvl := QuotedStr('2') + ',' +  QuotedStr('1') + ',' + QuotedStr('3') + ',' + QuotedStr('4') + ',' + QuotedStr('5') + ',' + QuotedStr('6') + ',' + QuotedStr('7')
      else if CopiedSchedTypeFromMqm = '2' then
        ConFirmLvl := QuotedStr('2') + ',' + QuotedStr('3') + ',' + QuotedStr('4') + ',' + QuotedStr('5') + ',' + QuotedStr('6') + ',' + QuotedStr('7')
      else if CopiedSchedTypeFromMqm = '3' then
        ConFirmLvl := QuotedStr('2') + ',' + QuotedStr('4') + ',' + QuotedStr('5') + ',' + QuotedStr('6') + ',' + QuotedStr('7')
      else if CopiedSchedTypeFromMqm = '4' then
        ConFirmLvl := QuotedStr('2') + ',' + QuotedStr('5') + ',' + QuotedStr('6') + ',' + QuotedStr('7')
      else if CopiedSchedTypeFromMqm = '5' then
        ConFirmLvl := QuotedStr('2') + ',' + QuotedStr('6') + ',' + QuotedStr('7')
      else if CopiedSchedTypeFromMqm = '6' then
        ConFirmLvl := QuotedStr('2') + ',' + QuotedStr('7');

      SQL.Add(' PS_SCHED_TYPE ' + ' in (' + ConFirmLvl + ')');

      if CBCopiedBackwardFromMqmDays = '1' then
        SQL.Add(' AND ')
      else
        SQL.Add(')')
    end;

    if CBCopiedBackwardFromMqmDays = '1' then
    begin
      NumDaysFromToday := now + StrToInt(CopiedBackwardFromMqmDays);

      TempDateTime := NumDaysFromToday;
      DecodeDate(TempDateTime, year, month, day);
      SelectionDateTime := ConvertDateFormatDb2Oracle(TempDateTime, true, true);  //QuotedStr(IntToStr(Month) + '/' + IntToStr(Day) + '/' + IntToStr(Year));

      SQL.Add(' PS_SCH_START ' + ' <= ' + SelectionDateTime);
      SQL.Add(')');
    end;

//    SQL.Add(' and exists (select 1 from '+ RES +' r where r.RS_IDENTIFIER = psm.MS_IDENTIFIER and r.RS_RSC_CODE = psm.MS_RSC_CODE and r.RS_WKCNTER in (' + WorkCentersHandledList+'))');
    SQL.Add(' and exists (select 1 from '+ PROD_STEP +' S where S.PD_IDENTIFIER = ' + IniAppGlobals.Identifier + ' and S.PD_WKCNTER in (' + WorkCentersHandledList+'))');
    ExecSQL;
  end;

  SrvQry.sql.Clear;
  SrvQry.SQL.Add('insert into ' + PROD_SCHED_MCM
              + '(MS_PREQ_NO, MS_PSTEP_ID, MS_PSUBST_ID,MS_REPROC_NO,MS_VERS_NO	,MS_UPD_CODE,MS_UPD_OP,MS_TYPE_PROD,MS_PROD_LINE,MS_PROD_UM,MS_STEP_TYP,MS_INIT_QUENT	,'
              + '  MS_ST_GROUP	, '
              + '  MS_STEP_IS_GRPED	, '
              + '  MS_SCHED_TYPE	, '
              + '  MS_WKCNTER	, '
              + '  MS_WKCT_PROC	,'
              + '  MS_ALTERNATIVE_CODE	,'
              + '  MS_RSC_CODE	, '
              + '  MS_PROD_SUBLIN_RSC	, '
              + '  MS_NUM_RSC_COMPONENTS	, '
              + '  MS_QTY	, '
              + '  MS_SUP_BASE	,'
              + '  MS_SUP_REAL	, '
              + '  MS_SUP_OVERLAP	,'
              + '  MS_EXE_MIN	, '
              + '  MS_SCH_START	,'
              + '  MS_SCH_END	, '
