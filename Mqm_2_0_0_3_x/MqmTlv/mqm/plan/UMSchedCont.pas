function TMSchedCont.QtyInUM(id: TSchedId; um: string; out resQty: double; out MultQty : double): boolean;
var
  sc:         TSCSchedOnPlan;
  job:        TSCProdSched;
  grp:        TSCProdGroup;
  i:          integer;
  jobQty, TotJobQty: double;
  multiplier: double;
begin
  Result := true;
  sc := TSCSchedOnPlan(m_codeList[id]);

  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    ResQty := 0;
    TotJobQty := 0;
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      if not QtyInUM(job.m_Id, um, jobQty, multiplier) then
      begin
        Result := false;
        exit
      end;
      TotJobQty :=  TotJobQty + job.p_quantSched;
      ResQty := ResQty + jobQty
    end;
    MultQty :=  ResQty / TotJobQty;
  end
  else
  begin
    job := TSCProdSched(sc);
    if job.m_reqDet.m_BchUMList.GetMultiplierForUM(um, multiplier) then
    begin
      if multiplier = 0 then
         multiplier := 1;
      resQty := job.p_quantSched * multiplier;
      MultQty := multiplier
    end
    else
      result := false;
  end
end;

