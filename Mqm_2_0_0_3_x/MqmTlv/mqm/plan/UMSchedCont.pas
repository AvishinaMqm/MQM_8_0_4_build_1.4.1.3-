function TMSchedCont.GetMaterialRequiredQty(Id : TSchedId; ArtCode : string) : double;
var
  sc : TSCSchedOnPlan;
  job : TSCProdSched;
  tDet : TSCProdReqDet;
  MacSetupRec: TMacSetup;
  I,J : Integer;
  MacSetupList : TList;
  MacSetup: TMQMMachineSetup;
  IssArt: PTIssuedArt;
begin
  Result := 0;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdGroup then
  begin
  end
  else
  begin
    job  := TSCProdSched(sc);
    tDet := TSCProdReqDet(job.m_reqDet);
    MacSetupRec.WrkCtrCode       := '';
    MacSetupRec.ResCat           := '';
    MacSetupRec.ResCode          := '';
    MacSetupRec.MachineSetupCode := '';
    MacSetupList := TList.Create;

    tDet.m_MacSetupList.GetMacSetup(MacSetupRec, MacSetupList);

    for i := 0 to MacSetupList.Count-1 do
    begin
      MacSetup := MacSetupList[i];

      if not Assigned(MacSetup) then continue;

      for J := 0 to MacSetup.m_IssuedArtList.p_count - 1 do
      begin
        IssArt := MacSetup.m_IssuedArtList.p_Item[J];
        if IssArt.Article.p_ArtCode = ArtCode then
        begin
          Result := IssArt.RequiredQty;
          MacSetupList.Free;
          Exit;
        end;
      end;
    end;
    MacSetupList.Free;
  end;
end;

