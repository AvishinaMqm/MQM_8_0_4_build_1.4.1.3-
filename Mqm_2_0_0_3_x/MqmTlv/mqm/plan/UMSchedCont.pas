  sc : TSCSchedOnPlan;
  Found : boolean;
begin
  Result := false;
  Found := false;
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  //Assert (sc is TSCProdSched);
  if not (sc is TSCProdSched) then Exit;
  job := TSCProdSched(sc);
  tDet := TSCProdReqDet(job.m_reqDet);

  for Ps := 0 to tDet.m_list.Count -1 do
  begin
    Job := TSCProdSched(tDet.m_list[Ps]);
    if Job.m_isDeleted then
      Continue;
    if (SplitFamily = Job.m_SplitFamilyCode) then
    begin
      if not Found then
        Found := true
      else
      begin
        Result := true;
        exit
      end;
    end;

  end;

end;

