procedure TMSchedCont.LoadJobProperties(OnStart : boolean; qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText; ErrList: TStringList; UpdateNr : integer;
                                        WorkCentersHandledList, WorkCentersViewedList : String; ChangedReqInClause: string = '');
type
 TPropWorkCenters = record
   PropertyCode : String;
   WorkCenters : TStringList;
 end;
 PTPropWorkCenters = ^TPropWorkCenters;
var
  tbInfoPropRes , tbInfoProperty, tbInfoAltWc, tbInfoRes, tbInfoProp, tbInfoProdStep, tbiCR : ^TTblInfo;
  code, val,
  RscCode, WorkCentersList :  string;
  hdr, OldHdr: TSCProdReqHdr;
  det:        TSCProdReqDet;
  StepId , I, PropIdx, RowCnt : integer;
  PropId : TPropId;
  IsDateProp : boolean;
  Year, Month, Day: Word;
  PropDate : TDateTime;
  PP_preqNo, PP_PropertyCode, PP_PropValue, PP_pstepId, PP_Rsc : TField;
  FPropertyCode, FWorkCenterCode : TField;
  OldHdrCode, PropertyCode, WorkCenterCode : String;
  PrgHour, PrgMinute, PrgSecond, PrgMilliSecond, PrgPrevSecond : Word;
  PrgIndex, PrgBlock : integer;
  PPropWorkCenters : PTPropWorkCenters;
  PropertiesList : Tlist;
  PropInTheList : TStringList;
begin
  det := nil;
  hdr := nil;
  PropDate := 0;
  PropertiesList := TList.Create;
  PropInTheList := TStringList.Create;
  PropInTheList.Sorted := true;

  if WorkCentersHandledList = '' then
  begin
    if WorkCentersViewedList = '' then
      WorkCentersList := ''
    else
      WorkCentersList := WorkCentersViewedList;
  end
  else
  begin
    if WorkCentersViewedList = '' then
      WorkCentersList := WorkCentersHandledList
    else
      WorkCentersList := WorkCentersHandledList + ',' + WorkCentersViewedList;
  end;

  if WorkCentersList = '' then exit;


  if Assigned(ProgBar) then
  begin
    Application.ProcessMessages;
    ProgBar.SetPosition(0);
    ProgBar.SetMax(2000);
    PrgBlock := trunc(2000/100) + 1;
    PrgIndex := 0;
    PrgPrevSecond := 0;
  end;

  if Assigned(Status) then
    Status.Caption := _('Reading Jobs Properties from database...');

//  IniAppGlobals.Time_LoadJobsproperties := NOW;

  Application.ProcessMessages;

  tbInfoPropRes := @tblInfo[tbl_prop_res];
  tbInfoProperty := @tblInfo[tbl_prop];
  tbInfoAltWc := @tblInfo[tbl_wkc_alt];
  tbInfoRes := @tblInfo[tbl_res];
  tbInfoProp := @tblInfo[tbl_prop_prod];
  tbInfoProdStep := @tblInfo[tbl_prod_step];
  tbiCR := @tblInfo[tbl_Req_Change];

  with qry do
  begin
    SQL.Clear;
    SQL.Add('select distinct ');
    SQL.Add('PR.' + CreateFld(tbInfoPropRes.pfx, fli_PropertyCode) + ' PropertyCode,');
    SQL.Add('PR.' + CreateFld(tbInfoPropRes.pfx, fli_wkCtrCode) + ' WorkCenterCode ');
    SQL.Add('from ' + tbInfoPropRes.GetTableName + ' PR ');
    SQL.Add('join ' + tbInfoProperty.GetTableName + ' P ');
    SQL.Add('on P.' + CreateFld(tbInfoProperty.pfx, fli_Identifier) + ' = PR.' + CreateFld(tbInfoPropRes.pfx, fli_Identifier) + ' ');
    SQL.Add('and P.' + CreateFld(tbInfoProperty.pfx, fli_PropertyCode) + ' = PR.' + CreateFld(tbInfoPropRes.pfx, fli_PropertyCode) + ' ');
    SQL.Add('and P.' + CreateFld(tbInfoProperty.pfx, fli_RP_MainLevel) + ' IN (' + QuotedStr('2') + ',' + QuotedStr('5') + ') ');
    SQL.Add(WHERE_IDF_Condition('PR.RP_IDENTIFIER'));
    SQL.Add('and PR.' + CreateFld(tbInfoPropRes.pfx,fli_wkCtrCode) + ' IN ' + '(' + WorkCentersList + ') ');
