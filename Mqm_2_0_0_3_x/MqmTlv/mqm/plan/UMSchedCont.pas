    SQL.Add('select ');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_preqNo) + ',');
    SQL.Add('PA.' + CreateFld(tbInfoPArt.pfx, fli_Prod_Balance) + ',');
