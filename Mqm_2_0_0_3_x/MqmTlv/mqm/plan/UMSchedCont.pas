function TMSchedCont.GetLinkInfo(id: TSchedID; var linkInfo: TSQlinkInfo): boolean;
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
begin
  Result := true;
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  if sc.m_isDeleted then
  begin
    Result := false;
    Exit;
  end;

  linkInfo.isOnPlan := Assigned(sc.m_srvPtr);

  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    job := grp.m_list[0];
    linkInfo.isGroup     := true;
    linkInfo.grpId       := CSchedIdNull;
    linkInfo.subLinRscId := -1;
    linkInfo.subLinRscId := job.m_subLinRscId;
    linkInfo.IsGenericPlan := job.m_reqDet.m_GenericPlan = '1'
  end else
  begin
    job := TSCProdSched(sc);
    linkInfo.isGroup     := false;

    if not Assigned(job.m_grp) then
      linkInfo.grpId := CSchedIdNull
    else
      linkInfo.grpId := job.m_grp.m_Id;

    linkInfo.subLinRscId := job.m_subLinRscId;
    linkInfo.IsGenericPlan := job.m_reqDet.m_GenericPlan = '1';
  end;

  linkInfo.schedStart  := sc.p_schedStart;

  Result := true
end;


