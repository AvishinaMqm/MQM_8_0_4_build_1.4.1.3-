function TMSchedCont.GetProgInfo(id: TSchedID; var ProgInfo: TSQProgInfo): boolean;
var
  sc:  TSCSchedOnPlan;
  FirstJob, job: TSCProdSched;
  grp: TSCProdGroup;
  i: integer;
  AreProgressesDifferent, HostAreProgressesDifferent : boolean;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
//  Assert(id = sc.m_Id);
  if not (id = sc.m_Id) then Exit;
  job := nil;
  grp := nil;
  Result := true;

  if not (sc is TSCProdGroup) then
  begin
    job := TSCProdSched(sc);
    ProgInfo.PrgSt          := job.m_PrgSt;
    ProgInfo.PrgCurDt       := job.m_PrgCurDt;
    ProgInfo.PrEd           := job.m_PrgEd;
    ProgInfo.PrgQty         := job.m_PrgQty;
    ProgInfo.PrgStartingQty := job.m_PrgStartingQty;
    ProgInfo.PrgStartingQtyOrig := job.m_PrgStartingQtyOrig;
    ProgInfo.PrgRemTime     := job.m_PrgRemTime;
    ProgInfo.ProgType       := job.m_ProgType;
    ProgInfo.ProgRsc        := job.m_ProgRsc;
    ProgInfo.ProgTypeHost   := job.m_ProgTypeHost;
    ProgInfo.ProgRscHost    := job.m_ProgRscHost;
    ProgInfo.PrgStHost      := job.m_PrgStHost;
    ProgInfo.PrgCurDtHost   := job.m_PrgCurDtHost;
    ProgInfo.PrEdHost       := job.m_PrgEdHost;
    ProgInfo.PrgQtyHost     := job.m_PrgQtyHost;
    ProgInfo.PrgRemTimeHost := job.m_PrgRemTimeHost;
    ProgInfo.JobProgSaved   := job.m_ProgSaved;

    if progInfo.ProgType = '1' then
      ProgInfo.ProgressStatus := prg_Starting
    else if progInfo.ProgType = '2' then
      ProgInfo.ProgressStatus := prg_General
    else if progInfo.ProgType = '3' then
      ProgInfo.ProgressStatus := prg_Final
    else if (progInfo.ProgType = '4') or (progInfo.ProgType = '5') then
      ProgInfo.ProgressStatus := prg_FinalSplit
    else
      ProgInfo.ProgressStatus := prg_none;

    exit;
  end;

  AreProgressesDifferent := false;
  HostAreProgressesDifferent := false;

  grp := TSCProdGroup(sc);
  for i := 0 to grp.m_list.Count - 1 do
  begin
    job := grp.m_list[i];

    if I = 0 then
      FirstJob := grp.m_list[i];

    if (job.m_ProgType <> Firstjob.m_ProgType) then
      AreProgressesDifferent := true
    else
    begin
      if (job.m_ProgType <> '') then
      begin
        if (job.m_ProgRsc <> Firstjob.m_ProgRsc)
        or (job.m_PrgSt <> Firstjob.m_PrgSt)
        or (job.m_PrgEd <> Firstjob.m_PrgEd) then
          AreProgressesDifferent := true;
      end;
    end;

    if (job.m_ProgTypeHost <> Firstjob.m_ProgTypeHost) then
      HostAreProgressesDifferent := true
    else
    begin
      if (job.m_ProgTypeHost <> '') then
      begin
        if (job.m_ProgRscHost <> Firstjob.m_ProgRscHost)
        or (job.m_PrgStHost <> Firstjob.m_PrgStHost)
        or (job.m_PrgEdHost <> Firstjob.m_PrgEdHost) then
          HostAreProgressesDifferent := true;
      end;
    end;

    if (i = 0) or ((job.m_ProgType <> '') and (ProgInfo.ProgType = '')) then
    begin
      ProgInfo.ProgRsc        := job.m_ProgRsc;
      ProgInfo.PrgSt          := job.m_PrgSt;
      ProgInfo.PrgCurDt       := job.m_PrgCurDt;
      ProgInfo.PrEd           := job.m_PrgEd;
      ProgInfo.PrgQty         := job.m_PrgQty;
      ProgInfo.PrgStartingQty := job.m_PrgStartingQty;
      ProgInfo.PrgStartingQtyOrig := job.m_PrgStartingQtyOrig;
      ProgInfo.PrgRemTime     := job.m_PrgRemTime;
    end;
    if (i = 0) or ((job.m_ProgTypeHost <> '') and (ProgInfo.ProgTypeHost = '')) then
    begin
      ProgInfo.ProgRscHost    := job.m_ProgRscHost;
      ProgInfo.PrgStHost      := job.m_PrgStHost;
      ProgInfo.PrgCurDtHost   := job.m_PrgCurDtHost;
      ProgInfo.PrEdHost       := job.m_PrgEdHost;
      ProgInfo.PrgQtyHost     := job.m_PrgQtyHost;
      ProgInfo.PrgRemTimeHost := job.m_PrgRemTimeHost;
    end;
    if (i = 0) then
    begin
      ProgInfo.ProgType       := job.m_ProgType;
      ProgInfo.ProgTypeHost   := job.m_ProgTypeHost;
      Continue;
    end;

    if (job.m_ProgType = '') and (ProgInfo.ProgType <> '') and (ProgInfo.ProgType <> '1') then
      ProgInfo.ProgType := '2';

    if job.m_ProgType <> '' then
    begin

      if ProgInfo.ProgType = '' then
      begin
        if (job.m_ProgType = '1') or (job.m_ProgType = '2') then
          ProgInfo.ProgType := job.m_ProgType
        else
          ProgInfo.ProgType := '2';
      end;

      if job.m_ProgType <> ProgInfo.ProgType then
        ProgInfo.ProgType := '2';

      if (job.m_PrgSt > 0) and (job.m_PrgSt < ProgInfo.PrgSt) then
        ProgInfo.PrgSt := job.m_PrgSt;

      if (job.m_PrgCurDt > 0) and (job.m_PrgCurDt > ProgInfo.PrgCurDt) then
        ProgInfo.PrgCurDt := job.m_PrgCurDt;

      if (job.m_PrgEd > 0) and (job.m_PrgEd > ProgInfo.PrEd) then
        ProgInfo.PrEd := job.m_PrgEd;

      ProgInfo.PrgQty := ProgInfo.PrgQty + job.m_PrgQty;

      if job.m_PrgStartingQty > ProgInfo.PrgStartingQty then
        ProgInfo.PrgStartingQty := job.m_PrgStartingQty;

      if job.m_PrgStartingQtyOrig > ProgInfo.PrgStartingQtyOrig then
        ProgInfo.PrgStartingQtyOrig := job.m_PrgStartingQtyOrig;

      if job.m_PrgRemTime = -1  then
        ProgInfo.PrgRemTime := -1
      else
      begin
        if ProgInfo.PrgRemTime <> -1 then
          ProgInfo.PrgRemTime := ProgInfo.PrgRemTime + job.m_PrgRemTime;
      end;

    end;

    if (job.m_ProgTypeHost = '') and (ProgInfo.ProgTypeHost <> '') and (ProgInfo.ProgTypeHost <> '1') then
      ProgInfo.ProgTypeHost := '2';

    if job.m_ProgTypeHost <> '' then
    begin
      if ProgInfo.ProgTypeHost = '' then
      begin
        if (job.m_ProgTypeHost = '1') or (job.m_ProgTypeHost = '2') then
          ProgInfo.ProgTypeHost := job.m_ProgTypeHost
        else
          ProgInfo.ProgTypeHost := '2';
      end;

      if job.m_ProgTypeHost <> ProgInfo.ProgTypeHost then
        ProgInfo.ProgTypeHost := '2';

      if (job.m_PrgStHost > 0) and (job.m_PrgStHost < ProgInfo.PrgStHost) then
        ProgInfo.PrgStHost := job.m_PrgStHost;

      if (job.m_PrgCurDtHost > 0) and (job.m_PrgCurDtHost > ProgInfo.PrgCurDtHost) then
        ProgInfo.PrgCurDtHost := job.m_PrgCurDtHost;

      if (job.m_PrgEdHost > 0) and (job.m_PrgEdHost > ProgInfo.PrEdHost) then
        ProgInfo.PrEdHost := job.m_PrgEdHost;

      ProgInfo.PrgQtyHost := ProgInfo.PrgQtyHost + job.m_PrgQtyHost;

      if job.m_PrgRemTimeHost = -1  then
        ProgInfo.PrgRemTimeHost := -1
      else
      begin
        if ProgInfo.PrgRemTimeHost <> -1 then
          ProgInfo.PrgRemTimeHost := ProgInfo.PrgRemTimeHost + job.m_PrgRemTimeHost;
      end;
    end;

  end;

  if progInfo.ProgType = '1' then
    ProgInfo.ProgressStatus := prg_Starting
  else if progInfo.ProgType = '2' then
    ProgInfo.ProgressStatus := prg_General
  else if progInfo.ProgType = '3' then
    ProgInfo.ProgressStatus := prg_Final
  else if (progInfo.ProgType = '4') or (progInfo.ProgType = '5') then
    ProgInfo.ProgressStatus := prg_FinalSplit
  else
    ProgInfo.ProgressStatus := prg_none;

  if (AreProgressesDifferent or HostAreProgressesDifferent) and (Firstjob.m_reqDet.m_stepType = CST_batch) then
  begin
    for i := 0 to grp.m_list.Count - 1 do
    begin
      job := grp.m_list[i];
      if AreProgressesDifferent then
      begin
        job.m_ProgType := progInfo.ProgType;
        job.m_ProgRsc := ProgInfo.ProgRsc;
        job.m_PrgSt := ProgInfo.PrgSt;
        job.m_PrgCurDt := ProgInfo.PrgCurDt;
        job.m_PrgEd := ProgInfo.PrEd;
        job.m_PrgRemTime := -1;
      end;
      if HostAreProgressesDifferent then
      begin
        job.m_ProgTypeHost := progInfo.ProgTypeHost;
        job.m_ProgRscHost := ProgInfo.ProgRscHost;
        job.m_PrgStHost := ProgInfo.PrgStHost;
        job.m_PrgCurDtHost := ProgInfo.PrgCurDtHost;
        job.m_PrgEdHost := ProgInfo.PrEdHost;
        job.m_PrgRemTimeHost := -1;
      end;
    end;
  end;

end;

