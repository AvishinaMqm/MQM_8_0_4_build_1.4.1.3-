procedure TMSchedCont.LoadRandom(lev1, lev2, lev3, propNum: integer;
                                 wkcProcData: TStringList);
var
  hdr, det, job: integer;
  tHdr:          TSCProdReqHdr;
  tDet:          TSCProdReqDet;
  Tjob:          TSCProdSched;
  lev1Calc,
  lev2Calc,
  lev3Calc:      integer;
  ndx:           integer;
  prop:          integer;
  propCorr:      integer;
  propVal:       string;
  pId:           TPropId;
begin
  Clear;

  // add the production request headers
  lev1Calc := 1 + lev1 - (lev1 div 3) + random(2 * (lev1 div 3));

  for hdr := 0 to lev1Calc-1 do
  begin
    tHdr := AddReqHdr(IntToStr(hdr));

    // add the data to the header
    tHdr.m_prodLine      := '0';
    tHdr.m_prodType      := '1';
    tHdr.m_prodUMCode    := 'm';
    tHdr.m_NumOfDecimals := GetUmNumOfDecimals(tHdr.m_prodUMCode);
    tHdr.m_prodDelivDate := Now + 30;

    // add the production request details
    lev2Calc := 1 + lev2 - (lev2 div 3) + random(2 * (lev2 div 3));

    for det := 1 to lev2Calc-1 do
    begin
      tDet := AddReqDet(tHdr, det);

      // add the data to the detail
      case random(3) of
      0: tDet.m_stepType := CST_batch;
      1: tDet.m_stepType := CST_continuous;
      else
        tDet.m_stepType := CST_printing
      end;
      tDet.m_materialArrivDate := Now;
      tDet.m_planStart         := Now;
      tDet.m_lowStartTimeLimit := Now;
      tDet.m_planEnd           := Now + 20;
      tDet.m_highEndTimeLimit  := Now + 40;
      tDet.m_calCod            := 'GEN';
      tDet.m_quantInit         := 100.0 + random(5000);
      tDet.m_quantFinl         := tDet.m_quantInit + 200.0;
      tDet.m_weight            := 50.0;

      ndx := random(wkcProcData.Count);
      tDet.m_planWkctr         := wkcProcData.Names[ndx];
      tDet.m_planWkctrProc     := Copy(wkcProcData[ndx], Pos('=', wkcProcData[ndx])+1, 200);

      // add the properties
      prop := 1 + propNum - (propNum div 3) + random(2 * (propNum div 3));

      if prop > (GetPropertyCount div 2) then
        prop := GetPropertyCount div 2;

      for propCorr := 0 to prop-1 do
      begin
        repeat
          pId := GetPropFromPos(propCorr);
        until not tDet.m_propList.HasProperty(pId);

        if IsPropAlpha(pId) then
          propVal := 'PV ' + Format('%3d', [random(200)])
        else
          propVal := FloatToStr(Random(100) + Random(200)/1000);
        tDet.m_propList.AddProperty(GetPropCodeFromID(pId), '', propVal)
      end;

      // add the jobs
      lev3Calc := 1 + lev3 - (lev3 div 3) + random(2 * (lev3 div 3));

      for job := 1 to lev3Calc-1 do
      begin
        if random(30) < 5 then
          tJob := TSCProdSched(AddJobDet(tDet, job, random(15)))
        else
          tJob := TSCProdSched(AddJobDet(tDet, job, CSnoGroupDef));

        // add the data to the job
        tJob.m_fromPD         := true;
        tJob.m_status         := CSS_none;
        tJob.m_subLinRscId    := 0;
        tJob.p_quantSched     := tDet.m_quantInit / lev3Calc;
        tJob.p_schedStart     := Now;
        tJob.p_schedEnd       := Now + 40;
        tJob.m_srvPtr         := nil;
        tJob.m_reprocNo       := 0;
        tJob.p_SetStepType    := '1';
        tJob.m_comment        := 'comment';

//        tJob.m_PlanedwkCtrCode      := tDet.m_planWkctr;   //  Get The default value of PD
//        tJob.m_ActualWrkCtrProc        := tDet.m_planWkctrProc;  //  Get The default value of PD
        tJob.p_exeMin         := (1 + random(10*24) / 24) * 24 * 60;
        tJob.p_supMinBase     := tJob.p_exeMin / 5 * (1 + random(3));
        tJob.p_supMinReal     := tJob.p_supMinBase;
        tJob.p_supMinOvlp     := 0;
        tJob.m_fwdConnSubStp  := 0;
        tJob.m_fwdConnReProcs := 0;
        tJob.m_bkwConnSubStp  := 0;
        tJob.m_bkwConnReProcs := 0;
        tJob.p_NewSetup  := -1;
      end
    end
  end
end;

