      SqlUpdate :=  SqlUpdate + ' AND';
      SqlUpdate :=  SqlUpdate + ' PS_REPROC_NO = :PS_REPROC_NO';
    end;

    SQL.Clear;
    qry.sql.text := SqlUpdate;

    arraysize := -1;

    for ph := 0 to m_prodReqList.Count-1 do
    begin
      if Assigned(ProgBar) then
         ProgBar.SetPosition(ph);

      if arraysize >= 1000 then
      begin
        qry.execute(arraysize + 1);
        SQL.Clear;
        qry.sql.text := SqlUpdate;
        arraysize := -1;
      end;

      if ph mod 100 = 0 then Application.ProcessMessages;
      tHdr := TSCProdReqHdr(m_prodReqList[ph]);

      for pd := 0 to tHdr.m_list.Count-1 do
      begin
        tDet := TSCProdReqDet(tHdr.m_list[pd]);

        for ps := 0 to tDet.m_list.Count-1 do
        begin
          tJob := TSCProdSched(tDet.m_list[ps]);
          if (tJob.m_status in [CSS_AfterInsert]) then
          begin
            tJob.m_status := CSS_none;
            continue;
          end;
          if (tJob.m_isDeleted) then continue;
          if (tJob.m_VisbleInBin = CSB_ReadOnly) and not tJob.m_ChangeViewWC then continue;
          if tJob.m_fromPD then continue;
          if (IsProgressed(tjob.m_Id) <> prg_none) then continue;
          if assigned(tjob.m_grp) and CanDetachGroup(tjob.m_grp.m_Id) then continue;
          // not all job updated with modi , also none might arrive.
          if (tJob.m_status in [CSS_modi]) or (tJob.m_status in [CSS_none]) then
          begin

          //  try

              if DBAppGlobals.m_Network_Stoped_Dur_Save then
                CopyBackupValuesBeforeInsert(tJob, false)
              else
                CopyBackupValuesBeforeInsert(tJob, true);

              if Assigned(tJob.m_grp) then
                GroupCode := tJob.m_grp.m_code
              else
                GroupCode := 0;
              if Assigned(tJob.m_srvPtr) then
                RscCode := fRslv(tJob.m_srvPtr)
              else
                RscCode := CVoidCharStr;

              if tJob.m_ProgType = '' then
                ExeMinutesForSave := SafeFloat(tjob.p_exeMin)
              else
                ExeMinutesForSave := SafeFloat(tJob.p_GetExeMinForSave);

              supMinBaseForSave := trunc(tJob.p_supMinBase*100)/100;
              supMinRealForSave := trunc(tJob.p_supMinReal*100)/100;
              supMinOvlpForSave := trunc(tJob.p_supMinOvlp*100)/100;

              if not tJob.m_UserReqSplitOnHost and not tJob.m_ChangeViewWC then
              begin
              if (tjob.p_rscCode_ORIGINAL = RscCode) and
                 (tjob.P_AlternativeCode_ORIGINAL = tjob.m_AlternativeCode) and
                 (tjob.p_WorkCenterCode_ORIGINAL = tJob.m_PlanWkCtrCode) and
                 (tjob.p_ProcessCode_ORIGINAL = tJob.m_PlanWrkCtrProc) and
                 (tjob.p_GroupCode_ORIGINAL = GroupCode) and
                 (tjob.p_SchedType_ORIGINAL = tJob.p_GetStepType) and
                 (tjob.p_NumSubRscComponents_ORIGINAL = tJob.m_numOfRscComp) and
                 (tjob.p_SubLinRscId_ORIGINAL = tJob.m_subLinRscId) and
                 (tjob.p_MachSetupCode_ORIGINAL = tJob.m_MachSetupCode) and
                 (tjob.p_schedStart_ORIGINAL = tJob.p_schedStart) and
                 (tjob.p_schedEnd_ORIGINAL = tJob.p_schedEnd) and
                 (tJob.p_exeMin_ORIGINAL = ExeMinutesForSave) and
                 (tjob.p_supMinBase_ORIGINAL = supMinBaseForSave) and
                 (tjob.p_supMinReal_ORIGINAL = supMinRealForSave) and
                 (tjob.p_supMinOvlp_ORIGINAL = supMinOvlpForSave) and
                 (tjob.p_quantSched_ORIGINAL = tJob.p_quantSched) and
                 (tjob.p_quantManualChg_ORIGINAL = tJob.p_quantManualChg) and
                 (tjob.p_LearningCurve_ORIGINAL = tJob.p_CurveCode) and
                 (tjob.P_VersionIdentifier_ORIGINAL = tJob.P_VersionIdentifier) and
                 (tjob.p_Comment_ORIGINAL = tjob.m_comment) and
                 (tjob.P_VersionScheduleResource_ORIGINAL = tJob.P_VersionScheduleResource) and
                 (tjob.P_VersionScheduleStart_ORIGINAL = tJob.P_VersionScheduleStart) and
                 (tjob.P_VersionScheduleEnd_ORIGINAL = tJob.P_VersionScheduleEnd) then continue;
              end;

              if IfHostDeletedJob(tJob.m_reqDet.m_hdr.m_code,tJob.m_reqDet.m_code,Unsechedule) then continue;
              if Unsechedule and assigned(tjob.m_srvPtr) then RscCode := '';

              Inc(arraysize);
              qry.params.arraysize := arraysize + 1;

              qry.params[0].asIntegers[arraysize] := updNum + 1;
              qry.params[1].asstrings[arraysize]  := RscCode;
              qry.params[2].asstrings[arraysize]  := tJob.m_AlternativeCode;

              if Assigned(tJob.m_grp) then
              begin
                if (tDet.m_stepType = CST_Continuous) and not m_GroupRecalcForUpdate.find(IntToStr(tJob.m_grp.m_Id),TempIndex) then
                begin
                  UpdContGrpTimings(tJob.m_grp.m_Id, tJob.m_grp.m_Id);
                  m_GroupRecalcForUpdate.add(IntToStr(tJob.m_grp.m_Id));
                end;
                qry.params[3].asIntegers[arraysize] := tJob.m_grp.m_code;
              end
              else
                qry.params[3].asIntegers[arraysize] := 0;

              qry.params[4].asstrings[arraysize]            := tJob.m_PlanWkCtrCode;
              qry.params[5].asstrings[arraysize]            := tJob.m_PlanWrkCtrProc;
              qry.params[6].asFloats[arraysize]             := tJob.p_qtySchdWithoutChg;//tJob.p_quantSched;
              qry.params[7].asFloats[arraysize]             := ExeMinutesForSave;
              qry.params[8].asFloats[arraysize]             := supMinBaseForSave;
              qry.params[9].asFloats[arraysize]             := supMinRealForSave;
              qry.params[10].asFloats[arraysize]            := supMinOvlpForSave;
              qry.params[11].asFloats[arraysize]            := tJob.m_subLinRscId;

              if RscCode = CVoidCharStr then
                qry.params[12].asstrings[arraysize]               := '0'
              else
                qry.params[12].asstrings[arraysize]               := tJob.p_GetStepType;


              if (tJob.m_subLinRscId = -1) then
                 qry.params[13].asIntegers[arraysize]   := 0
              else
                 qry.params[13].asIntegers[arraysize]   := tJob.m_numOfRscComp;

              if RscCode <> '' then
              begin
                if Assigned(tJob.m_grp) and (tJob.m_reqDet.m_stepType = CST_continuous) then
                begin
                  qry.params[14].asDateTimes[arraysize] := tJob.p_SchedStartOfJobInContGroup;//tJob.p_schedStart;
                  qry.params[15].asDateTimes[arraysize] := tJob.p_SchedEndOfJobInContGroup  //tJob.p_schedEnd;
                end
                else
                begin
                  qry.params[14].asDateTimes[arraysize] := tJob.p_schedStart;
                  qry.params[15].asDateTimes[arraysize] := tJob.p_schedEnd;
                end;
                p_sc.GetFldValue(tJob.m_Id , CSC_ProgStart, ActualStart, dataType);
                qry.params[16].asDateTimes[arraysize] := ActualStart;
                p_sc.GetFldValue(tJob.m_Id , CSC_ProgEnd, ActualEnd, dataType);
                qry.params[17].asDateTimes[arraysize] := ActualEnd
              end
              else
              begin
                qry.params[14].asDateTimes[arraysize]        := 0;
                qry.params[15].asDateTimes[arraysize]        := 0;
                qry.params[16].asDateTimes[arraysize]        := 0;
                qry.params[17].asDateTimes[arraysize]        := 0
              end;

              qry.params[18].asstrings[arraysize]            := tJob.m_comment;
              qry.params[19].asFloats[arraysize]             := tJob.p_quantManualChg;

              qry.params[20].asstrings[arraysize]            := IniAppGlobals.WkstCode;
              qry.params[21].asDateTimes[arraysize]          := Now;

              qry.params[22].asstrings[arraysize]            := tJob.P_wkcCodeTimingFile;
              qry.params[23].asstrings[arraysize]            := tJob.P_wkcProcTimingFile;
              qry.params[24].asstrings[arraysize]            := tJob.P_resCodeTimingFile;
              qry.params[25].asstrings[arraysize]            := tJob.P_resCatTimingFile;


              if Unsechedule and assigned(tjob.m_srvPtr) then
              begin
                 qry.params[3].asIntegers[arraysize] := CSnoGroupDef;
              end;

              qry.params[26].asstrings[arraysize] := tJob.m_SplitFamilyCode;

              qry.params[27].asstrings[arraysize] := '';
              if (tJob.m_code > 0) and (tJob.m_reqDet.m_hdr.m_LeadStepForSplit <> -1) and (tJob.m_reqDet.m_hdr.m_ConfLevels <> '') and
                 (tJob.m_reqDet.m_hdr.m_LeadStepForSplit = tJob.m_reqDet.m_code) then
              begin
                if (RscCode <> '') then
                begin
                  qry.params[27].asstrings[arraysize] := tJob.m_NewReqUniqId;
                  tJob.m_uniqueIdSavedInDB := true;
                end
                else
                begin
                  tJob.m_NewReqUniqId := '';
                end;
              end;

              qry.params[28].asDateTimes[arraysize]   := tjob.p_LastScheudleChange_ORIGINAL;
              if (RscCode = '') then
              begin
                qry.params[28].asDateTimes[arraysize] := 0;
                tJob.p_LastScheudleChange := 0;
              end
              else if (RscCode <> tjob.p_rscCode_ORIGINAL) or (tjob.p_schedStart_ORIGINAL <> tJob.p_schedStart) then
              begin
                qry.params[28].asDateTimes[arraysize]   := now;
                tJob.p_LastScheudleChange := now;
              end;

              qry.params[29].asstrings[arraysize] := tJob.p_CurveCodeSaved;
              qry.params[30].asstrings[arraysize] := tJob.p_CurveCodeByOccToOcc;

              if tJob.p_FirstScheduleResource = '' then
              begin
                tJob.p_FirstScheduleResource := RscCode;
                tJob.p_FirstScheduleStart    := qry.params[14].AsDateTimes[arraysize];
                tJob.p_FirstScheduleEnd      := qry.params[15].AsDateTimes[arraysize];

                qry.params[31].asStrings[arraysize]   := tJob.P_FirstScheduleResource;
                qry.params[32].asDateTimes[arraysize] := tJob.P_FirstScheduleStart;
                qry.params[33].asDateTimes[arraysize] := tJob.P_FirstScheduleEnd;
              end
              else
              begin
                qry.params[31].asStrings[arraysize]   := tJob.P_FirstScheduleResource;
                qry.params[32].asDateTimes[arraysize] := tJob.P_FirstScheduleStart;
                qry.params[33].asDateTimes[arraysize] := tJob.P_FirstScheduleEnd;
              end;

              qry.params[34].asStrings[arraysize]   := tJob.P_VersionIdentifier;
              qry.params[35].asStrings[arraysize]   := tJob.P_VersionScheduleResource;
              qry.params[36].AsDateTimes[arraysize] := tJob.P_VersionScheduleStart;
              qry.params[37].AsDateTimes[arraysize] := tJob.P_VersionScheduleEnd;
              qry.params[38].AsDateTimes[arraysize] := UTCNow;
              qry.params[39].asintegers[arraysize] := tJob.m_GroupAutomaticInternalSortingSequence;
              qry.params[40].asStrings[arraysize]   := tJob.m_reqDet.m_planWkctr;
              qry.params[41].asStrings[arraysize]   := tJob.m_reqDet.m_planWkctrProc;

              qry.params[42].AsFloats[arraysize]   := tJob.p_NewSetup;

              qry.params[43].asintegers[arraysize]  := strtoint(IniAppGlobals.Identifier);
              qry.params[44].asstrings[arraysize]   := tJob.m_reqDet.m_hdr.m_code;
              qry.params[45].asintegers[arraysize]  := tJob.m_reqDet.m_code;
              qry.params[46].asintegers[arraysize]  := tJob.m_code;
              qry.params[47].asintegers[arraysize]  := 0;

             // ExecSQL;

              LogChangeType := '';
              if (RscCode <> '') and (tJob.p_rscCode_ORIGINAL = '') then LogChangeType := 'S';
              if (RscCode = '') and (tJob.p_rscCode_ORIGINAL <> '') then LogChangeType := 'U';
              if (RscCode <> '') and (tJob.p_rscCode_ORIGINAL <> '') and
                   ((tJob.p_rscCode_ORIGINAL <> RscCode) or
                    (tJob.p_schedStart_ORIGINAL <> tJob.p_schedStart) or
                    (tJob.p_schedEnd_ORIGINAL <> tJob.p_schedEnd) or
                    (tJob.p_schedType_ORIGINAL <> tJob.p_GetStepType)) then LogChangeType := 'M';

              if (LogChangeType <> '') then
              begin
                if LogChangeType = 'U' then
                begin
                  LogRscCode    := tJob.p_rscCode_ORIGINAL;
                  LogSchedStart := tJob.p_schedStart_ORIGINAL;
                  LogSchedEnd   := tJob.p_schedEnd_ORIGINAL;
                  LogSchedType  := tJob.p_schedType_ORIGINAL;
                end
                else
                begin
                  LogRscCode    := RscCode;
                  LogSchedStart := tJob.p_schedStart;
                  LogSchedEnd   := tJob.p_schedEnd;
                  LogSchedType  := tJob.p_GetStepType;


                  if (LogChangeType = 'M') and (LogSchedType = '0') and (tJob.p_schedType_ORIGINAL = '2') then
                  begin
                    try
                      m_LogStr.Add(' ----------------------- ');
                      m_LogStr.Add('From save update1');
                      m_LogStr.Add('WkstCode : ' + IniAppGlobals.WkstCode);
                      m_LogStr.Add('Req : ' + tjob.m_reqDet.m_hdr.m_code);
                      m_LogStr.Add('schedType ORIGINAL : ' + tJob.p_schedType_ORIGINAL);
                      m_LogStr.Add('rscCode ORIGINAL : ' + tJob.p_rscCode_ORIGINAL);
                      m_LogStr.Add('rscCode : ' + RscCode);
                      m_LogStr.Add('SchedType_Changed_On_Start : ' + RscCode);

                      m_LogStr.Add('date and time ' + DateTimeToStr(NOW));
                      m_LogStr.Add(' ----------------------- ');

                      tJob.p_SetStepType := '2';
                      LogSchedType  := tJob.p_GetStepType;
                    except

                    end;
                  end;

                  /////////////

                end;
                AddToListLogLines(LogListInfo, 'P', tHdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo,'Upd', LogChangeType , LogRscCode,
                         LogschedStart, LogschedEnd, tJob.p_quantSched, LogSchedType, tJob.m_grpRemovedReason);
              end;

              if (tJob.p_GetStepType = '0') and (RscCode <> '') then
              begin
                //if not tJob.p_SchedType_Changed_On_Start then
                //begin
                //  tJob.p_SchedType_Changed_On_Start := true;
                  try
                    tJob.p_SetStepType := '1';
                    m_LogStr.Add(' ----------------------- ');
                    m_LogStr.Add('From Save update2');
                    m_LogStr.Add('WkstCode : ' + IniAppGlobals.WkstCode);
                    m_LogStr.Add('Req : ' + tjob.m_reqDet.m_hdr.m_code);
                    m_LogStr.Add('schedType ORIGINAL : ' + tJob.p_schedType_ORIGINAL);
                    m_LogStr.Add('rscCode ORIGINAL : ' + tJob.p_rscCode_ORIGINAL);
                    m_LogStr.Add('rscCode : ' + RscCode);
                    m_LogStr.Add('SchedType_Changed_On_Start : ' + RscCode);
                    m_LogStr.Add('date and time ' + DateTimeToStr(NOW));
                    m_LogStr.Add(' ----------------------- ');
                  except

                  end;
                //end;
              end;

              if tJob.m_status = CSS_modi then
                tJob.m_status := CSS_none;

             { except

                on E: Exception do
                begin
                  showmessage(_('Updating of') + ' ' + _('Request:') + ' ' + tJob.m_reqDet.m_hdr.m_code + ' ' + _('Step:') + IntTostr(tJob.m_reqDet.m_code) + ' ' + E.message);   // _('was ignored')
                  raise;
                end;

            end;      }

            tjob.p_rscCode_ORIGINAL := RscCode;
            tJob.p_LastScheudleChange_ORIGINAL := tJob.p_LastScheudleChange;
            tjob.P_AlternativeCode_ORIGINAL := tjob.m_AlternativeCode;
            tjob.p_WorkCenterCode_ORIGINAL := tJob.m_PlanWkCtrCode;
            tjob.p_ProcessCode_ORIGINAL := tJob.m_PlanWrkCtrProc;
            tjob.p_GroupCode_ORIGINAL := GroupCode;
            tjob.p_SchedType_ORIGINAL := tJob.p_GetStepType;
            tjob.p_NumSubRscComponents_ORIGINAL := tJob.m_numOfRscComp;
            tjob.p_SubLinRscId_ORIGINAL := tJob.m_subLinRscId;
            tjob.p_MachSetupCode_ORIGINAL := tJob.m_MachSetupCode;
            tjob.p_schedStart_ORIGINAL := tJob.p_schedStart;
            tjob.p_schedEnd_ORIGINAL := tJob.p_schedEnd;
            tjob.p_exeMin_ORIGINAL   := ExeMinutesForSave;
            tjob.p_supMinBase_ORIGINAL := supMinBaseForSave;
            tjob.p_supMinReal_ORIGINAL := supMinRealForSave;
            tjob.p_supMinOvlp_ORIGINAL := supMinOvlpForSave;
            tjob.p_quantManualChg_ORIGINAL := tJob.p_quantManualChg;
            tjob.p_quantSched_ORIGINAL := tJob.p_quantSched;
            tjob.p_Comment_ORIGINAL := tJob.m_comment;
            tjob.p_LearningCurve_ORIGINAL := tJob.p_CurveCode;
            tjob.p_Comment_ORIGINAL := tjob.m_comment;
            tjob.P_VersionIdentifier_ORIGINAL   := tJob.P_VersionIdentifier;
            tjob.P_VersionScheduleResource_ORIGINAL := tJob.P_VersionScheduleResource;
            tjob.P_VersionScheduleStart_ORIGINAL := tJob.P_VersionScheduleStart;
            tjob.P_VersionScheduleEnd_ORIGINAL   := tJob.P_VersionScheduleEnd;

          end
          else
        end
      end
    end;

    if arraysize >= 0 then
    begin
      qry.execute(arraysize + 1);
    end;

    if LogListInfo.count > 0 then
      WriteLogLineToDBFromParamList(LogListInfo, Qry);

    for I := 0 to LogListInfo.count - 1 do
      dispose(PTLogInfo(LogListInfo[I]));
    LogListInfo.free;

    // work on the Progressed
    // Application.ProcessMessages removed — prevents reentrancy wiping params
    SQL.Clear;
    SQL.Add('update ' + SuffixTblName + tbiPS.GetTableName + ' set');
    SQL.Add(CreateFld(tbiPS.pfx, fli_updCode)                   + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_updCode)             + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_quant)                     + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_quant)               + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_exeMin)                    + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_exeMin)              + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_Comment)                   + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_Comment)             + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_ChangedQuantity)           + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_ChangedQuantity)     + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_ActualStart)               + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_ActualStart)         + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_ActualEnd)                 + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_ActualEnd)           + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_usrCg)                     + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_usrCg)               + ',');
    SQL.Add(CreateFld(tbiPS.pfx, fli_usrTmCg)                   + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_usrTmCg));
    SQL.Add('where');

    SQL.Add(CreateFld(tbiPS.pfx, fli_IDENTIFIER)                + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_IDENTIFIER)          + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_preqNo)                    + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_preqNo)              + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_pstepId)                   + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_pstepId)             + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_psubstId)                  + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_psubstId)            + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_reprocNo)                  + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_reprocNo));

  //  Prepare;   // FireDAC: cannot Prepare before param values assigned (EFDException -335)
    // Application.ProcessMessages removed — prevents reentrancy wiping params

    for ph := 0 to m_prodReqList.Count-1 do
    begin
      if Assigned(ProgBar) then
        ProgBar.SetPosition(ph);

      tHdr := TSCProdReqHdr(m_prodReqList[ph]);

      for pd := 0 to tHdr.m_list.Count-1 do
      begin
        tDet := TSCProdReqDet(tHdr.m_list[pd]);

        for ps := 0 to tDet.m_list.Count-1 do
        begin
          tJob := TSCProdSched(tDet.m_list[ps]);
          if (tJob.m_isDeleted) then continue;
   //       if (IsProgressed(tjob.m_Id) = prg_none) then continue;
          if (tJob.m_VisbleInBin = CSB_ReadOnly) then continue;
          if tJob.m_fromPD then continue;
          updateActualDates := false;
          if (IsProgressed(tjob.m_Id) <> prg_none) or (assigned(tjob.m_grp) and CanDetachGroup(TJob.m_grp.m_id)) then
          begin
            p_sc.GetFldValue(tJob.m_Id , CSC_ProgStart, ActualStart, dataType);
            p_sc.GetFldValue(tJob.m_Id , CSC_ProgEnd, ActualEnd, dataType);
            if (DateTimeToStr(tJob.p_ActualStartDate_ORIGINAL) <> DateTimeToStr(ActualStart)) or
               (DateTimeToStr(tJob.p_ActualEndDate_ORIGINAL) <> DateTimeToStr(ActualEnd)) then
                updateActualDates := true;
          end;

          if not updateActualDates and (IsProgressed(tjob.m_Id) = prg_none) and not assigned(tjob.m_grp) then continue;
          if not updateActualDates and (IsProgressed(tjob.m_Id) = prg_none) and not CanDetachGroup(tjob.m_grp.m_Id) then continue;
          // not all job updated with modi , also none might arrive.
          if (tJob.m_status in [CSS_modi]) or (tJob.m_status in [CSS_none]) then
          begin

          //  try

            ExeMinutesForSave := tJob.p_GetExeMinForSave;

            if (not updateActualDates) and
               (tjob.p_quantSched_ORIGINAL = tJob.p_quantSched) and
               (tjob.p_quantManualChg_ORIGINAL = tJob.p_quantManualChg) and
               (tJob.p_exeMin_ORIGINAL = ExeMinutesForSave) and
               (tjob.p_Comment_ORIGINAL = tJob.m_comment) then continue;

            ParamByName(CreateFld(tbiPS.pfx, fli_IDENTIFIER)).AsInteger            := strtoint(IniAppGlobals.Identifier);
            ParamByName(CreateFld(tbiPS.pfx, fli_preqNo)).AsString                 := tHdr.m_code;
            ParamByName(CreateFld(tbiPS.pfx, fli_pstepId)).AsInteger               := tDet.m_code;
            ParamByName(CreateFld(tbiPS.pfx, fli_psubstId)).AsInteger              := tJob.m_code;
            ParamByName(CreateFld(tbiPS.pfx, fli_reprocNo)).AsInteger              := tJob.m_reprocNo;
            ParamByName(CreateFld(tbiPS.pfx, fli_updCode)).AsInteger               := updNum + 1;
            ParamByName(CreateFld(tbiPS.pfx, fli_quant)).AsFloat                   := tJob.p_qtySchdWithoutChg;//tJob.p_quantSched;
            ParamByName(CreateFld(tbiPS.pfx, fli_exeMin)).AsFloat                  := ExeMinutesForSave;//tJob.p_ExeMinIgnoreProgress;
            ParamByName(CreateFld(tbiPS.pfx, fli_Comment)).AsString                := tJob.m_comment;
            ParamByName(CreateFld(tbiPS.pfx, fli_ChangedQuantity)).AsFloat         := tJob.p_quantManualChg;
            ParamByName(CreateFld(tbiPS.pfx, fli_ActualStart)).AsDateTime          := ActualStart;
            ParamByName(CreateFld(tbiPS.pfx, fli_ActualEnd)).AsDateTime            := ActualEnd;
            ParamByName(CreateFld(tbiPS.pfx, fli_usrCg)).AsString                  := IniAppGlobals.WkstCode;
            ParamByName(CreateFld(tbiPS.pfx, fli_usrTmCg)).AsDateTime              := Now;

            ExecSQL;

            SqlUpdate := SQL.Text;  // save WriteLogLineToDB overwrites qry.SQL
            WriteLogLineToDB(Qry, 'U', tHdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo,'Udt', '' ,tJob.GetRscCode, 0, 0, tJob.p_quantSched, tjob.p_GetStepType, 'update/work on the Progressed');
            SQL.Text := SqlUpdate;  // restore UPDATE SQL for next iteration
            if tJob.m_status = CSS_modi then
              tJob.m_status := CSS_none;

            if updateActualDates then
            begin
              tJob.p_ActualStartDate_ORIGINAL := ActualStart;
              tJob.p_ActualEndDate_ORIGINAL := ActualEnd;
            end;
            tjob.p_exeMin_ORIGINAL   := ExeMinutesForSave;
            tjob.p_quantManualChg_ORIGINAL := tJob.p_quantManualChg;
            tjob.p_quantSched_ORIGINAL := tJob.p_quantSched;
            tjob.p_Comment_ORIGINAL := tJob.m_comment;

          {  except
              CopyUnSavedValuesToFolder(tJob, fRslv, UpdNum , SevedClickTime, false);
              showmessage(_('Updating of') + ' ' + _('Request:') + ' ' + tJob.m_reqDet.m_hdr.m_code + ' ' + _('Step:') + IntTostr(tJob.m_reqDet.m_code) + ' ' + _('was ignored'));
              continue
            end; }
          end
        end
      end
    end;

    // work on the Igrored Progressed

    Application.ProcessMessages;

    SQL.Clear;
    SQL.Add('update ' + SuffixTblName + tbiPS.GetTableName + ' set');
    SQL.Add(CreateFld(tbiPS.pfx, fli_Prog_Override_Type)        + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_Prog_Override_Type));
    SQL.Add('where');
    SQL.Add(CreateFld(tbiPS.pfx, fli_IDENTIFIER)            + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_IDENTIFIER)      + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_preqNo)                + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_preqNo)          + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_pstepId)               + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_pstepId)         + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_psubstId)              + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_psubstId)        + ' and');
    SQL.Add(CreateFld(tbiPS.pfx, fli_reprocNo)              + '=');
    SQL.Add(':' + CreateFld(tbiPS.pfx, fli_reprocNo));

  //  Prepare;   // FireDAC: cannot Prepare before param values assigned (EFDException -335)
    // Application.ProcessMessages removed — prevents reentrancy wiping params

    for ph := 0 to m_prodReqList.Count-1 do
    begin
      if Assigned(ProgBar) then
        ProgBar.SetPosition(ph);

      tHdr := TSCProdReqHdr(m_prodReqList[ph]);

      for pd := 0 to tHdr.m_list.Count-1 do
      begin
        tDet := TSCProdReqDet(tHdr.m_list[pd]);

        for ps := 0 to tDet.m_list.Count-1 do
        begin
          tJob := TSCProdSched(tDet.m_list[ps]);
          if (tJob.m_isDeleted) then continue;
          if (tJob.m_VisbleInBin = CSB_ReadOnly) then continue;
          if tJob.m_fromPD then continue;
          if (tJob.m_ProgressOverride <> Prg_Ignored) and (tJob.m_ProgressOverride <> Prg_ReApplied) then continue;
          // not all job updated with modi , also none might arrive.
          if (tJob.m_status in [CSS_modi]) or (tJob.m_status in [CSS_none]) then
          begin
            try
              ParamByName(CreateFld(tbiPS.pfx, fli_IDENTIFIER)).AsInteger          := strtoint(IniAppGlobals.Identifier);
              ParamByName(CreateFld(tbiPS.pfx, fli_preqNo)).AsString               := tHdr.m_code;
              ParamByName(CreateFld(tbiPS.pfx, fli_pstepId)).AsInteger             := tDet.m_code;
              ParamByName(CreateFld(tbiPS.pfx, fli_psubstId)).AsInteger            := tJob.m_code;
              ParamByName(CreateFld(tbiPS.pfx, fli_reprocNo)).AsInteger            := tJob.m_reprocNo;
              ParamByName(CreateFld(tbiPS.pfx, fli_Prog_Override_Type)).AsString   := '1';
              ExecSQL;
              SqlUpdate := SQL.Text;  // saveUpdateOverrideProgress + WriteLogLineToDB overwrite qry.SQL
              UpdateOverrideProgress(Qry, tJob);

              if tJob.m_ProgressOverride = Prg_Ignored then
                tJob.m_ProgressOverride := Prg_IgnoredAndSave
              else
                tJob.m_ProgressOverride := Prg_ReAppliedAndSave;
              if tJob.m_status = CSS_modi then
                tJob.m_status := CSS_none;
              WriteLogLineToDB(Qry, 'U', tHdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo,'Udt', '' ,tJob.GetRscCode, 0, 0, tJob.p_quantSched, tjob.p_GetStepType, 'update/work on the Igrored Progressed');
              SQL.Text := SqlUpdate;  // restore UPDATE SQL for next iteration

              continue;
            except

            end
          end;
        end
      end
    end;
  end;

end;

