function TMSchedCont.GetPropDinamicVal(id: TSchedID; OrigPropVal : double) : double;
var
  Precent : double;
  sc      : TSCSchedOnPlan;
  tjob    : TSCProdSched;
begin
  Result := OrigPropVal;
  if OrigPropVal = 0 then
     Exit;
  sc := TSCSchedOnPlan(m_codeList[id]);
  if not (sc is TSCProdSched) then exit;
  tjob := TSCProdSched(sc);

  if tJob.m_reqDet.m_quantInit = 0 then
  begin
    Result := 0;
    Exit;
  end;

  Precent := (100 * tjob.p_quantSched) / tJob.m_reqDet.m_quantInit;
  Result  := (Precent/100) * OrigPropVal;
end;

