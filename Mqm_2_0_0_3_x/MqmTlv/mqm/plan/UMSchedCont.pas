procedure TMSchedCont.ResetAutoSeqMaxBefore;
var
  tJob :  TSCProdSched;
  ps : TSCSchedOnPlan;
  grp : TSCProdGroup;
  i: integer;
begin
  for i := 0 to m_codeList.Count-1 do
  begin
    if Assigned(m_codeList[i]) then
    begin
      ps := m_codeList[i];
      if (ps is TSCProdSched) then
      begin
        tJob := TSCProdSched(ps);
        if Assigned(GetExtLinkPtr(tJob.m_Id)) then
          tJob.m_AutoSeqMaxBefore := -1;
        continue;
      end;

      if ps is TSCProdGroup then
      begin
        grp := TSCProdGroup(ps);
        if Assigned(GetExtLinkPtr(grp.m_Id)) then
           grp.m_AutoSeqMaxBefore := -1;
      end;
    end;
  end;
end;

