          begin
            qryWW.SQL.Clear;
            qryWW.SQL.Add('select ' + CreateFld(tbiWW.pfx, fli_TypeOfUse));
            qryWW.SQL.Add(' from ' + tbiWW.GetTableName + ' Where ');
            qryWW.SQL.Add(CreateFld(tbiWW.pfx, fli_wkstCode) + '=''' + IniAppGlobals.WkstCode + '''');
            qryWW.SQL.Add(' And ' + CreateFld(tbiWW.pfx, fli_wkCtrCode) + '=''' + PS_wkCtrCode.AsString + '''');
            qryWW.SQL.Add(AND_IDF_Condition(CreateFld(tbiWW.pfx, fli_Identifier)));
            qryWW.Open;
            if not qryWW.Eof then
              tmpStr := Trim(qryWW.FieldByName(CreateFld(tbiWW.pfx, fli_TypeOfUse)).AsString)
            else
              tmpStr := 'N'; // sentinel: not found in WW
            qryWW.Close;
            WwTypeOfUseCache.Add(Trim(PS_wkCtrCode.AsString) + '=' + tmpStr);
          end;
          if tmpStr = '2' then
            tJob.m_VisbleInBin := CSB_ReadOnly
          else if tmpStr <> 'N' then
            tJob.m_VisbleInBin := CSB_Normal;
        end
        else
        begin
          if (WW_TypeOfUse1.AsString = '2') or tJob.m_Mqm_environment then
            tJob.m_VisbleInBin := CSB_ReadOnly
          else
            tJob.m_VisbleInBin := CSB_Normal;
        end;

        FindOrAddProdSchedFromDatabase('1', tHdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo);
        tJob.m_ProdSched_ID_FromDatabase := m_ProdSchedDatabase.Count - 1;

      end
      else
      begin   //takes Jobs without PS
        tJob := CreateNewJob(tDet, 0, CSnoGroupDef);

        if not PD_SplitFamaly.IsNull then
          tJob.m_SplitFamilyCode := PD_SplitFamaly.AsString;

        if not (PD_GrpContinueSeq.IsNull) then
          tJob.P_Grp_Sequence := trim(PD_GrpContinueSeq.AsString);

        if (tDet.p_CurveType <> CSC_No) and not (PD_LearningCurveCode.IsNull) then
          tJob.p_CurveCode := PD_LearningCurveCode.AsString;

     //   tJob.p_LearningCurve_ORIGINAL := tJob.p_CurveCode;

        if (WW_TypeOfUse1.AsString = '2') then
          tJob.m_VisbleInBin := CSB_ReadOnly
        else
          tJob.m_VisbleInBin  := CSB_Normal;
        tJob.m_fromPD         := true;
        tJob.p_quantSched     := tDet.m_quantInit;

        tJob.m_GroupType :=  PD_CanGroup.AsString;
        tJob.m_forcedGrpNo := PD_ForcedGroupNo.AsInteger;
   //    tJob.m_forcedGrpNo := (-1) * tJob.m_forcedGrpNo;
        if (tJob.m_GroupType = '2') and (tJob.m_forcedGrpNo < 0) then
          AddForcedGroup(tJob.m_Id,tJob.m_forcedGrpNo);

      end;

      //LeadTime(tJob.m_Id,nil);  // get the leadtime for the current job
      if tDet.m_quantInit = 0 then
      begin
        tDet.p_LeadTimePrev := 0;
        tDet.P_LeadTimeNext := 0;
        tDet.p_LeadTimePrevBatch := 0;
        tDet.P_LeadTimeNextBatch := 0;
      end
      else
      begin
        tDet.P_LeadTimePrev := PD_PrevLeadTime.AsFloat /  tDet.m_quantInit;
        tDet.P_LeadTimeNext := PD_NextLeadTime.AsFloat /  tDet.m_quantInit;
        tDet.P_LeadTimePrevBatch := PD_PrevLeadTimeBatch.AsFloat;
        tDet.p_LeadTimeNextBatch := PD_NextLeadTimeBatch.AsFloat;
      end;


      if RS_Rsc.IsNull then
      begin
        tJob.p_SetStepType    := '0';
        tJob.p_exeMin         := 0;
        tJob.p_supMinReal     := 0;
        tJob.p_supMinOvlp     := 0;
        tJob.p_supMinBase     := 0;
        tJob.p_schedStart     := 0;
        tJob.p_schedEnd       := 0;
      end
      else
      begin
        tJob.p_SetStepType := PS_schedType.AsString;
      end;

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          //PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;
      Next;

      inc(PrgIndex);
      if PrgIndex mod 500 = 0 then
        Application.ProcessMessages;

    end;
  end;

  qry.Close;

  //---------------------------------------------------------------------------

  for I := 0 to m_prodReqList.Count - 1 do
  begin

    if Assigned(ProgBar) then
    begin
      DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
      if PrgPrevSecond <> PrgSecond then
      begin
        PrgPrevSecond := PrgSecond;
        PrgIndex := PrgIndex + PrgBlock;
        ProgBar.SetPosition(PrgIndex);
      end;
    end;

    if I mod 200 = 0 then Application.ProcessMessages;

    tHdr := TSCProdReqHdr(m_prodReqList[i]);

    for j := 0 to tHdr.m_list.Count-1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[j]);
      if (tDet.m_list.count = 1) then
      begin
        tJob := tDet.m_list[0];
        tmpqty := tJob.p_quantSched;
        if ((tJob.p_qtySchdWithoutChg <> tDet.m_quantInit) and
           ((tJob.p_qtySchdWithoutChg + tJob.p_quantManualChg ) <> tDet.m_quantInit) and
           (not tJob.m_fromPD) and  (tJob.p_GetStepType <> '') and (tJob.p_GetStepType <> '0') and
           (tDet.m_stepType = CST_continuous)) then
        begin
          tJob.p_quantSched := tDet.m_quantInit;
          tJob.p_quantManualChg := 0;
        end;

        if ( ( (tJob.p_qtySchdWithoutChg <> tDet.m_quantInit) and
               ((tJob.p_qtySchdWithoutChg + tJob.p_quantManualChg) <> tDet.m_quantInit)) or
               ((tJob.p_qtySchdWithoutChg + tJob.p_quantManualChg) = tDet.m_quantInit)) then
        begin
          tJob.p_quantSched := tDet.m_quantInit;
          tJob.p_quantManualChg := 0;
        end;

        if ((tDet.m_stepType = CST_continuous))
        and (tJob.p_quantSched <> tmpqty) and (tmpqty > 0) then
        begin
          tJob.p_exeMin := tJob.p_exeMin * tJob.p_quantSched / tmpqty;
       //   tJob.p_exeMin_ORIGINAL := tJob.p_exeMin;
        end;

      end;

    end;
  end;

  //------------------------------------------------------

  with qry do
  begin
    close;
    sql.Clear;
    sql.Add(' select * from ' + tbiSP_OVER.GetTableName);
    SQL.Add(WHERE_IDF_Condition(CreateFld(tbiSP_OVER.pfx, fli_Identifier)));
    FetchOptions.RowsetSize := 5000;
    open;
    if not Eof then
       OverrProgressList := TList.Create;
    while not Eof do
    begin
      New(RecProgOverInfo);
      RecProgOverInfo.Preq_No             := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_preqNo)).AsString;
      RecProgOverInfo.Pstep_id            := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_pstepId)).AsInteger;
      RecProgOverInfo.Psubst_id           := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_psubstId)).AsInteger;
      RecProgOverInfo.Reproc_no           := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_reprocNo)).AsInteger;
      RecProgOverInfo.ProgType            := Trim(FieldByName(CreateFld(tbiSP_OVER.pfx, fli_ProgressType)).AsString);
      RecProgOverInfo.ProgRsc             := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_rsc)).AsString;
      RecProgOverInfo.ProgGroup           := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_ProgressGroup)).AsInteger;
      RecProgOverInfo.PrgSt               := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_progrStart)).AsDateTime;
      RecProgOverInfo.PrgCurDt            := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_prgCurrDate)).AsDateTime;
      RecProgOverInfo.PrEd                := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_progrEnd)).AsDateTime;
      RecProgOverInfo.PrgQty              := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_quant)).AsFloat;
      RecProgOverInfo.PrgStartingQty      := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_StartingQty)).AsFloat;
      RecProgOverInfo.PrgRemTime          := FieldByName(CreateFld(tbiSP_OVER.pfx, fli_prgRemTime)).AsFloat;

      if FieldByName(CreateFld(tbiSP_OVER.pfx, fli_ProgressReApplied)).AsString = '1' then
         RecProgOverInfo.ProgressReApplied := true
      else
        RecProgOverInfo.ProgressReApplied := false;
      OverrProgressList.add(RecProgOverInfo);

      if Assigned(ProgBar) then
      begin
        DecodeTime(Now, PrgHour, PrgMinute, PrgSecond, PrgMilliSecond);
        if PrgPrevSecond <> PrgSecond then
        begin
          PrgPrevSecond := PrgSecond;
          PrgIndex := PrgIndex + PrgBlock;
          ProgBar.SetPosition(PrgIndex);
        end;
      end;

      Next;

    end;

  end;

  qry.close;

  //------------------------------------------------------

  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    PrgIndex := 0;
  end;

  if Assigned(Status) then
    Status.Caption := _('Reading Progresses from database...');
  Application.ProcessMessages;

  // Organize in list all progress
  //-------------------------------------------------------

  ProgInfoList := TList.Create;

  with qry.sql do
  begin
    Clear;
    Add('select ' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_preqNo) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_pstepId) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_psubstId) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_reprocNo) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_ProgressType) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_progrStart) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_prgCurrDate) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_progrEnd) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_rsc) + ',' +
      tbiSP.GetTableName + '.' + CreateFld(tbiSP.pfx, fli_quant) + ',' +
      tbiPD.GetTableName + '.' + CreateFld(tbiPD.pfx, fli_StepType) + ',');
    Add(tbiPD.GetTableName + '.' + CreateFld(tbiPD.pfx, fli_ForcedGroupNo) + ',');
    Add(tbiPD.GetTableName + '.' + CreateFld(tbiPD.pfx, fli_GrpContinueSeq) + ',');
    Add(tbiPS.GetTableName + '.' + CreateFld(tbiPS.pfx, fli_subLinRscId) + ',');
    Add(tbiPS.GetTableName + '.' + CreateFld(tbiPS.pfx, fli_stGroup));
    Add(' from ' + tbiSP.GetTableName);

    if DBAppGlobals.MCM_App then
    begin
      Add(' join ' + tbiPD.GetTableName + ' on ' +
         CreateFld(tbiPD.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier) + ' AND ' +
         CreateFld(tbiPD.pfx, fli_SchedulByMcm) + '=''' + '1' + '''' + ' AND ' +
         CreateFld(tbiPD.pfx, fli_preqNo) + '=' + CreateFld(tbiSP.pfx, fli_preqNo) + ' AND ' +
         CreateFld(tbiPD.pfx, fli_pstepId) + '=' + CreateFld(tbiSP.pfx, fli_pstepId))
    end
    else
    begin
      Add(' join ' + tbiPD.GetTableName + ' on ' +
         CreateFld(tbiPD.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier) + ' AND ' +
         CreateFld(tbiPD.pfx, fli_SchedulByMqm) + '=''' + '1' + '''' + ' AND ' +
         CreateFld(tbiPD.pfx, fli_preqNo)  + '=' + CreateFld(tbiSP.pfx, fli_preqNo) + ' AND ' +
         CreateFld(tbiPD.pfx, fli_pstepId) + '=' + CreateFld(tbiSP.pfx, fli_pstepId));
    end;

    Add(' join ' + tbiWW.GetTableName + ' on ' +
         CreateFld(tbiWW.pfx, fli_Identifier) + '=' + CreateFld(tbiPD.pfx, fli_Identifier) + ' AND ' +
         CreateFld(tbiWW.pfx, fli_wkstCode)  + '=''' + IniAppGlobals.WkstCode + '''' + ' AND ' +
         CreateFld(tbiWW.pfx, fli_Visible)  + '<>''' + '0' + '''' + ' AND ' +
         CreateFld(tbiWW.pfx, fli_wkCtrCode) + '=' + CreateFld(tbiPD.pfx, fli_wkCtrCode));
    Add(' join ' + tbiRS.GetTableName + ' on ' + CreateFld(tbiRS.pfx, fli_rsc) + '=' + CreateFld(tbiSP.pfx, fli_rsc));
    Add(' AND ' + CreateFld(tbiRS.pfx, fli_Identifier) + '=' + CreateFld(tbiSP.pfx, fli_Identifier));
    Add(' left join ' + tbiPS.GetTableName + ' on ' + CreateFld(tbiPS.pfx, fli_Identifier)   + '=' + CreateFld(tbiSP.pfx, fli_Identifier) + ' AND ' +
                                                CreateFld(tbiPS.pfx, fli_preqNo)   + '=' + CreateFld(tbiSP.pfx, fli_preqNo) + ' AND ' +
                                                CreateFld(tbiPS.pfx, fli_pstepId)  + '=' + CreateFld(tbiSP.pfx, fli_pstepId) + ' AND ' +
                                                CreateFld(tbiPS.pfx, fli_psubstId) + '=' + CreateFld(tbiSP.pfx, fli_psubstId) + ' AND ' +
                                                CreateFld(tbiPS.pfx, fli_reprocNo) + '=' + CreateFld(tbiSP.pfx, fli_reprocNo));
    Add(WHERE_IDF_Condition(CreateFld(tbiSP.pfx, fli_Identifier)));
    // ORDER BY removed � Pascal re-sorts with SortProgress after fetch
    qry.FetchOptions.RowsetSize := 5000;
    qry.open;

    SP_preqNo       := qry.FieldByName(CreateFld(tbiSP.pfx, fli_preqNo));
    SP_pstepId      := qry.FieldByName(CreateFld(tbiSP.pfx, fli_pstepId));
    SP_psubstId     := qry.FieldByName(CreateFld(tbiSP.pfx, fli_psubstId));
    SP_reprocNo     := qry.FieldByName(CreateFld(tbiSP.pfx, fli_reprocNo));
    SP_ProgressType := qry.FieldByName(CreateFld(tbiSP.pfx, fli_ProgressType));
    SP_progrStart   := qry.FieldByName(CreateFld(tbiSP.pfx, fli_progrStart));
    SP_prgCurrDate  := qry.FieldByName(CreateFld(tbiSP.pfx, fli_prgCurrDate));
    SP_progrEnd     := qry.FieldByName(CreateFld(tbiSP.pfx, fli_progrEnd));
    SP_progQty      := qry.FieldByName(CreateFld(tbiSP.pfx, fli_quant));
    SP_rsc          := qry.FieldByName(CreateFld(tbiSP.pfx, fli_rsc));
    PS_stGroup      := qry.FieldByName(CreateFld(tbiPS.pfx, fli_stGroup));
    PS_subLinRscId  := qry.FieldByName(CreateFld(tbiPS.pfx, fli_subLinRscId));
    PD_StepType     := qry.FieldByName(CreateFld(tbiPD.pfx, fli_StepType));
    PD_ForcedGroupNo := qry.FieldByName(CreateFld(tbiPD.pfx, fli_ForcedGroupNo));
    PD_GrpContinueSeq := qry.FieldByName(CreateFld(tbiPD.pfx, fli_GrpContinueSeq));

    ValidRscCache := TStringList.Create;
    ValidRscCache.NameValueSeparator := '=';

    while not Qry.Eof do
    begin

      tmpStr := Trim(SP_rsc.AsString);
      J := ValidRscCache.IndexOfName(tmpStr);
      if J >= 0 then
      begin
        if ValidRscCache.ValueFromIndex[J] = '0' then
        begin Qry.Next; Continue; end;
      end
      else
      begin
        if TMqmRes(p_pl.FindResByCode(tmpStr)) = nil then
        begin
          ValidRscCache.Add(tmpStr + '=0');
          Qry.Next; Continue;
        end;
        ValidRscCache.Add(tmpStr + '=1');
      end;

      new(PTProgInfo);
      PTProgInfo.preqNo    := SP_preqNo.AsString;
      PTProgInfo.pstepId   := SP_pstepId.AsInteger;
      PTProgInfo.psubstId  := SP_psubstId.AsInteger;
      PTProgInfo.reprocNo  := SP_reprocNo.AsInteger;
      PTProgInfo.ProgType  := SP_ProgressType.AsString;
      PTProgInfo.PrgSt     := SP_progrStart.AsDateTime;
      PTProgInfo.PrgCurDt  := SP_prgCurrDate.AsDateTime;
      PTProgInfo.PrEd      := SP_progrEnd.AsDateTime;
      PTProgInfo.ProgRsc   := Trim(SP_rsc.AsString);
      PTProgInfo.StepTypePD := PD_StepType.AsString;
      PTProgInfo.PrgQty    := SP_progQty.AsFloat;
      PTProgInfo.GroupNumberPS := -1;
      if not PS_stGroup.IsNull then
        PTProgInfo.GroupNumberPS := PS_stGroup.AsInteger;
      PTProgInfo.StepTypePD := PD_StepType.AsString;
      PTProgInfo.ForcedGroupPD := PD_ForcedGroupNo.AsInteger;
      PTProgInfo.GrpContinueSeqPD := '';
      if not (PD_GrpContinueSeq.IsNull) then
         PTProgInfo.GrpContinueSeqPD := Trim(PD_GrpContinueSeq.AsString);
      PTProgInfo.SubResourcePS := 0;
      if not (PS_subLinRscId.IsNull) then
         PTProgInfo.SubResourcePS := PS_subLinRscId.AsInteger;
      Progresses_Index := ProgInfoList.Add(PTProgInfo);
      Qry.Next
    end;

  {  I1 := -1;
    while true do
    begin
      I1 := I1 + 1;
      if I1 >= Progresses_Index then break;
      PTProgInfo := PTSQProgInfo(ProgInfoList[I1]);
      NextPTProgInfo := PTSQProgInfo(ProgInfoList[I1 + 1]);
      Overlapping := false;
      if (NextPTProgInfo.ProgRsc <> PTProgInfo.ProgRsc) or
         ((NextPTProgInfo.SubResourcePS <> PTProgInfo.SubResourcePS) and
          (NextPTProgInfo.SubResourcePS > 0)) then continue;
      if  (PTProgInfo.ForcedGroupPD <> 0)
      and (PTProgInfo.ForcedGroupPD = NextPTProgInfo.ForcedGroupPD)
      and (PTProgInfo.GrpContinueSeqPD = NextPTProgInfo.GrpContinueSeqPD) then continue;
      if (PTProgInfo.StepTypePD = 'B') or (PTProgInfo.StepTypePD = 'H') or (PTProgInfo.StepTypePD = 'P') then continue;

      if PTProgInfo.ProgType = '1' then
      begin
        PTProgInfo.PrgCurDt := PTProgInfo.PrgSt + (1 /24 /60/60);
        PTProgInfo.PrEd := PTProgInfo.PrgSt + (1 /24 /60/60);
        PTProgInfo.ProgType := '3'
      end
      else if PTProgInfo.ProgType = '2' then
      begin
        PTProgInfo.PrEd := PTProgInfo.PrgCurDt;
        PTProgInfo.ProgType := '3'
      end;

      if (NextPTProgInfo.PrgSt <= PTProgInfo.PrEd) then
      begin
        PTProgInfo.PrgCurDt := NextPTProgInfo.PrgSt - (1 /24 /60/60);
        PTProgInfo.PrEd := NextPTProgInfo.PrgSt - (1 /24 /60/60);
      end;

      if (PTProgInfo.PrgSt >= PTProgInfo.PrEd) then
      begin
        PTProgInfo.PrgSt := PTProgInfo.PrEd - (1 /24 /60/60);
        Overlapping := true;
      end;

      if PTProgInfo.ForcedGroupPD <> 0 then
      begin
        I := I1;
        while true do
        begin
          if I = 0 then break;
          CurrentPTProgInfo := PTSQProgInfo(ProgInfoList[I]);
          I := I - 1;
          PrevPTProgInfo := PTSQProgInfo(ProgInfoList[I]);
          if PrevPTProgInfo.ProgRsc <> CurrentPTProgInfo.ProgRsc then break;
          if PrevPTProgInfo.SubResourcePS <> CurrentPTProgInfo.SubResourcePS then break;
          if PrevPTProgInfo.ForcedGroupPD <> CurrentPTProgInfo.ForcedGroupPD then break;
          if PrevPTProgInfo.GrpContinueSeqPD <> CurrentPTProgInfo.GrpContinueSeqPD then break;
          PrevPTProgInfo.PrEd := CurrentPTProgInfo.PrEd;
          PrevPTProgInfo.PrgCurDt := CurrentPTProgInfo.PrgCurDt;
          PrevPTProgInfo.PrgSt := CurrentPTProgInfo.PrgSt;
          PrevPTProgInfo.ProgType := CurrentPTProgInfo.ProgType;
        end;
      end;
      I := I1;
      while Overlapping do
      begin
        if I = 0 then break;
        CurrentPTProgInfo := PTSQProgInfo(ProgInfoList[I]);
        I := I - 1;
        PrevPTProgInfo := PTSQProgInfo(ProgInfoList[I]);
        if PrevPTProgInfo.ProgRsc <> CurrentPTProgInfo.ProgRsc then break;
        if PrevPTProgInfo.SubResourcePS <> CurrentPTProgInfo.SubResourcePS then break;
        if PrevPTProgInfo.PrEd < CurrentPTProgInfo.PrgSt then break;

        if  (CurrentPTProgInfo.ForcedGroupPD <> 0)
        and (CurrentPTProgInfo.ForcedGroupPD = PrevPTProgInfo.ForcedGroupPD)
        and (CurrentPTProgInfo.GrpContinueSeqPD = PrevPTProgInfo.GrpContinueSeqPD) then
        begin
          PrevPTProgInfo.PrEd := CurrentPTProgInfo.PrEd;
          PrevPTProgInfo.PrgCurDt := CurrentPTProgInfo.PrgCurDt;
          PrevPTProgInfo.PrgSt := CurrentPTProgInfo.PrgSt;
        end
        else
        begin
          PrevPTProgInfo.PrEd := CurrentPTProgInfo.PrgSt - (1 /24 /60/60);
          PrevPTProgInfo.PrgCurDt := CurrentPTProgInfo.PrgSt - (1 /24 /60/60);
          if PrevPTProgInfo.PrgSt < PrevPTProgInfo.PrEd then break;
          PrevPTProgInfo.PrgSt := PrevPTProgInfo.PrEd - (1 /24 /60/60);
        end;

      end;
    end;  }

    qry.Close;
    ValidRscCache.Free;
    ValidRscCache := nil;
    Application.ProcessMessages;
    ProgInfoList.Sort(SortProgress);
    Application.ProcessMessages;

  end;

//-------------------------------------------------------

  Application.ProcessMessages;

  // Do not delete ever this sql , otherwise can cause problems for the next one ...
(*
  with qry.SQL do
  begin
    Clear;
    Add('select * from ' + tbiSP.GetTableName);
    qry.open;
    Application.ProcessMessages;
    if qry.EOF then
    begin
      qry.close;
      qry.Transaction.Commit;
      qryWW.Free;
      Exit;
    end;
  end;
*)
  qryST := CreateQuery(Main_DB);

  { Update all progresses of steps. If a progress exist and the step is not scheduled,
    there is also a need to take the execution time from MMQST }

  with qry.sql do
  begin
    Clear;
    Add('select ' + tbiSP.GetTableName + '.*,' + tbiPD.GetTableName + '.*,' + tbiWW.GetTableName + '.*,' + tbiPS.GetTableName + '.*,');
    Add(CreateFld(tbiRS.pfx, fli_NumOfRsc) + ', ');
    Add('PST0.' + CreateFld(tbiST.pfx, fli_SetUpTimJob) + ' as ST_Setup0, ');
    Add('PST0.' + CreateFld(tbiST.pfx, fli_ExecTimeInitQty) + ' as ST_Exec0, ');
    Add('PST1.' + CreateFld(tbiST.pfx, fli_SetUpTimJob) + ' as ST_Setup1, ');
    Add('PST1.' + CreateFld(tbiST.pfx, fli_ExecTimeInitQty) + ' as ST_Exec1, ');
