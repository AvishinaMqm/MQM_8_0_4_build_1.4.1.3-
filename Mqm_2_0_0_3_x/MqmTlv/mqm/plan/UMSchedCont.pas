procedure TMSchedCont.GetALLStepBrothersForGrouping(id : TSchedId ; SchedList : TMSchedList; CheckScheduled : boolean);
var
  job,JobBrother:    TSCProdSched;
  sc : TSCSchedOnPlan;
  grp : TSCProdGroup;
  ReqHdr: TSCProdReqHdr;
  CurrStep,I,J  : Integer;
  wkc         : TMqmWrkCtr;
  GroupingType: CGroupingType;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdGroup then
  begin
    grp := TSCProdGroup(sc);
    job := TSCProdSched(grp.m_list[0]);
  end
  else
    job := TSCProdSched(m_codeList[id]);

  CurrStep := job.m_reqDet.m_code;
  ReqHdr := TSCProdReqHdr(job.m_reqDet.m_hdr);

  GroupingType := TMqmWrkCtr(job.p_WrkCtrPtr).GetGroupType(job.p_Process);

  for I := 0 to ReqHdr.m_list.Count - 1 do
  begin

    if (GroupingType = MultiStepForward_grp) then
    begin
      if (CurrStep <= TSCProdReqDet(ReqHdr.m_list[I]).m_code) then continue;
    end
    else if (GroupingType = MultiStepBackward_grp) then
    begin
      if (CurrStep >= TSCProdReqDet(ReqHdr.m_list[I]).m_code) then continue;
    end
    else if (GroupingType = MultiStepForwardBackward_grp) then
    begin
      if (CurrStep = TSCProdReqDet(ReqHdr.m_list[I]).m_code) then continue;
    end;

    if (TSCProdReqDet(ReqHdr.m_list[I]).p_Count > 1) then
    begin
      SchedList.ClearList;
      exit
    end;

    if (TSCProdReqDet(ReqHdr.m_list[I]).p_Count = 1) then
    begin

      JobBrother := nil;
      for J := 0 to (TSCProdReqDet(ReqHdr.m_list[I]).m_list.count) - 1 do
      begin
        JobBrother := TSCProdSched(TSCProdReqDet(ReqHdr.m_list[I]).m_list[J]);
        if JobBrother.m_isDeleted then
          continue
        else
          break
      end;

      if (JobBrother.m_VisbleInBin = CSB_ReadOnly) or (JobBrother.m_VisbleInBin = CSB_NotVisible) then continue;

      if CheckScheduled and Assigned(GetExtLinkPtr(JobBrother.m_Id)) then
      begin
        SchedList.ClearList;
        exit
      end;

      wkc := TMqmWrkCtr(p_sc.GetWrkCtrPtr(JobBrother.m_Id));
      if assigned(wkc) then
      begin
        if (wkc.GetGroupType(JobBrother.p_Process) = No_grp) then
          exit
        else if (wkc.GetGroupType(JobBrother.p_Process) = FromOtherStep_grp) then
          SchedList.AddLink(TSCProdSched(TSCProdReqDet(ReqHdr.m_list[I]).m_list[0]).m_Id);
      end;
    end;
  end;

end;

