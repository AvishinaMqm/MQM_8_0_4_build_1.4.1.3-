function TMSchedCont.IsMsgFromHostArrived(allJobs : Boolean; id: TSchedId): boolean;
var
  Ph,Pd,Ps : Integer;
  Hdr : TSCProdReqHdr;
  Det : TSCProdReqDet;
  Job : TSCProdSched;
  sc  : TSCSchedOnPlan;
  grp : TSCProdGroup;
  Count : Integer;
begin
  Result := false;
  Count := 0;

  if allJobs then
  begin
    for Ph := 0 to m_prodReqList.Count-1 do
    begin
      Hdr := TSCProdReqHdr(m_prodReqList[Ph]);
      if Assigned(Hdr) then
      begin
        for Pd := 0 to Hdr.m_list.Count - 1 do
        begin
          Det := TSCProdReqDet(Hdr.m_list[pd]);
          for Ps := 0 to Det.m_list.Count -1 do
          begin
            Job := Det.m_list[Ps];
            if (Job.m_MsgFromHost = CSH_New_request) or (Job.m_MsgFromHost = CSH_Historical) or
               (Job.m_MsgFromHost = CSH_Jobs_unscheduled) or (Job.m_MsgFromHost = CSH_Minor_change) or (Job.m_MsgFromHost = CSH_New_step) then
            begin
              Count := Count + 1;
              if count > 1 then
              begin
                Result := true;
                Exit;
              end
            end;
          end;
        end;
      end;
    end;
  end
  else
  begin
    sc := TSCSchedOnPlan(m_codeList[id]);
    if sc is TSCProdGroup then
    begin
      grp := TSCProdGroup(sc);
      job := grp.m_list[0];
    end
    else
      job := TSCProdSched(sc);
    if (Job.m_MsgFromHost = CSH_New_request) or (Job.m_MsgFromHost = CSH_Historical) or
    (Job.m_MsgFromHost = CSH_Jobs_unscheduled) or (Job.m_MsgFromHost = CSH_Minor_change) or (Job.m_MsgFromHost = CSH_New_step) then
        Result := true;
  end;
end;

