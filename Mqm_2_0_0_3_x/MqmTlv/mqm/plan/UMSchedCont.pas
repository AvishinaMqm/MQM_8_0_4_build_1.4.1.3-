procedure TMSchedCont.LoadStepTimes(OnStart : boolean; qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText; ErrList: TStringList; UpdateNr : integer;
                                    WorkCentersHandledList, WorkCentersViewedList : String; ChangedReqInClause: string = '');
var
  tbiST, tbiPD, tbiCR : ^TTblInfo;
  Request, WorkCentersList : string;
  step, I    : integer;
  PRecTiming : PTRecTiming;
  ST_preqNo, ST_pstepId, ST_wkcCode, ST_wkcProc, ST_resCat,
  ST_resCode, ST_supTime, ST_exeTime : TField;
  List : TList;
begin

  if WorkCentersHandledList = '' then
  begin
    if WorkCentersViewedList = '' then
      WorkCentersList := ''
    else
      WorkCentersList := WorkCentersViewedList;
  end
  else
  begin
    if WorkCentersViewedList = '' then
      WorkCentersList := WorkCentersHandledList
    else
      WorkCentersList := WorkCentersHandledList + ',' + WorkCentersViewedList;
  end;

  if WorkCentersList = '' then exit;


  if Assigned(Status) then
    Status.Caption := _('Reading Jobs step time from database...');

  Application.ProcessMessages;
  Request := 'DUMMY';
  Step    := -1;

  tbiST := @tblInfo[tbl_Step_times];
  tbiPD := @tblInfo[tbl_prod_step];
  tbiCR := @tblInfo[tbl_Req_Change];

  with qry.SQL do
  begin
    Clear;
    Add('select ');
    Add(CreateFld(tbiST.pfx, fli_preqNo) + ',');
    Add(CreateFld(tbiST.pfx, fli_pstepId) + ',');
    Add(CreateFld(tbiST.pfx,fli_wkCtrCode) + ',');
    Add(CreateFld(tbiST.pfx,fli_wkcProc) + ',');
    Add(CreateFld(tbiST.pfx,fli_RscCat) + ',');
    Add(CreateFld(tbiST.pfx,fli_rsc) + ',');
    Add(CreateFld(tbiST.pfx,fli_SetUpTimJob) + ',');
    Add(CreateFld(tbiST.pfx,fli_ExecTimeInitQty) + ' ');
    Add('from ' + tbiST.GetTableName + ' ST ');
    Add(WHERE_IDF_Condition('ST.ST_IDENTIFIER'));
    if not OnStart then
    begin
      if ChangedReqInClause <> '' then
        Add('AND ST.' + CreateFld(tbiST.pfx, fli_preqNo) + ' IN (' + ChangedReqInClause + ') ')
      else
      begin
        Add('AND exists (');
        Add('Select 1 from ' + tbiCR.GetTableName + ' CR ');
        Add(WHERE_IDF_Condition('CR.RC_IDENTIFIER'));
        Add('AND CR.' + CreateFld(tbiCR.pfx, fli_IDENTIFIER) + ' = ST.'  + CreateFld(tbiST.pfx, fli_IDENTIFIER));
        Add(' AND CR.' + CreateFld(tbiCR.pfx, fli_updCode) + ' = ' + IntToStr(UpdateNr) + ' ');
        Add('and CR.' + CreateFld(tbiCR.pfx, fli_preqNo) + ' = ST.'  + CreateFld(tbiST.pfx, fli_preqNo));
        if (IniAppGlobals.External_Database_Update = '1') then
          Add(' and CR.' + CreateFld(tbiCR.pfx, fli_wkstCode) + '=''' + IniAppGlobals.WkstCode + '''');
        Add(') ');
      end;
    end;
    Add('AND exists (');
    Add('Select 1 from ' + tbiPD.GetTableName + ' PD ');
    Add(WHERE_IDF_Condition('PD.PD_IDENTIFIER'));
    Add('AND PD.' + CreateFld(tbiPD.pfx, fli_IDENTIFIER) + ' = ST.' + CreateFld(tbiST.pfx, fli_IDENTIFIER) + ' ');
    Add(' AND PD.' + CreateFld(tbiPD.pfx, fli_preqNo) + ' = ST.' + CreateFld(tbiST.pfx, fli_preqNo) + ' ');
    Add(' and PD.' + CreateFld(tbiPD.pfx, fli_pstepId) + ' = ST.' + CreateFld(tbiST.pfx, fli_pstepId) + ' ');
    Add(' and PD.' + CreateFld(tbiPD.pfx,fli_wkCtrCode) + ' IN ' + '(' + WorkCentersList + ')');
    Add(') ');
    Add('order by ');
    Add('ST.' + CreateFld(tbiST.pfx, fli_preqNo) + ',');
    Add('ST.' + CreateFld(tbiST.pfx, fli_pstepId));
    qry.open;
    ST_preqNo       := qry.FieldByName(CreateFld(tbiST.pfx, fli_preqNo));
    ST_pstepId      := qry.FieldByName(CreateFld(tbiST.pfx, fli_pstepId));
    ST_wkcCode      := qry.FieldByName(CreateFld(tbiST.pfx,fli_wkCtrCode));
    ST_wkcProc      := qry.FieldByName(CreateFld(tbiST.pfx,fli_wkcProc));
    ST_resCat       := qry.FieldByName(CreateFld(tbiST.pfx,fli_RscCat));
    ST_resCode      := qry.FieldByName(CreateFld(tbiST.pfx,fli_rsc));
    ST_supTime      := qry.FieldByName(CreateFld(tbiST.pfx,fli_SetUpTimJob));
    ST_exeTime      := qry.FieldByName(CreateFld(tbiST.pfx,fli_ExecTimeInitQty));

    Status.Caption := _('Loading Jobs step time to memory...');
    Application.ProcessMessages;

    while not Qry.Eof do
    begin
      if (Request <> ST_preqNo.AsString) or (step <> ST_pstepId.AsInteger) then
      begin
        Request := ST_preqNo.asstring;
        step    := ST_pstepId.AsInteger;
        List := FindRequestHeader(Self, Request, step);
      end;

      if not Assigned(List) then
      begin
        Qry.Next;
        continue;
      end;

      new(PRecTiming);
      PRecTiming.wkcCode        := trim(ST_wkcCode.AsString);
      PRecTiming.wkcProc        := trim(ST_wkcProc.AsString);
      PRecTiming.resCat         := trim(ST_resCat.AsString);
      PRecTiming.resCode        := trim(ST_resCode.AsString);
      PRecTiming.supTime        := ST_supTime.AsFloat;
      PRecTiming.exeTime        := ST_exeTime.AsFloat;
      List.add(PRecTiming);
      Qry.Next;

    end;

    Application.ProcessMessages;
  end;

end;

