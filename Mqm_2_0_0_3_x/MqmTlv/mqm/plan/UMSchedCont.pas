function TMSchedCont.GetJobQtyAtDateForMaterials(Id: TSchedId; Res: TObject; StartExecusionDate, CurrentDate, EndDate : TDateTime; SchedQty : double): double;
var
  MinutesUpToCurrentDate, TotalMinutes: double;
  Cal: TPGCALObj;
  ActArea:  TMqmActArea;
begin
  Result := 0;

  if (CurrentDate <= StartExecusionDate) then exit;

  if (CurrentDate >= EndDate) then
  begin
    Result := SchedQty;
    exit;
  end;

  if not assigned(Res) then
    Exit;

  //Assert(Res is TMqmVisibleRes);
  if not (Res is TMqmVisibleRes) then Exit;
  ActArea := TMqmActArea(TMQMVisibleRes(Res).p_ActArea[0]);
  Cal := TMQMVisibleRes(Res).GetCalendar;

  if not assigned(Cal) then
    Exit;

  MinutesUpToCurrentDate := cal.DiffWH(StartExecusionDate, CurrentDate, ActArea.m_CrossDownTmList)*60;
  TotalMinutes := cal.DiffWH(StartExecusionDate, EndDate, ActArea.m_CrossDownTmList)*60;

  MinutesUpToCurrentDate := GetMinutesExcludeLearningCurveAffect(Id, 0, MinutesUpToCurrentDate);
  TotalMinutes := GetMinutesExcludeLearningCurveAffect(Id, 0, TotalMinutes);
  Result := SchedQty/TotalMinutes*MinutesUpToCurrentDate;

end;

