procedure TMSchedCont.CleanServingCodeList;
var
  I : Integer;
begin
  for I := m_ServingCodeList.Count - 1 downto 0 do
  begin
    PTServingCode(m_ServingCodeList[I]).List.Free;
    dispose(PTServingCode(m_ServingCodeList[I]));
  end;
end;

