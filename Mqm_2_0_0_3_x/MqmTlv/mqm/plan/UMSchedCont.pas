function TMSchedCont.FindOrAddProdSchedFromDatabase(Action : String; Request : string; Step : integer; SubStep : integer; Reprocess : integer) : boolean;
var
  MQMPS : PTMQMPS;
  I: integer;
  Multiplier, NumberOfEntries, LowestHighestValue : integer;
begin
  Result := false;

  NumberOfEntries := m_ProdSchedDatabase.Count;
  LowestHighestValue := NumberOfEntries;

  if NumberOfEntries > 0 then
  begin

    Multiplier := 1;
    while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
    I := Multiplier - 1;

    while (Multiplier > 0) do
    begin
      Multiplier := trunc(Multiplier / 2);

      if (i >= NumberOfEntries) then
      begin
        i := i - Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_PREQ_NO < Request) then
      begin
        i := i + Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_PREQ_NO > Request) then
      begin
        if I < LowestHighestValue then LowestHighestValue := I;
        i := i - Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_PSTEP_ID < Step) then
      begin
        i := i + Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_PSTEP_ID > Step) then
      begin
        if I < LowestHighestValue then LowestHighestValue := I;
        i := i - Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_PSUBST_ID < SubStep) then
      begin
        i := i + Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_PSUBST_ID > SubStep) then
      begin
        if I < LowestHighestValue then LowestHighestValue := I;
        i := i - Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_REPROCCS < Reprocess) then
      begin
        i := i + Multiplier;
        Continue;
      end;

      if (PTMQMPS(m_ProdSchedDatabase[I]).PS_REPROCCS > Reprocess) then
      begin
        if I < LowestHighestValue then LowestHighestValue := I;
        i := i - Multiplier;
        Continue;
      end;

      Result := true;
      Exit;

    end;
  end;

  if Action = '0' then Exit;

  new(MQMPS);
  MQMPS.PS_PREQ_NO := Request;
  MQMPS.PS_PSTEP_ID := Step;
  MQMPS.PS_PSUBST_ID := SubStep;
  MQMPS.PS_REPROCCS := Reprocess;
  m_ProdSchedDatabase.insert(LowestHighestValue, MQMPS);
end;

