procedure TMSchedCont.SetLearningCurveCode(Id : TSchedId; CurveCode : string);
var
  sc:  TSCSchedOnPlan;
  job  : TSCProdSched;
  Grp  :  TSCProdGroup;
  I : Integer;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc = nil then exit;
  if sc is TSCProdGroup then
  begin
    Grp := TSCProdGroup(sc);
    for I := 0 to grp.m_List.Count - 1 do
    begin
      job := TSCProdSched(grp.m_list[I]);
      SetLearningCurveCode(job.m_Id, CurveCode);
    end;
  end
  else
  begin
    job := TSCProdSched(sc);
    job.p_CurveCode := CurveCode;
    if Job.m_fromPD then
      Job.m_status := CSS_new
    else
      Job.m_status := CSS_modi;
  end;
end;

