      ParamByName(CreateFld(tbiSP_OVER.pfx, fli_psubstId)).Value   := tJob.m_code;
      ParamByName(CreateFld(tbiSP_OVER.pfx, fli_reprocNo)).Value   := tJob.m_reprocNo;

      ExecSQL;
      WriteLogLineToDB(qry, 'P', tJob.m_reqDet.m_hdr.m_code, tJob.m_reqDet.m_code, tJob.m_code, tJob.m_reprocNo,'Dlt', '' ,tJob.GetRscCode, 0, 0, tJob.p_quantSched, tjob.p_GetStepType, 'UpdateOverrideProgress');

      // ===================== INSERT =====================
      Unprepare;
      Params.Clear;
      SQL.Clear;

      SQL.Add('insert into ' + tbiSP_OVER.GetTableName + '(');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_Identifier)   + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_preqNo)       + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_pstepId)      + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_psubstId)     + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_reprocNo)     + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_ProgressType) + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_rsc)          + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_progrStart)   + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_prgCurrDate)  + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_progrEnd)     + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_quant)        + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_StartingQty)  + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_prgRemTime)  + ',');
      SQL.Add(CreateFld(tbiSP_OVER.pfx, fli_ProgressReApplied));
      SQL.Add(') values (');
      SQL.Add(':' + CreateFld(tbiSP_OVER.pfx, fli_Identifier)   + ',');
      SQL.Add(':' + CreateFld(tbiSP_OVER.pfx, fli_preqNo)       + ',');
