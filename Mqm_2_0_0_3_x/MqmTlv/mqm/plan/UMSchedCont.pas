function TMSchedCont.FindProdSched(hdrCode: string; detCode, jobCode, ReprocNo: integer ; var IsHeaderDetFound : boolean): TSchedID;
var
  hdr: TSCProdReqHdr;
  det: TSCProdReqDet;
  job: TSCProdSched;
begin
  IsHeaderDetFound := false;
  Result := CSchedIDnull;

  hdr := FindHdrFromCode(self, hdrCode);
  if not Assigned(hdr) then exit;

  det := hdr.FindDetFromCode(detCode);
  if not Assigned(det) then exit;

  IsHeaderDetFound := true;

  job := det.FindJobFromCode(jobCode, ReprocNo);
  if not Assigned(job) then exit;

  Result := job.m_Id
end;

