function TMSchedCont.GetServingGroupLowestHighiestDates(id: TSchedId; var ServingGroupCode : string; var LowestDateTime : TDateTime;
                var HighestDateTime : TDateTime {;  FillDateList : boolean; var StrDateList : TStringList}) : boolean;
var
  tHdr: TSCProdReqHdr;
  scP, scJ :  TSCProdSched;
  ProdReqDet : TSCProdReqDet;
  ps : TSCSchedOnPlan;
  scG : TSCProdGroup;
  I,J,H : Integer;
  TmpLowestDateTime, TmpHighestDateTime : TDateTime;
  objWkc, objWkcJ : TMqmWrkCtr;
  ListAltWcStr : TStringList;
begin
  LowestDateTime := 0;
  HighestDateTime := 0;
  ServingGroupCode := '';
  Result := false;

  ps := TSCSchedOnPlan(m_codeList[id]);
  if ps is TSCProdGroup then
  begin
    scG := TSCProdGroup(m_codeList[id]);
    scP := TSCProdSched(scG.m_list[0]);
  end
  else
    scP := TSCProdSched(m_codeList[id]);

  objWkc := TMqmWrkCtr(p_sc.GetWrkCtrPtr(scP.m_Id));
  if not assigned(objWkc) then exit;
  ListAltWcStr := objWkc.GetAltWcList;
  if not assigned(ListAltWcStr) then exit;

  if (scP.m_reqDet.m_hdr.m_ServingCode <> '') and Assigned(scP.m_reqDet.m_hdr.m_ServingCodeHdrList) then
  begin
    for H := 0 to scP.m_reqDet.m_hdr.m_ServingCodeHdrList.Count - 1 do
    begin
      tHdr := TSCProdReqHdr(scP.m_reqDet.m_hdr.m_ServingCodeHdrList[H]);
      for I := 0 to tHdr.m_list.Count - 1 do
      begin
        ProdReqDet := TSCProdReqDet(tHdr.m_list[I]);
        for J := 0 to ProdReqDet.m_list.Count - 1 do
        begin
          scJ := TSCProdSched(ProdReqDet.m_list[J]);
          objWkcJ := TMqmWrkCtr(p_sc.GetWrkCtrPtr(scJ.m_Id));
          if not assigned(objWkcJ) then continue;
          if ListAltWcStr.IndexOf(objWkcJ.p_WrkCtrCode) = -1 then continue;
          if (scJ.p_rscCode = '') then continue;
          Result := true;
          if Assigned(scJ.m_grp) then
            TmpLowestDateTime := TSCProdGroup(scJ.m_grp).p_schedStart
          else
            TmpLowestDateTime := scJ.p_schedStart;
          if (LowestDateTime > TmpLowestDateTime) or (LowestDateTime = 0) then
          begin
            LowestDateTime := TmpLowestDateTime;
            ServingGroupCode := tHdr.m_ServingCode;
          end;
          TmpHighestDateTime := scJ.p_schedStart;
          if (HighestDateTime < TmpHighestDateTime) or (HighestDateTime = 0) then
          begin
            ServingGroupCode := tHdr.m_ServingCode;
            HighestDateTime := TmpHighestDateTime;
          end;
        end;
      end;
    end;
  end;
end;

