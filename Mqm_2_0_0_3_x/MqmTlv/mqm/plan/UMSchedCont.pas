function TMSchedCont.CopyBackupValuesBeforeInsert(tJob : TSCProdSched; Savebackup : boolean) : boolean;
begin
  if Savebackup then
  begin
    tJob.m_Backup_Saved := true;
    tJob.m_fromPD_Saved := tJob.m_fromPD;
    tJob.m_status_Saved := tJob.m_status;
    tJob.m_LastScheudleChange_ORIGINAL_Saved  := tJob.P_LastScheudleChange_ORIGINAL;
    tJob.m_rscCode_ORIGINAL_Saved             := tJob.P_rscCode_ORIGINAL;
    tJob.m_AlternativeCode_ORIGINAL_Saved     := tJob.P_AlternativeCode_ORIGINAL;
    tJob.m_WorkCenterCode_ORIGINAL_Saved      := tJob.P_WorkCenterCode_ORIGINAL;
    tJob.m_ProcessCode_ORIGINAL_Saved         := tJob.P_ProcessCode_ORIGINAL;
    tJob.m_GroupCode_ORIGINAL_Saved           := tJob.P_GroupCode_ORIGINAL;
    tJob.m_SchedType_ORIGINAL_Saved           := tJob.P_SchedType_ORIGINAL;
    tJob.m_NumSubRscComponents_ORIGINAL_Saved := tJob.P_NumSubRscComponents_ORIGINAL;
    tJob.m_SubLinRscId_ORIGINAL_Saved         := tJob.P_SubLinRscId_ORIGINAL;
    tJob.m_MachSetupCode_ORIGINAL_Saved       := tJob.P_MachSetupCode_ORIGINAL;
    tJob.m_schedStart_ORIGINAL_Saved          := tJob.P_schedStart_ORIGINAL;
    tJob.m_schedEnd_ORIGINAL_Saved            := tJob.P_schedEnd_ORIGINAL;
    tJob.m_exeMin_ORIGINAL_Saved              := tJob.P_exeMin_ORIGINAL;
    tJob.m_supMinBase_ORIGINAL_Saved          := tJob.P_supMinBase_ORIGINAL;
    tJob.m_supMinReal_ORIGINAL_Saved          := tJob.P_supMinReal_ORIGINAL;
    tJob.m_supMinOvlp_ORIGINAL_Saved          := tJob.P_supMinOvlp_ORIGINAL;
    tJob.m_quantSched_ORIGINAL_Saved          := tJob.P_quantSched_ORIGINAL;
    tJob.m_quantManualChange_ORIGINAL_Saved   := tJob.p_quantManualChg_ORIGINAL;
    tJob.m_Comment_ORIGINAL_Saved             := tJob.P_Comment_ORIGINAL;
    tJob.m_LearningCurve_ORIGINAL_Saved       := tJob.p_LearningCurve_ORIGINAL;
