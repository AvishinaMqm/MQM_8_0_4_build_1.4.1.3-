procedure TMSchedCont.GetStepProgQtys(ProdReq: string; StepId: integer; var IniProg: double;
                                        var GenProg: double; var FinalProg: double;
                                        var FinalSplitProg: double);
var
  i: integer;
  tHdr: TSCProdReqHdr;
  tDet: TSCProdReqDet;
  tJob:  TSCProdSched;
begin
  IniProg         := 0;
  GenProg         := 0;
  FinalProg       := 0;
  FinalSplitProg  := 0;

  tHdr := FindHdrFromCode(self, ProdReq);
  if not Assigned(tHdr) then exit;

  tDet := tHdr.FindDetFromCode(StepId);
  if not Assigned(tDet) then exit;

  for i := 0 to tDet.m_list.Count-1 do
  begin
    tJob := tDet.m_list[i];
    if tJob.m_ProgType <> '' then
    begin
      case StrToInt(tJob.m_ProgType) of
        1 : IniProg         := IniProg        + tJob.m_PrgQty;
        2 : GenProg         := GenProg        + tJob.m_PrgQty;
        3 : FinalProg       := FinalProg      + tJob.m_PrgQty;
        4 : FinalSplitProg  := FinalSplitProg + tJob.m_PrgQty;
      end;
    end;
  end;
end;

