Procedure TMSchedCont.SetEarliestLatestDate(id: TSchedID; LowStrDate : TDateTime; HighEndDate : TDateTime; OnlyLowStartDate : boolean; OnlyHighEndDate : boolean; FrcHighestDate : boolean; FrcDate : CScFrcDate);
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  grp: TSCProdGroup;
  i:   integer;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdSched then
  begin
    job := TSCProdSched(sc);
    if OnlyHighEndDate then
    begin
      if job.m_reqDet.m_highEndTimeLimitTemp > 0 then
        job.m_reqDet.m_highEndTimeLimit := HighEndDate;
      if FrcHighestDate then
        job.m_reqDet.m_FrcHighestDate := FrcDate
    end
    else
    begin
      job.m_reqDet.m_lowStartTimeLimit := LowStrDate;
      if not OnlyLowStartDate then
        job.m_reqDet.m_highEndTimeLimit := HighEndDate;
    end;
  end
  else
  begin
    grp := TSCProdGroup(sc);
    for i := 0 to grp.m_list.Count-1 do
    begin
      job := TSCProdSched(grp.m_list[i]);
      if OnlyHighEndDate then
      begin
        if job.m_reqDet.m_highEndTimeLimitTemp > 0 then
          job.m_reqDet.m_highEndTimeLimit := HighEndDate;
        if FrcHighestDate then
          job.m_reqDet.m_FrcHighestDate := FrcDate
      end
      else
      begin
        job.m_reqDet.m_lowStartTimeLimit := LowStrDate;
        if not OnlyLowStartDate then
          job.m_reqDet.m_highEndTimeLimit := HighEndDate;
      end;
    end
  end;
end;

