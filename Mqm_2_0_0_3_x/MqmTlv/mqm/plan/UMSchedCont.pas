function TMSchedCont.IsProgressedTypeAllowSplitRemainQty(id: TSchedID): CProgress;
var
  progInfo: TSQProgInfo;
begin
  p_sc.GetprogInfo(id, progInfo);

  if progInfo.ProgTypeHost = '1' then
    Result := prg_Starting
  else if progInfo.ProgTypeHost = '2' then
    Result := prg_General
  else if progInfo.ProgTypeHost = '3' then
    Result := prg_Final
  else if (progInfo.ProgTypeHost = '4') or (progInfo.ProgTypeHost = '5') then
    Result := prg_FinalSplit
  else
    Result := prg_none;
end;

//----------------------------------------------------------------------------//

function TMSchedCont.IsProgressed(id: TSchedID): CProgress;
var
  progInfo: TSQProgInfo;
begin
  p_sc.GetprogInfo(id, progInfo);

  if progInfo.ProgType = '1' then
    Result := prg_Starting
  else if progInfo.ProgType = '2' then
    Result := prg_General
  else if progInfo.ProgType = '3' then
    Result := prg_Final
  else if (progInfo.ProgType = '4') or (progInfo.ProgType = '5') then
    Result := prg_FinalSplit
  else
    Result := prg_none;
end;

