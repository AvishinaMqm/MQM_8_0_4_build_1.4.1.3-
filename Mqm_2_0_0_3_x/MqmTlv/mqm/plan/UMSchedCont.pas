procedure TMSchedCont.FindJobsToGroupByProcessPropertyRules(FromRefresh : boolean; ProgBar: TMqmProgBar; Status: TStaticText);
var
  Hdr, Hdr2  : TSCProdReqHdr;
  Job, JobTested, JobG : TSCProdSched;
  det, Det2 : TSCProdReqDet;
  grp : TSCProdGroup;
  I, J, k, P, G, StartingGroupNumber, GroupNumber : integer;
  PROCESS_GROUP_BY : PTPROCESS_GROUP_BY;
  FoundCompatible, JobDone : boolean;
  ErrDesc: string;
  StringToCheckFirstInGroup, StringToCheck : string;
  RGroupRuleCriteria : PRGroupRuleCriteria;
  GroupRuleCriteria_List, TempGroupList : Tlist;
  JobId, TestedJobId, GroupId : TSchedid;
begin
  if m_ProcessGroupedBy.count = 0 then exit;

  GroupRuleCriteria_List := Tlist.Create;
  TempGroupList := Tlist.Create;

//  IniAppGlobals.Time_PropertyRules := NOW;

  if Assigned(Status) then
    Status.Caption := _('Find Jobs To Group by Process property rules...');

  // adding to list the jobs that maching the rules
  for i := 0 to m_prodReqList.Count - 1 do
  begin
    Application.ProcessMessages;
    Hdr := TSCProdReqHdr(m_prodReqList[i]);
    for J := 0 to Hdr.m_list.Count - 1 do
    begin
      det := TSCProdReqDet(Hdr.m_list[J]);
      if det.m_CanGroup <> '1' then continue;
      if det.m_forcedGrpNo > 0 then continue;

      if FromRefresh then
      begin
        if not ((TSCProdSched(det.m_list[0]).m_MsgFromHost = CSH_New_request) or
                (TSCProdSched(det.m_list[0]).m_MsgFromHost = CSH_New_step) or
                (TSCProdSched(det.m_list[0]).m_MsgFromHost = CSH_Minor_change)) then
          continue;
      end;

      if det.m_stepClosed then continue;
      if TSCProdSched(det.m_list[0]).m_VisbleInBin <> CSB_Normal then continue;
      for K := 0 to det.m_list.Count - 1 do
      begin
        if Assigned(TSCProdSched(det.m_list[K]).m_grp) then continue;
        if TSCProdSched(det.m_list[K]).m_isDeleted then continue;
        if Assigned(p_sc.GetExtLinkPtr(TSCProdSched(det.m_list[K]).m_Id)) then continue;
        if (CProgress(p_sc.IsProgressed(TSCProdSched(det.m_list[K]).m_Id)) <> prg_none) then continue;
        PROCESS_GROUP_BY := GetPropertyRulesForGroupByProcess(det.m_planWkctrProc);
        if Assigned(PROCESS_GROUP_BY) then
        begin
          if CheckJobValueToGroupByRules(TSCProdSched(det.m_list[K]), PROCESS_GROUP_BY, StringToCheck) then
          begin
            RGroupRuleCriteria := FindGroupRuleCriteria(GroupRuleCriteria_List, StringToCheck, false);
            RGroupRuleCriteria.JobIdsList.Add(pointer(TSCProdSched(det.m_list[K]).m_Id));
          end;
        end
        else
          break;
      end;
    end;
  end;

  // marking groups that maching to rule
  for I := 0 to m_grpList.Count - 1 do
  begin
    Application.ProcessMessages;
    Grp := TSCProdGroup(m_grpList[I]);
    if Assigned(p_sc.GetExtLinkPtr(TSCProdGroup(Grp).m_Id)) then continue;
    if (CProgress(p_sc.IsProgressed(TSCProdGroup(Grp).m_Id)) <> prg_none) then continue;

    FoundCompatible := true;
    for G := 0 to Grp.m_list.Count - 1 do
    begin
      JobG := TSCProdSched(Grp.m_list[G]);
      if (G = 0) then
      begin
        PROCESS_GROUP_BY := GetPropertyRulesForGroupByProcess(JobG.m_reqDet.m_planWkctrProc);
        if not Assigned(PROCESS_GROUP_BY) then
        begin
          FoundCompatible := false;
          break;
        end;
        if not CheckJobValueToGroupByRules(JobG, PROCESS_GROUP_BY, StringToCheckFirstInGroup) then
        begin
          FoundCompatible := false;
          break;
        end;
        continue;
      end;

      if CheckJobValueToGroupByRules(JobG, PROCESS_GROUP_BY, StringToCheck) then
      begin
        if StringToCheck <> StringToCheckFirstInGroup then
        begin
          FoundCompatible := false;
          break;
        end;
      end
      else
      begin
        FoundCompatible := false;
        break;
      end;
    end;

    if FoundCompatible then
    begin
      RGroupRuleCriteria := FindGroupRuleCriteria(GroupRuleCriteria_List, StringToCheck, true);
      if RGroupRuleCriteria <> nil then
        RGroupRuleCriteria.GroupList.Add(Pointer(Grp.m_id));
    end;
  end;

  if Assigned(ProgBar) then
  begin
    ProgBar.SetPosition(0);
    ProgBar.SetMax(GroupRuleCriteria_List.Count);
  end;

  for I := 0 to GroupRuleCriteria_List.Count - 1 do
  begin
    Application.ProcessMessages;
    if Assigned(ProgBar) then
      ProgBar.SetPosition(I + 1);

    RGroupRuleCriteria := PRGroupRuleCriteria(GroupRuleCriteria_List[I]);

    for J := 0 to RGroupRuleCriteria.JobIdsList.Count - 1 do
    begin
      JobId := TSchedId(RGroupRuleCriteria.JobIdsList[J]);
      JobDone := false;
      for G := 0 to RGroupRuleCriteria.GroupList.Count - 1 do
      begin
        GroupId := TSchedId(RGroupRuleCriteria.GroupList[G]);
        if not p_sc.CanAddJobToGroup(JobId, GroupId , CanAddJobToGroupOnBin, CanAddJobToGroupSameType, ErrDesc) then
           Continue;
        addJobToGroup(JobId, GroupId);
        JobDone := true;
        break
      end;
      if JobDone then continue;

      for G := J + 1 to RGroupRuleCriteria.JobIdsList.Count - 1 do
      begin
        TestedJobId := TSchedid(RGroupRuleCriteria.JobIdsList[G]);
        if not CanAddTwoJobsOnSameGroup(TestedJobId, JobId) then continue;
        GroupId := CreateTempGroupWithCodeZero(JobId);
        TempGroupList.Add(Pointer(GroupId));
        RGroupRuleCriteria.GroupList.Add(Pointer(GroupId));
        break
      end;

    end;

  end;

  if TempGroupList.Count > 0 then
  begin
    if not DBAppGlobals.MCM_App then
      StartingGroupNumber := GET_GRP_STARTING_NUMBER(TempGroupList.Count,'GROUPNUMBER')
    else
      StartingGroupNumber := GET_GRP_STARTING_NUMBER(TempGroupList.Count,'GRPNUMBERMCM');
    GroupNumber := StartingGroupNumber - 1;
  end;

  for I := 0 to TempGroupList.Count - 1 do
  begin
    GroupId := TSchedId(TempGroupList[I]);
    if p_sc.IsGroup(GroupId) and (p_sc.GetGroupCode(GroupId) = 0) then
    begin
      inc(GroupNumber);
      p_sc.SetGroupCode(GroupId, GroupNumber);
    end;
  end;

  for I := 0 to GroupRuleCriteria_List.Count - 1 do
  begin
    RGroupRuleCriteria := PRGroupRuleCriteria(GroupRuleCriteria_List[I]);
    RGroupRuleCriteria.JobIdsList.Free;
    RGroupRuleCriteria.GroupList.Free;
    Dispose(RGroupRuleCriteria);
  end;
  GroupRuleCriteria_List.Free;
  TempGroupList.Free;

  if Assigned(ProgBar) then
    ProgBar.SetPosition(0);
  if Assigned(Status) then
    Status.Caption := '';

  Application.ProcessMessages;
//  IniAppGlobals.Time_PropertyRules := Now - IniAppGlobals.Time_PropertyRules;
//  IniAppGlobals.LogTimes.Clear;
//  IniAppGlobals.LogTimes.Add('Time_PropertyRules : ' + FloatTostr(IniAppGlobals.Time_PropertyRules * 60 * 60 *  24));
//  IniAppGlobals.LogTimes.SaveToFile(LocAppGlobals.AppDir + '\PropertyRules.txt');
end;

