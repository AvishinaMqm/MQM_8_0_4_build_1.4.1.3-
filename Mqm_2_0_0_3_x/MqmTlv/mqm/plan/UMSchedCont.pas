procedure TMSchedCont.LoadSplitInfoForMqmFromMcm(qry: TMqmQuery; ProgBar: TMqmProgBar; Status: TStaticText; ErrList: TStringList);
var
  tbiMCM, tbiRES : ^TTblInfo;
  SplitInfoFromMcm : PTMQMSplitInfoFromMcm;
  MS_preqNo, MS_pstepId, MS_psubstId, MS_wkCtrCode, MS_ProcessCode, MS_Qty, MS_SchedType, RES_wkCtrCode : TField;
  OldReq : string;
  OldStep, I : integer;
  TempTList : TList;
  hdr : TSCProdReqHdr;
  det: TSCProdReqDet;
  procedure ClearList;
  var
    i : Integer;
  begin
    for i := 0 to TempTList.Count-1 do
      Dispose(PTMQMSplitInfoFromMcm(TempTList[i]));
    TempTList.Clear;
  end;

begin
  tbiMCM := @tblInfo[tbl_prod_sched_mcm];
  tbiRES := @tblInfo[tbl_res];
  TempTList := TList.Create;

  if Assigned(Status) then
    Status.Caption := _('Loading Split Info for Mqm from Mcm...');
  Application.ProcessMessages;

  with Qry.SQL do
  begin
    Clear;
    Add('select ' + tbiMCM.GetTableName + '.*,');
    Add(tbiRES.GetTableName + '.' + CreateFld(tbiRES.pfx, fli_rsc) + ',');
    Add(tbiRES.GetTableName + '.' + CreateFld(tbiRES.pfx, fli_wkCtrCode));
    Add(' from ' + tbiMCM.GetTableName);
    Add(' left join ' + tbiRES.GetTableName + ' on ' +
          CreateFld(tbiRES.pfx, fli_IDENTIFIER)  + '=' + CreateFld(tbiMCM.pfx, fli_IDENTIFIER) + ' AND ' +
          CreateFld(tbiRES.pfx, fli_rsc)  + '=' + CreateFld(tbiMCM.pfx, fli_rsc));
    Add(WHERE_IDF_Condition(CreateFld(tbiMCM.pfx, fli_Identifier)));
    Add(' order by MS_PREQ_NO, MS_PSTEP_ID, MS_PSUBST_ID');
    qry.open;

    OldReq := '';
    OldStep := -1;

    MS_preqNo       := Qry.FieldByName(CreateFld(tbiMCM.pfx, fli_preqNo));
    MS_pstepId      := Qry.FieldByName(CreateFld(tbiMCM.pfx, fli_pstepId));
    MS_psubstId     := Qry.FieldByName(CreateFld(tbiMCM.pfx, fli_psubstId));
    MS_Qty          := Qry.FieldByName(CreateFld(tbiMCM.pfx, fli_quant));
    MS_wkCtrCode    := Qry.FieldByName(CreateFld(tbiMCM.pfx, fli_wkCtrCode));
    MS_ProcessCode  := Qry.FieldByName(CreateFld(tbiMCM.pfx, fli_wkcProc));
    MS_SchedType    := Qry.FieldByName(CreateFld(tbiMCM.pfx, fli_schedType));

    RES_wkCtrCode   := Qry.FieldByName(CreateFld(tbiRES.pfx, fli_wkCtrCode));

    while not Qry.Eof do
    begin

      hdr := FindHdrFromCode(self, MS_preqNo.AsString);
      if hdr = nil then
      begin
        Qry.next;
        continue
      end;

      if (OldReq <> '') and ((OldReq <> MS_preqNo.AsString) or
         ((OldReq = MS_preqNo.AsString) and (OldStep <> MS_pstepId.AsInteger))) then
      begin

        if TempTList.Count > 0 then
        begin
          hdr := FindHdrFromCode(self, OldReq);
          if hdr <> nil then
          begin
            det := hdr.FindDetFromCode(OldStep);
            if det <> nil then
            begin
              if (TempTList.Count = 1) and (PTMQMSplitInfoFromMcm(TempTList[0]).SchedwkCtrCode = '') then
                ClearList
              else
              begin
                for I := 0 to TempTList.Count -1 do
                begin
                  new(SplitInfoFromMcm);
                  SplitInfoFromMcm.Qty             := PTMQMSplitInfoFromMcm(TempTList[I]).Qty;
                  SplitInfoFromMcm.SchedwkCtrCode  := PTMQMSplitInfoFromMcm(TempTList[I]).SchedwkCtrCode;
                  SplitInfoFromMcm.ProcessCode     := PTMQMSplitInfoFromMcm(TempTList[I]).ProcessCode;
                  det.m_SplitInfoList_FromMcmToMqm.Add(SplitInfoFromMcm);
                  det.m_SplitFromMcmToMqmAndAlterWorkCenter := true;
                end;
                ClearList;
              end;
            end;
          end;
        end;
        new(SplitInfoFromMcm);
        SplitInfoFromMcm.Qty             := MS_Qty.AsFloat;
        if (MS_SchedType.AsString <> '0') and not RES_wkCtrCode.IsNull then
          SplitInfoFromMcm.SchedwkCtrCode := RES_wkCtrCode.asstring
        else
          SplitInfoFromMcm.SchedwkCtrCode := Trim(MS_wkCtrCode.AsString);
        SplitInfoFromMcm.ProcessCode    := Trim(MS_ProcessCode.AsString);
        if MS_SchedType.AsString = '0' then
          SplitInfoFromMcm.SchduleType := '0'
        else
          SplitInfoFromMcm.SchduleType := '2';
        TempTList.Add(SplitInfoFromMcm);
      end
      else
      begin
        if (MS_psubstId.AsInteger > 0) and (MS_SchedType.AsString = '0') then
        begin
          if TempTList.Count > 0 then
            ClearList;
        end
        else
        begin
          if (MS_psubstId.AsInteger = 0) then
          begin
            new(SplitInfoFromMcm);
            SplitInfoFromMcm.Qty             := MS_Qty.AsFloat;
            if (MS_SchedType.AsString <> '0') and not RES_wkCtrCode.IsNull then
              SplitInfoFromMcm.SchedwkCtrCode := RES_wkCtrCode.asstring
            else
              SplitInfoFromMcm.SchedwkCtrCode := Trim(MS_wkCtrCode.AsString);
            SplitInfoFromMcm.ProcessCode     := Trim(MS_ProcessCode.AsString);
            SplitInfoFromMcm.SchduleType     := MS_SchedType.AsString;
            TempTList.Add(SplitInfoFromMcm);
          end

          else if (MS_psubstId.AsInteger > 0) and (TempTList.Count > 0) then
          begin
            if (PTMQMSplitInfoFromMcm(TempTList[0]).SchduleType <> '0') then
            begin
              new(SplitInfoFromMcm);
              SplitInfoFromMcm.Qty             := MS_Qty.AsFloat;
              if (MS_SchedType.AsString <> '0') and not RES_wkCtrCode.IsNull then
                SplitInfoFromMcm.SchedwkCtrCode := RES_wkCtrCode.asstring
              else
                SplitInfoFromMcm.SchedwkCtrCode := Trim(MS_wkCtrCode.AsString);
              SplitInfoFromMcm.ProcessCode     := Trim(MS_ProcessCode.AsString);
              TempTList.Add(SplitInfoFromMcm);
            end
            else
              ClearList;
          end;
        end;
      end;
      OldReq := MS_preqNo.AsString;
      OldStep := MS_pstepId.AsInteger;
      Qry.next
    end;

    if TempTList.Count > 0 then
    begin
      hdr := FindHdrFromCode(self, OldReq);
      if hdr <> nil then
      begin
        det := hdr.FindDetFromCode(OldStep);
        if det <> nil then
        begin
          if (TempTList.Count = 1) and (PTMQMSplitInfoFromMcm(TempTList[0]).SchedwkCtrCode = '') then
            ClearList
          else
          begin
            for I := 0 to TempTList.Count -1 do
            begin
              new(SplitInfoFromMcm);
              SplitInfoFromMcm.Qty             := PTMQMSplitInfoFromMcm(TempTList[I]).Qty;
              SplitInfoFromMcm.SchedwkCtrCode  := PTMQMSplitInfoFromMcm(TempTList[I]).SchedwkCtrCode;
              SplitInfoFromMcm.ProcessCode     := PTMQMSplitInfoFromMcm(TempTList[I]).ProcessCode;
              det.m_SplitInfoList_FromMcmToMqm.Add(SplitInfoFromMcm);
              det.m_SplitFromMcmToMqmAndAlterWorkCenter := true;
            end;
            ClearList;
          end;
        end;
      end;
    end;

  end;
  TempTList.Free;
  qry.close;
end;

