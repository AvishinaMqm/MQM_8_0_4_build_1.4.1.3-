procedure TMSchedCont.AddForcedGroup(JobID,GroupNo: TschedID);
var
  grp: TSCProdGroup;
begin
  grp := FindGroupFromCode(self, GroupNo);
  if Assigned(grp) and (p_sc.GetGrpNumSons(Grp.m_Id) < 200) then
    addJobToGroup(JobId,grp.m_Id);
  if not Assigned(grp) then
    CreateGroup(JobID);
end;

