                                      else
                                        TempDateTime2 := TempDateTime2 + 1;
                                   end;
                                   FoundVal := GetFldSupport(id, DateFieldSupport,temp,dataType,false);
                                   try
                                      TempDateTime := temp;
                                      {if FoundVal and FoundPropVal then
                                      begin
                                        TempDateTime2 := GetDateTimeFormatForStr(Propvalue);
