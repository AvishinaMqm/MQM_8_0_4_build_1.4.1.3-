function  TMSchedCont.GetConnMachReqCode(Id, ConnId: TSchedId): string;
var
  i: integer;
  tHdr, ConnHdr: TSCProdReqHdr;
  tJob, tConnJob:  TSCProdSched;
  connPs, ps : TSCSchedOnPlan;
begin
  Result := '';

  ps := m_codeList[id];
  if not (ps is TSCProdSched) then exit;

  tJob := TSCProdSched(ps);
  if not Assigned(tJob.m_reqDet) then exit;

  tHdr := TSCProdReqHdr(tJob.m_reqDet.m_hdr);
  if not Assigned(tHdr) then exit;

  ConnPs := m_codeList[ConnId];
  if not (ConnPs is TSCProdSched) then exit;

  tConnJob := TSCProdSched(ConnPs);
  if not Assigned(tConnJob.m_reqDet) then exit;

  ConnHdr := TSCProdReqHdr(tConnJob.m_reqDet.m_hdr);
  if not Assigned(ConnHdr) then exit;

  for i := 0 to tHdr.m_PrecLinkedReqList.Count-1 do
  begin
    if (PTLinkReqRec(tHdr.m_PrecLinkedReqList[i]).Request = ConnHdr) then
    begin
      Result := PTLinkReqRec(tHdr.m_PrecLinkedReqList[i]).MachSetupCode;
      exit
    end
  end
end;
