function TMSchedCont.AddReqHdr(code: string): pointer;
var
  hdr: TSCProdReqHdr;
//  L, H, i: integer;
//  Found: boolean;
begin
  hdr := TSCProdReqHdr.Create;
  hdr.m_code := code;
{
  L := 0;
  H := m_prodReqList.Count-1;
  Found := false;
  i := 0;

  while (L < H) and not Found do
  begin

    i := (H-L) div 2;
    if i < L then i := L;
    if i > H then i := H;

    if (code < TSCProdReqHdr(m_prodReqList[i]).m_code) then
      H := i - 1
    else
      if (code > TSCProdReqHdr(m_prodReqList[i]).m_code) then
        L := i + 1
      else
      begin
//        Result := TSCProdReqHdr(sc.m_prodReqList[i]);
        Found := true
      end;
  end;

  m_prodReqList.Insert(i, hdr);
  m_prodReqListSorted := true;
}
  m_prodReqListSorted := false; //Eran25062010
