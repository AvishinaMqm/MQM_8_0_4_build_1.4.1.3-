procedure TMSchedCont.UnscheduleAllStepsReqForDataChange(Hdr: TSCProdReqHdr;
                                                         SignedAsDeleted: boolean;
                                                         ShowMsg: boolean;
                                                         DispoList: TStringList);
var
  tDet    : TSCProdReqDet;
  tJob    : TSCProdSched;
  pd,ps   : Integer;
  actArea : TMqmActArea;
  extPtr  : TMqmActArea;
  Group_id    : TSchedId;
  Remove      : boolean;
  Qry : TMqmQuery;
  tbiSP : ^TTblinfo;
begin
  Remove := false;
  Qry := CreateQuery(Main_DB);
  Qry.Transaction := CreateTransaction(Main_DB);
  Qry.Transaction.StartTransaction;

  tbiSP := @tblInfo[tbl_sched_progress];

  tJob := nil;
  tDet := nil;
  try

  for pd := 0 to Hdr.m_list.Count - 1 do
  begin
    Application.ProcessMessages;
    tDet := TSCProdReqDet(Hdr.m_list[pd]);

    with Qry.SQL do
    begin
      Clear;
      Add('select * from ' + tbiSP.GetTableName);
      Add(WHERE_IDF_Condition(CreateFld(tbiSP.pfx, fli_Identifier)));
      Add(' and ' + CreateFld(tbiSP.pfx, fli_preqNo) + '=' + QuotedStr(Hdr.m_code));
      Add(' and   ' + CreateFld(tbiSP.pfx, fli_pstepId) + '=' + IntToStr(tDet.m_code));
      Qry.open;
      if not Qry.EOF then continue;
    end;

 //   DispoList.Add('Deleted requests : ' + Hdr.m_code + ' Step : ' + IntTostr(tDet.m_code));
    for ps := 0 to tDet.m_list.Count - 1 do
    begin
      Application.ProcessMessages;
      tJob := TSCProdSched(tDet.m_list[ps]);
      if assigned(tJob.m_grp) then
      begin
        if GetGrpNumSons(tJob.m_grp.m_id) = 1 then
        begin
          Group_id := tJob.m_grp.m_id;
          extPtr := p_sc.GetExtLinkPtr(Group_id);
          if Assigned(extPtr) then
          begin
            actArea := TMqmActArea(extPtr);
            actArea.RemoveSchedObj(Group_id);
            Remove := true;
          end;
          RemoveJobFromGroup(tJob.m_id, 'Unscheduled - data changed');
          DeleteGroup(Group_id);
        end
        else
        begin
          RemoveJobFromGroup(tJob.m_id, 'Unscheduled - data changed');
        end;
      end
      else
      begin
        if Assigned(tJob.m_srvPtr) then
        begin
          actArea := TMqmActArea(tJob.m_srvptr);
          if Assigned(actArea) then
          begin
            actArea.RemoveSchedObj(tjob.m_id);
            tJob.m_srvPtr := nil;
            tJob.m_ProgType := '';
            Remove := true;
          end;
        end;
      end;
      if SignedAsDeleted then
      begin
        if tJob.m_isDeleted and (tJob.m_status = CSS_del) then continue;
        tJob.m_isDeleted := true;
        tJob.m_deleteReason := 'UnscheduleAllStepsReqForDataChange - SignedAsDeleted';
        tJob.m_status := CSS_del;
      end
      else if Remove then
      begin
        WriteLogLineToDB(Qry, 'P', Hdr.m_code, tDet.m_code, tJob.m_code, tJob.m_reprocNo,'Uns', '' ,tJob.GetRscCode, 0, 0, tJob.p_quantSched, tjob.p_GetStepType, 'refresh-UnscheduleAllStepsReqForDataChange');
        tJob.m_MsgFromHost := CSH_Jobs_unscheduled
      end
      else
        tJob.m_MsgFromHost := CSH_Minor_change;
      if ShowMsg and SignedAsDeleted then
        DispoList.Add(_('Deleted Request:') + ' ' + Hdr.m_code + ' ' + _('Step:') + ' ' + IntTostr(tDet.m_code))
      else if ShowMsg and not SignedAsDeleted then
        DispoList.Add(_('Unschedule Request:') + ' ' + Hdr.m_code + ' ' + _('Step:') + ' ' + IntTostr(tDet.m_code));
    end;
  end;

  except
    if MessageDlg(_('An error occured while refreshing.') + #13#10 + _('Unschedule All Steps Request For Data Changed:') +
              ' ' + _('Request:') + Hdr.m_code + ', ' + _('Step:') + IntToStr(tDet.m_code) + ', ' + _('Sub step:') + IntToStr(tJob.m_code) + '  ' + #13#10 +  ' Technical code: UMSchedCont:UnscheduleAllStepsReqForDataChange' , mtConfirmation, [mbOk], 0) = idOk then
    begin
      Exit;
      Qry.free;
    end;
  end;

  Qry.Transaction.commit;
  Qry.free;
end;

