function TMSchedCont.HasPrevStepOrConnRequest(Id: TSchedId): boolean;  // TMG
var
  sc:  TSCSchedOnPlan;
  job: TSCProdSched;
  ReqDet : TSCProdReqDet;
  Hdr: TSCProdReqHdr;
  I : integer;
begin
  result := false;

  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdGroup then
  begin
    for I := 0 to TSCProdGroup(sc).m_list.Count - 1 do
    begin
      job := TSCProdSched(TSCProdGroup(sc).m_list[I]);
      if not Assigned(Job.m_reqDet) then continue;
      ReqDet := job.GetPrevStepToSched(job.m_reqDet.m_code);
      if ReqDet <> nil then
      begin
        result := true;
        break;
      end;
      Hdr := TSCProdReqHdr(Job.m_reqDet.m_hdr);
      if not Assigned(Hdr) then continue;
      result := Hdr.m_PrecLinkedReqList.Count > 0;
      if result then break;
    end;
  end
  else
  begin
    job := TSCProdSched(sc);
    if not Assigned(Job.m_reqDet) then exit;
    ReqDet := job.GetPrevStepToSched(job.m_reqDet.m_code);
    if ReqDet <> nil then
    begin
      result := true;
      Exit;
    end;
    Hdr := TSCProdReqHdr(Job.m_reqDet.m_hdr);
    if not Assigned(Hdr) then exit;
    result := Hdr.m_PrecLinkedReqList.Count > 0;
  end;

end;

