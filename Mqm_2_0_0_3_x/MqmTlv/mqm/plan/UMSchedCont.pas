function TMSchedCont.GetPropertyRulesForGroupByProcess(Process : string) : PTPROCESS_GROUP_BY;
var
  I : Integer;
begin
  Result := nil;
  for I := 0 to m_ProcessGroupedBy.Count - 1 do
  begin
    if Process = PTPROCESS_GROUP_BY(m_ProcessGroupedBy[I]).Process then
    begin
      Result := m_ProcessGroupedBy[I];
      Exit;
    end;
  end;

end;

