function SortCloneCodeListByDate (Item1, Item2: Pointer): Integer;
var
  job1, job2 : TSCProdSched;
  grp1, grp2:  TSCProdGroup;
  sc1, sc2:   TSCSchedOnPlan;
  date1, date2: TDateTime;
begin

  job1 := nil;
  job2 := nil;
  grp1 := nil;
  grp2 := nil;

  sc1 := TSCSchedOnPlan(Item1);
  sc2 := TSCSchedOnPlan(Item2);

  if (sc1 is TSCProdSched) then
    job1 := TSCProdSched(Item1)
  else
    if (sc1 is TSCProdGroup) then
      grp1 := TSCProdGroup(Item1);

  if (sc2 is TSCProdSched) then
      job2 := TSCProdSched(Item2)
  else
  if (sc2 is TSCProdGroup) then
    grp2 := TSCProdGroup(Item2);

  if Assigned(job1) then
  begin
    if Assigned(job1.m_srvPtr) and (not Assigned(job1.m_grp)) then
      Date1 := job1.p_schedStart
    else
      Date1 := 9999999.0;
  end else
  begin
    if Assigned(grp1) and (grp1.m_list.count > 0) then
      Date1 := TSCProdSched(grp1.m_list[0]).p_schedStart
    else
      Date1 := 9999999.0;
  end;

  if Assigned(job2) then
  begin
    if Assigned(job2.m_srvPtr) and (not Assigned(job2.m_grp)) then
      Date2 := job2.p_schedStart
    else
      Date2 := 9999999.0;
  end else
  begin
    if Assigned(grp2) and (grp2.m_list.count > 0) then
      Date2 := TSCProdSched(grp2.m_list[0]).p_schedStart
    else
      Date2 := 9999999.0;
  end;

  if Date1 < Date2 then
    Result := -1
  else if Date1 > Date2 then
    Result := 1
  else
    Result := 0;

end;

