procedure TMSchedCont.Clear;
var
  i: integer;
begin
  for i := 0 to m_grpList.Count-1 do
    TSCProdGroup(m_grpList[i]).Destroy;

  for i := 0 to m_prodReqList.Count-1 do
    TSCProdReqHdr(m_prodReqList[i]).Destroy;

  m_prodReqList.Clear;

  for i := 0 to m_ProdSchedDatabase.Count - 1 do
    dispose(PTMQMPS(m_ProdSchedDatabase[i]));
  m_ProdSchedDatabase.Clear;

  for i := 0 to m_ProcessGroupedBy.Count - 1 do
    dispose(PTPROCESS_GROUP_BY(m_ProcessGroupedBy[i]));
  m_ProcessGroupedBy.Clear;

  for i := 0 to m_MtrList.Count-1 do
    TSCMaterialSched(m_MtrList[i]).Destroy;

  m_MtrList.Clear;
  m_grpList.Clear;
  m_codeList.Clear;
  m_CloneCodeList.Clear;
  m_ProdReqLeadStepSplitList.Clear;
end;

