function TMSchedCont.GetRealOverlapForGroup(resObj : TObject; Calcforward : boolean; Ovrlapdate : TDateTime; GroupId : TSchedID; IndexId : integer) : TDateTime;
var
  sc    : TSCSchedOnPlan;
  Group : TSCProdGroup;
  jobSc : TSCProdSched;
  I : Integer;
  cal:        TPGCALObj;
  planInfo:   TSQplanInfo;
  VisRes : TMqmVisibleRes;
begin
  Result := Ovrlapdate;
  sc := TSCSchedOnPlan(m_codeList[GroupId]);
  //assert(sc is TSCProdGroup);
  if not (sc is TSCProdGroup) then exit;
  Group := TSCProdGroup(sc);

  VisRes := TMqmVisibleRes(resObj);
  cal := VisRes.p_Calendar;
  if not assigned(cal) then exit;

  while true do
  begin
    if Calcforward then
      Inc(IndexId)
    else
      Dec(IndexId);
    if (indexId < 0) or (indexId = Group.m_list.Count) then break;

    jobSc := TSCProdSched(Group.m_list[indexId]);
    p_sc.GetPlanInfo(jobSc.m_id, planInfo);
    if Calcforward then
      cal.OfsByWH((planInfo.supMinReal + planInfo.exeMin)/60, true,
                result, result, nil)
    else
      cal.OfsByWH(-(planInfo.supMinReal + planInfo.exeMin)/60, false,
                result, result, nil)
  end;

end;

