function FindProgressData(ProgInfoList : TList; Request : string; Step : integer; SubStep : Integer; RepRocces : integer): PTSQProgInfo;
var
  i: integer;
  Multiplier, NumberOfEntries : integer;
  EntryFound : boolean;
begin

  Result := nil;

  NumberOfEntries := ProgInfoList.Count;
  if NumberOfEntries = 0 then exit;
  Multiplier := 1;
  while Multiplier < NumberOfEntries do Multiplier := Multiplier * 2;
  i := Multiplier - 1;
  EntryFound := false;

  while (Multiplier > 0) do
  begin

    Multiplier := trunc(Multiplier/2);

    if (i >= NumberOfEntries) then
    begin
      i := i - Multiplier;
      continue;
    end;

    if (PTSQProgInfo(ProgInfoList[i]).preqNo = Request) and
      (PTSQProgInfo(ProgInfoList[i]).pstepId = Step) and
      (PTSQProgInfo(ProgInfoList[i]).psubstId = SubStep) and
      (PTSQProgInfo(ProgInfoList[i]).reprocNo = RepRocces) then
    begin
      EntryFound := true;
      break;
    end;

    if (PTSQProgInfo(ProgInfoList[i]).preqNo < Request)
    or ((PTSQProgInfo(ProgInfoList[i]).preqNo = Request) and
       (PTSQProgInfo(ProgInfoList[i]).pstepId < Step))
    or ((PTSQProgInfo(ProgInfoList[i]).preqNo = Request) and
       (PTSQProgInfo(ProgInfoList[i]).pstepId = Step) and
       (PTSQProgInfo(ProgInfoList[i]).psubstId < SubStep))
    or ((PTSQProgInfo(ProgInfoList[i]).preqNo = Request) and
       (PTSQProgInfo(ProgInfoList[i]).pstepId = Step) and
       (PTSQProgInfo(ProgInfoList[i]).psubstId = SubStep) and
       (PTSQProgInfo(ProgInfoList[i]).reprocNo < RepRocces)) then

      i := i + Multiplier
    else
      i := i - Multiplier;

  end;

  if EntryFound then Result := PTSQProgInfo(ProgInfoList[i]);

end;

