                                     changeStepQty: boolean): string;
var
  sc:  TSCSchedOnPlan;
  tJob: TSCProdSched;
  tDet: TSCProdReqDet;
begin
  result := '';
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdSched then //TSCProdGroup
  begin
    tjob := TSCProdSched(sc);
    tDet := tJob.m_reqDet;


    if tdet.m_stepClosed = true then
    begin
      result := _('Step is closed, can''t change quantity.');
      exit;
    end;

    if (tjob.p_quantSched + ChangedQuant) < 0 then
    begin
      result := _('Can''t have negative quantity');
      exit;
    end;

    if (tjob.p_quantSched + ChangedQuant) < tjob.m_PrgQty then
    begin
      result := _('Job quantity can not be less than progressed quantity');
      exit;
    end;

//    if (tjob.m_ProgType = '3') or  (tjob.m_ProgType = '4') then
//    begin
//      result := _('Step has final progress, can''t change quantity.');
//      exit;
//    end;

    if ( ((tjob.m_ProgType = '1') or (tjob.m_ProgType = '2')) and
        ((tjob.p_quantSched + ChangedQuant) < 1) ) then
    begin
      result := _('Job quantity can not be less than progressed quantity');
      exit;
    end;

    if getChgQtyValue then
    begin
      ChangedQuant  := tjob.p_quantManualChg;
    end else
    begin
      if changeStepQty then
         tjob.p_quantSched   :=  tjob.p_quantSched +  ChangedQuant - tjob.p_quantManualChg
      else
         tjob.p_quantManualChg := tjob.p_quantManualChg + ChangedQuant;

      tjob.m_status := CSS_modi;
    end;
  end;

end;

//----------------------------------------------------------------------------//
// Checks - and if OnlyCheck flag is not set, also overwrites - scheduled quantity.
// If the checking job and quantity lead to an error, the return String is not blank.
//----------------------------------------------------------------------------//
function TMSchedCont.ChangeSchedQty(id: TSchedID; NewQty: double; OnlyCheck: boolean): string;
var
  sc  : TSCSchedOnPlan;
  tJob: TSCProdSched;
  tDet: TSCProdReqDet;
begin
  Result := '';
  sc := TSCSchedOnPlan(m_codeList[id]);
  if sc is TSCProdSched then
  begin
    tJob := TSCProdSched(sc);
    tDet := tJob.m_reqDet;
    if tDet.m_stepClosed then
    begin
      Result := _('Step is closed, can''t change quantity.');
      exit;
    end;
    if NewQty < 0 then
    begin
      Result := _('Can''t have negative quantity.');
      exit;
    end;
    if NewQty < tJob.m_PrgQty then
    begin
      Result := _('Job quantity can not be less than progressed quantity.');
      exit;
    end;
    if (tJob.m_ProgType = '3') or  (tJob.m_ProgType = '4') then
    begin
      Result := _('Step has final progress, can''t change quantity.');
      exit;
    end;
    if not OnlyCheck then begin
      tJob.p_quantSched := NewQty;
      tJob.m_status := CSS_modi;
      if Assigned(GetExtLinkPtr(id)) then p_pl.RecalcTimings(id);
    end;
  end;
end;

