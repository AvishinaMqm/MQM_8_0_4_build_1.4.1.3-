procedure TMSchedCont.UpdatePropFromDB(qry : TMqmQuery; updNum : Integer; ProgBar: TMqmProgBar; EventFromHost : boolean);
var
  SqlStr : string;
  tbInfo : ^TTblInfo;
  hdrCode, RscCode, PropCode : string;
  detCode, I : integer;
  Hdr: TSCProdReqHdr;
  tDet : TSCProdReqDet;
  PropIPJob : TPropID;
begin
  tbInfo := @tblInfo[tbl_PROP_PROD_PLANNER];
  SqlStr := 'select * from ' + tbInfo.GetTableName;
  SqlStr := SqlStr + WHERE_IDF_Condition(CreateFld(tbInfo.pfx, fli_Identifier)) + ' AND ';
  SqlStr := SqlStr + CreateFld(tbInfo.pfx, fli_updCode) + '>' + IntToStr(m_corrPropUpd) + ' and ';
  SqlStr := SqlStr + CreateFld(tbInfo.pfx, fli_updCode) + '<=' + IntToStr(updNum);
  SqlStr := SqlStr + ' order by ';
  SqlStr := SqlStr + CreateFld(tbInfo.pfx, fli_preqNo)  + ',';
  SqlStr := SqlStr + CreateFld(tbInfo.pfx, fli_pstepId);
  with qry do
  begin
    sql.Text := SqlStr;
   // Prepare;
    Open;

    if Assigned(ProgBar) then
      ProgBar.SetPosition(0);

    if Assigned(ProgBar) then
      ProgBar.SetPosition(qry.RecordCount);

    while not EOF do
    begin
      Application.ProcessMessages;
      if Assigned(ProgBar) then
        ProgBar.SetPosition(qry.RecNo);
      hdrCode := FieldByName(CreateFld(tbInfo.pfx, fli_preqNo)).AsString;
      detCode := FieldByName(CreateFld(tbInfo.pfx, fli_pstepId)).AsInteger;
      hdr := FindHdrFromCode(self, hdrCode);
      if not Assigned(hdr) then
      begin
        Next;
        continue
      end;

      tdet := hdr.FindDetFromCode(detCode);
      if not Assigned(tdet) then
      begin
        Next;
        continue
      end;

      for I := tdet.m_propList.p_PropCount - 1 downto 0 do
      begin
        tdet.m_propList.GetProperty(I, PropIPJob, RscCode);
        if not IsPropPlanner(PropIPJob) then continue;
        PropCode := GetPropCodeFromID(PropIPJob);
        tdet.m_propList.DeletFromList(PropCode);
      end;

      while (not EOF) and (hdr.m_code = FieldByName(CreateFld(tbInfo.pfx, fli_preqNo)).AsString) and
            (tdet.m_code = FieldByName(CreateFld(tbInfo.pfx, fli_pstepId)).AsInteger) do
      begin
        tdet.m_propList.AddProperty(FieldByName(CreateFld(tbInfo.pfx, fli_PropertyCode)).AsString, '' ,
               FieldByName(CreateFld(tbInfo.pfx, fli_PropValue)).AsString);
        next;
      end;

    end;

    if not EventFromHost then
      m_corrPropUpd := updNum;
    Application.ProcessMessages;
  end;

end;

