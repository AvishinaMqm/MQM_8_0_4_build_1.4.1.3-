procedure TMSchedCont.UpdateMachineSpeedAndSetup(id: TSchedId; Newspeed, NewTime, Newsetup, NewSetupJob : double; remove : boolean);
type
  TSpeedUpdate  = Record
    REQ_NO : string;
    STEP_NO : Integer;
  end;
  PSpeedUpdate = ^TSpeedUpdate;

  function CheckExist(Req : string; Step : integer;  List : TList) : boolean;
  var
    X : integer;
  begin
    Result := false;
    for X := 0 to List.Count - 1 do
    begin
      if (PSpeedUpdate(List[x]).REQ_NO = req) and (PSpeedUpdate(List[x]).STEP_NO = step) then
      begin
        Result := true;
        break
      end;
    end;
  end;

var
  tbiSPEED : ^TTblInfo;
  qry: TMqmQuery;
  sc:  TSCSchedOnPlan;
  job, tjob: TSCProdSched;
  I, J, R, S, D : Integer;
  Req : variant;
  Request : string;
  step : integer;
  dataType : CBinColValType;
  tHdr : TSCProdReqHdr;
  tDet : TSCProdReqDet;
  found : boolean;
  JobSetupOnly, SplitJobRevert, SkipStepOverride : boolean;
begin
  sc := TSCSchedOnPlan(m_codeList[id]);
  if not (id = sc.m_Id) then Exit;

  if sc is TSCProdGroup then
  begin
    for i := 0 to TSCProdGroup(sc).m_list.Count-1 do
    begin
      job := TSCProdSched(TSCProdGroup(sc).m_list[i]);
      UpdateMachineSpeedAndSetup(job.m_Id, Newspeed, NewTime, Newsetup,NewSetupJob,remove);
    end;
  end
  else
  begin
    job := TSCProdSched(sc);

    Request  := Job.m_reqDet.m_hdr.m_code;
    Step := Job.m_reqDet.m_code;

    tHdr := FindHdrFromCode(self, Request);

    for S := 0 to tHdr.m_list.Count - 1 do
    begin
      tDet := TSCProdReqDet(tHdr.m_list[S]);
      if not Assigned(tDet) then continue;
      if tDet.m_code = Step then break
    end;

    found := false;
    for D := 0 to tDet.m_list.Count - 1 do
    begin
      tJob := TSCProdSched(tDet.m_list[D]);
      if tJob.m_Id = id then
      begin
        found := true;
        break;
      end;
    end;

    if not found then exit;

    // Changes that affect ONLY the per-job setup, never the step-level override
    // (the override is shared by all split brothers via m_reqDet and a single
    // row in tbl_OverrideStepParameters):
    //  - JobSetupOnly  : on a split job the user set just a per-job setup.
    //  - SplitJobRevert: "Back to standard" on a split job - revert only this
    //    job's per-job setup; the other brothers keep the shared step setup.
    // In both cases we must not wipe m_reqDet here nor write/delete the step row.
    JobSetupOnly     := (not remove) and (NewSetupJob >= 0) and (Newspeed <= 0) and (Newsetup < 0);
    SplitJobRevert   := remove and (p_sc.GetJobNumBrothers(Id) > 1);
    SkipStepOverride := JobSetupOnly or SplitJobRevert;

    if (p_sc.GetJobNumBrothers(Id) > 1) and not SkipStepOverride then
    begin
      tJob.p_exeMin := NewTime / p_sc.GetJobComponents(tJob.m_Id, true);
      tJob.m_reqDet.p_NewSpeed := -1;
      tjob.m_reqDet.p_IsSpeedChanged := false;

      tJob.p_supMinReal := Newsetup;
      tJob.m_reqDet.p_NewSetup := -1;
      tJob.m_reqDet.p_IsSetupChanged := false;
      Newspeed := -1;
      Newsetup := -1;
    end;

    if remove then
    begin
      if SplitJobRevert then
      begin
        // Split: revert only THIS job's per-job setup; keep the shared step
        // override intact, and restore this job's setup back to that step value
        // (or to standard if there is no step override).
        tJob.p_NewSetup := -1;
        tJob.p_NewSetupChanged := false;
        tJob.m_status := CSS_modi;
        if tJob.m_reqDet.p_IsSetupChanged then
          tJob.p_supMinReal := tJob.m_reqDet.p_NewSetup
        else
          tJob.p_supMinReal := Newsetup;
      end
      else
      begin
        tJob.p_exeMin := NewTime / p_sc.GetJobComponents(tJob.m_Id, true);
        tJob.m_reqDet.p_NewSpeed := -1;
        tjob.m_reqDet.p_IsSpeedChanged := false;

        tJob.p_supMinReal := Newsetup;
        tJob.m_reqDet.p_NewSetup := -1;
        tJob.m_reqDet.p_IsSetupChanged := false;

        tJob.p_NewSetup := -1;
        if NewSetupJob > -1 then
          tJob.m_status :=  CSS_modi;
        tJob.p_NewSetupChanged := false;
      end;
    end
    else
    begin
      if Newspeed > 0 then
      begin
        tJob.p_exeMin := NewTime / p_sc.GetJobComponents(tJob.m_Id, true);
        tJob.m_reqDet.p_NewSpeed := NewSpeed;
        tJob.m_reqDet.p_IsSpeedChanged := true
      end;

      if Newsetup >= 0 then
      begin
        tJob.p_supMinReal := Newsetup;     // setup change
        tJob.m_reqDet.p_NewSetup := Newsetup;
        tJob.m_reqDet.p_IsSetupChanged := true
      end;

      if NewsetupJob >= 0 then
      begin
        tJob.p_supMinReal := NewsetupJob;
        tJob.p_NewSetupChanged := true;
        tJob.m_status :=  CSS_modi;
        tJob.p_NewSetup := NewsetupJob     // setup job change
      end;
    end;
    tJob.m_CalculatedTimes := false;

    // Persist the step-level override row only when a step parameter actually
    // changed. For a job-level-only edit (apply or revert of a per-job setup)
    // the value is saved via the job itself (m_status = CSS_modi), so we must
    // not write or delete the shared step row here.
    if not SkipStepOverride then
    begin
    tbiSPEED := @tblInfo[tbl_OverrideStepParameters];

    Qry := CreateQuery(Main_DB);
    Qry.Transaction := CreateTransaction(Main_DB);
    Qry.Transaction.StartTransaction;

    with qry do
    begin
      SQL.Clear;

      if remove or (p_sc.GetJobNumBrothers(Id) > 1) then
      begin
        SQL.Clear;
        SQL.Add('Delete from ' + tbiSPEED.GetTableName);
        SQL.Add(' where ');
        SQL.Add(CreateFld(tbiSPEED.pfx, fli_Identifier)         + ' = ');
        SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_Identifier)   + ' and ');
        SQL.Add(CreateFld(tbiSPEED.pfx, fli_preqNo)             + ' = ');
        SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_preqNo)       + ' and ');
        SQL.Add(CreateFld(tbiSPEED.pfx, fli_pstepId)            + ' = ');
        SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_pstepId));
        Application.ProcessMessages;
        ParamByName(CreateFld(tbiSPEED.pfx, fli_Identifier)).AsString := IniAppGlobals.Identifier;
        ParamByName(CreateFld(tbiSPEED.pfx, fli_preqNo)).AsString    := Request;
        ParamByName(CreateFld(tbiSPEED.pfx, fli_pstepId)).AsInteger  := step;
        ExecSQL;
      end
      else
      begin
        begin

          Application.ProcessMessages;
          SQL.Clear;
          SQL.Add('select ');
          SQL.Add(CreateFld(tbiSPEED.pfx, fli_preqNo) + ',');
          SQL.Add(CreateFld(tbiSPEED.pfx, fli_pstepId));
          SQL.Add(' from ' + tbiSPEED.GetTableName);
          SQL.Add(WHERE_IDF_Condition(CreateFld(tbiSPEED.pfx, fli_Identifier)));
          SQL.Add(' and ' + CreateFld(tbiSPEED.pfx, fli_preqNo)  + '=' + QuotedStr(Request));
          SQL.Add(' and ' + CreateFld(tbiSPEED.pfx, fli_pstepId)  + '=' + IntToStr(step));
          Open;
          if not EOF then
          begin

            Application.ProcessMessages;
            SQL.Clear;
            SQL.Add('update ' + tbiSPEED.GetTableName + ' set ');
            if (Newspeed > 0) and (Newsetup >= 0) then
            begin
              SQL.Add(CreateFld(tbiSPEED.pfx, fli_speed)           + '=');
              SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_speed)     + ',');
              SQL.Add(CreateFld(tbiSPEED.pfx, fli_setup)           + '=');
              SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_setup));
            end
            else if (Newspeed > 0) then
            begin
              SQL.Add(CreateFld(tbiSPEED.pfx, fli_speed)           + '=');
              SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_speed));
            end
            else if (Newsetup >= 0) then
            begin
              SQL.Add(CreateFld(tbiSPEED.pfx, fli_setup)           + '=');
              SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_setup));
            end;

            SQL.Add(' where ');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_IDENTIFIER)            + '=');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_IDENTIFIER)      + ' and ');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_preqNo)                + '=');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_preqNo)          + ' and ');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_pstepId)               + '=');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_pstepId));
            ParamByName(CreateFld(tbiSPEED.pfx, fli_IDENTIFIER)).AsInteger  := strtoint(IniAppGlobals.Identifier);
            ParamByName(CreateFld(tbiSPEED.pfx, fli_preqNo)).AsString   := Request;
            ParamByName(CreateFld(tbiSPEED.pfx, fli_pstepId)).AsInteger := Step;

            if (Newspeed > 0) and (Newsetup >= 0) then
            begin
              ParamByName(CreateFld(tbiSPEED.pfx, fli_speed)).AsFloat   := NewSpeed;
              ParamByName(CreateFld(tbiSPEED.pfx, fli_setup)).AsFloat   := Newsetup
            end
            else if Newspeed > 0 then
              ParamByName(CreateFld(tbiSPEED.pfx, fli_speed)).AsFloat   := NewSpeed
           // else
           //   ParamByName(CreateFld(tbiSPEED.pfx, fli_speed)).AsFloat   := -1;
            else if Newsetup >= 0 then
              ParamByName(CreateFld(tbiSPEED.pfx, fli_setup)).AsFloat   := Newsetup; /// set new setup
           // else
           //   ParamByName(CreateFld(tbiSPEED.pfx, fli_setup)).AsFloat     := -1;
            Application.ProcessMessages;
          end
          else
          begin
            SQL.Clear;
            SQL.Add('insert into ' + tbiSPEED.GetTableName + '(');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_Identifier)       + ',');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_preqNo)           + ',');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_pstepId)          + ',');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_speed)            + ',');
            SQL.Add(CreateFld(tbiSPEED.pfx, fli_setup));
            SQL.Add(') values (');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_Identifier)    + ',');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_preqNo)        + ',');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_pstepId)       + ',');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_speed)         + ',');
            SQL.Add(':' + CreateFld(tbiSPEED.pfx, fli_setup));

            SQL.Add(')');
            Application.ProcessMessages;

            ParamByName(CreateFld(tbiSPEED.pfx, fli_Identifier)).AsString    := IniAppGlobals.Identifier;
            ParamByName(CreateFld(tbiSPEED.pfx, fli_preqNo)).AsString        := Request;
            ParamByName(CreateFld(tbiSPEED.pfx, fli_pstepId)).AsInteger      := step;

            if Newspeed > 0 then
              ParamByName(CreateFld(tbiSPEED.pfx, fli_speed)).AsFloat        := NewSpeed
            else
              ParamByName(CreateFld(tbiSPEED.pfx, fli_speed)).AsFloat        := -1;

            if Newsetup >= 0 then
               ParamByName(CreateFld(tbiSPEED.pfx, fli_setup)).AsFloat       := Newsetup
            else
               ParamByName(CreateFld(tbiSPEED.pfx, fli_setup)).AsFloat        := -1;

          end;

          ExecSQL;
        end;
      end;
    end;

    Qry.Transaction.commit;
    Qry.free;
    end;

  end;

  //RequestList.free;

  //for I := 0 to RequestStepChange.Count - 1 do
  //   dispose(PSpeedUpdate(RequestStepChange[I]));
  //RequestStepChange.Free;
  //end;
end;

